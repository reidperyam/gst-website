{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "types": ["node", "vitest/globals"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": [
    "dist",
    "coverage",
    "playwright-report",
    "test-results",
    "public",
    ".vercel",
    ".cache",
    "mcp-server"
  ]
}
