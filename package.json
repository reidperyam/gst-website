{
  "name": "minimal",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:run && npm run test:e2e",
    "radar:seed": "npx tsx -e \"import { seedRadarCache } from './tests/e2e/fixtures/seed-radar-cache'; seedRadarCache();\"",
    "radar:unseed": "npx tsx -e \"import { clearRadarCache } from './tests/e2e/fixtures/seed-radar-cache'; clearRadarCache();\""
  },
  "dependencies": {
    "@astrojs/vercel": "^9.0.4",
    "@upstash/redis": "^1.36.4",
    "@vercel/speed-insights": "^1.3.1",
    "astro": "^5.16.15",
    "chart.js": "^4.5.1",
    "d3-geo": "^3.1.1",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "topojson-client": "^3.1.0",
    "us-atlas": "^3.0.1",
    "world-atlas": "^2.0.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@types/d3-geo": "^3.1.0",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-transition": "^3.0.9",
    "@types/d3-zoom": "^3.0.8",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.1.0",
    "@types/topojson-client": "^3.1.5",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "jsdom": "^27.4.0",
    "playwright": "^1.58.0",
    "vitest": "^4.0.18",
    "xlsx": "^0.18.5"
  }
}
