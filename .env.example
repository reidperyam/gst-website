# ═══════════════════════════════════════════════════════════════════════
# GST Website — Environment Variables
#
# Copy this file to .env and fill in your values.
# All variables are declared in astro.config.mjs env.schema — see
# src/docs/development/DEVELOPER_TOOLING.md § Environment variables.
#
# PUBLIC_* vars are safe for client-side code.
# All others are server secrets (never inlined into the bundle).
# ═══════════════════════════════════════════════════════════════════════

# ── Inoreader API (Radar feed) ──────────────────────────────────────
# Register app at: https://www.inoreader.com/developers/
INOREADER_APP_ID=your_app_id
INOREADER_APP_KEY=your_app_key

# OAuth tokens (obtained via one-time OAuth flow)
# See scripts/inoreader-auth.mjs for setup
INOREADER_ACCESS_TOKEN=your_access_token
INOREADER_REFRESH_TOKEN=your_refresh_token

# Folder prefix used to identify GST Radar sources in Inoreader
INOREADER_FOLDER_PREFIX=GST-

# ── Upstash Redis (optional — Radar token persistence) ──────────────
# Without these, tokens fall back to env vars (no cross-invocation persistence)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Sentry (optional — error monitoring) ────────────────────────────
# DSN enables client+server error capture
PUBLIC_SENTRY_DSN=

# Source map upload (Production only — do NOT set locally)
# SENTRY_AUTH_TOKEN=   (set in Vercel, not here)
# SENTRY_ORG=          (set in Vercel, not here)
# SENTRY_PROJECT=      (set in Vercel, not here)

# ── Google Analytics (optional) ─────────────────────────────────────
# Defaults are baked into the schema; override only if needed
# PUBLIC_GA_MEASUREMENT_ID=G-WTGM9Y1YB0
# PUBLIC_ENABLE_ANALYTICS=true
