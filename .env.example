# Inoreader API credentials
# Register app at: https://www.inoreader.com/developers/
INOREADER_APP_ID=your_app_id
INOREADER_APP_KEY=your_app_key

# OAuth tokens (obtained via one-time OAuth flow)
# See scripts/inoreader-auth.mjs for setup
INOREADER_ACCESS_TOKEN=your_access_token
INOREADER_REFRESH_TOKEN=your_refresh_token

# Revalidation interval in seconds (6 hours = 21600)
RADAR_REVALIDATE_SECONDS=21600

# Folder prefix used to identify GST Radar sources in Inoreader
INOREADER_FOLDER_PREFIX=GST-
