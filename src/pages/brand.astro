    transition: opacity var(--transition-fast);
  }

  .brand-breadcrumb-demo :global(.breadcrumb__item a:hover) {
    opacity: 0.8;
  }

  .brand-breadcrumb-demo :global(.breadcrumb__separator) {
    margin: 0 var(--spacing-sm);
  }

  /* Wizard progress (desktop) */
  .brand-wizard-progress {
    display: flex;
    justify-content: center;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
  }

  .brand-progress-segment {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xs);
    flex: 1;
    max-width: 100px;
    min-width: 40px;
    opacity: 0.4;
    transition: opacity var(--transition-normal);
  }

  .brand-progress-segment--active,
  .brand-progress-segment--completed {
    opacity: 1;
  }

  .brand-progress-number {
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
    color: var(--border-light);
    transition: color var(--transition-normal), transform var(--transition-normal);
  }

  :global(html.dark-theme) .brand-progress-number {
    color: rgba(255, 255, 255, 0.3);
  }

  .brand-progress-segment--active .brand-progress-number {
    color: var(--color-primary);
    transform: scale(1.15);
  }

  .brand-progress-segment--completed .brand-progress-number path {
    fill: var(--color-primary);
    stroke: var(--color-primary);
  }

  .brand-progress-number-text {
    font-size: 1.1rem;
    font-weight: var(--font-weight-bold);
    fill: var(--text-muted);
  }

  .brand-progress-segment--active .brand-progress-number-text {
    fill: var(--text-primary);
  }

  .brand-progress-segment--completed .brand-progress-number-text {
    fill: var(--bg-light);
  }

  :global(html.dark-theme) .brand-progress-segment--completed .brand-progress-number-text {
    fill: var(--bg-dark);
  }

  .brand-progress-label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    text-align: center;
  }

  .brand-progress-segment--active .brand-progress-label {
    color: var(--text-primary);
  }

  /* Wizard progress (mobile) */
  .brand-wizard-progress-mobile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .brand-progress-mobile-label {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-secondary);
    letter-spacing: 0.02em;
  }

  .brand-progress-mobile-current {
    color: var(--color-primary);
    font-weight: var(--font-weight-bold);
  }

  .brand-progress-mobile-name {
    color: var(--text-primary);
  }

  .brand-progress-mobile-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-xs);
  }

  .brand-progress-dot {
    width: 2.75rem;
    height: 2.75rem;
    background: none;
    border: none;
    padding: var(--spacing-sm);
    color: var(--border-light);
    opacity: 0.4;
    cursor: default;
    transition: color var(--transition-normal), opacity var(--transition-normal), transform var(--transition-normal);
  }

  :global(html.dark-theme) .brand-progress-dot {
    color: rgba(255, 255, 255, 0.3);
  }

  .brand-progress-dot svg {
    width: 100%;
    height: 100%;
  }

  .brand-progress-dot--even svg path {
    transform: rotate(180deg);
    transform-origin: 32px 32px;
  }

  .brand-progress-dot--active,
  .brand-progress-dot--completed {
    opacity: 1;
  }

  .brand-progress-dot--active {
    color: var(--color-primary);
    transform: scale(1.2);
  }

  .brand-progress-dot--completed svg path {
    fill: var(--color-primary);
    stroke: var(--color-primary);
  }

  /* Card grid */
  .brand-card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gap-extra-wide);
    margin-bottom: var(--spacing-lg);
  }

  .brand-card-grid--single {
    grid-template-columns: 1fr;
    max-width: 400px;
  }

  /* Details/Summary */
  .brand-details {
    border: 1px solid var(--border-light);
