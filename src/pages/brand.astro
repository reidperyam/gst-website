  }

  /* Left-align specimens (override global margin: 0 auto) */
  .brand-component-item .brutal-tool-shell,
  .brand-component-item .cta-box {
    margin-left: 0;
    margin-right: auto;
    text-align: left;
  }

  .cta-box h2 {
    font-size: 2rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
