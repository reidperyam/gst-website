  .brand-section__note {
    margin-bottom: var(--spacing-xl);
    color: var(--text-muted);
  }

  .brand-group-title {
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-lg);
  }

  .brand-group-title:first-of-type {
    margin-top: 0;
  }

  .brand-subgroup-title {
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-sm);
  }

  /* Brand Identity */
  .brand-identity-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--spacing-2xl);
    align-items: start;
  }

  .brand-identity-logos {
    display: flex;
    gap: var(--spacing-xl);
    align-items: flex-end;
  }

  .brand-logo-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .brand-logo-item img,
  .brand-logo-item :global(.brand-logo-composite) {
    border: 1px solid var(--border-light);
    border-radius: 6px;
    padding: var(--spacing-md);
    background: var(--bg-light-alt);
  }

  .brand-logo-item :global(.brand-logo-delta),
  .brand-logo-item :global(.brand-logo-composite) {
    color: var(--color-primary);
  }

  .brand-identity-info h3 {
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-xs);
  }

  .brand-identity-info h3:first-child {
    margin-top: 0;
  }

  .brand-identity-info p {
    margin-bottom: var(--spacing-sm);
  }

  /* Color Swatches */
  .brand-swatch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--gap-normal);
  }

  .brand-swatch__color {
    aspect-ratio: 1;
    border-radius: 6px;
    border: 1px solid var(--border-light);
    margin-bottom: var(--spacing-xs);
  }

  .brand-swatch__color--checker {
    background-image:
      linear-gradient(45deg, var(--checkerboard-line) 25%, transparent 25%),
      linear-gradient(-45deg, var(--checkerboard-line) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, var(--checkerboard-line) 75%),
      linear-gradient(-45deg, transparent 75%, var(--checkerboard-line) 75%);
    background-size: 10px 10px;
    background-position: 0 0, 0 5px, 5px -5px, -5px 0px;
  }

  .brand-swatch__label {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-secondary);
    word-break: break-all;
  }

  .brand-swatch__value {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-muted);
    min-height: 1.2em;
  }

  .brand-swatch__usage {
    font-size: 0.65rem;
    color: var(--text-faded);
    line-height: 1.3;
  }

  /* Typography Specimens */
  .brand-type-specimens {
    display: flex;
    flex-direction: column;
  }

  .brand-type-specimen {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-lg);
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid var(--border-light);
