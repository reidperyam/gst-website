  }

  .brand-spacing-bar {
    height: 12px;
    background: var(--color-primary);
    border-radius: 2px;
    min-width: 4px;
  }

  .brand-spacing-value {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* Shadows */
  .brand-shadow-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap-wide);
  }

  /* Transitions */
  .brand-transition-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap-wide);
  }

  .brand-transition-value {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-muted);
  }

  /* Components */
  .brand-component-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-wide);
    align-items: flex-start;
    margin-bottom: var(--spacing-lg);
  }

