    font-weight: var(--font-weight-bold);
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-sm);
    line-height: 1.3;
  }

  .brand-trust-brutal p {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* Project card — brutalist */
  .brand-project-brutal {
    background: transparent;
    border: 2px solid var(--border-light);
    padding: 1.5rem;
    cursor: pointer;
    transition: border-color var(--transition-fast);
    display: flex;
    flex-direction: column;
  }

  .brand-project-brutal:hover {
    border-color: var(--color-primary);
  }

  :global(html.dark-theme) .brand-project-brutal {
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(html.dark-theme) .brand-project-brutal:hover {
    border-color: var(--color-primary);
  }

  .brand-project-brutal__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  .brand-project-brutal__title {
    font-weight: 900;
    font-size: 1.1rem;
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-primary);
    line-height: 1.3;
  }

  .brand-project-brutal__industry {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-muted);
    margin-top: 0.25rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .brand-project-brutal__year {
    font-family: monospace;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--text-muted);
    border: 1px solid var(--border-light);
    padding: 0.25rem 0.5rem;
    white-space: nowrap;
  }

  .brand-project-brutal__metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1rem 0;
    padding: 1rem;
    background: transparent;
    border-left: 3px solid var(--color-primary);
  }

  .brand-project-brutal__value {
    font-size: var(--text-sm);
    font-weight: 700;
    font-family: monospace;
    color: var(--text-primary);
  }

  .brand-project-brutal__value--arr {
    color: var(--color-primary);
  }

  .brand-project-brutal__summary {
    font-size: 0.875rem;
    font-family: monospace;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 1rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .brand-project-brutal__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .brand-project-brutal__tag {
    background: transparent;
    color: var(--text-secondary);
    padding: 0.25rem 0.5rem;
    font-size: 0.65rem;
    font-weight: 700;
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    border: 1px solid var(--border-light);
  }

  .brand-project-brutal__tag--theme {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .brand-project-brutal__cta {
    width: 100%;
    padding: 0.875rem 1rem;
    background: var(--color-primary);
    color: var(--bg-dark);
    border: 2px solid var(--color-primary);
    cursor: pointer;
    font-size: 0.7rem;
    font-weight: 700;
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: auto;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .brand-project-brutal__cta:hover {
    background: transparent;
    color: var(--color-primary);
  }

  /* Teaser card — brutalist */
  .brand-teaser-brutal {
    max-width: 600px;
    padding: 2rem;
    background: transparent;
    border: 2px solid var(--border-light);
    border-top: 3px solid var(--color-primary);
    border-radius: 0;
    text-align: left;
  }

  :global(html.dark-theme) .brand-teaser-brutal {
    border-color: rgba(255, 255, 255, 0.1);
    border-top-color: var(--color-primary);
  }

  .brand-teaser-brutal__header {
    margin-bottom: var(--spacing-lg);
  }

  .brand-teaser-brutal__header h2 {
    font-size: 1.1rem;
    font-weight: 700;
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-primary);
    margin: 0;
  }

  .brand-teaser-brutal__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .brand-teaser-brutal__features li {
    font-size: var(--text-sm);
    font-family: monospace;
    color: var(--text-secondary);
    line-height: 1.6;
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
  }

  .brand-teaser-brutal__badge {
    font-size: 0.65rem;
    font-weight: 700;
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px var(--spacing-sm);
    background: transparent;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
    display: inline-block;
    margin-top: var(--spacing-md);
  }

  .brand-teaser-brutal__cta {
    margin-top: var(--spacing-lg);
    display: inline-flex;
  }

  /* Recommendation card — brutalist */
  .brand-rec-brutal {
    display: flex;
    gap: var(--gap-normal);
    padding: var(--spacing-md);
    border: 2px solid var(--border-light);
    border-left: 3px solid var(--color-primary);
    border-radius: 0;
    cursor: pointer;
    transition: opacity var(--transition-normal);
  }

  :global(html.dark-theme) .brand-rec-brutal {
    border-color: rgba(255, 255, 255, 0.1);
    border-left-color: var(--color-primary);
  }

  .brand-rec-brutal.is-dismissed {
    opacity: 0.45;
    border-style: dashed;
  }

  .brand-rec-brutal__body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    width: 100%;
  }

  .brand-rec-brutal__title {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    font-family: monospace;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
  }

  .brand-rec-brutal__desc {
    font-size: var(--text-sm);
    font-family: monospace;
    color: var(--text-secondary);
    line-height: 1.55;
    transition: max-height var(--transition-normal), opacity var(--transition-normal);
    max-height: 200px;
    opacity: 1;
    overflow: hidden;
  }

  .brand-rec-brutal.is-collapsed .brand-rec-brutal__desc {
    max-height: 0;
    opacity: 0;
  }

  .brand-rec-brutal__badge {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    font-size: 0.6rem;
    font-weight: var(--font-weight-bold);
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 1px var(--spacing-sm);
    border-radius: 0;
    line-height: 1;
    background: transparent;
    color: var(--text-muted);
    border: 1px solid var(--border-light);
  }

  .brand-rec-brutal__badge--high {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .brand-rec-brutal__badge--effort {
    color: var(--hub-authority-blue);
    border-color: var(--hub-authority-blue);
  }

  .brand-rec-brutal__na {
    flex-shrink: 0;
    padding: 1px var(--spacing-sm);
    margin-right: var(--spacing-xs);
    font-size: 0.6rem;
    font-weight: var(--font-weight-bold);
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    background: transparent;
    border: 1px dashed var(--border-light);
    border-radius: 0;
    cursor: pointer;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .brand-rec-brutal__na:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  /* Attention card */
  .brand-attention-card {
    padding: calc(var(--spacing-xl) * 0.5) var(--spacing-xl);
    border-left: 3px solid var(--color-primary);
    background: rgba(5, 205, 153, 0.03);
    border-radius: 4px;
    cursor: pointer;
    transition: padding var(--transition-normal), opacity var(--transition-normal);
  }

  .brand-attention-card--high {
    border-left-color: var(--hub-authority-blue);
    background: var(--hub-authority-blue-bg);
  }

  .brand-attention-card--medium {
    border-left-color: var(--dm-methodology-brown);
    background: var(--dm-methodology-brown-bg);
  }

  :global(html.dark-theme) .brand-attention-card {
    background: rgba(5, 205, 153, 0.06);
  }

  .brand-attention-card.is-dismissed {
    opacity: 0.45;
    border-style: dashed;
  }

  .brand-attention-card.is-collapsed {
    padding: var(--spacing-sm) var(--spacing-xl);
  }

  .brand-attention-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .brand-attention-title {
    font-size: var(--text-base);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    line-height: 1.4;
    margin: 0;
    flex: 1;
    min-width: 0;
  }

  .brand-attention-na {
    flex-shrink: 0;
    padding: 2px var(--spacing-sm);
    font-size: 0.65rem;
    font-weight: var(--font-weight-bold);
    font-family: var(--font-family);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    background: rgba(200, 200, 200, 0.08);
    border: 1px dashed var(--border-light);
    border-radius: 4px;
    cursor: pointer;
    transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
  }

  .brand-attention-na:hover {
    color: var(--text-primary);
    border-color: var(--text-secondary);
    background: rgba(200, 200, 200, 0.15);
  }

  .brand-attention-divider {
    width: 2rem;
    height: 2px;
    border: none;
    background: var(--hub-authority-blue);
    opacity: 0.4;
    margin: var(--spacing-md) 0;
    transition: max-height var(--transition-normal), opacity var(--transition-normal);
  }

  .brand-attention-card.is-collapsed .brand-attention-divider {
    max-height: 0;
    opacity: 0;
    margin: 0;
    overflow: hidden;
  }

  .brand-attention-desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.7;
    margin: 0;
    transition: max-height var(--transition-normal), opacity var(--transition-normal);
    max-height: 200px;
    overflow: hidden;
  }

  .brand-attention-card.is-collapsed .brand-attention-desc {
    max-height: 0;
    opacity: 0;
  }

  /* Breadcrumb demo */
  .brand-breadcrumb-demo {
    padding: var(--spacing-lg) 0 0;
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .brand-breadcrumb-demo :global(.breadcrumb__list) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: baseline;
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .brand-breadcrumb-demo :global(.breadcrumb__item) {
    display: flex;
    align-items: baseline;
    white-space: nowrap;
  }

  .brand-breadcrumb-demo :global(.breadcrumb__item a) {
    color: var(--color-primary);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .brand-breadcrumb-demo :global(.breadcrumb__item a:hover) {
    opacity: 0.8;
  }

  .brand-breadcrumb-demo :global(.breadcrumb__separator) {
    margin: 0 var(--spacing-sm);
  }

  /* Wizard progress (desktop) */
  .brand-wizard-progress {
    display: flex;
    justify-content: center;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
  }

  .brand-progress-segment {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xs);
    flex: 1;
    max-width: 100px;
    min-width: 40px;
    opacity: 0.4;
    transition: opacity var(--transition-normal);
  }

  .brand-progress-segment--active,
  .brand-progress-segment--completed {
    opacity: 1;
  }

  .brand-progress-number {
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
    color: var(--border-light);
    transition: color var(--transition-normal), transform var(--transition-normal);
  }

  :global(html.dark-theme) .brand-progress-number {
    color: rgba(255, 255, 255, 0.3);
  }

  .brand-progress-segment--active .brand-progress-number {
    color: var(--color-primary);
    transform: scale(1.15);
  }

  .brand-progress-segment--completed .brand-progress-number path {
    fill: var(--color-primary);
    stroke: var(--color-primary);
  }

  .brand-progress-number-text {
    font-size: 1.1rem;
    font-weight: var(--font-weight-bold);
    fill: var(--text-muted);
  }

  .brand-progress-segment--active .brand-progress-number-text {
    fill: var(--text-primary);
  }

  .brand-progress-segment--completed .brand-progress-number-text {
    fill: var(--bg-light);
  }

  :global(html.dark-theme) .brand-progress-segment--completed .brand-progress-number-text {
    fill: var(--bg-dark);
  }

  .brand-progress-label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    text-align: center;
  }

  .brand-progress-segment--active .brand-progress-label {
    color: var(--text-primary);
  }

  /* Wizard progress (mobile) */
  .brand-wizard-progress-mobile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .brand-progress-mobile-label {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-secondary);
    letter-spacing: 0.02em;
  }

  .brand-progress-mobile-current {
    color: var(--color-primary);
    font-weight: var(--font-weight-bold);
  }

  .brand-progress-mobile-name {
    color: var(--text-primary);
  }

  .brand-progress-mobile-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-xs);
  }

  .brand-progress-dot {
    width: 2.75rem;
    height: 2.75rem;
    background: none;
    border: none;
    padding: var(--spacing-sm);
    color: var(--border-light);
    opacity: 0.4;
    cursor: default;
    transition: color var(--transition-normal), opacity var(--transition-normal), transform var(--transition-normal);
  }

  :global(html.dark-theme) .brand-progress-dot {
    color: rgba(255, 255, 255, 0.3);
  }

  .brand-progress-dot svg {
    width: 100%;
    height: 100%;
  }

  .brand-progress-dot--even svg path {
    transform: rotate(180deg);
    transform-origin: 32px 32px;
  }

  .brand-progress-dot--active,
  .brand-progress-dot--completed {
    opacity: 1;
  }

  .brand-progress-dot--active {
    color: var(--color-primary);
    transform: scale(1.2);
  }

  .brand-progress-dot--completed svg path {
    fill: var(--color-primary);
    stroke: var(--color-primary);
  }

  /* Option cards */
  .brand-options-grid {
    display: grid;
    gap: var(--spacing-md);
    max-width: 340px;
  }

  .brand-option-card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--bg-light);
    border: 2px solid var(--border-light);
    border-radius: 8px;
    cursor: pointer;
    transition: all var(--transition-normal);
    text-align: left;
    font-family: var(--font-family);
    color: var(--text-primary);
    box-shadow: var(--shadow-sm);
  }

  .brand-option-card:hover {
    border-color: var(--color-primary);
    background: rgba(5, 205, 153, 0.06);
    box-shadow: 0 2px 12px var(--accent-light-bg-hover);
    transform: translateY(-1px);
  }

  .brand-option-card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .brand-option-card--selected {
    border-color: var(--color-primary);
    background: var(--accent-dark-bg);
    box-shadow: 0 0 0 1px var(--color-primary), 0 2px 12px var(--border-dark);
  }

  :global(html.dark-theme) .brand-option-card {
    background: var(--bg-dark-secondary);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
  }

  :global(html.dark-theme) .brand-option-card:hover {
    background: var(--accent-dark-bg);
    box-shadow: 0 2px 12px var(--border-dark);
  }

  :global(html.dark-theme) .brand-option-card--selected {
    background: var(--accent-light-bg-hover);
  }

  .brand-option-label {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .brand-option-icon {
    flex-shrink: 0;
    opacity: 0.7;
  }

  .brand-option-card--selected .brand-option-icon {
    opacity: 1;
  }

  .brand-option-description {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: 1.5;
    margin-left: calc(10px + var(--spacing-sm));
  }

  /* Option cards — brutalist variant */
  .brand-option-card-brutal {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    padding: var(--spacing-md) var(--spacing-lg);
    background: transparent;
    border: 2px solid var(--border-light);
    border-radius: 0;
    cursor: pointer;
    transition: border-color var(--transition-fast), background var(--transition-fast), color var(--transition-fast);
    text-align: left;
    font-family: var(--font-family);
    color: var(--text-primary);
  }

  .brand-option-card-brutal:hover {
    border-color: var(--color-primary);
    background: var(--accent-subtle-bg);
  }

  .brand-option-card-brutal:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .brand-option-card-brutal--selected {
    border-color: var(--color-primary);
    background: var(--color-primary);
  }

  .brand-option-card-brutal--selected .brand-option-label-brutal {
    color: var(--bg-dark);
  }

  .brand-option-card-brutal--selected .brand-option-description-brutal {
    color: rgba(10, 10, 10, 0.7);
  }

  .brand-option-card-brutal--selected .brand-option-icon {
    opacity: 1;
    filter: brightness(0);
  }

  :global(html.dark-theme) .brand-option-card-brutal {
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(html.dark-theme) .brand-option-card-brutal:hover {
    border-color: var(--color-primary);
  }

  :global(html.dark-theme) .brand-option-card-brutal--selected {
    background: var(--color-primary);
  }

  :global(html.dark-theme) .brand-option-card-brutal--selected .brand-option-description-brutal {
    color: rgba(10, 10, 10, 0.7);
  }

  .brand-option-label-brutal {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-primary);
  }

  .brand-option-description-brutal {
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: 1.5;
    margin-left: calc(10px + var(--spacing-sm));
  }

  /* Card grid */
  .brand-card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gap-extra-wide);
    margin-bottom: var(--spacing-lg);
  }

  .brand-card-grid--single {
    grid-template-columns: 1fr;
    max-width: 400px;
  }

  /* Trust card */
  .brand-trust-card {
    padding: var(--spacing-2xl);
    background: rgba(5, 205, 153, 0.03);
    border: 1px solid rgba(5, 205, 153, 0.1);
    border-radius: 8px;
    transition: all var(--transition-normal);
    display: flex;
    flex-direction: column;
  }

  .brand-trust-card:hover {
    background: rgba(5, 205, 153, 0.08);
    border-color: rgba(5, 205, 153, 0.2);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(5, 205, 153, 0.1);
  }

  .brand-trust-card h3 {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
    line-height: 1.4;
  }

  .brand-trust-card p {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  :global(html.dark-theme) .brand-trust-card {
    background: rgba(5, 205, 153, 0.05);
    border-color: rgba(5, 205, 153, 0.15);
  }

  :global(html.dark-theme) .brand-trust-card:hover {
    background: rgba(5, 205, 153, 0.12);
    border-color: rgba(5, 205, 153, 0.25);
  }

  /* Project card */
  .brand-project-card {
    background: var(--bg-light);
    border: 1px solid var(--border-light);
    padding: 1.5rem;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
  }

  .brand-project-card:hover {
    box-shadow: 0 10px 30px rgba(5, 205, 153, 0.15);
    transform: translateY(-4px);
    border-color: var(--color-primary);
  }

  .brand-project-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  .brand-project-card__title {
    font-weight: 900;
    font-size: 1.25rem;
    color: var(--text-primary);
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .brand-project-card__industry {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  .brand-year-badge {
    background: var(--filter-chip-bg);
    color: var(--text-secondary);
    padding: 0.35rem 0.75rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .brand-project-card__metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1rem 0;
    padding: 1rem;
    background: var(--search-input-bg, rgba(26, 26, 26, 0.02));
    border-left: 3px solid var(--color-primary);
  }

  .brand-metric__label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .brand-metric__value {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--text-primary);
  }

  .brand-metric__value--arr {
    color: var(--color-primary);
  }

  .brand-project-card__summary {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 1rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .brand-project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .brand-tag {
    background: var(--filter-chip-bg, rgba(26, 26, 26, 0.05));
    color: var(--text-secondary);
    padding: 0.35rem 0.65rem;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .brand-tag--theme {
    background: var(--accent-light-bg);
    color: var(--color-primary);
  }

  .brand-project-card__cta {
    width: 100%;
    padding: 0.875rem 1rem;
    background: transparent;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: auto;
    transition: all var(--transition-normal);
  }

  .brand-project-card__cta:hover {
    background: var(--color-primary);
    color: var(--bg-dark);
  }

  /* Teaser card */
  .brand-teaser-card {
    max-width: 600px;
    padding: 2rem;
    background: rgba(5, 205, 153, 0.03);
    border: 1px solid rgba(5, 205, 153, 0.3);
    border-radius: 8px;
    text-align: center;
  }

  :global(html.dark-theme) .brand-teaser-card {
    background: rgba(5, 205, 153, 0.05);
    border-color: rgba(5, 205, 153, 0.3);
  }

  .brand-teaser-card__header {
    margin-bottom: var(--spacing-md);
  }

  .brand-teaser-card__header h2 {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
  }

  .brand-teaser-card__features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-sm);
  }

  .brand-teaser-card__features li {
    font-size: var(--text-base);
    color: var(--text-secondary);
    line-height: 1.7;
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
    text-align: left;
  }

  .brand-bullet-icon {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
    margin-top: 5px;
    color: var(--color-primary);
  }

  .brand-badge {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--spacing-xs) var(--spacing-sm);
    background: rgba(5, 205, 153, 0.1);
    color: var(--color-primary);
    border-radius: 4px;
    border: 1px solid rgba(5, 205, 153, 0.2);
    display: inline-block;
  }

  .brand-teaser-card .brand-badge {
    margin-top: var(--spacing-md);
  }

  .brand-teaser-card__cta {
    margin-top: var(--spacing-lg);
    display: inline-block;
  }

  /* Search input */
  .brand-search-box {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .brand-search-icon {
    position: absolute;
    left: 0.75rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--text-faded);
    pointer-events: none;
    width: 18px;
    height: 18px;
  }

  .brand-search-input {
    width: 100%;
    padding: 0.75rem 0.75rem 0.75rem 2.5rem;
    background: var(--search-input-bg, rgba(26, 26, 26, 0.02));
    border: 1px solid var(--search-input-border, rgba(26, 26, 26, 0.1));
    color: var(--text-primary);
    font-size: var(--text-sm);
    font-family: var(--font-family);
    transition: all var(--transition-fast);
    border-radius: 0;
  }

  .brand-search-input:focus {
    outline: none;
    background: var(--bg-light);
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px var(--search-input-focus-shadow, rgba(5, 205, 153, 0.1));
  }

  .brand-search-input::placeholder {
    color: var(--text-faded);
  }

  /* Filter chips */
  .brand-filter-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .brand-filter-chip {
    padding: 0.5rem 1rem;
    background: var(--filter-chip-bg, rgba(26, 26, 26, 0.05));
    color: var(--text-secondary);
    border: 1px solid transparent;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    transition: all 0.2s;
    user-select: none;
  }

  .brand-filter-chip:hover {
    background: var(--filter-chip-bg-hover, rgba(26, 26, 26, 0.08));
    border-color: var(--color-primary);
  }

  .brand-filter-chip--active {
    background: var(--color-primary);
    color: var(--bg-light);
    border-color: var(--color-primary);
  }

  .brand-filter-chip--active:hover {
    background: var(--color-primary);
    color: var(--bg-light);
  }

  /* Filter button */
  .brand-filter-button {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    cursor: pointer;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    font-weight: 700;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: var(--spacing-sm);
    position: relative;
    font-family: var(--font-family);
    transition: color var(--transition-fast);
  }

  .brand-filter-button:hover {
    color: var(--color-primary);
  }

  .brand-filter-badge {
    background: var(--color-primary);
    color: var(--bg-light);
    font-size: 0.65rem;
    font-weight: 700;
    padding: 0.15rem 0.45rem;
    border-radius: 50%;
    min-width: 18px;
    text-align: center;
    line-height: 1.2;
  }

  /* Modal */
  .brand-modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 700px;
    width: 90%;
    max-height: 85vh;
    padding: 2rem;
    background: var(--bg-light);
    border: 1px solid var(--border-light);
    border-radius: 0;
    clip-path: polygon(2.5% 0%, 97.5% 0%, 100% 2.5%, 100% 97.5%, 97.5% 100%, 2.5% 100%, 0% 97.5%, 0% 2.5%);
    z-index: 1000;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    overflow-y: auto;
  }

  .brand-modal::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }

  :global(html.dark-theme) .brand-modal {
    background: var(--bg-dark-secondary);
    border-color: var(--border-dark);
  }

  .brand-modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: transparent;
    border: 2px solid transparent;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    transition: all 0.2s;
  }

  .brand-modal__close:hover {
    color: var(--color-primary);
    background: var(--accent-light-bg);
  }

  .brand-modal__header {
    margin-bottom: 1.5rem;
  }

  .brand-modal__title {
    font-size: 1.75rem;
    font-weight: 900;
    color: var(--text-primary);
    margin: 0 0 0.25rem 0;
    letter-spacing: -0.01em;
  }

  .brand-modal__industry {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin: 0;
  }

  .brand-modal__metrics {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border-light);
  }

  .brand-modal__section {
    margin-bottom: 1.5rem;
  }

  .brand-modal__section-title {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-secondary);
    margin: 0 0 0.75rem 0;
  }

  .brand-modal__tech-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .brand-tech-tag {
    background: var(--filter-chip-bg-hover, rgba(26, 26, 26, 0.08));
    color: var(--text-secondary);
    padding: 0.35rem 0.65rem;
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  /* Filter drawer demo (inline) */
  .brand-drawer-demo {
    max-width: 400px;
    background: var(--bg-light);
    border: 1px solid var(--border-light);
    border-left: 2px solid var(--color-primary);
    box-shadow: var(--shadow-lg);
  }

  :global(html.dark-theme) .brand-drawer-demo {
    background: var(--bg-dark-secondary);
  }

  .brand-drawer-demo__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    border-bottom: 1px solid var(--border-light);
  }

  .brand-drawer-demo__title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-primary);
    margin: 0;
  }

  .brand-drawer-demo__close {
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0.5rem;
    display: flex;
    transition: color var(--transition-fast);
  }

  .brand-drawer-demo__close:hover {
    color: var(--color-primary);
  }

  .brand-drawer-demo__content {
    padding: 1.5rem;
  }

  .brand-clear-filters {
    background: transparent;
    border: 1px solid var(--clear-filters-border, rgba(26, 26, 26, 0.1));
    color: var(--clear-filters-text, rgba(26, 26, 26, 0.6));
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    margin-bottom: 1.5rem;
    font-family: var(--font-family);
    transition: all var(--transition-fast);
  }

  .brand-clear-filters:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .brand-filter-section {
    margin-bottom: 1.5rem;
  }

  .brand-filter-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  /* Filter drawer — brutalist variant */
  .brand-drawer-brutal {
    max-width: 400px;
    background: transparent;
    border: 2px solid var(--border-light);
    border-left: 3px solid var(--color-primary);
  }

  :global(html.dark-theme) .brand-drawer-brutal {
    border-color: rgba(255, 255, 255, 0.1);
    border-left-color: var(--color-primary);
  }

  .brand-drawer-brutal__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--spacing-md) var(--spacing-lg);
    border-bottom: 2px solid var(--color-primary);
  }

  .brand-drawer-brutal__title {
    font-size: 0.7rem;
    font-weight: var(--font-weight-bold);
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-primary);
    margin: 0;
  }

  .brand-drawer-brutal__close {
    background: transparent;
    border: 1px solid var(--border-light);
    cursor: pointer;
    color: var(--text-muted);
    padding: 4px;
    display: flex;
    transition: color var(--transition-fast), border-color var(--transition-fast);
  }

  .brand-drawer-brutal__close:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .brand-drawer-brutal__content {
    padding: var(--spacing-lg);
  }

  .brand-clear-brutal {
    background: transparent;
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
    padding: var(--spacing-xs) var(--spacing-md);
    font-size: 0.65rem;
    font-weight: var(--font-weight-bold);
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    margin-bottom: var(--spacing-xl);
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .brand-clear-brutal:hover {
    background: var(--color-primary);
    color: var(--bg-dark);
  }

  .brand-filter-section-brutal {
    margin-bottom: var(--spacing-lg);
  }

  .brand-filter-label-brutal {
    font-size: 0.65rem;
    font-weight: var(--font-weight-bold);
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: var(--spacing-sm);
    padding-bottom: var(--spacing-xs);
    border-bottom: 1px solid var(--border-light);
  }

  .brand-filter-chips-brutal {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
  }

  .brand-chip-brutal {
    padding: var(--spacing-xs) var(--spacing-md);
    background: transparent;
    color: var(--text-secondary);
    border: 1px solid var(--border-light);
    border-radius: 0;
    cursor: pointer;
    font-size: 0.7rem;
    font-weight: var(--font-weight-bold);
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: border-color var(--transition-fast), background var(--transition-fast), color var(--transition-fast);
  }

  .brand-chip-brutal:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .brand-chip-brutal--active {
    background: var(--color-primary);
    color: var(--bg-dark);
    border-color: var(--color-primary);
  }

  :global(html.dark-theme) .brand-chip-brutal {
    border-color: rgba(255, 255, 255, 0.1);
  }

  :global(html.dark-theme) .brand-chip-brutal:hover {
    border-color: var(--color-primary);
  }

  :global(html.dark-theme) .brand-chip-brutal--active {
    background: var(--color-primary);
    color: var(--bg-dark);
  }

  /* Details/Summary */
  .brand-details {
    border: 1px solid var(--border-light);
    border-radius: 6px;
  }

  .brand-details__summary {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md) var(--spacing-lg);
    cursor: pointer;
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: 600;
    list-style: none;
    transition: color var(--transition-fast);
  }

  .brand-details__summary::-webkit-details-marker {
    display: none;
  }

  .brand-details__summary:hover {
    color: var(--text-primary);
  }

  .brand-details__toggle::before {
    content: '+';
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    display: inline-block;
    width: 1em;
    text-align: center;
  }

  .brand-details[open] .brand-details__toggle::before {
    content: '−';
  }

  .brand-details__body {
    padding: 0 var(--spacing-lg) var(--spacing-lg);
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: var(--text-sm);
    border-top: 1px solid var(--border-light);
    padding-top: var(--spacing-md);
  }

  .brand-details__body p {
    margin: 0;
  }

  /* Stats bar */
  .brand-stats-bar {
    background: var(--color-primary);
  }

  .brand-stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .brand-stat-item {
    text-align: center;
    padding: 1.5rem 1rem;
    border-right: 2px solid rgba(0, 0, 0, 0.1);
  }

  .brand-stat-item:last-child {
    border-right: none;
  }

  .brand-stat-value {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--bg-dark);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .brand-stat-label {
    font-size: 0.75rem;
    color: var(--bg-dark);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  /* Bench table — brutalist variant */
  .brand-bench-brutal {
    width: 100%;
    border-collapse: collapse;
  }

  .brand-bench-brutal td {
    padding: var(--spacing-sm) var(--spacing-md);
    font-size: var(--text-xs);
    font-family: var(--font-family);
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
  }

  .brand-bench-brutal td:first-child {
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--text-primary);
  }

  .brand-bench-brutal td:last-child {
    text-align: right;
    font-family: monospace;
    font-weight: var(--font-weight-bold);
    color: var(--text-secondary);
  }

  .brand-bench-brutal__active td {
    border-left: 3px solid var(--color-primary);
    background: transparent;
  }

  .brand-bench-brutal__active td:last-child {
    color: var(--color-primary);
  }

  .brand-bench-brutal__label {
    display: inline-block;
    font-size: 0.6rem;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 1px var(--spacing-xs);
    border-radius: 0;
    margin-left: var(--spacing-xs);
    vertical-align: middle;
  }

  .brand-bench-brutal__label--score {
    background: transparent;
    color: var(--color-primary);
    border: 1px solid var(--color-primary);
  }

  .brand-bench-brutal__label--stage {
    background: transparent;
    color: var(--hub-authority-blue);
    border: 1px solid var(--hub-authority-blue);
  }

  /* Container demo */
  .brand-container-demo {
    border: 1px dashed var(--color-primary);
    border-radius: 4px;
    padding: 2px;
  }

  .brand-container-inner {
    background: var(--accent-subtle-bg);
    padding: var(--spacing-lg) var(--spacing-2xl);
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-family: monospace;
  }

  /* CTA Box */
  .brand-cta-box {
    background: var(--bg-light);
    border: 2px solid var(--color-primary);
    padding: 3rem;
    max-width: 600px;
    text-align: center;
    position: relative;
  }

  :global(html.dark-theme) .brand-cta-box {
    background: var(--cta-box-bg);
  }

  .brand-cta-box h2 {
    font-size: 2rem;
    color: var(--text-primary);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .brand-cta-box p {
    color: var(--text-secondary);
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .brand-section {
      padding: var(--spacing-2xl) 0;
    }

    .brand-identity-grid {
      grid-template-columns: 1fr;
    }

    .brand-swatch-grid {
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    }

    .brand-type-specimen {
      flex-direction: column;
      gap: var(--spacing-xs);
    }

    .brand-shadow-grid,
    .brand-transition-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .brand-spacing-name {
      width: 130px;
    }

    .brand-card-grid {
      grid-template-columns: 1fr;
    }

    .brand-modal__metrics {
      grid-template-columns: repeat(2, 1fr);
    }

    .brand-stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .brand-section {
      padding: var(--spacing-xl) 0;
    }

    .brand-swatch-grid {
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    }

    .brand-shadow-grid,
    .brand-transition-grid {
      grid-template-columns: 1fr;
    }

    .brand-spacing-row {
      flex-wrap: wrap;
    }

    .brand-spacing-name {
      width: 100%;
    }

    .brand-identity-logos {
      flex-direction: column;
      align-items: flex-start;
    }

    .brand-modal__metrics {
      grid-template-columns: repeat(2, 1fr);
    }

    .brand-stats-grid {
      grid-template-columns: 1fr;
    }

    .brand-stat-item {
      border-right: none;
      border-bottom: 2px solid rgba(0, 0, 0, 0.1);
    }

    .brand-stat-item:last-child {
      border-bottom: none;
    }

    .brand-stat-value {
      font-size: 2rem;
    }
  }

  /* Print */
  @media print {
    .brand-transition-demo:hover {
      transform: none;
    }
  }
</style>

<script>
  function rgbToHex(rgb: string): string {
    if (rgb === 'transparent' || rgb === 'rgba(0, 0, 0, 0)') return 'transparent';

    const rgbaMatch = rgb.match(/rgba?\((\d+),\s*(\d+),\s*(\d+)(?:,\s*([\d.]+))?\)/);
    if (!rgbaMatch) return rgb;

    const r = parseInt(rgbaMatch[1]);
    const g = parseInt(rgbaMatch[2]);
    const b = parseInt(rgbaMatch[3]);
    const a = rgbaMatch[4] !== undefined ? parseFloat(rgbaMatch[4]) : 1;

    const hex = '#' + [r, g, b].map(c => c.toString(16).padStart(2, '0')).join('');

    if (a < 1) {
      return `${hex} (${Math.round(a * 100)}%)`;
    }
    return hex;
  }

  function readAndPopulate(): void {
    const root = document.documentElement;
    const style = getComputedStyle(root);

    // Color swatches: use temp element for resolved values
    document.querySelectorAll<HTMLElement>('.brand-swatch').forEach(el => {
      const varName = el.dataset.var;
      if (!varName) return;

      const temp = document.createElement('div');
      temp.style.display = 'none';
      temp.style.backgroundColor = `var(${varName})`;
      root.appendChild(temp);
      const resolved = getComputedStyle(temp).backgroundColor;
      root.removeChild(temp);

      const valueEl = el.querySelector('.brand-swatch__value');
      if (valueEl) valueEl.textContent = rgbToHex(resolved);
    });

    // Spacing values
    document.querySelectorAll<HTMLElement>('.brand-spacing-row').forEach(el => {
      const varName = el.dataset.var;
      if (!varName) return;
      const raw = style.getPropertyValue(varName).trim();
      const valueEl = el.querySelector('.brand-spacing-value');
      if (valueEl) valueEl.textContent = raw;
    });

    // Shadow values
    document.querySelectorAll<HTMLElement>('.brand-shadow-value').forEach(el => {
      const varName = el.dataset.var;
      if (!varName) return;
      el.textContent = style.getPropertyValue(varName).trim();
    });

    // Transition values
    document.querySelectorAll<HTMLElement>('.brand-transition-value').forEach(el => {
      const varName = el.dataset.var;
      if (!varName) return;
      el.textContent = style.getPropertyValue(varName).trim();
    });

    // Font stack
    const fontStackEl = document.querySelector<HTMLElement>('.brand-font-stack');
    if (fontStackEl) {
      fontStackEl.textContent = style.getPropertyValue('--font-family').trim();
    }

    // Typography utility class specimens: read computed styles
    document.querySelectorAll<HTMLElement>('.brand-type-specimen').forEach(el => {
      const specimen = el.querySelector<HTMLElement>('[data-specimen]');
      if (!specimen) return;

      const metaEl = el.querySelector('.brand-type-meta');
      if (metaEl) {
        const cs = getComputedStyle(specimen);
        metaEl.textContent = `${cs.fontSize} / wt ${cs.fontWeight} / lh ${cs.lineHeight}`;
      }

      // Text size scale values
      const varName = el.dataset.var;
      const valueEl = el.querySelector('.brand-type-value');
      if (varName && valueEl) {
        valueEl.textContent = style.getPropertyValue(varName).trim();
      }
    });
  }

  // Re-read values on theme toggle (MutationObserver on html class changes)
  new MutationObserver(() => readAndPopulate()).observe(
    document.documentElement,
    { attributes: true, attributeFilter: ['class'] }
  );

  // Initial population
  document.addEventListener('DOMContentLoaded', readAndPopulate);

  // Delta chevron toggle demo
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('chevron-toggle');
    const demo = document.getElementById('chevron-demo');
    if (toggle && demo) {
      toggle.addEventListener('click', () => {
        demo.classList.toggle('is-collapsed');
      });
    }

    // Modal demo
    const modalOpen = document.getElementById('demo-modal-open');
    const modal = document.getElementById('demo-modal') as HTMLDialogElement;
    const modalClose = document.getElementById('demo-modal-close');
    if (modalOpen && modal && modalClose) {
      modalOpen.addEventListener('click', () => modal.showModal());
      modalClose.addEventListener('click', () => modal.close());
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.close();
      });
    }

    // Option card single-select demo (current)
    document.querySelectorAll<HTMLElement>('[data-demo-option]').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll<HTMLElement>('[data-demo-option]').forEach(c =>
          c.classList.remove('brand-option-card--selected'));
        card.classList.add('brand-option-card--selected');
      });
    });

    // Option card single-select demo (brutalist)
    document.querySelectorAll<HTMLElement>('[data-demo-option-brutal]').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll<HTMLElement>('[data-demo-option-brutal]').forEach(c =>
          c.classList.remove('brand-option-card-brutal--selected'));
        card.classList.add('brand-option-card-brutal--selected');
      });
    });

    // Filter chip toggle demo (current)
    document.querySelectorAll<HTMLElement>('[data-demo-chip]').forEach(chip => {
      chip.addEventListener('click', () => {
        chip.classList.toggle('brand-filter-chip--active');
      });
    });

    // Filter chip toggle demo (brutalist)
    document.querySelectorAll<HTMLElement>('[data-demo-chip-brutal]').forEach(chip => {
      chip.addEventListener('click', () => {
        chip.classList.toggle('brand-chip-brutal--active');
      });
    });

    // Slider demo — sync range, number input, and display value
    const slider = document.getElementById('demo-slider') as HTMLInputElement;
    const sliderDirect = document.getElementById('demo-slider-direct') as HTMLInputElement;
    const sliderValue = document.getElementById('demo-slider-value');
    if (slider && sliderDirect && sliderValue) {
      slider.addEventListener('input', () => {
        sliderValue.textContent = slider.value;
        sliderDirect.value = slider.value;
      });
      sliderDirect.addEventListener('input', () => {
        const v = Math.min(Math.max(parseInt(sliderDirect.value) || 1, 1), 50);
        slider.value = String(v);
        sliderValue.textContent = String(v);
      });
    }

    // Recommendation card — collapse toggle and N/A dismiss
    const recCard = document.getElementById('demo-rec-card');
    const recNa = document.getElementById('demo-rec-na');
    if (recCard) {
      recCard.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.brand-rec-na')) return;
        recCard.classList.toggle('is-collapsed');
      });
    }
    if (recNa && recCard) {
      recNa.addEventListener('click', () => {
        recCard.classList.toggle('is-dismissed');
      });
    }

    // Brutalist recommendation card — collapse toggle and N/A dismiss
    const recBrutal = document.getElementById('demo-rec-brutal');
    const recBrutalNa = document.getElementById('demo-rec-brutal-na');
    if (recBrutal) {
      recBrutal.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.brand-rec-brutal__na')) return;
        recBrutal.classList.toggle('is-collapsed');
      });
    }
    if (recBrutalNa && recBrutal) {
      recBrutalNa.addEventListener('click', () => {
        recBrutal.classList.toggle('is-dismissed');
      });
    }

    // Attention card — collapse toggle and N/A dismiss
    const attCard = document.getElementById('demo-attention-card');
    const attNa = document.getElementById('demo-attention-na');
    if (attCard) {
      attCard.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.brand-attention-na')) return;
        attCard.classList.toggle('is-collapsed');
      });
    }
    if (attNa && attCard) {
      attNa.addEventListener('click', () => {
        attCard.classList.toggle('is-dismissed');
      });
    }
  });
</script>
