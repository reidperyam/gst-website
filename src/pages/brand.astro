  .brand-component-item .brutal-tool-shell,
  .brand-component-item .cta-box {
    margin-left: 0;
    margin-right: auto;
    text-align: left;
  }

  .brand-skeleton-demo {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    padding: var(--spacing-lg);
    background: var(--bg-light);
    border-radius: 6px;
    border: 1px solid var(--border-light);
    max-width: 400px;
