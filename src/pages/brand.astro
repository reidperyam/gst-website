---
import BaseLayout from '../layouts/BaseLayout.astro';
import ColorSpecimens from '../components/brand/ColorSpecimens.astro';
import CompositeLogo from '../components/CompositeLogo.astro';
import { palettes } from '../data/palettes';
import { trackPageView } from '../utils/analytics';
import DeltaIcon from '../components/DeltaIcon.astro';
import TableOfContents from '../components/TableOfContents.astro';

trackPageView('brand', 'Brand Style Reference');
---

<BaseLayout
  title="Brand Style Reference | GST"
  description="GST visual identity reference — colors, typography, spacing, and component patterns rendered live from the design system."
  showPalettePanel
>

<div class="container">
  <h1 class="brutal-heading-lg brand-page__title">Brand Style Reference</h1>
</div>

<div class="brand-layout">
  <TableOfContents
    testId="brand-toc"
    collapsible={true}
    scrollSpy={true}
    separatorBefore={[6, 10]}
    items={[
      { href: "#identity", label: "Brand Identity", isLayer: true, sublistSource: { mode: "query", scopeId: "identity" }, dataAttrs: { section: "identity" } },
      { href: "#colors", label: "Color Palette", isLayer: true, sublistSource: { mode: "query", scopeId: "colors" }, dataAttrs: { section: "colors" } },
      { href: "#typography", label: "Typography", isLayer: true, sublistSource: { mode: "query", scopeId: "typography" }, dataAttrs: { section: "typography" } },
      { href: "#spacing", label: "Spacing Scale", isLayer: true, sublistSource: { mode: "query", scopeId: "spacing" }, dataAttrs: { section: "spacing" } },
      { href: "#shadows", label: "Shadows" },
      { href: "#transitions", label: "Transitions" },
      { href: "#components", label: "Components", isLayer: true, sublistSource: { mode: "query", scopeId: "components" }, dataAttrs: { section: "components" } },
      { href: "#component-states", label: "Component States", isLayer: true, sublistSource: { mode: "query", scopeId: "component-states" }, dataAttrs: { section: "component-states" } },
      { href: "#accessibility", label: "Accessibility", isLayer: true, sublistSource: { mode: "query", scopeId: "accessibility" }, dataAttrs: { section: "accessibility" } },
      { href: "#responsive-demos", label: "Responsive Behavior", isLayer: true, sublistSource: { mode: "query", scopeId: "responsive-demos" }, dataAttrs: { section: "responsive-demos" } },
      { href: "#ui-library", label: "UI Component Library", isLayer: true, sublistSource: { mode: "query", scopeId: "ui-library" }, dataAttrs: { section: "ui-library" } },
      { href: "#toc-component", label: "Table of Contents", isLayer: true, sublistSource: { mode: "query", scopeId: "toc-component" }, dataAttrs: { section: "toc-component" } },
    ]}
  />

  <div class="brand-content palette-scope palette-0" id="palette-scope">

<!-- Section 1: Brand Identity -->
<section class="brand-section" id="identity">
  <div class="container">
    <h2 class="brutal-heading-md brand-section__title">Brand Identity</h2>

    <div class="brand-identity-grid">
      <div class="brand-identity-logos">
        <div class="brand-logo-item">
          <DeltaIcon size={80} class="brand-logo-delta" />
          <span class="brutal-text-small">Delta Icon</span>
        </div>
        <div class="brand-logo-item">
          <CompositeLogo size={120} class="brand-logo-composite" />
          <span class="brutal-text-small">Composite Logo</span>
        </div>
        <div class="brand-logo-item">
          <img src="/images/icon.svg" alt="GST composite logo (static)" width="120" height="120" />
          <span class="brutal-text-small">Static (PWA/OG)</span>
        </div>
      </div>

      <div class="brand-identity-info">
        <h3 class="brutal-heading-sm" id="brand-voice">Brand Voice</h3>
        <p class="brutal-text-base">Authoritative, precise, technical. No jargon for jargon's sake — clarity over complexity.</p>

        <h3 class="brutal-heading-sm" id="wordmark">Wordmark</h3>
        <p class="brutal-text-base"><strong>Global Strategic Technologies</strong> — formal contexts, first mention, legal. <strong>GST</strong> — shorthand, UI labels, repeat references.</p>

        <h3 class="brutal-heading-sm" id="logo-usage">Logo Usage</h3>
        <p class="brutal-text-base">Single teal-stroke delta variant. Works on both light and dark backgrounds without modification. Minimum clear space: the icon's own width on all sides.</p>
      </div>
    </div>
  </div>
</section>

<!-- Section 2: Color Palette (includes palette explorer migrated from /colors) -->
<section class="brand-section" id="colors">
    <div class="container">
      <h2 class="brutal-heading-md brand-section__title">Color Palette</h2>
      <p class="brutal-text-small brand-section__note brand-section__note--desktop">Toggle dark mode via the header to see theme-specific values. Open the palette panel (right edge) to switch palettes and edit colors live.</p>
      <p class="brutal-text-small brand-section__note brand-section__note--mobile">Toggle dark mode via the header to see theme-specific values. Color swatches are read-only on mobile. Use a desktop browser for the interactive palette explorer.</p>
      <p class="brutal-text-base colors-palette-concept" id="palette-concept">{palettes[0].concept}</p>

      <h3 class="brutal-heading-sm brand-group-title" id="colors-primary">Primary &amp; Secondary</h3>
      <div class="brand-swatch-grid">
        <div class="brand-swatch" data-var="--color-primary">
          <div class="brand-swatch__color" style="background: var(--color-primary);"></div>
          <div class="brand-swatch__label">--color-primary</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Primary actions, active states, accents</div>
        </div>
        <div class="brand-swatch" data-var="--color-primary-dark">
          <div class="brand-swatch__color" style="background: var(--color-primary-dark);"></div>
          <div class="brand-swatch__label">--color-primary-dark</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Hover/pressed state for primary</div>
        </div>
        <div class="brand-swatch" data-var="--color-secondary">
          <div class="brand-swatch__color" style="background: var(--color-secondary);"></div>
          <div class="brand-swatch__label">--color-secondary</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Secondary emphasis, amber highlights</div>
        </div>
        <div class="brand-swatch" data-var="--color-secondary-dark">
          <div class="brand-swatch__color" style="background: var(--color-secondary-dark);"></div>
          <div class="brand-swatch__label">--color-secondary-dark</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Dark-theme secondary variant</div>
        </div>
      </div>

      <h3 class="brutal-heading-sm brand-group-title" id="colors-semantic">Semantic</h3>
      <div class="brand-swatch-grid">
        <div class="brand-swatch" data-var="--color-success">
          <div class="brand-swatch__color" style="background: var(--color-success);"></div>
          <div class="brand-swatch__label">--color-success</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Positive outcomes, passing states</div>
        </div>
        <div class="brand-swatch" data-var="--color-warning">
          <div class="brand-swatch__color" style="background: var(--color-warning);"></div>
          <div class="brand-swatch__label">--color-warning</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Caution indicators, attention-needed</div>
        </div>
        <div class="brand-swatch" data-var="--color-error">
          <div class="brand-swatch__color" style="background: var(--color-error);"></div>
          <div class="brand-swatch__label">--color-error</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Errors, critical states, negative deltas</div>
        </div>
        <div class="brand-swatch" data-var="--color-info">
          <div class="brand-swatch__color" style="background: var(--color-info);"></div>
          <div class="brand-swatch__label">--color-info</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Informational highlights (alias of primary)</div>
        </div>
      </div>

      <h3 class="brutal-heading-sm brand-group-title" id="colors-text">Text Hierarchy</h3>
      <div class="brand-swatch-grid">
        <div class="brand-swatch" data-var="--text-primary">
          <div class="brand-swatch__color brand-swatch__color--checker" style="background-color: var(--text-primary);"></div>
          <div class="brand-swatch__label">--text-primary</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Headings, high-emphasis body text</div>
        </div>
        <div class="brand-swatch" data-var="--text-secondary">
          <div class="brand-swatch__color brand-swatch__color--checker" style="background-color: var(--text-secondary);"></div>
          <div class="brand-swatch__label">--text-secondary</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Body text, descriptions</div>
        </div>
        <div class="brand-swatch" data-var="--text-muted">
          <div class="brand-swatch__color brand-swatch__color--checker" style="background-color: var(--text-muted);"></div>
          <div class="brand-swatch__label">--text-muted</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Labels, captions, supporting text</div>
        </div>
        <div class="brand-swatch" data-var="--text-faded">
          <div class="brand-swatch__color brand-swatch__color--checker" style="background-color: var(--text-faded);"></div>
          <div class="brand-swatch__label">--text-faded</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Placeholders, disabled text, timestamps</div>
        </div>
      </div>

      <h3 class="brutal-heading-sm brand-group-title" id="colors-backgrounds">Backgrounds</h3>
      <div class="brand-swatch-grid">
        <div class="brand-swatch" data-var="--bg-light">
          <div class="brand-swatch__color" style="background: var(--bg-light);"></div>
          <div class="brand-swatch__label">--bg-light</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Page background, card surfaces</div>
        </div>
        <div class="brand-swatch" data-var="--bg-light-alt">
          <div class="brand-swatch__color" style="background: var(--bg-light-alt);"></div>
          <div class="brand-swatch__label">--bg-light-alt</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Alternate sections, tool shells</div>
        </div>
        <div class="brand-swatch" data-var="--bg-dark">
          <div class="brand-swatch__color" style="background: var(--bg-dark);"></div>
          <div class="brand-swatch__label">--bg-dark</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Dark-theme page bg, service cards</div>
        </div>
        <div class="brand-swatch" data-var="--bg-dark-secondary">
          <div class="brand-swatch__color" style="background: var(--bg-dark-secondary);"></div>
          <div class="brand-swatch__label">--bg-dark-secondary</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Elevated dark surfaces, modals</div>
        </div>
        <div class="brand-swatch" data-var="--bg-dark-tertiary">
          <div class="brand-swatch__color" style="background: var(--bg-dark-tertiary);"></div>
          <div class="brand-swatch__label">--bg-dark-tertiary</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Footer, section backgrounds (dark)</div>
        </div>
      </div>

      <h3 class="brutal-heading-sm brand-group-title" id="colors-borders">Borders &amp; Accents</h3>
      <div class="brand-swatch-grid">
        <div class="brand-swatch" data-var="--border-light">
          <div class="brand-swatch__color brand-swatch__color--checker" style="background-color: var(--border-light);"></div>
          <div class="brand-swatch__label">--border-light</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Dividers, card borders, table lines</div>
        </div>
        <div class="brand-swatch" data-var="--accent-light-bg">
          <div class="brand-swatch__color brand-swatch__color--checker" style="background-color: var(--accent-light-bg);"></div>
          <div class="brand-swatch__label">--accent-light-bg</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Active row highlights, accent fills</div>
        </div>
        <div class="brand-swatch" data-var="--accent-light-bg-hover">
          <div class="brand-swatch__color brand-swatch__color--checker" style="background-color: var(--accent-light-bg-hover);"></div>
          <div class="brand-swatch__label">--accent-light-bg-hover</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Hover state for accent backgrounds</div>
        </div>
        <div class="brand-swatch" data-var="--accent-border-light">
          <div class="brand-swatch__color brand-swatch__color--checker" style="background-color: var(--accent-border-light);"></div>
          <div class="brand-swatch__label">--accent-border-light</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Subtle accent borders, badge outlines</div>
        </div>
        <div class="brand-swatch" data-var="--accent-border-medium">
          <div class="brand-swatch__color brand-swatch__color--checker" style="background-color: var(--accent-border-medium);"></div>
          <div class="brand-swatch__label">--accent-border-medium</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Stronger accent borders, focus rings</div>
        </div>
      </div>

      <h3 class="brutal-heading-sm brand-group-title" id="colors-expanded">Expanded Palette</h3>
      <p class="brutal-text-small brand-section__note">Purpose-named tokens shared across all tools. Tool-specific variables (TechPar zones, ICG maturity, DM domain, RegMap categories) derive from these.</p>
      <div class="brand-swatch-grid">
        <div class="brand-swatch" data-var="--color-authority">
          <div class="brand-swatch__color" style="background: var(--color-authority);"></div>
          <div class="brand-swatch__label">--color-authority</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Institutional credibility — hub authority line, DM results, TechPar personnel</div>
        </div>
        <div class="brand-swatch" data-var="--color-distinguish">
          <div class="brand-swatch__color" style="background: var(--color-distinguish);"></div>
          <div class="brand-swatch__label">--color-distinguish</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Differentiation accent — RegMap industry, TechPar R&amp;D OpEx, chart series</div>
        </div>
        <div class="brand-swatch" data-var="--color-subdued">
          <div class="brand-swatch__color" style="background: var(--color-subdued);"></div>
          <div class="brand-swatch__label">--color-subdued</div>
          <div class="brand-swatch__value"></div>
          <div class="brand-swatch__usage">Muted neutral — DM methodology, process/background contexts</div>
        </div>
      </div>

      <!-- Palette specimens and derived tool colors -->
      <ColorSpecimens />
    </div>
</section>

<!-- Section 3: Typography -->
<section class="brand-section" id="typography">
  <div class="container">
    <h2 class="brutal-heading-md brand-section__title">Typography</h2>

    <h3 class="brutal-heading-sm brand-group-title" id="type-font-stack">Font Stack</h3>
    <p class="brutal-text-base"><code class="brand-code">--font-family</code>: <span class="brand-font-stack" data-var="--font-family"></span></p>

    <h3 class="brutal-heading-sm brand-group-title" id="type-sizes">Text Size Scale</h3>
    <div class="brand-type-specimens">
      <div class="brand-type-specimen" data-var="--text-xs">
        <span data-specimen style="font-size: var(--text-xs);">The quick brown fox — text-xs</span>
        <code class="brand-code">--text-xs</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-sm">
        <span data-specimen style="font-size: var(--text-sm);">The quick brown fox — text-sm</span>
        <code class="brand-code">--text-sm</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-base">
        <span data-specimen style="font-size: var(--text-base);">The quick brown fox — text-base</span>
        <code class="brand-code">--text-base</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-lg">
        <span data-specimen style="font-size: var(--text-lg);">The quick brown fox — text-lg</span>
        <code class="brand-code">--text-lg</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-xl">
        <span data-specimen style="font-size: var(--text-xl);">The quick brown fox — text-xl</span>
        <code class="brand-code">--text-xl</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-2xl">
        <span data-specimen style="font-size: var(--text-2xl);">The quick brown fox — text-2xl</span>
        <code class="brand-code">--text-2xl</code>
        <span class="brand-type-value"></span>
      </div>
    </div>

    <h3 class="brutal-heading-sm brand-group-title" id="type-weights">Font Weights</h3>
    <div class="brand-type-specimens">
      <div class="brand-type-specimen">
        <span data-specimen style="font-weight: var(--font-weight-normal);">Normal (400) — The quick brown fox</span>
        <code class="brand-code">--font-weight-normal</code>
      </div>
      <div class="brand-type-specimen">
        <span data-specimen style="font-weight: var(--font-weight-semibold);">Semibold (600) — The quick brown fox</span>
        <code class="brand-code">--font-weight-semibold</code>
      </div>
      <div class="brand-type-specimen">
        <span data-specimen style="font-weight: var(--font-weight-bold);">Bold (700) — The quick brown fox</span>
        <code class="brand-code">--font-weight-bold</code>
      </div>
    </div>

    <h3 class="brutal-heading-sm brand-group-title" id="type-utilities">Typography Utilities</h3>
    <p class="brutal-text-small brand-section__note">Monospace-first variants for controls, data display, and tool interfaces. Designed to complement the existing Helvetica Neue system typography.</p>

    <div class="brand-type-specimens">
      <div class="brand-type-specimen">
        <span class="brutal-heading-xl" data-specimen>Heading XL</span>
        <code class="brand-code">.brutal-heading-xl</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-heading-lg" data-specimen>Heading LG</span>
        <code class="brand-code">.brutal-heading-lg</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-heading-md" data-specimen>Heading MD</span>
        <code class="brand-code">.brutal-heading-md</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-heading-sm" data-specimen>Heading SM</span>
        <code class="brand-code">.brutal-heading-sm</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-text-base" data-specimen>Text Base — The quick brown fox jumps over the lazy dog</span>
        <code class="brand-code">.brutal-text-base</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-text-small" data-specimen>Text Small — The quick brown fox jumps over the lazy dog</span>
        <code class="brand-code">.brutal-text-small</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-text-tiny" data-specimen>Text Tiny — The quick brown fox jumps over the lazy dog</span>
        <code class="brand-code">.brutal-text-tiny</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-label" data-specimen>Label</span>
        <code class="brand-code">.brutal-label</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-label-small" data-specimen>Label Small</span>
        <code class="brand-code">.brutal-label-small</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-data" data-specimen>$18,240,000</span>
        <code class="brand-code">.brutal-data</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-data-sm" data-specimen>12.4%</span>
        <code class="brand-code">.brutal-data-sm</code>
        <span class="brand-type-meta"></span>
      </div>
    </div>
  </div>
</section>

<!-- Section 4: Spacing Scale -->
<section class="brand-section" id="spacing">
  <div class="container">
    <h2 class="brutal-heading-md brand-section__title">Spacing Scale</h2>

    <h3 class="brutal-heading-sm brand-group-title" id="spacing-tokens">Spacing Tokens</h3>
    <div class="brand-spacing-list">
      <div class="brand-spacing-row" data-var="--spacing-xs">
        <code class="brand-code brand-spacing-name">--spacing-xs</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-xs);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-sm">
        <code class="brand-code brand-spacing-name">--spacing-sm</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-sm);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-md">
        <code class="brand-code brand-spacing-name">--spacing-md</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-md);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-lg">
        <code class="brand-code brand-spacing-name">--spacing-lg</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-lg);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-xl">
        <code class="brand-code brand-spacing-name">--spacing-xl</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-xl);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-2xl">
        <code class="brand-code brand-spacing-name">--spacing-2xl</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-2xl);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-2_5xl">
        <code class="brand-code brand-spacing-name">--spacing-2_5xl</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-2_5xl);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-3xl">
        <code class="brand-code brand-spacing-name">--spacing-3xl</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-3xl);"></div>
        <span class="brand-spacing-value"></span>
