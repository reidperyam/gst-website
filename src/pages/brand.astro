---
import BaseLayout from '../layouts/BaseLayout.astro';
import { trackPageView } from '../utils/analytics';
import TableOfContents from '../components/TableOfContents.astro';
import BrandIdentity from '../components/brand/BrandIdentity.astro';
import BrandColors from '../components/brand/BrandColors.astro';
import BrandTypography from '../components/brand/BrandTypography.astro';
import BrandComponents from '../components/brand/BrandComponents.astro';
import BrandAccessibility from '../components/brand/BrandAccessibility.astro';
import BrandUILibrary from '../components/brand/BrandUILibrary.astro';

trackPageView('brand', 'Brand Style Reference');
---

<BaseLayout
  title="Brand Style Reference | GST"
  description="GST visual identity reference — colors, typography, spacing, and component patterns rendered live from the design system."
  showPalettePanel
>
  <div class="container">
    <h1 class="brutal-heading-lg brand-page__title">Brand Style Reference</h1>
  </div>

  <div class="brand-layout">
    <TableOfContents
      testId="brand-toc"
      collapsible={true}
      scrollSpy={true}
      separatorBefore={[6, 10]}
      items={[
        {
          href: '#identity',
          label: 'Brand Identity',
          isLayer: true,
          sublistSource: { mode: 'query', scopeId: 'identity' },
          dataAttrs: { section: 'identity' },
        },
        {
          href: '#colors',
          label: 'Color Palette',
          isLayer: true,
          sublistSource: { mode: 'query', scopeId: 'colors' },
          dataAttrs: { section: 'colors' },
        },
        {
          href: '#typography',
          label: 'Typography',
          isLayer: true,
          sublistSource: { mode: 'query', scopeId: 'typography' },
          dataAttrs: { section: 'typography' },
        },
        {
          href: '#spacing',
          label: 'Spacing Scale',
          isLayer: true,
          sublistSource: { mode: 'query', scopeId: 'spacing' },
          dataAttrs: { section: 'spacing' },
        },
        { href: '#shadows', label: 'Shadows' },
        { href: '#transitions', label: 'Transitions' },
        {
          href: '#components',
          label: 'Components',
          isLayer: true,
          sublistSource: { mode: 'query', scopeId: 'components' },
          dataAttrs: { section: 'components' },
        },
        {
          href: '#component-states',
          label: 'Component States',
          isLayer: true,
          sublistSource: { mode: 'query', scopeId: 'component-states' },
          dataAttrs: { section: 'component-states' },
        },
        {
          href: '#accessibility',
          label: 'Accessibility',
          isLayer: true,
          sublistSource: { mode: 'query', scopeId: 'accessibility' },
          dataAttrs: { section: 'accessibility' },
        },
        {
          href: '#responsive-demos',
          label: 'Responsive Behavior',
          isLayer: true,
          sublistSource: { mode: 'query', scopeId: 'responsive-demos' },
          dataAttrs: { section: 'responsive-demos' },
        },
        {
          href: '#ui-library',
          label: 'UI Component Library',
          isLayer: true,
          sublistSource: { mode: 'query', scopeId: 'ui-library' },
          dataAttrs: { section: 'ui-library' },
        },
        {
          href: '#toc-component',
          label: 'Table of Contents',
          isLayer: true,
          sublistSource: { mode: 'query', scopeId: 'toc-component' },
          dataAttrs: { section: 'toc-component' },
        },
      ]}
    />

    <div class="brand-content palette-scope palette-0" id="palette-scope">
      <BrandIdentity />
      <BrandColors />
      <BrandTypography />
      <BrandComponents />
      <BrandAccessibility />
      <BrandUILibrary />
    </div><!-- .brand-content .palette-scope -->
  </div><!-- .brand-layout -->
</BaseLayout>

<!-- REPLACED: ~3,980 lines of inline HTML moved to 6 components in src/components/brand/ -->
<!-- Sections: BrandIdentity, BrandColors, BrandTypography, BrandComponents, BrandAccessibility, BrandUILibrary -->

<style is:global>
  /* Brand Page Title */
  .brand-page__title {
    padding-top: var(--spacing-2xl);
    margin-bottom: 0;
  }

  /* Brand Page Layout */
  .brand-section {
    padding: var(--spacing-3xl) 0;
    border-bottom: 1px solid var(--border-light);
  }

  .brand-section:last-child {
    border-bottom: none;
  }

  .brand-section__title {
    margin-bottom: var(--spacing-xl);
    padding-bottom: var(--spacing-sm);
    border-bottom: 2px solid var(--color-primary);
  }

  .brand-section__note--mobile {
    display: none;
  }

  .brand-section__note {
    margin-bottom: var(--spacing-xl);
    color: var(--text-muted);
  }

  .brand-group-title {
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-lg);
  }

  .brand-group-title:first-of-type {
    margin-top: 0;
  }

  .brand-subgroup-title {
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-sm);
  }

  /* Brand Identity */
  .brand-identity-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--spacing-2xl);
    align-items: start;
  }

  .brand-identity-logos {
    display: flex;
    gap: var(--spacing-xl);
    align-items: flex-end;
  }

  .brand-logo-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .brand-logo-item img,
  .brand-logo-item .brand-logo-composite {
    border: 1px solid var(--border-light);
    border-radius: 6px;
    padding: var(--spacing-md);
    background: var(--bg-light-alt);
  }

  .brand-logo-item .brand-logo-delta,
  .brand-logo-item .brand-logo-composite {
    color: var(--color-primary);
  }

  .brand-identity-info h3 {
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-xs);
  }

  .brand-identity-info h3:first-child {
    margin-top: 0;
  }

  .brand-identity-info p {
    margin-bottom: var(--spacing-sm);
  }

  /* Color Swatches */
  .brand-swatch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--gap-normal);
  }

  .brand-swatch__color {
    aspect-ratio: 1;
    border-radius: 6px;
    border: 1px solid var(--border-light);
    margin-bottom: var(--spacing-xs);
  }

  .brand-swatch__color--checker {
    background-image:
      linear-gradient(45deg, var(--checkerboard-line) 25%, transparent 25%),
      linear-gradient(-45deg, var(--checkerboard-line) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, var(--checkerboard-line) 75%),
      linear-gradient(-45deg, transparent 75%, var(--checkerboard-line) 75%);
    background-size: 10px 10px;
    background-position:
      0 0,
      0 5px,
      5px -5px,
      -5px 0;
  }

  .brand-swatch__label {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-secondary);
    word-break: break-all;
  }

  .brand-swatch__value {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-muted);
    min-height: 1.2em;
  }

  .brand-swatch__usage {
    font-size: 0.65rem;
    color: var(--text-faded);
    line-height: 1.3;
  }

  /* Typography Specimens */
  .brand-type-specimens {
    display: flex;
    flex-direction: column;
  }

  .brand-type-specimen {
    display: flex;
    align-items: baseline;
    gap: var(--spacing-lg);
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid var(--border-light);
  }

  .brand-type-specimen > span:first-child {
    flex: 1;
    min-width: 0;
  }

  .brand-type-meta,
  .brand-type-value {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .brand-code {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-muted);
    background: var(--accent-subtle-bg);
    padding: 2px 6px;
    border-radius: 3px;
    white-space: nowrap;
  }

  .brand-font-stack {
    font-family: monospace;
    color: var(--text-secondary);
  }

  /* Spacing Scale */
  .brand-spacing-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  .brand-spacing-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .brand-spacing-name {
    width: 160px;
    flex-shrink: 0;
  }

  .brand-spacing-bar {
    height: 12px;
    background: var(--color-primary);
    border-radius: 2px;
    min-width: 4px;
  }

  .brand-spacing-value {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* Shadows */
  .brand-shadow-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap-wide);
  }

  /* Transitions */
  .brand-transition-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--gap-wide);
  }

  .brand-transition-value {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-muted);
  }

  /* Components */
  .brand-component-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-wide);
    align-items: flex-start;
    margin-bottom: var(--spacing-lg);
  }

  .brand-component-item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    align-items: flex-start;
  }

  .brand-component-item--full {
    width: 100%;
  }

  .brand-skeleton-demo {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
    padding: var(--spacing-lg);
    background: var(--bg-light);
    border-radius: 6px;
    border: 1px solid var(--border-light);
    max-width: 400px;
  }

  /* Breadcrumb demo */
  .brand-breadcrumb-demo {
    padding: var(--spacing-lg) 0 0;
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .brand-breadcrumb-demo .breadcrumb__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: baseline;
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .brand-breadcrumb-demo .breadcrumb__item {
    display: flex;
    align-items: baseline;
    white-space: nowrap;
  }

  .brand-breadcrumb-demo .breadcrumb__item a {
    color: var(--color-primary);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .brand-breadcrumb-demo .breadcrumb__item a:hover {
    opacity: 0.8;
  }

  .brand-breadcrumb-demo .breadcrumb__separator {
    margin: 0 var(--spacing-sm);
  }

  /* Wizard progress (desktop) */
  .brand-wizard-progress {
    display: flex;
    justify-content: center;
    gap: var(--spacing-xs);
    flex-wrap: wrap;
  }

  .brand-progress-segment {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xs);
    flex: 1;
    max-width: 100px;
    min-width: 40px;
    opacity: 0.4;
    transition: opacity var(--transition-normal);
  }

  .brand-progress-segment--active,
  .brand-progress-segment--completed {
    opacity: 1;
  }

  .brand-progress-number {
    width: 3rem;
    height: 3rem;
    flex-shrink: 0;
    color: light-dark(var(--border-light), rgba(255, 255, 255, 0.3));
    transition:
      color var(--transition-normal),
      transform var(--transition-normal);
  }

  .brand-progress-segment--active .brand-progress-number {
    color: var(--color-primary);
    transform: scale(1.15);
  }

  .brand-progress-number-text {
    font-size: 1.1rem;
    font-weight: var(--font-weight-bold);
    fill: var(--text-muted);
  }

  .brand-progress-segment--active .brand-progress-number-text {
    fill: var(--text-primary);
  }

  .brand-progress-segment--completed .brand-progress-number-text {
    fill: light-dark(#ffffff, #0a0a0a);
  }

  .brand-progress-label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    text-align: center;
  }

  .brand-progress-segment--active .brand-progress-label {
    color: var(--text-primary);
  }

  /* Wizard progress (mobile) */
  .brand-wizard-progress-mobile {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .brand-progress-mobile-label {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-secondary);
    letter-spacing: 0.02em;
  }

  .brand-progress-mobile-current {
    color: var(--color-primary);
    font-weight: var(--font-weight-bold);
  }

  .brand-progress-mobile-name {
    color: var(--text-primary);
  }

  .brand-progress-mobile-dots {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-xs);
  }

  .brand-progress-dot {
    width: 2.75rem;
    height: 2.75rem;
    background: none;
    border: none;
    padding: var(--spacing-sm);
    color: light-dark(var(--border-light), rgba(255, 255, 255, 0.3));
    opacity: 0.4;
    cursor: default;
    transition:
      color var(--transition-normal),
      opacity var(--transition-normal),
      transform var(--transition-normal);
  }

  .brand-progress-dot svg {
    width: 100%;
    height: 100%;
  }

  .brand-progress-dot--even svg path {
    transform: rotate(180deg);
    transform-origin: 32px 32px;
  }

  .brand-progress-dot--active,
  .brand-progress-dot--completed {
    opacity: 1;
  }

  .brand-progress-dot--active {
    color: var(--color-primary);
    transform: scale(1.2);
  }

  .brand-progress-dot--completed svg path {
    fill: var(--color-primary);
    stroke: var(--color-primary);
  }

  .brand-progress-segment--completed .brand-progress-number path {
    fill: var(--color-primary);
    stroke: var(--color-primary);
  }

  /* Card grid */
  .brand-card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gap-extra-wide);
    margin-bottom: var(--spacing-lg);
  }

  .brand-card-grid--single {
    grid-template-columns: 1fr;
    max-width: 400px;
  }

  /* Details/Summary */
  .brand-details {
    border: 1px solid var(--border-light);
    border-radius: 6px;
  }

  .brand-details__summary {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md) var(--spacing-lg);
    cursor: pointer;
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: 600;
    list-style: none;
    transition: color var(--transition-fast);
  }

  .brand-details__summary::-webkit-details-marker {
    display: none;
  }

  .brand-details__summary:hover {
    color: var(--text-primary);
  }

  .brand-details__toggle::before {
    content: '+';
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    display: inline-block;
    width: 1em;
    text-align: center;
  }

  .brand-details[open] .brand-details__toggle::before {
    content: '−';
  }

  .brand-details__body {
    padding: 0 var(--spacing-lg) var(--spacing-lg);
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: var(--text-sm);
    border-top: 1px solid var(--border-light);
    padding-top: var(--spacing-md);
  }

  .brand-details__body p {
    margin: 0;
  }

  /* Container demo */
  .brand-container-demo {
    border: 1px dashed var(--color-primary);
    border-radius: 4px;
    padding: 2px;
  }

  .brand-container-inner {
    background: var(--accent-subtle-bg);
    padding: var(--spacing-lg) var(--spacing-2xl);
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-family: monospace;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .brand-section__note--desktop {
      display: none;
    }

    .brand-section__note--mobile {
      display: block;
    }

    .brand-section {
      padding: var(--spacing-2xl) 0;
    }

    .brand-identity-grid {
      grid-template-columns: 1fr;
    }

    .brand-swatch-grid {
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    }

    .brand-type-specimen {
      flex-direction: column;
      gap: var(--spacing-xs);
    }

    .brand-shadow-grid,
    .brand-transition-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .brand-spacing-name {
      width: 130px;
    }

    .brand-card-grid {
      grid-template-columns: 1fr;
    }

    .brand-type-specimen > span:first-child {
      overflow-wrap: break-word;
    }

    .brand-component-item {
      max-width: 100%;
      overflow-x: auto;
    }

    .a11y-contrast-table,
    .a11y-kb-table {
      overflow-x: auto;
    }
  }

  @media (max-width: 480px) {
    .brand-section {
      padding: var(--spacing-xl) 0;
    }

    .brand-swatch-grid {
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    }

    .brand-swatch__usage {
      display: none;
    }

    .brand-shadow-grid,
    .brand-transition-grid {
      grid-template-columns: 1fr;
    }

    .brand-spacing-row {
      flex-wrap: wrap;
    }

    .brand-spacing-name {
      width: 100%;
    }

    .brand-identity-logos {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  /* ═══════════════════════════════════════════════════════════
     PALETTE EXPLORER — variables and scope overrides
     (migrated from colors.astro)
     ═══════════════════════════════════════════════════════════ */

  .colors-palette-concept {
    color: var(--text-secondary);
    max-width: 680px;
    height: 3.2em;
    overflow: hidden;
    margin-bottom: var(--spacing-xl);
  }

  /* palette-scope layout (palette CSS vars now in palettes.css) */
  .palette-scope {
    padding-bottom: var(--spacing-3xl);
  }

  /* ── REMOVED: :root alt-color definitions, dark-theme overrides,
       .palette-scope tool derivations, .palette-0 through .palette-5
       — all moved to src/styles/palettes.css ── */

  /* ── Component State Demo Layout ── */
  .brand-state-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--gap-wide);
    align-items: flex-start;
    margin-bottom: var(--spacing-lg);
  }

  .brand-state-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: var(--gap-wide);
    margin-bottom: var(--spacing-lg);
  }

  .brand-state-item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
    align-items: flex-start;
  }

  .brand-state-item--wide {
    min-width: 240px;
  }

  /* ── Forced state: hover ── */
  .brutal-btn--primary[data-demo-state='hover'] {
    background: transparent;
    color: var(--color-primary);
  }

  .brutal-btn--secondary[data-demo-state='hover'] {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .brutal-option-card[data-demo-state='hover'] {
    border-color: var(--color-primary);
    background: var(--accent-subtle-bg);
  }

  .brutal-choice-btn[data-demo-state='hover'] {
    border-color: var(--color-primary);
    color: var(--text-primary);
  }

  /* ── Forced state: focus ── */
  .brutal-btn[data-demo-state='focus'] {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .brutal-field__input[data-demo-state='focus'] {
    border-color: var(--color-primary);
    border-style: solid;
  }

  .brutal-option-card[data-demo-state='focus'] {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .brutal-choice-btn[data-demo-state='focus'] {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* ── Forced state: error ── */
  .brutal-field__input[data-demo-state='error'] {
    border-color: var(--color-error);
    border-style: solid;
  }

  /* ── Forced state: readonly ── */
  .brutal-field__input[data-demo-state='readonly'] {
    color: var(--text-muted);
    cursor: default;
  }

  /* ── Forced state: focus on link ── */
  .brutal-link-interactive[data-demo-state='focus'] {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  /* ── Accessibility Section ── */
  .a11y-contrast-table {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-bottom: var(--spacing-xl);
    max-width: 600px;
  }

  .a11y-contrast-row {
    display: grid;
    grid-template-columns: 24px 1fr auto auto;
    gap: var(--spacing-md);
    align-items: center;
    padding: var(--spacing-xs) var(--spacing-sm);
    font-family: monospace;
    font-size: var(--text-xs);
    background: var(--bg-light-alt);
    border: 1px solid light-dark(var(--border-light), var(--border-dark-default));
  }

  .a11y-swatch {
    width: 24px;
    height: 24px;
    border: 1px solid light-dark(var(--border-light), var(--border-dark-default));
  }

  .a11y-var {
    color: var(--text-secondary);
  }

  .a11y-ratio {
    color: var(--text-muted);
    text-align: right;
  }

  .a11y-badge {
    font-size: 0.65rem;
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px var(--spacing-xs);
    border: 1px solid;
  }

  .a11y-badge--pass {
    color: var(--color-success);
    border-color: var(--color-success);
  }

  .a11y-badge--warn {
    color: var(--color-warning);
    border-color: var(--color-warning);
  }

  .a11y-badge--fail {
    color: var(--color-error);
    border-color: var(--color-error);
  }

  .a11y-touch-demo {
    position: relative;
    display: inline-flex;
  }

  .a11y-touch-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 44px;
    height: 44px;
    border: 2px dashed var(--color-primary);
    display: flex;
