  /* ── Modal ─────────────────────────────────────────── */
  .modal {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    max-width: 700px;
    width: 90%;
    max-height: 85vh;
    padding: 2rem;
    background: light-dark(#ffffff, #1a1a1a);
    border: 1px solid light-dark(var(--border-light), var(--border-dark));
    border-radius: 0;
    clip-path: polygon(
      2.5% 0%,
      97.5% 0%,
      100% 2.5%,
      100% 97.5%,
      97.5% 100%,
      2.5% 100%,
      0% 97.5%,
      0% 2.5%
    );
    z-index: var(--z-modal);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    overflow-y: auto;
  }

  .modal::backdrop {
    background: rgba(0, 0, 0, 0.5);
  }

  .modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: transparent;
    border: 2px solid transparent;
    cursor: pointer;
    color: var(--text-muted);
    padding: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    min-height: 44px;
    transition: all 0.2s;
  }

  .modal__close:hover {
    color: var(--color-primary);
