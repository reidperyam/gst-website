  /* ═══════════════════════════════════════════════════════════
     Brand-page specimen styles — demo production components.
     Moved from global.css to keep them colocated with the page
     that uses them. Uses is:global so selectors remain unscoped.
     ═══════════════════════════════════════════════════════════ */

  /* ── Search Input ──────────────────────────────────── */
  .search-box {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .search-icon {
