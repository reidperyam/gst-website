    transition: color var(--transition-fast);
  }

  .filter-drawer-demo__close:hover {
    color: var(--color-primary);
  }

  .filter-drawer-demo__content {
    padding: 1.5rem;
  }

  .clear-filters {
    background: transparent;
    border: 1px solid var(--clear-filters-border, rgba(26, 26, 26, 0.1));
    color: var(--clear-filters-text, rgba(26, 26, 26, 0.6));
    padding: 0.5rem 1rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    margin-bottom: 1.5rem;
    font-family: var(--font-family);
    transition: all var(--transition-fast);
  }

  .clear-filters:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .filter-section {
    margin-bottom: 1.5rem;
  }

  .filter-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  /* ── Stats Bar (current specimen) ─────────────────── */
  .stats-bar {
    background: var(--color-primary);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
  }

  .stat-item {
    text-align: center;
    padding: 1.5rem 1rem;
  }

  .stat-value {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--bg-dark);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .stat-label {
    font-size: 0.75rem;
    color: var(--bg-dark);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  /* ── CTA Box ───────────────────────────────────────── */
  .cta-box {
    background: var(--bg-light);
    border: 2px solid var(--color-primary);
    padding: 3rem;
    max-width: 600px;
    text-align: center;
