</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Delta chevron toggle demo
    const toggle = document.getElementById('chevron-toggle');
    const demo = document.getElementById('chevron-demo');
    if (toggle && demo) {
      toggle.addEventListener('click', () => {
        demo.classList.toggle('is-collapsed');
      });
    }

    // Modal demo
    const modalOpen = document.getElementById('demo-modal-open');
    const modal = document.getElementById('demo-modal') as HTMLDialogElement;
    const modalClose = document.getElementById('demo-modal-close');
    if (modalOpen && modal && modalClose) {
      modalOpen.addEventListener('click', () => modal.showModal());
      modalClose.addEventListener('click', () => modal.close());
      modal.addEventListener('click', (e) => {
        if (e.target === modal) modal.close();
      });
    }

    // Brutalist slider demo — sync range, number input, and display value
    const sliderBrutal = document.getElementById('demo-slider-brutal') as HTMLInputElement;
    const sliderBrutalDirect = document.getElementById('demo-slider-brutal-direct') as HTMLInputElement;
    const sliderBrutalValue = document.getElementById('demo-slider-brutal-value');
    if (sliderBrutal && sliderBrutalDirect && sliderBrutalValue) {
      sliderBrutal.addEventListener('input', () => {
        sliderBrutalValue.textContent = sliderBrutal.value;
        sliderBrutalDirect.value = sliderBrutal.value;
      });
      sliderBrutalDirect.addEventListener('input', () => {
        const v = Math.min(Math.max(parseInt(sliderBrutalDirect.value) || 1, 1), 50);
        sliderBrutal.value = String(v);
        sliderBrutalValue.textContent = String(v);
      });
    }

    // Option card single-select demo (current)
    document.querySelectorAll<HTMLElement>('[data-demo-option]').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll<HTMLElement>('[data-demo-option]').forEach(c =>
          c.classList.remove('option-card--selected'));
        card.classList.add('option-card--selected');
      });
    });

    // Option card single-select demo (brutalist)
    document.querySelectorAll<HTMLElement>('[data-demo-option-brutal]').forEach(card => {
      card.addEventListener('click', () => {
        document.querySelectorAll<HTMLElement>('[data-demo-option-brutal]').forEach(c =>
          c.classList.remove('option-card-brutal--selected'));
        card.classList.add('option-card-brutal--selected');
      });
    });

    // Filter chip toggle demo (brutalist)
    document.querySelectorAll<HTMLElement>('[data-demo-chip-brutal]').forEach(chip => {
      chip.addEventListener('click', () => {
        chip.classList.toggle('brand-chip-brutal--active');
      });
    });

    // Slider demo — sync range, number input, and display value
    const slider = document.getElementById('demo-slider') as HTMLInputElement;
    const sliderDirect = document.getElementById('demo-slider-direct') as HTMLInputElement;
    const sliderValue = document.getElementById('demo-slider-value');
    if (slider && sliderDirect && sliderValue) {
      slider.addEventListener('input', () => {
        sliderValue.textContent = slider.value;
        sliderDirect.value = slider.value;
      });
      sliderDirect.addEventListener('input', () => {
        const v = Math.min(Math.max(parseInt(sliderDirect.value) || 1, 1), 50);
        slider.value = String(v);
        sliderValue.textContent = String(v);
      });
    }

    // Recommendation card — collapse toggle and N/A dismiss
    const recCard = document.getElementById('demo-rec-card');
    const recNa = document.getElementById('demo-rec-na');
    if (recCard) {
      recCard.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.rec-na')) return;
        recCard.classList.toggle('is-collapsed');
      });
    }
    if (recNa && recCard) {
      recNa.addEventListener('click', () => {
        recCard.classList.toggle('is-dismissed');
      });
    }

    // Brutalist recommendation card — collapse toggle and N/A dismiss
    const recBrutal = document.getElementById('demo-rec-brutal');
    const recBrutalNa = document.getElementById('demo-rec-brutal-na');
    if (recBrutal) {
      recBrutal.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.brand-rec-brutal__na')) return;
        recBrutal.classList.toggle('is-collapsed');
      });
    }
    if (recBrutalNa && recBrutal) {
      recBrutalNa.addEventListener('click', () => {
        recBrutal.classList.toggle('is-dismissed');
      });
    }

    // Brutalist attention card — collapse toggle and N/A dismiss
    const attBrutal = document.getElementById('demo-attention-brutal');
    const attBrutalNa = document.getElementById('demo-attention-brutal-na');
    if (attBrutal) {
      attBrutal.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.brand-attention-brutal__na')) return;
        attBrutal.classList.toggle('is-collapsed');
      });
    }
    if (attBrutalNa && attBrutal) {
      attBrutalNa.addEventListener('click', () => {
        attBrutal.classList.toggle('is-dismissed');
      });
    }

    // Attention card — collapse toggle and N/A dismiss
    const attCard = document.getElementById('demo-attention-card');
    const attNa = document.getElementById('demo-attention-na');
    if (attCard) {
      attCard.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('.attention-na')) return;
        attCard.classList.toggle('is-collapsed');
      });
    }
    if (attNa && attCard) {
      attNa.addEventListener('click', () => {
        attCard.classList.toggle('is-dismissed');
      });
    }

    // Responsive demo: sync theme to iframes
    const syncThemeToFrames = () => {
      const isDark = document.documentElement.classList.contains('dark-theme');
      document.querySelectorAll<HTMLIFrameElement>('.responsive-demo-frame iframe').forEach(f => {
        f.contentWindow?.postMessage({ type: 'theme-sync', dark: isDark }, '*');
      });
    };
    // Observe theme class changes on <html>
    const themeObserver = new MutationObserver(syncThemeToFrames);
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
    // Initial sync after iframes load
    document.querySelectorAll<HTMLIFrameElement>('.responsive-demo-frame iframe').forEach(f => {
      f.addEventListener('load', syncThemeToFrames);
    });
  });
</script>
