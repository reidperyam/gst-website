---
import BaseLayout from '../layouts/BaseLayout.astro';
import { trackPageView } from '../utils/analytics';

trackPageView('brand', 'Brand Style Reference');
---

<BaseLayout
  title="Brand Style Reference | GST"
  description="GST visual identity reference — colors, typography, spacing, and component patterns rendered live from the design system."
>

<!-- Section 1: Brand Identity -->
<section class="brand-section" id="identity">
  <div class="container">
    <h2 class="heading-md brand-section__title">Brand Identity</h2>

    <div class="brand-identity-grid">
      <div class="brand-identity-logos">
        <div class="brand-logo-item">
          <img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="GST delta icon" width="80" height="80" />
          <span class="text-small">Delta Icon</span>
        </div>
        <div class="brand-logo-item">
          <img src="/images/icon.svg" alt="GST composite logo" width="120" height="120" />
          <span class="text-small">Composite Logo</span>
        </div>
      </div>

      <div class="brand-identity-info">
        <h3 class="heading-sm">Brand Voice</h3>
        <p class="text-base">Authoritative, precise, technical. No jargon for jargon's sake — clarity over complexity.</p>

        <h3 class="heading-sm">Wordmark</h3>
        <p class="text-base"><strong>Global Strategic Technologies</strong> — formal contexts, first mention, legal. <strong>GST</strong> — shorthand, UI labels, repeat references.</p>

        <h3 class="heading-sm">Logo Usage</h3>
        <p class="text-base">Single teal-stroke delta variant. Works on both light and dark backgrounds without modification. Minimum clear space: the icon's own width on all sides.</p>
      </div>
    </div>
  </div>
</section>

<!-- Section 2: Color Palette -->
<section class="brand-section" id="colors">
  <div class="container">
    <h2 class="heading-md brand-section__title">Color Palette</h2>
    <p class="text-small brand-section__note">Toggle dark mode via the header to see theme-specific values. All hex values are computed live from CSS variables.</p>

    <h3 class="heading-sm brand-group-title">Primary &amp; Secondary</h3>
    <div class="brand-swatch-grid">
      <div class="brand-swatch" data-var="--color-primary">
        <div class="brand-swatch__color" style="background: var(--color-primary);"></div>
        <div class="brand-swatch__label">--color-primary</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Primary actions, active states, accents</div>
      </div>
      <div class="brand-swatch" data-var="--color-primary-dark">
        <div class="brand-swatch__color" style="background: var(--color-primary-dark);"></div>
        <div class="brand-swatch__label">--color-primary-dark</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Hover/pressed state for primary</div>
      </div>
      <div class="brand-swatch" data-var="--color-secondary">
        <div class="brand-swatch__color" style="background: var(--color-secondary);"></div>
        <div class="brand-swatch__label">--color-secondary</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Secondary emphasis, amber highlights</div>
      </div>
      <div class="brand-swatch" data-var="--color-secondary-dark">
        <div class="brand-swatch__color" style="background: var(--color-secondary-dark);"></div>
        <div class="brand-swatch__label">--color-secondary-dark</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Dark-theme secondary variant</div>
      </div>
    </div>

    <h3 class="heading-sm brand-group-title">Semantic</h3>
    <div class="brand-swatch-grid">
      <div class="brand-swatch" data-var="--color-success">
        <div class="brand-swatch__color" style="background: var(--color-success);"></div>
        <div class="brand-swatch__label">--color-success</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Positive outcomes, passing states</div>
      </div>
      <div class="brand-swatch" data-var="--color-warning">
        <div class="brand-swatch__color" style="background: var(--color-warning);"></div>
        <div class="brand-swatch__label">--color-warning</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Caution indicators, attention-needed</div>
      </div>
      <div class="brand-swatch" data-var="--color-error">
        <div class="brand-swatch__color" style="background: var(--color-error);"></div>
        <div class="brand-swatch__label">--color-error</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Errors, critical states, negative deltas</div>
      </div>
      <div class="brand-swatch" data-var="--color-info">
        <div class="brand-swatch__color" style="background: var(--color-info);"></div>
        <div class="brand-swatch__label">--color-info</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Informational highlights (alias of primary)</div>
      </div>
    </div>

    <h3 class="heading-sm brand-group-title">Text Hierarchy</h3>
    <div class="brand-swatch-grid">
      <div class="brand-swatch" data-var="--text-primary">
        <div class="brand-swatch__color brand-swatch__color--checker" style="background: var(--text-primary);"></div>
        <div class="brand-swatch__label">--text-primary</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Headings, high-emphasis body text</div>
      </div>
      <div class="brand-swatch" data-var="--text-secondary">
        <div class="brand-swatch__color brand-swatch__color--checker" style="background: var(--text-secondary);"></div>
        <div class="brand-swatch__label">--text-secondary</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Body text, descriptions</div>
      </div>
      <div class="brand-swatch" data-var="--text-muted">
        <div class="brand-swatch__color brand-swatch__color--checker" style="background: var(--text-muted);"></div>
        <div class="brand-swatch__label">--text-muted</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Labels, captions, supporting text</div>
      </div>
      <div class="brand-swatch" data-var="--text-faded">
        <div class="brand-swatch__color brand-swatch__color--checker" style="background: var(--text-faded);"></div>
        <div class="brand-swatch__label">--text-faded</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Placeholders, disabled text, timestamps</div>
      </div>
    </div>

    <h3 class="heading-sm brand-group-title">Backgrounds</h3>
    <div class="brand-swatch-grid">
      <div class="brand-swatch" data-var="--bg-light">
        <div class="brand-swatch__color" style="background: var(--bg-light);"></div>
        <div class="brand-swatch__label">--bg-light</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Page background, card surfaces</div>
      </div>
      <div class="brand-swatch" data-var="--bg-light-alt">
        <div class="brand-swatch__color" style="background: var(--bg-light-alt);"></div>
        <div class="brand-swatch__label">--bg-light-alt</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Alternate sections, tool shells</div>
      </div>
      <div class="brand-swatch" data-var="--bg-dark">
        <div class="brand-swatch__color" style="background: var(--bg-dark);"></div>
        <div class="brand-swatch__label">--bg-dark</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Dark-theme page bg, service cards</div>
      </div>
      <div class="brand-swatch" data-var="--bg-dark-secondary">
        <div class="brand-swatch__color" style="background: var(--bg-dark-secondary);"></div>
        <div class="brand-swatch__label">--bg-dark-secondary</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Elevated dark surfaces, modals</div>
      </div>
      <div class="brand-swatch" data-var="--bg-dark-tertiary">
        <div class="brand-swatch__color" style="background: var(--bg-dark-tertiary);"></div>
        <div class="brand-swatch__label">--bg-dark-tertiary</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Footer, section backgrounds (dark)</div>
      </div>
    </div>

    <h3 class="heading-sm brand-group-title">Borders &amp; Accents</h3>
    <div class="brand-swatch-grid">
      <div class="brand-swatch" data-var="--border-light">
        <div class="brand-swatch__color brand-swatch__color--checker" style="background: var(--border-light);"></div>
        <div class="brand-swatch__label">--border-light</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Dividers, card borders, table lines</div>
      </div>
      <div class="brand-swatch" data-var="--accent-light-bg">
        <div class="brand-swatch__color brand-swatch__color--checker" style="background: var(--accent-light-bg);"></div>
        <div class="brand-swatch__label">--accent-light-bg</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Active row highlights, accent fills</div>
      </div>
      <div class="brand-swatch" data-var="--accent-light-bg-hover">
        <div class="brand-swatch__color brand-swatch__color--checker" style="background: var(--accent-light-bg-hover);"></div>
        <div class="brand-swatch__label">--accent-light-bg-hover</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Hover state for accent backgrounds</div>
      </div>
      <div class="brand-swatch" data-var="--accent-border-light">
        <div class="brand-swatch__color brand-swatch__color--checker" style="background: var(--accent-border-light);"></div>
        <div class="brand-swatch__label">--accent-border-light</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Subtle accent borders, badge outlines</div>
      </div>
      <div class="brand-swatch" data-var="--accent-border-medium">
        <div class="brand-swatch__color brand-swatch__color--checker" style="background: var(--accent-border-medium);"></div>
        <div class="brand-swatch__label">--accent-border-medium</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Stronger accent borders, focus rings</div>
      </div>
    </div>

    <h3 class="heading-sm brand-group-title">Tool-Specific</h3>

    <h4 class="label brand-subgroup-title">Hub Shared</h4>
    <div class="brand-swatch-grid">
      <div class="brand-swatch" data-var="--hub-authority-blue">
        <div class="brand-swatch__color" style="background: var(--hub-authority-blue);"></div>
        <div class="brand-swatch__label">--hub-authority-blue</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Authority line text, stage badges</div>
      </div>
      <div class="brand-swatch" data-var="--hub-authority-blue-bg">
        <div class="brand-swatch__color brand-swatch__color--checker" style="background: var(--hub-authority-blue-bg);"></div>
        <div class="brand-swatch__label">--hub-authority-blue-bg</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Stage badge background fill</div>
      </div>
    </div>

    <h4 class="label brand-subgroup-title">TechPar Zones</h4>
    <div class="brand-swatch-grid">
      <div class="brand-swatch" data-var="--techpar-zone-healthy">
        <div class="brand-swatch__color" style="background: var(--techpar-zone-healthy);"></div>
        <div class="brand-swatch__label">--techpar-zone-healthy</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Within benchmark range</div>
      </div>
      <div class="brand-swatch" data-var="--techpar-zone-ahead">
        <div class="brand-swatch__color" style="background: var(--techpar-zone-ahead);"></div>
        <div class="brand-swatch__label">--techpar-zone-ahead</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Spending below benchmark</div>
      </div>
      <div class="brand-swatch" data-var="--techpar-zone-underinvest">
        <div class="brand-swatch__color" style="background: var(--techpar-zone-underinvest);"></div>
        <div class="brand-swatch__label">--techpar-zone-underinvest</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Potential underinvestment</div>
      </div>
      <div class="brand-swatch" data-var="--techpar-zone-above">
        <div class="brand-swatch__color" style="background: var(--techpar-zone-above);"></div>
        <div class="brand-swatch__label">--techpar-zone-above</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Above benchmark range</div>
      </div>
      <div class="brand-swatch" data-var="--techpar-zone-elevated">
        <div class="brand-swatch__color" style="background: var(--techpar-zone-elevated);"></div>
        <div class="brand-swatch__label">--techpar-zone-elevated</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Elevated overspend warning</div>
      </div>
      <div class="brand-swatch" data-var="--techpar-zone-critical">
        <div class="brand-swatch__color" style="background: var(--techpar-zone-critical);"></div>
        <div class="brand-swatch__label">--techpar-zone-critical</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Critical overspend</div>
      </div>
    </div>

    <h4 class="label brand-subgroup-title">Diligence Machine</h4>
    <div class="brand-swatch-grid">
      <div class="brand-swatch" data-var="--dm-methodology-brown">
        <div class="brand-swatch__color" style="background: var(--dm-methodology-brown);"></div>
        <div class="brand-swatch__label">--dm-methodology-brown</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Methodology section accents</div>
      </div>
      <div class="brand-swatch" data-var="--dm-results-blue">
        <div class="brand-swatch__color" style="background: var(--dm-results-blue);"></div>
        <div class="brand-swatch__label">--dm-results-blue</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Results/output section accents</div>
      </div>
      <div class="brand-swatch" data-var="--dm-positive">
        <div class="brand-swatch__color" style="background: var(--dm-positive);"></div>
        <div class="brand-swatch__label">--dm-positive</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Positive diligence findings</div>
      </div>
      <div class="brand-swatch" data-var="--dm-negative">
        <div class="brand-swatch__color" style="background: var(--dm-negative);"></div>
        <div class="brand-swatch__label">--dm-negative</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Negative/risk findings</div>
      </div>
      <div class="brand-swatch" data-var="--dm-warning">
        <div class="brand-swatch__color" style="background: var(--dm-warning);"></div>
        <div class="brand-swatch__label">--dm-warning</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Caution-level findings</div>
      </div>
      <div class="brand-swatch" data-var="--dm-success">
        <div class="brand-swatch__color" style="background: var(--dm-success);"></div>
        <div class="brand-swatch__label">--dm-success</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Pass/complete states</div>
      </div>
    </div>

    <h4 class="label brand-subgroup-title">ICG Maturity</h4>
    <div class="brand-swatch-grid">
      <div class="brand-swatch" data-var="--icg-maturity-reactive">
        <div class="brand-swatch__color" style="background: var(--icg-maturity-reactive);"></div>
        <div class="brand-swatch__label">--icg-maturity-reactive</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Lowest maturity level</div>
      </div>
      <div class="brand-swatch" data-var="--icg-maturity-aware">
        <div class="brand-swatch__color" style="background: var(--icg-maturity-aware);"></div>
        <div class="brand-swatch__label">--icg-maturity-aware</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Early-stage maturity</div>
      </div>
      <div class="brand-swatch" data-var="--icg-maturity-optimizing">
        <div class="brand-swatch__color" style="background: var(--icg-maturity-optimizing);"></div>
        <div class="brand-swatch__label">--icg-maturity-optimizing</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Active optimization stage</div>
      </div>
      <div class="brand-swatch" data-var="--icg-maturity-strategic">
        <div class="brand-swatch__color" style="background: var(--icg-maturity-strategic);"></div>
        <div class="brand-swatch__label">--icg-maturity-strategic</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Highest maturity level</div>
      </div>
    </div>

    <h4 class="label brand-subgroup-title">Regulatory Map</h4>
    <div class="brand-swatch-grid">
      <div class="brand-swatch" data-var="--regmap-category-industry">
        <div class="brand-swatch__color" style="background: var(--regmap-category-industry);"></div>
        <div class="brand-swatch__label">--regmap-category-industry</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Industry-specific regulations</div>
      </div>
      <div class="brand-swatch" data-var="--regmap-category-cyber">
        <div class="brand-swatch__color" style="background: var(--regmap-category-cyber);"></div>
        <div class="brand-swatch__label">--regmap-category-cyber</div>
        <div class="brand-swatch__value"></div>
        <div class="brand-swatch__usage">Cybersecurity regulations</div>
      </div>
    </div>
  </div>
</section>

<!-- Section 3: Typography -->
<section class="brand-section" id="typography">
  <div class="container">
    <h2 class="heading-md brand-section__title">Typography</h2>

    <h3 class="heading-sm brand-group-title">Font Stack</h3>
    <p class="text-base"><code class="brand-code">--font-family</code>: <span class="brand-font-stack" data-var="--font-family"></span></p>

    <h3 class="heading-sm brand-group-title">Utility Classes</h3>
    <div class="brand-type-specimens">
      <div class="brand-type-specimen">
        <span class="heading-xl" data-specimen>Heading XL</span>
        <code class="brand-code">.heading-xl</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="heading-lg" data-specimen>Heading LG</span>
        <code class="brand-code">.heading-lg</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="heading-md" data-specimen>Heading MD</span>
        <code class="brand-code">.heading-md</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="heading-sm" data-specimen>Heading SM</span>
        <code class="brand-code">.heading-sm</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="text-base" data-specimen>Text Base</span>
        <code class="brand-code">.text-base</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="text-small" data-specimen>Text Small</span>
        <code class="brand-code">.text-small</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="text-tiny" data-specimen>Text Tiny</span>
        <code class="brand-code">.text-tiny</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="label" data-specimen>Label</span>
        <code class="brand-code">.label</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="label-small" data-specimen>Label Small</span>
        <code class="brand-code">.label-small</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="nav-link" data-specimen>Nav Link</span>
        <code class="brand-code">.nav-link</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="button-text" data-specimen>Button Text</span>
        <code class="brand-code">.button-text</code>
        <span class="brand-type-meta"></span>
      </div>
    </div>

    <h3 class="heading-sm brand-group-title">Text Size Scale</h3>
    <div class="brand-type-specimens">
      <div class="brand-type-specimen" data-var="--text-xs">
        <span data-specimen style="font-size: var(--text-xs);">The quick brown fox — text-xs</span>
        <code class="brand-code">--text-xs</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-sm">
        <span data-specimen style="font-size: var(--text-sm);">The quick brown fox — text-sm</span>
        <code class="brand-code">--text-sm</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-base">
        <span data-specimen style="font-size: var(--text-base);">The quick brown fox — text-base</span>
        <code class="brand-code">--text-base</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-lg">
        <span data-specimen style="font-size: var(--text-lg);">The quick brown fox — text-lg</span>
        <code class="brand-code">--text-lg</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-xl">
        <span data-specimen style="font-size: var(--text-xl);">The quick brown fox — text-xl</span>
        <code class="brand-code">--text-xl</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-2xl">
        <span data-specimen style="font-size: var(--text-2xl);">The quick brown fox — text-2xl</span>
        <code class="brand-code">--text-2xl</code>
        <span class="brand-type-value"></span>
      </div>
    </div>

    <h3 class="heading-sm brand-group-title">Font Weights</h3>
    <div class="brand-type-specimens">
      <div class="brand-type-specimen">
        <span data-specimen style="font-weight: var(--font-weight-normal);">Normal (400) — The quick brown fox</span>
        <code class="brand-code">--font-weight-normal</code>
      </div>
      <div class="brand-type-specimen">
        <span data-specimen style="font-weight: var(--font-weight-semibold);">Semibold (600) — The quick brown fox</span>
        <code class="brand-code">--font-weight-semibold</code>
      </div>
      <div class="brand-type-specimen">
        <span data-specimen style="font-weight: var(--font-weight-bold);">Bold (700) — The quick brown fox</span>
