    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: 600;
    list-style: none;
    transition: color var(--transition-fast);
  }

  .brand-details__summary::-webkit-details-marker {
    display: none;
  }

  .brand-details__summary:hover {
    color: var(--text-primary);
  }

  .brand-details__toggle::before {
    content: '+';
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    display: inline-block;
    width: 1em;
    text-align: center;
  }

  .brand-details[open] .brand-details__toggle::before {
    content: '−';
  }

  .brand-details__body {
    padding: 0 var(--spacing-lg) var(--spacing-lg);
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: var(--text-sm);
    border-top: 1px solid var(--border-light);
    padding-top: var(--spacing-md);
  }

  .brand-details__body p {
    margin: 0;
  }

  /* Container demo */
  .brand-container-demo {
    border: 1px dashed var(--color-primary);
