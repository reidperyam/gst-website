    padding: var(--spacing-lg) var(--spacing-2xl);
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-family: monospace;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .brand-section__note--desktop {
      display: none;
    }

    .brand-section__note--mobile {
      display: block;
    }

    .brand-section {
      padding: var(--spacing-2xl) 0;
    }

    .brand-identity-grid {
      grid-template-columns: 1fr;
    }

    .brand-swatch-grid {
      grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    }

    .brand-type-specimen {
      flex-direction: column;
      gap: var(--spacing-xs);
    }

    .brand-shadow-grid,
    .brand-transition-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .brand-spacing-name {
      width: 130px;
    }

    .brand-card-grid {
      grid-template-columns: 1fr;
    }

    .brand-type-specimen > span:first-child {
      overflow-wrap: break-word;
      word-break: break-word;
    }

    .brand-component-item {
      max-width: 100%;
      overflow-x: auto;
    }

    .a11y-contrast-table,
    .a11y-kb-table {
      overflow-x: auto;
    }
  }

  @media (max-width: 480px) {
    .brand-section {
      padding: var(--spacing-xl) 0;
    }

    .brand-swatch-grid {
      grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    }

    .brand-swatch__usage {
      display: none;
    }

    .brand-shadow-grid,
    .brand-transition-grid {
      grid-template-columns: 1fr;
    }

    .brand-spacing-row {
      flex-wrap: wrap;
    }

    .brand-spacing-name {
      width: 100%;
    }

    .brand-identity-logos {
      flex-direction: column;
      align-items: flex-start;
    }
  }

