---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import CTASection from '../../components/CTASection.astro';
import { trackPageView } from '../../utils/analytics';

trackPageView('hub', 'Strategic Intelligence Hub | GST');

const faqItems = [
    {
        question: "What tools are available in the GST Hub?",
        answer: "The Hub includes the Diligence Machine, which generates customized technology due diligence agendas based on target parameters. We also provide reference architectures, integration checklists, and VDR structure templates drawn from patterns proven across 100+ engagements."
    },
    {
        question: "Are the Hub tools free to use?",
        answer: "Yes. All tools, frameworks, and resources in the GST Hub are freely available. We built them to help PE investors and technical leaders make better-informed decisions, whether or not they engage GST for advisory work."
    },
    {
        question: "Who are these resources designed for?",
        answer: "The Hub is built for private equity investors evaluating technology assets, portfolio company executives managing platform transitions, and technical leaders navigating complex architecture decisions. The content is calibrated for professionals who need actionable insight, not generic advice."
    },
];
---

<BaseLayout
    title="Hub | GST"
    description="Professional-grade tools, resources, and perspectives for technology M&A diligence and digital transformation. Built for PE investors and portfolio executives."
    ogTitle="The GST Hub | GST"
    ogDescription="Professional-grade tools and frameworks for technology due diligence and value creation."
    ogImage="/og-image.png"
    ogUrl="https://globalstrategic.tech/hub"
    faqItems={faqItems}
>
    <Hero
        title="The GST Hub"
        description="Professional-grade tools, frameworks, and technical perspectives to help you de-risk technology investments and accelerate outcomes."
    />

    <section class="hub-intro">
        <div class="container">
            <p>These resources codify years of technical advisory experience across 100+ M&A transactions, platform modernizations, and value creation engagements. Built for PE investors, portfolio company executives, and technical leaders navigating technology challenges and opportunities.</p>
        </div>
    </section>

    <section class="hub-grid-section">
        <div class="container">
            <div class="hub-cards">
                <a href="/hub/tools" class="hub-card">
                    <div class="hub-card-header">
                        <svg class="hub-card-icon" width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <rect x="4" y="8" width="40" height="32" rx="2" stroke="currentColor" stroke-width="2"/>
                            <path d="M12 20L18 26L12 32" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            <line x1="22" y1="32" x2="36" y2="32" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span class="hub-card-label">Tools</span>
                    </div>
                    <h3>Tools</h3>
                    <p>Calculators and scoring models that put numbers behind the questions investors actually ask: What will this migration cost? How exposed is this codebase? Where is the value?</p>
                    <span class="hub-card-cta">Explore Tools →</span>
                </a>

                <a href="/hub/library" class="hub-card">
                    <div class="hub-card-header">
                        <svg class="hub-card-icon" width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M8 6H32L40 14V42H8V6Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                            <path d="M32 6V14H40" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                            <line x1="16" y1="22" x2="32" y2="22" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            <line x1="16" y1="28" x2="32" y2="28" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            <line x1="16" y1="34" x2="28" y2="34" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span class="hub-card-label">Resources</span>
                    </div>
                    <h3>The Library</h3>
                    <p>Diligence playbooks, integration checklists, and reference architectures drawn from real transactions. Built from patterns proven across 100+ engagements.</p>
                    <span class="hub-card-cta">Browse Knowledge →</span>
                </a>

                <a href="/hub/radar" class="hub-card">
                    <div class="hub-card-header">
                        <svg class="hub-card-icon" width="48" height="48" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <circle cx="24" cy="24" r="4" stroke="currentColor" stroke-width="2"/>
                            <circle cx="24" cy="24" r="12" stroke="currentColor" stroke-width="2" opacity="0.6"/>
                            <circle cx="24" cy="24" r="20" stroke="currentColor" stroke-width="2" opacity="0.3"/>
                            <line x1="24" y1="2" x2="24" y2="8" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            <line x1="24" y1="40" x2="24" y2="46" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            <line x1="2" y1="24" x2="8" y2="24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                            <line x1="40" y1="24" x2="46" y2="24" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                        </svg>
                        <span class="hub-card-label">Perspectives</span>
                    </div>
                    <h3>The Radar</h3>
                    <p>Rapid-response analysis of emerging technology shifts, AI developments, and M&A market dynamics.</p>
                    <span class="hub-card-cta">Read the Perspective →</span>
                </a>
            </div>
        </div>
    </section>

    <section class="faq-section">
        <div class="container">
            <h2 class="heading-lg">Frequently Asked Questions</h2>
            <div class="faq-list">
                {faqItems.map((item) => (
                    <details class="faq-item">
                        <summary class="faq-question">{item.question}</summary>
                        <div class="faq-answer" set:html={item.answer} />
                    </details>
                ))}
            </div>
        </div>
    </section>

    <CTASection
        title="Let's discuss your next challenge"
        description="Schedule a confidential consultation to discuss your objectives."
        buttonText="Schedule a Consultation"
        calendlyUrl="https://calendly.com/globalstrategictech"
    />
</BaseLayout>

<style>
    .hub-intro {
        padding: 0 0 var(--spacing-3xl);
    }

    .hub-intro p {
        max-width: 800px;
        font-size: 1.5rem;
        color: var(--text-primary);
        line-height: 1.6;
        font-weight: 400;
    }

    .hub-grid-section {
        padding: 2.5rem 0;
    }

    .hub-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem;
    }

    .hub-card {
        padding: var(--spacing-2xl);
        background: rgba(5, 205, 153, 0.03);
        border: 1px solid rgba(5, 205, 153, 0.1);
        border-radius: 8px;
        transition: all var(--transition-normal);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        text-decoration: none;
        color: inherit;
        position: relative;
    }

    .hub-card:hover {
        background: rgba(5, 205, 153, 0.08);
        border-color: rgba(5, 205, 153, 0.3);
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(5, 205, 153, 0.15);
    }

    .hub-card:active {
        transform: translateY(-2px);
    }

    .hub-card:focus {
        outline: 3px solid var(--color-secondary);
        outline-offset: 2px;
    }

    .hub-card:focus:not(:focus-visible) {
        outline: none;
    }

    .hub-card:focus-visible {
        outline: 3px solid var(--color-secondary);
        outline-offset: 2px;
    }

    :global(html.dark-theme) .hub-card {
        background: rgba(5, 205, 153, 0.05);
        border-color: rgba(5, 205, 153, 0.15);
    }

    :global(html.dark-theme) .hub-card:hover {
        background: rgba(5, 205, 153, 0.12);
        border-color: rgba(5, 205, 153, 0.35);
        box-shadow: 0 8px 24px rgba(5, 205, 153, 0.2);
    }

    .hub-card-header {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--spacing-md);
        margin-bottom: var(--spacing-xl);
    }

    .hub-card-icon {
        color: var(--color-primary);
        flex-shrink: 0;
    }

    .hub-card-label {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-primary);
    }

    .hub-card h3 {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: var(--spacing-md);
        line-height: 1.3;
    }

    .hub-card p {
        font-size: 1rem;
        color: var(--text-secondary);
        line-height: 1.7;
        margin-bottom: var(--spacing-xl);
        flex-grow: 1;
    }

    .hub-card-cta {
        font-size: 0.95rem;
        font-weight: 600;
        color: var(--color-primary);
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-xs);
        transition: gap var(--transition-fast);
    }

    .hub-card:hover .hub-card-cta {
        gap: var(--spacing-sm);
    }

    @media (max-width: 1024px) {
        .hub-cards {
            grid-template-columns: repeat(2, 1fr);
            gap: var(--spacing-xl);
        }

        .hub-card {
            padding: var(--spacing-xl);
        }

        .hub-card h3 {
            font-size: 1.25rem;
        }

        .hub-card p {
            font-size: 0.95rem;
        }
    }

    @media (max-width: 768px) {
        .hub-intro p {
            font-size: 1.1rem;
        }

        .hub-grid-section {
            padding: var(--spacing-2xl) 0;
        }

        .hub-cards {
            grid-template-columns: 1fr;
            gap: var(--spacing-lg);
        }

        .hub-card {
            padding: var(--spacing-xl);
        }

        .hub-card-header {
            gap: var(--spacing-sm);
            margin-bottom: var(--spacing-lg);
        }

        .hub-card-icon {
            width: 40px;
            height: 40px;
        }

        .hub-card h3 {
            font-size: 1.2rem;
        }

        .hub-card p {
            font-size: 0.95rem;
            line-height: 1.7;
            margin-bottom: var(--spacing-lg);
        }
    }

    @media (max-width: 480px) {
        .hub-intro {
            padding: 0 0 var(--spacing-2xl);
        }

        .hub-intro p {
            font-size: 1rem;
            line-height: 1.7;
        }

        .hub-grid-section {
            padding: var(--spacing-xl) 0;
        }

        .hub-cards {
            gap: var(--spacing-md);
        }

        .hub-card {
            padding: var(--spacing-lg);
        }

        .hub-card-header {
            margin-bottom: var(--spacing-md);
        }

        .hub-card-icon {
            width: 36px;
            height: 36px;
        }

        .hub-card h3 {
            font-size: 1.1rem;
            margin-bottom: var(--spacing-sm);
        }

        .hub-card p {
            font-size: 0.9rem;
            line-height: 1.65;
            margin-bottom: var(--spacing-md);
        }

        .hub-card-cta {
            font-size: 0.875rem;
        }
    }

    .faq-section {
        padding: var(--spacing-3xl) 0;
    }

    .faq-section .heading-lg {
        margin-bottom: var(--spacing-2xl);
        text-align: center;
    }

    .faq-list {
        max-width: 800px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: var(--spacing-md);
    }

    .faq-item {
        background: rgba(5, 205, 153, 0.03);
        border: 1px solid rgba(5, 205, 153, 0.1);
        border-radius: 8px;
        transition: background var(--transition-normal), border-color var(--transition-normal);
    }

    .faq-item[open] {
        background: rgba(5, 205, 153, 0.06);
        border-color: rgba(5, 205, 153, 0.2);
    }

    .faq-question {
        padding: var(--spacing-xl);
        font-size: var(--text-lg);
        font-weight: var(--font-weight-semibold);
        color: var(--text-primary);
        cursor: pointer;
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--spacing-md);
        transition: color var(--transition-fast);
    }

    .faq-question::-webkit-details-marker {
        display: none;
    }

    .faq-question::after {
        content: '+';
        font-size: var(--text-2xl);
        font-weight: var(--font-weight-bold);
        color: var(--color-primary);
        flex-shrink: 0;
        transition: transform var(--transition-fast);
    }

    .faq-item[open] .faq-question::after {
        content: '\2212';
    }

    .faq-question:hover {
        color: var(--color-primary);
    }

    .faq-answer {
        padding: 0 var(--spacing-xl) var(--spacing-xl);
        font-size: var(--text-base);
        color: var(--text-secondary);
        line-height: 1.7;
    }

    .faq-answer :global(p) {
        margin: 0 0 var(--spacing-md) 0;
    }

    .faq-answer :global(p:last-child) {
        margin-bottom: 0;
    }

    :global(html.dark-theme) .faq-item {
        background: rgba(5, 205, 153, 0.05);
        border-color: rgba(5, 205, 153, 0.15);
    }

    :global(html.dark-theme) .faq-item[open] {
        background: rgba(5, 205, 153, 0.08);
        border-color: rgba(5, 205, 153, 0.25);
    }

    @media (max-width: 768px) {
        .faq-section {
            padding: var(--spacing-2xl) 0;
        }

        .faq-question {
            padding: var(--spacing-lg);
            font-size: var(--text-base);
        }

        .faq-answer {
            padding: 0 var(--spacing-lg) var(--spacing-lg);
            font-size: var(--text-sm);
        }
    }

    @media (max-width: 480px) {
        .faq-question {
            padding: var(--spacing-md);
        }

        .faq-answer {
            padding: 0 var(--spacing-md) var(--spacing-md);
            font-size: var(--text-sm);
        }
    }
</style>

<script>
    import { trackEvent } from '../../utils/analytics';

    document.querySelectorAll('.faq-item').forEach((item) => {
        item.addEventListener('toggle', () => {
            const details = item as HTMLDetailsElement;
            const question = details.querySelector('.faq-question')?.textContent?.trim() || '';
            trackEvent({
                event: 'faq_interaction',
                category: 'engagement',
                question,
                action: details.open ? 'open' : 'close',
                page: 'hub',
            });
        });
    });
</script>
