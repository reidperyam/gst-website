        .tp-kpi-grid :global(.tp-kpi-cell--highlight) {
            grid-column: 1 / -1;
        }
    }

    @media (max-width: 768px) {
        .tp-stage-grid {
            grid-template-columns: repeat(3, 1fr);
        }

        .tp-input-wrap,
        .tp-seg {
            max-width: 100%;
        }
