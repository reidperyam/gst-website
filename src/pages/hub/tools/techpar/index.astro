    /* ── ARR quick-pick chips ──────────────────────────────────── */
    .tp-arr-quick {
        display: flex;
        flex-wrap: wrap;
        margin-bottom: var(--spacing-sm);
        border: 1px solid var(--text-muted);
        overflow: hidden;
        max-width: 280px;
    }

    .tp-arr-chip {
        flex: 1;
        background: transparent;
        border: none;
        border-right: 1px solid var(--text-muted);
        color: var(--text-muted);
        font-family: var(--font-family);
        font-size: var(--text-xs);
        padding: var(--spacing-sm) var(--spacing-sm);
        cursor: pointer;
        transition: all var(--transition-fast);
        white-space: nowrap;
        text-align: center;
    }

    .tp-arr-chip:last-child {
        border-right: none;
    }

    .tp-arr-chip:hover:not(.tp-arr-chip--active) {
        color: var(--text-secondary);
    }

    .tp-arr-chip--active {
        background: var(--accent-light-bg);
        color: var(--color-primary);
    }

    .tp-arr-chip--active:hover {
        background: var(--accent-light-bg);
        color: var(--color-primary);
    }

    /* ── Stage grid ───────────────────────────────────────────── */
    .tp-stage-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: var(--spacing-sm);
        margin-bottom: var(--spacing-lg);
    }

    .tp-stage-card {
        padding: var(--spacing-sm) var(--spacing-sm);
        border: 1px solid var(--border-light);
        background: var(--bg-light-alt);
        cursor: pointer;
        transition: all var(--transition-fast);
        text-align: center;
        font-family: var(--font-family);
    }

    .tp-stage-card__name {
        font-size: var(--text-xs);
        color: var(--text-secondary);
        display: block;
        margin-bottom: 2px;
    }

    .tp-stage-card__range {
        font-size: var(--text-xs);
        color: var(--text-muted);
    }

    .tp-stage-card--active {
        border-color: var(--color-primary);
        background: var(--accent-light-bg);
    }

    .tp-stage-card--active .tp-stage-card__name {
        color: var(--color-primary);
    }

    .tp-stage-card--active .tp-stage-card__range {
        color: var(--color-primary);
    }

    .tp-stage-card:hover:not(.tp-stage-card--active) {
        border-color: var(--text-muted);
    }

    /* ── Segmented controls ───────────────────────────────────── */
    .tp-seg-row {
        display: flex;
        gap: var(--spacing-sm);
        flex-wrap: wrap;
        margin-bottom: var(--spacing-sm);
    }

    .tp-seg {
        display: flex;
        width: 100%;
        border: 1px solid var(--text-muted);
        overflow: hidden;
        max-width: 320px;
    }

    .tp-seg__btn {
        flex: 1;
        padding: var(--spacing-sm) var(--spacing-lg);
        font-family: var(--font-family);
        font-size: var(--text-xs);
        color: var(--text-muted);
        background: transparent;
        border: none;
        border-right: 1px solid var(--text-muted);
        cursor: pointer;
        transition: all var(--transition-fast);
        text-align: center;
    }

    .tp-seg__btn:last-child {
        border-right: none;
    }

    .tp-seg__btn--active {
        background: var(--accent-light-bg);
        color: var(--color-primary);
    }

    .tp-seg--sm {
        max-width: 180px;
        margin-bottom: var(--spacing-xs);
    }

    .tp-seg--sm .tp-seg__btn {
        padding: var(--spacing-xs) var(--spacing-sm);
    }

    .tp-seg--wide {
        max-width: 440px;
    }

    .tp-seg__btn:hover:not(.tp-seg__btn--active) {
        color: var(--text-secondary);
    }

    /* ── Deep dive wrap ───────────────────────────────────────── */
    .tp-deep-wrap {
        display: none;
        background: var(--bg-light-alt);
        border: 1px solid var(--border-light);
        padding: var(--spacing-md);
        margin-bottom: var(--spacing-sm);
    }

    .tp-deep-wrap--on {
        display: block;
    }

    .tp-deep-head {
        color: var(--text-muted);
        margin-bottom: var(--spacing-sm);
    }

    .tp-deep-sum {
        color: var(--text-secondary);
        margin-top: var(--spacing-sm);
        padding-top: var(--spacing-sm);
        border-top: 1px solid var(--border-light);
    }

    .tp-deep-sum span {
        color: var(--color-primary);
    }

    /* ── CapEx toggle ─────────────────────────────────────────── */
    .tp-capex-row {
        display: none;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-sm) var(--spacing-sm);
        background: var(--bg-light-alt);
        border: 1px solid var(--border-light);
        margin-bottom: var(--spacing-lg);
        cursor: pointer;
    }

    .tp-capex-row--vis {
        display: flex;
    }

    .tp-capex-row input[type=checkbox] {
        accent-color: var(--color-primary);
        width: 14px;
        height: 14px;
        cursor: pointer;
        flex-shrink: 0;
    }

    /* ── Exit field visibility ────────────────────────────────── */
    .tp-exit-field {
        display: none;
    }

    .tp-exit-field--vis {
        display: block;
    }

    /* ── Navigation buttons ───────────────────────────────────── */
    .tp-nav-row {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        margin-top: var(--spacing-xl);
    }

    .tp-nav-row__next {
        margin-left: auto;
        text-align: right;
    }

    .tp-nav-row__hint {
        display: block;
        margin-top: 4px;
        color: var(--text-muted);
    }

    .tp-nav-row__actions {
        display: flex;
        gap: var(--spacing-xs);
        margin-left: auto;
    }

    .tp-btn-share {
        padding: var(--spacing-xs) var(--spacing-sm);
        background: transparent;
        color: var(--text-muted);
        border: 1px solid var(--border-light);
        font-family: var(--font-family);
        font-size: var(--text-xs);
        cursor: pointer;
        letter-spacing: 0.03em;
        transition: all var(--transition-fast);
    }

    .tp-btn-share:hover {
        color: var(--color-primary);
        border-color: var(--color-primary);
    }

    .tp-btn-share--copied {
        color: var(--color-primary);
        border-color: var(--color-primary);
    }

    /* Button overrides (base styles from global .hub-btn) */
    .tp-btn-next {
        flex: 1;
        padding: var(--spacing-md);
        color: var(--bg-dark);
    }

    .tp-btn-next:hover {
        background: var(--color-primary-dark);
        opacity: 1;
    }

    .tp-btn-next:disabled {
        opacity: 0.3;
    }

    .tp-btn-back {
        padding: var(--spacing-md) var(--spacing-xl);
        background: var(--bg-light-alt);
    }

    .tp-btn-back:hover {
        border-color: var(--text-muted);
    }

    /* ── Empty state ──────────────────────────────────────────── */
    .tp-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 40vh;
        gap: var(--spacing-sm);
        text-align: center;
    }

    .tp-empty--hidden {
        display: none;
    }

    .tp-empty__sym {
        width: 64px;
        height: 64px;
        color: var(--text-muted);
    }

    .tp-empty__msg {
        color: var(--text-muted);
        line-height: 1.6;
    }

    .tp-empty__cta {
        margin-top: var(--spacing-sm);
        padding: var(--spacing-sm) var(--spacing-xl);
        border: 1px solid var(--color-primary);
        background: transparent;
        color: var(--color-primary);
        font-family: var(--font-family);
        font-size: var(--text-xs);
        cursor: pointer;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        transition: all var(--transition-fast);
    }

    .tp-empty__cta:hover {
        background: var(--accent-light-bg);
    }

    /* ── Analysis content ─────────────────────────────────────── */
    .tp-analysis-content {
        display: none;
    }

    .tp-analysis-content--on {
        display: block;
    }

    /* ── Primary KPI hero ─────────────────────────────────────── */
    .tp-kpi-hero {
        padding: var(--spacing-xl);
        background: var(--bg-light-alt);
        border: 1px solid var(--border-light);
        margin-bottom: var(--spacing-lg);
    }

    .tp-kpi-hero__num {
        font-size: 4.5rem;
        font-weight: var(--font-weight-bold);
        line-height: 1;
        transition: color var(--transition-fast);
    }

    .tp-kpi-hero__lbl {
        color: var(--text-secondary);
        margin-top: var(--spacing-xs);
    }

    .tp-kpi-hero__basis {
        margin-top: 2px;
    }

    /* Zone pill */
    /* Zone pill is injected via innerHTML */
    .tp-kpi-hero :global(.tp-zone-pill) {
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-xs) var(--spacing-md);
        font-size: var(--text-xs);
        letter-spacing: 0.05em;
        border: 1px solid;
    }

    .tp-kpi-hero :global(.tp-zone-dot) {
        width: 5px;
        height: 5px;
        border-radius: 50%;
    }

    /* Benchmark bar */
    .tp-bench-wrap {
        margin-top: var(--spacing-lg);
    }

    .tp-bench-track {
        height: 3px;
        background: var(--bg-light-alt);
        position: relative;
        border-radius: 2px;
    }

    .tp-bench-fill {
        position: absolute;
        height: 100%;
        top: 0;
        left: 0;
        transition: width var(--transition-slow), background var(--transition-fast);
        border-radius: 2px;
    }

    .tp-bench-lbls {
        display: flex;
        justify-content: space-between;
        margin-top: var(--spacing-xs);
    }

    .tp-bench-lbl {
        color: var(--text-muted);
    }

    .tp-bench-mid {
        color: var(--color-primary);
    }

    /* ── Signal card ──────────────────────────────────────────── */
    .tp-signal {
        padding: var(--spacing-lg);
        border: 1px solid var(--border-light);
        background: var(--bg-light-alt);
        margin-bottom: var(--spacing-lg);
    }

    .tp-signal__stage {
        color: var(--text-muted);
        margin-bottom: 2px;
    }

    .tp-signal__zone {
        margin-bottom: var(--spacing-sm);
    }

    .tp-signal__head {
        line-height: 1.3;
        margin-bottom: var(--spacing-sm);
    }

    .tp-signal__body {
        color: var(--text-secondary);
        line-height: 1.7;
    }

    .tp-signal__div {
        height: 1px;
        background: var(--border-light);
        margin: var(--spacing-md) 0;
    }

    /* Signal metrics are injected via innerHTML */
    .tp-signal :global(.tp-sig-met) {
        margin-bottom: var(--spacing-sm);
    }

    .tp-signal :global(.tp-sig-met:last-child) {
        margin-bottom: 0;
    }

    .tp-signal :global(.tp-sig-mlbl) {
        font-size: var(--text-xs);
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: var(--spacing-xs);
    }

    .tp-signal :global(.tp-sig-mval) {
        font-size: var(--text-2xl);
        font-weight: var(--font-weight-semibold);
        line-height: 1;
    }

    .tp-signal :global(.tp-sig-msub) {
        font-size: var(--text-xs);
        color: var(--text-muted);
        margin-top: var(--spacing-xs);
    }

    .tp-signal :global(.tp-sig-note) {
        font-size: var(--text-xs);
        color: var(--text-secondary);
        line-height: 1.7;
    }

    /* ── KPI grid ─────────────────────────────────────────────── */
    .tp-kpi-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--spacing-sm);
        margin-bottom: var(--spacing-xl);
    }

    /* KPI cells are injected via innerHTML — use :global for children */
    .tp-kpi-grid :global(.tp-kpi-cell) {
        border: 1px solid var(--border-light);
        padding: var(--spacing-md);
        display: flex;
        flex-direction: column;
    }

    .tp-kpi-grid :global(.tp-kpi-cell--highlight) {
        grid-column: 1 / -1;
        background: var(--bg-light-alt);
        border-left: 3px solid var(--color-primary);
        padding: var(--spacing-lg);
    }

    .tp-kpi-grid :global(.tp-kpi-cell--highlight .tp-kpi-val) {
        font-size: var(--text-2xl);
    }

    .tp-kpi-grid :global(.tp-kpi-lbl) {
        font-size: 10px;
        color: var(--text-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: var(--font-weight-bold);
        line-height: 1;
        margin-bottom: var(--spacing-sm);
    }

    .tp-kpi-grid :global(.tp-kpi-val) {
        font-size: var(--text-lg);
        font-weight: var(--font-weight-semibold);
        line-height: 1;
        color: var(--text-primary);
        margin-bottom: var(--spacing-xs);
    }

    .tp-kpi-grid :global(.tp-kpi-val--pos) { color: var(--techpar-kpi-positive); }
    .tp-kpi-grid :global(.tp-kpi-val--warn) { color: var(--techpar-kpi-warn); }
    .tp-kpi-grid :global(.tp-kpi-val--bad) { color: var(--techpar-kpi-negative); }

    .tp-kpi-grid :global(.tp-kpi-sub) {
        font-size: 10px;
        color: var(--text-muted);
        line-height: 1.3;
        margin-top: auto;
        padding-top: var(--spacing-xs);
        border-top: 1px solid var(--border-light);
    }

    .tp-kpi-grid :global(.tp-kpi-cell--highlight .tp-kpi-sub) {
        border-top: none;
        padding-top: 0;
    }

    /* ── Category bars ────────────────────────────────────────── */
    .tp-cat-section {
        display: none;
        margin-bottom: var(--spacing-lg);
    }

    .tp-cat-section--on {
        display: block;
    }

    .tp-cat-head {
        margin-bottom: var(--spacing-md);
    }

    /* Category bar rows are injected via innerHTML */
    .tp-cat-section :global(.tp-cat-row) {
        margin-bottom: var(--spacing-md);
    }

    .tp-cat-section :global(.tp-cat-row:last-child) {
        margin-bottom: 0;
    }

    .tp-cat-section :global(.tp-cat-meta) {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: var(--spacing-xs);
    }

    .tp-cat-section :global(.tp-cat-name) {
        font-size: var(--text-xs);
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
    }

    .tp-cat-section :global(.tp-cat-pct) {
        font-size: var(--text-xs);
        font-weight: var(--font-weight-semibold);
    }

    .tp-cat-section :global(.tp-cat-bench) {
        font-size: var(--text-xs);
        color: var(--text-muted);
    }

    .tp-cat-section :global(.tp-cat-track) {
        height: 5px;
        background: var(--bg-light-alt);
        position: relative;
        border-radius: 3px;
        overflow: hidden;
    }

    .tp-cat-section :global(.tp-cat-band) {
        position: absolute;
        height: 100%;
        background: var(--techpar-chart-band-fill);
    }

    .tp-cat-section :global(.tp-cat-fill) {
        position: absolute;
        height: 100%;
        top: 0;
        left: 0;
        border-radius: 3px;
        transition: width var(--transition-slow);
    }

    /* ── Benchmark table ──────────────────────────────────────── */
    .tp-bench-table-wrap {
        margin-bottom: var(--spacing-lg);
    }

    .tp-bench-table-head {
        color: var(--color-primary);
        margin-bottom: var(--spacing-sm);
    }

    /* Adjacent benchmark notes get a dashed separator */
    .tool-bench-note + .tool-bench-note {
        margin-top: var(--spacing-xs);
        padding-top: var(--spacing-xs);
        border-top: 1px dashed var(--border-light);
    }

    /* ── Historical data section ────────────────────────────── */
    .tp-historical {
        margin-bottom: var(--spacing-md);
        border: 1px solid var(--border-light);
    }

    .tp-historical__trigger {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-sm) var(--spacing-md);
        cursor: pointer;
        color: var(--text-muted);
        transition: color var(--transition-fast);
        list-style: none;
    }

    .tp-historical__trigger::-webkit-details-marker {
        display: none;
    }

    .tp-historical__trigger::before {
        content: '\25B6';
        font-size: 0.6em;
        transition: transform var(--transition-fast);
    }

    .tp-historical[open] > .tp-historical__trigger::before {
        transform: rotate(90deg);
    }

    .tp-historical__trigger:hover {
        color: var(--text-secondary);
    }

    .tp-historical__body {
        padding: var(--spacing-sm) var(--spacing-md) var(--spacing-md);
        border-top: 1px solid var(--border-light);
    }

    .tp-historical__body :global(.tp-hist-row) {
        display: flex;
        align-items: flex-end;
        gap: var(--spacing-sm);
        margin-bottom: var(--spacing-md);
        padding-bottom: var(--spacing-md);
        border-bottom: 1px solid var(--border-light);
    }

    .tp-historical__body :global(.tp-hist-row:last-child) {
        border-bottom: none;
        margin-bottom: var(--spacing-sm);
    }

    .tp-historical__body :global(.tp-hist-field) {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 4px;
    }

    .tp-historical__body :global(.tp-hist-field--label) {
        flex: 0 0 80px;
    }

    .tp-historical__body :global(.tp-hist-field__lbl) {
        font-size: var(--text-xs);
        color: var(--text-muted);
        letter-spacing: 0.02em;
    }

    .tp-historical__body :global(.tp-hist-field input) {
        width: 100%;
        padding: var(--spacing-xs) var(--spacing-sm);
        font-family: var(--font-family);
        font-size: var(--text-xs);
        background: var(--bg-light);
        border: 1px solid var(--border-light);
        color: var(--text-primary);
    }

    .tp-historical__body :global(.tp-input-wrap) {
        width: 100%;
    }

    .tp-historical__body :global(.tp-hist-remove) {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 24px;
        height: 24px;
        padding: 0;
        margin-bottom: 1px;
        background: none;
        border: 1px solid var(--border-light);
        color: var(--text-muted);
        cursor: pointer;
        font-size: var(--text-sm);
        flex-shrink: 0;
    }

    .tp-historical__body :global(.tp-hist-remove:hover) {
        color: var(--techpar-zone-elevated);
        border-color: var(--techpar-zone-elevated);
    }

    .tp-hist-add {
        display: inline-flex;
        align-items: center;
        padding: var(--spacing-xs) var(--spacing-sm);
        background: none;
        border: 1px dashed var(--border-light);
        color: var(--text-muted);
        font-family: var(--font-family);
        font-size: var(--text-xs);
        cursor: pointer;
        transition: all var(--transition-fast);
    }

    .tp-hist-add:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
    }

    .tp-hist-add:disabled {
        opacity: 0.4;
        cursor: not-allowed;
    }

    /* ── Deep Dive prompt ─────────────────────────────────────── */
    .tp-deepdive-prompt {
        padding: var(--spacing-sm) var(--spacing-md);
        margin-bottom: var(--spacing-lg);
        border-left: 3px solid var(--techpar-zone-elevated);
        background: var(--bg-light-alt);
        color: var(--text-secondary);
        font-size: var(--text-xs);
        line-height: 1.7;
    }

    .tp-deepdive-prompt :global(.tp-deepdive-prompt__btn) {
        display: inline;
        padding: 0;
        background: none;
        border: none;
        color: var(--color-primary);
        font-family: var(--font-family);
        font-size: inherit;
        cursor: pointer;
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .tp-deepdive-prompt :global(.tp-deepdive-prompt__btn:hover) {
        color: var(--text-primary);
    }

    /* ── Recommendations ─────────────────────────────────────── */
    .tp-recs {
        margin-bottom: var(--spacing-lg);
        padding: var(--spacing-md);
        border: 1px solid var(--border-light);
        background: var(--bg-light-alt);
    }

    .tp-recs__title {
        color: var(--text-muted);
        margin-bottom: var(--spacing-sm);
    }

    .tp-recs__list {
        margin: 0;
        padding-left: var(--spacing-lg);
        color: var(--text-secondary);
        font-size: var(--text-sm);
        line-height: 1.7;
    }

    .tp-recs__list :global(li) {
        margin-bottom: var(--spacing-xs);
    }

    .tp-recs__list :global(li:last-child) {
        margin-bottom: 0;
    }

    /* ── Industry note ───────────────────────────────────────── */
    .tp-industry-note {
        padding: var(--spacing-sm) var(--spacing-md);
        margin-bottom: var(--spacing-lg);
        border-left: 3px solid var(--color-primary);
        background: var(--bg-light-alt);
        color: var(--text-secondary);
        font-size: var(--text-xs);
        line-height: 1.7;
    }

    /* ── Onboarding section ──────────────────────────────────── */
    .tp-onboarding {
        margin-bottom: var(--spacing-md);
        border: 1px solid var(--border-light);
    }

    .tp-onboarding__trigger {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-sm) var(--spacing-md);
        cursor: pointer;
        color: var(--text-muted);
        transition: color var(--transition-fast);
        list-style: none;
    }

    .tp-onboarding__trigger::-webkit-details-marker {
        display: none;
    }

    .tp-onboarding__trigger::before {
        content: '\25B6';
        font-size: 0.6em;
        transition: transform var(--transition-fast);
    }

    .tp-onboarding[open] > .tp-onboarding__trigger::before {
        transform: rotate(90deg);
    }

    .tp-onboarding__trigger:hover {
        color: var(--text-secondary);
    }

    .tp-onboarding__body {
        padding: var(--spacing-sm) var(--spacing-md) var(--spacing-md);
        color: var(--text-secondary);
        line-height: 1.7;
        border-top: 1px solid var(--border-light);
    }

    .tp-onboarding__body p {
        margin-bottom: var(--spacing-xs);
    }

    .tp-onboarding__body p:last-child {
        margin-bottom: 0;
    }

    /* ── Methodology section ─────────────────────────────────── */
    .tp-methodology {
        margin-bottom: var(--spacing-lg);
        border: 1px solid var(--border-light);
    }

    .tp-methodology__trigger {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-sm) var(--spacing-md);
        cursor: pointer;
        color: var(--text-muted);
        transition: color var(--transition-fast);
        list-style: none;
    }

    .tp-methodology__trigger::-webkit-details-marker {
        display: none;
    }

    .tp-methodology__trigger::before {
        content: '\25B6';
        font-size: 0.6em;
        transition: transform var(--transition-fast);
    }

    .tp-methodology[open] > .tp-methodology__trigger::before {
        transform: rotate(90deg);
    }

    .tp-methodology__trigger:hover {
        color: var(--text-secondary);
    }

    .tp-methodology__body {
        padding: var(--spacing-sm) var(--spacing-md) var(--spacing-md);
        color: var(--text-secondary);
        line-height: 1.7;
        border-top: 1px solid var(--border-light);
    }

    .tp-methodology__heading {
        font-size: var(--text-xs);
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-top: var(--spacing-md);
        margin-bottom: var(--spacing-xs);
    }

    .tp-methodology__heading:first-child {
        margin-top: 0;
    }

    .tp-methodology__body p {
        margin-bottom: var(--spacing-sm);
    }

    /* ── Scenario comparison ─────────────────────────────────── */
    .tp-scenario-list {
        margin-bottom: var(--spacing-lg);
