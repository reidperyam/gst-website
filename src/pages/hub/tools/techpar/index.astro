    .tp-traj-note--convergence {
        border-color: var(--color-primary);
        color: var(--text-secondary);
    }

    .tp-traj-chart-wrap {
        position: relative;
        height: min(42vh, 320px);
        margin-bottom: var(--spacing-sm);
    }

    .tp-traj-dot {
        position: absolute;
        width: 13px;
        height: 13px;
        border-radius: 50%;
        border: 2px solid var(--bg-light);
        transform: translate(-50%, -50%);
        pointer-events: none;
        z-index: 5;
        display: none;
        transition: left var(--transition-slow), top var(--transition-slow);
    }

    .tp-traj-legend {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-sm);
        margin-bottom: var(--spacing-lg);
    }

    /* Legend groups */
    .tp-traj-legend :global(.tp-tleg-group) {
        display: flex;
        justify-content: center;
        gap: var(--spacing-sm) var(--spacing-md);
        flex-wrap: wrap;
    }

    .tp-traj-legend :global(.tp-tleg-group--series) {
        padding-top: var(--spacing-xs);
        border-top: 1px solid var(--border-light);
    }

    /* Trajectory legend items are injected via innerHTML */
    .tp-traj-legend :global(.tp-tleg) {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        font-size: var(--text-xs);
        color: var(--text-secondary);
    }

    /* Default swatch — zone fill rectangles */
    .tp-traj-legend :global(.tp-tleg__sw) {
        width: 14px;
        height: 8px;
        border-radius: 1px;
        flex-shrink: 0;
    }

    /* Line swatch — centered horizontal line */
    .tp-traj-legend :global(.tp-tleg--line .tp-tleg__sw) {
        height: 0;
        border-top-width: 2px;
        border-top-style: solid;
        background: transparent;
        border-radius: 0;
        align-self: center;
    }

    .tp-traj-legend :global(.tp-tleg--dashed .tp-tleg__sw) {
        border-top-style: dashed;
    }

    /* Dot swatch — centered circle */
    .tp-traj-legend :global(.tp-tleg--dot .tp-tleg__sw) {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        border-width: 2px;
        border-style: solid;
        background: transparent;
    }

    /* ── Responsive ───────────────────────────────────────────── */
    @media (min-width: 640px) {
