    .tp-scenario-list__head {
        color: var(--text-muted);
        margin-bottom: var(--spacing-sm);
    }

    .tp-scenario-list :global(.tp-scenario-chip) {
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-xs);
        padding: var(--spacing-xs) var(--spacing-sm);
        border: 1px solid var(--border-light);
        background: var(--bg-light-alt);
        font-size: var(--text-xs);
        color: var(--text-secondary);
        margin-right: var(--spacing-xs);
        margin-bottom: var(--spacing-xs);
    }

    .tp-scenario-list :global(.tp-scenario-chip__zone) {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        margin-left: var(--spacing-xs);
    }

    .tp-scenario-list :global(.tp-scenario-chip__remove) {
        padding: 0 2px;
        background: transparent;
        border: none;
        color: var(--text-muted);
        font-size: 0.85rem;
        cursor: pointer;
        line-height: 1;
    }

    .tp-scenario-compare {
        margin-bottom: var(--spacing-lg);
    }

    .tp-scenario-compare__head {
        margin-bottom: var(--spacing-sm);
    }

    .tp-scenario-compare :global(table) {
        width: 100%;
        border-collapse: collapse;
        font-size: var(--text-xs);
