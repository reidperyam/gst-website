    .tp-cat-dot--pers { background: var(--techpar-category-personnel); }
    .tp-cat-dot--rd { background: var(--techpar-category-rd-opex); }
    .tp-cat-dot--capex { background: var(--techpar-category-rd-capex); }

    .tp-field {
        margin-bottom: var(--spacing-md);
    }

    .tp-field__label {
