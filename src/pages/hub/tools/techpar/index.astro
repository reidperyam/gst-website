---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import HubHeader from '../../../../components/hub/HubHeader.astro';
import DeltaIcon from '../../../../components/DeltaIcon.astro';
---

<BaseLayout
  title="TechPar | GST"
  description="A technology cost structure analysis tool for PE diligence and portfolio company benchmarking. Enter spend across infrastructure, personnel, and R&D to compute a blended technology cost ratio benchmarked against stage-adjusted ranges."
  ogTitle="TechPar | GST"
  ogDescription="Technology cost structure analysis tool. Enter spend across infrastructure, personnel, and R&D to compute a blended cost ratio benchmarked against stage-adjusted ranges."
  ogImage="/og-image.png"
  ogImageAlt="TechPar - Technology Cost Structure Benchmarking Tool"
  ogUrl="https://globalstrategic.tech/hub/tools/techpar"
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: 'TechPar',
      description:
        'Technology cost structure analysis tool for PE diligence and portfolio company benchmarking',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      publisher: { '@type': 'Organization', name: 'Global Strategic Technologies' },
      datePublished: '2026-02-01',
      dateModified: '2026-03-22',
      featureList: [
        'Blended technology cost ratio',
        'Stage-adjusted benchmarking',
        '36-month trajectory projection',
        'Infrastructure, personnel, and R&D breakdown',
      ],
      author: {
        '@type': 'Person',
        name: 'Reid Peryam',
        jobTitle: 'Strategic Technology Advisor',
        sameAs: ['https://www.linkedin.com/in/reidperyam/'],
        description:
          'Technology advisor with experience across 100+ PE technology diligence engagements',
        knowsAbout: [
          'Technology Cost Benchmarking',
          'SaaS Metrics',
          'Technical Due Diligence',
          'M&A Tech Strategy',
          'Infrastructure Cost Analysis',
        ],
      },
    })}
  />

  <section class="techpar-section">
    <div class="container">
      <HubHeader
        title="TechPar"
        subtitle="Benchmark total technology cost against stage-adjusted ranges. Built for IC packages, board reporting, and sell-side preparation."
      />

      <div data-techpar class="techpar-shell">
        <!-- Tab bar -->
        <div class="tp-tab-bar" data-tab-bar>
          <button class="tp-tab tp-tab--active" data-tab="profile" type="button">
            <svg
              class="tp-tab__icon"
              width="16"
              height="16"
              viewBox="0 0 64 64"
              fill="none"
              stroke="currentColor"
              stroke-width="6"
              stroke-linejoin="miter"
              aria-hidden="true"
            >
              <rect x="12" y="12" width="40" height="40"></rect>
            </svg>
            <span class="tp-tab__label">Profile</span>
          </button>
          <button class="tp-tab" data-tab="costs" type="button">
            <svg
              class="tp-tab__icon"
              width="16"
              height="16"
              viewBox="0 0 64 64"
              fill="none"
              stroke="currentColor"
              stroke-width="6"
              stroke-linejoin="miter"
              aria-hidden="true"
            >
              <circle cx="32" cy="32" r="20"></circle>
            </svg>
            <span class="tp-tab__label">Costs</span>
          </button>
          <button class="tp-tab" data-tab="analysis" type="button">
            <svg
              class="tp-tab__icon"
              width="16"
              height="16"
              viewBox="0 0 64 64"
              fill="none"
              stroke="currentColor"
              stroke-width="6"
              stroke-linejoin="miter"
              aria-hidden="true"
            >
              <path d="M12 52 L32 12 L52 52" fill="none"></path>
            </svg>
            <span class="tp-tab__label">Analysis</span>
          </button>
          <button class="tp-tab" data-tab="trajectory" type="button">
            <svg
              class="tp-tab__icon"
              width="16"
              height="16"
              viewBox="0 0 64 64"
              fill="none"
              stroke="currentColor"
              stroke-width="6"
              stroke-linejoin="miter"
              aria-hidden="true"
            >
              <path d="M32 12 L52 52 L12 52 Z"></path>
            </svg>
            <span class="tp-tab__label">Trajectory</span>
          </button>
        </div>
        <div class="tp-toolbar">
          <button class="tp-toolbar__reset" data-action="reset" type="button"
            >Reset all inputs</button
          >
        </div>

        <!-- ── TAB: PROFILE ──────────────────────────────────── -->
        <div class="tp-panel tp-panel--active" data-panel="profile">
          <details class="tp-onboarding" data-onboarding open>
            <summary class="tp-onboarding__trigger brutal-label-small">How to use TechPar</summary>
            <div class="tp-onboarding__body brutal-text-tiny">
              <p>
                <strong>TechPar</strong> benchmarks your total technology cost against stage-adjusted
                ranges derived from KeyBanc, OpenView, Bessemer, and GST engagement data.
              </p>
              <p>
                <strong>Who it's for:</strong> PE deal teams, portfolio company CTOs and CFOs, and board-level
                reporting.
              </p>
              <p>
                <strong>What you'll need:</strong> Annual recurring revenue (ARR) and monthly infrastructure
                spend at minimum. Additional cost categories (personnel, R&D, CapEx) unlock deeper analysis.
              </p>
              <p>
                <strong>How it works:</strong> Select your company stage, enter revenue and costs, and
                TechPar computes a blended technology cost ratio with zone classification, gap analysis,
                and 36-month trajectory projection.
              </p>
            </div>
          </details>

          <div class="tp-panel__header">
            <span class="tp-step brutal-label-small">Step 1 of 4</span>
            <h2 class="tp-panel__title brutal-heading-md">Company profile</h2>
            <p class="tp-panel__sub brutal-text-small">
              Stage and revenue drive all benchmark ranges. Everything else adapts to what you enter
              here.
            </p>
          </div>

          <div class="tp-section">
            <span class="brutal-tool-shell__section-label tp-sec-label"
              >Company stage <span class="tp-field__req">(required)</span></span
            >
            <div class="tp-stage-grid" data-stage-grid>
              <button
                class="brutal-option-card brutal-option-card--compact"
                data-stage="seed"
                type="button"
              >
                <span class="brutal-option-card__label">Seed / Pre-A</span>
                <span class="brutal-option-card__description">60&ndash;100%</span>
              </button>
              <button
                class="brutal-option-card brutal-option-card--compact"
                data-stage="series_a"
                type="button"
              >
                <span class="brutal-option-card__label">Series A</span>
                <span class="brutal-option-card__description">45&ndash;75%</span>
              </button>
              <button
                class="brutal-option-card brutal-option-card--compact"
                data-stage="series_bc"
                type="button"
              >
                <span class="brutal-option-card__label">Series B&ndash;C</span>
                <span class="brutal-option-card__description">35&ndash;55%</span>
              </button>
              <button
                class="brutal-option-card brutal-option-card--compact"
                data-stage="pe"
                type="button"
              >
                <span class="brutal-option-card__label">PE-backed</span>
                <span class="brutal-option-card__description">25&ndash;40%</span>
              </button>
              <button
                class="brutal-option-card brutal-option-card--compact"
                data-stage="enterprise"
                type="button"
              >
                <span class="brutal-option-card__label">Enterprise</span>
                <span class="brutal-option-card__description">18&ndash;32%</span>
              </button>
            </div>
            <div class="tp-hint brutal-text-tiny">
              Sets benchmark ranges and zone thresholds for your growth stage.
            </div>
          </div>

          <div class="tp-section">
            <span class="brutal-tool-shell__section-label tp-sec-label">Industry</span>
            <div class="tp-seg tp-seg--wide" data-seg="industry">
              <button class="tp-seg__btn tp-seg__btn--active" data-industry="saas" type="button"
                >SaaS</button
              >
              <button class="tp-seg__btn" data-industry="fintech" type="button">Fintech</button>
              <button class="tp-seg__btn" data-industry="marketplace" type="button"
                >Marketplace</button
              >
              <button class="tp-seg__btn" data-industry="infra_hw" type="button">Hardware</button>
              <button class="tp-seg__btn" data-industry="other" type="button">Other</button>
            </div>
            <div class="tp-hint brutal-text-tiny">
              Adds industry-specific context to the analysis. Benchmark ranges remain the same
              across industries.
            </div>
          </div>

          <div class="tp-section">
            <span class="brutal-tool-shell__section-label tp-sec-label">Display currency</span>
            <div class="tp-seg" data-seg="currency">
              <button class="tp-seg__btn tp-seg__btn--active" data-currency="$" type="button"
                >USD</button
              >
              <button class="tp-seg__btn" data-currency="€" type="button">EUR</button>
              <button class="tp-seg__btn" data-currency="£" type="button">GBP</button>
              <button class="tp-seg__btn" data-currency="C$" type="button">CAD</button>
              <button class="tp-seg__btn" data-currency="A$" type="button">AUD</button>
            </div>
            <div class="tp-hint brutal-text-tiny">
              Display only. All values remain in your local currency.
            </div>
          </div>

          <div class="tp-section">
            <span class="brutal-tool-shell__section-label tp-sec-label">Revenue</span>
            <div class="tp-field">
              <label class="tp-field__label brutal-text-small" for="tp-arr"
                >ARR or TTM Revenue <span class="tp-field__req">(required)</span></label
              >
              <div class="tp-arr-quick" data-arr-quick>
                <button class="tp-arr-chip" data-arr-val="10000000" type="button">$10M</button>
                <button class="tp-arr-chip" data-arr-val="25000000" type="button">$25M</button>
                <button class="tp-arr-chip" data-arr-val="50000000" type="button">$50M</button>
                <button class="tp-arr-chip" data-arr-val="100000000" type="button">$100M</button>
                <button class="tp-arr-chip" data-arr-val="250000000" type="button">$250M</button>
              </div>
              <div class="tp-input-wrap">
                <span class="tp-input-pre">$</span>
                <input
                  type="text"
                  id="tp-arr"
                  data-input="arr"
                  data-arr-display
                  inputmode="numeric"
                  placeholder="e.g. 12,500,000"
                  autocomplete="off"
                />
              </div>
              <div class="tp-hint brutal-text-tiny">
                Annual recurring revenue or trailing twelve months. All benchmarks are expressed
                relative to this figure.
              </div>
            </div>
          </div>

          <div class="tp-section">
            <span class="brutal-tool-shell__section-label tp-sec-label"
              >Revenue growth assumption</span
            >
            <div class="tp-seg-row">
              <div class="tp-seg" data-seg="growth">
                <button class="tp-seg__btn" data-growth="10" type="button">10%</button>
                <button class="tp-seg__btn" data-growth="20" type="button">20%</button>
                <button class="tp-seg__btn" data-growth="30" type="button">30%</button>
                <button class="tp-seg__btn" data-growth="50" type="button">50%</button>
              </div>
            </div>
            <div class="tp-input-wrap">
              <input
                type="number"
                id="tp-growth-custom"
                data-input="growthCustom"
                min="1"
                max="500"
                placeholder="Custom"
                class="tp-input--no-pre tp-input--has-suf"
              />
              <span class="tp-input-suf">%</span>
            </div>
            <div class="tp-hint brutal-text-tiny">
              Used in trajectory projections. Does not affect current-period KPIs.
            </div>
            <div
              class="tp-hint tp-hint--warn brutal-text-tiny"
              data-growth-warn
              style="display:none"
            >
              Growth above 100% produces extreme trajectory projections. Verify this reflects your
              planning model.
            </div>
          </div>

          <div class="tp-field tp-exit-field" data-exit-field>
            <label class="tp-field__label brutal-text-small" for="tp-exit-mult"
              >Exit multiple assumption</label
            >
            <div class="tp-arr-quick">
              <button
                class="tp-arr-chip"
                data-preset-for="exitMult"
                data-preset-val="6"
                type="button">6×</button
              >
              <button
                class="tp-arr-chip"
                data-preset-for="exitMult"
                data-preset-val="10"
                type="button">10×</button
              >
              <button
                class="tp-arr-chip"
                data-preset-for="exitMult"
                data-preset-val="12"
                type="button">12×</button
              >
              <button
                class="tp-arr-chip"
                data-preset-for="exitMult"
                data-preset-val="15"
                type="button">15×</button
              >
              <button
                class="tp-arr-chip"
                data-preset-for="exitMult"
                data-preset-val="20"
                type="button">20×</button
              >
            </div>
            <div class="tp-input-wrap">
              <input
                type="number"
                id="tp-exit-mult"
                data-input="exitMult"
                class="tp-input--no-pre tp-input--has-suf"
                min="1"
                max="30"
                value="12"
              />
              <span class="tp-input-suf">&times;</span>
            </div>
            <div class="tp-hint brutal-text-tiny">
              Revenue multiple at exit. Used in exit value calculations.
            </div>
          </div>

          <details class="tp-historical" data-historical>
            <summary class="tp-historical__trigger brutal-label-small"
              >Historical data (optional)</summary
            >
            <div class="tp-historical__body">
              <p class="tp-hint brutal-text-tiny">
                Add 1-2 prior fiscal years to show actual trajectory on the chart. Enter the annual
                ARR and total technology spend for each year.
              </p>
              <div data-hist-rows></div>
              <button class="tp-hist-add" data-hist-add type="button">+ Add year</button>
            </div>
          </details>

          <div class="tp-nav-row">
            <button
              class="brutal-btn brutal-btn--primary tp-btn-next"
              data-action="go-costs"
              type="button">Enter technology costs &rarr;</button
            >
          </div>
        </div>

        <!-- ── TAB: COSTS ────────────────────────────────────── -->
        <div class="tp-panel" data-panel="costs">
          <div class="tp-panel__header">
            <span class="tp-step brutal-label-small">Step 2 of 4</span>
            <h2 class="tp-panel__title brutal-heading-md">Technology costs</h2>
            <p class="tp-panel__sub brutal-text-small">
              Enter annual spend across each cost category. Infrastructure hosting is required. All
              others are optional and unlock additional KPIs.
            </p>
          </div>

          <!-- Mode toggle -->
          <div class="tp-section">
            <span class="brutal-tool-shell__section-label tp-sec-label">Input mode</span>
            <div class="tp-seg" data-seg="mode">
              <button class="tp-seg__btn tp-seg__btn--active" data-mode="quick" type="button"
                >Quick</button
              >
              <button class="tp-seg__btn" data-mode="deepdive" type="button">Deep Dive</button>
            </div>
            <div class="tp-hint brutal-text-tiny">
              Deep Dive breaks R&D into sub-categories and unlocks the revenue-per-engineer KPI.
            </div>
          </div>

          <!-- CapEx toggle -->
          <label class="tp-capex-row" data-capex-row>
            <input type="checkbox" data-input="gaapChk" />
            <span class="tp-capex-row__label brutal-text-small"
              >GAAP view: remove R&D CapEx from total (as capitalized on income statement)</span
            >
          </label>

          <!-- Infrastructure hosting -->
          <div class="tp-section">
            <span class="brutal-tool-shell__section-label tp-sec-label tp-sec-label--cat"
              ><span class="tp-cat-dot tp-cat-dot--infra"></span>Infrastructure and hosting</span
            >
            <div class="tp-field">
              <label class="tp-field__label brutal-text-small" for="tp-infra"
                ><span data-infra-label>Monthly cloud spend</span>
                <span class="tp-field__req">(required)</span></label
              >
              <div class="tp-seg tp-seg--sm" data-seg="infra-period">
                <button
                  class="tp-seg__btn tp-seg__btn--active"
                  data-infra-period="monthly"
                  type="button">Monthly</button
                >
                <button class="tp-seg__btn" data-infra-period="annual" type="button">Annual</button>
              </div>
              <div class="tp-arr-quick" data-infra-chips-monthly>
                <button
                  class="tp-arr-chip"
                  data-preset-for="infra"
                  data-preset-val="5000"
                  type="button">$5K</button
                >
                <button
                  class="tp-arr-chip"
                  data-preset-for="infra"
                  data-preset-val="15000"
                  type="button">$15K</button
                >
                <button
                  class="tp-arr-chip"
                  data-preset-for="infra"
                  data-preset-val="50000"
                  type="button">$50K</button
                >
                <button
                  class="tp-arr-chip"
                  data-preset-for="infra"
                  data-preset-val="150000"
                  type="button">$150K</button
                >
                <button
                  class="tp-arr-chip"
                  data-preset-for="infra"
                  data-preset-val="500000"
                  type="button">$500K</button
                >
              </div>
              <div class="tp-arr-quick" data-infra-chips-annual style="display:none">
                <button
                  class="tp-arr-chip"
                  data-preset-for="infra"
                  data-preset-val="50000"
                  type="button">$50K</button
                >
                <button
                  class="tp-arr-chip"
                  data-preset-for="infra"
                  data-preset-val="200000"
                  type="button">$200K</button
                >
                <button
                  class="tp-arr-chip"
                  data-preset-for="infra"
                  data-preset-val="500000"
                  type="button">$500K</button
                >
                <button
                  class="tp-arr-chip"
                  data-preset-for="infra"
                  data-preset-val="2000000"
                  type="button">$2M</button
                >
                <button
                  class="tp-arr-chip"
                  data-preset-for="infra"
                  data-preset-val="5000000"
                  type="button">$5M</button
                >
              </div>
              <div class="tp-input-wrap">
                <span class="tp-input-pre">$</span>
                <input
                  type="number"
                  id="tp-infra"
                  data-input="infra"
                  min="0"
                  step="1000"
                  placeholder="0"
                />
                <span class="tp-input-suf" data-infra-suf>/ mo</span>
              </div>
              <div class="tp-hint brutal-text-tiny" data-infra-hint>
                Cloud, data center, CDN, observability, managed services. Auto-converted to annual.
              </div>
              <div class="tp-infra-annual brutal-text-tiny" data-infra-annual style="display:none">
              </div>
              <div
                class="tp-hint tp-hint--warn brutal-text-tiny"
                data-infra-warn
                style="display:none"
              >
              </div>
            </div>
          </div>

          <!-- Infrastructure personnel -->
          <div class="tp-section">
            <span class="brutal-tool-shell__section-label tp-sec-label tp-sec-label--cat"
              ><span class="tp-cat-dot tp-cat-dot--pers"></span>Infrastructure personnel</span
            >
            <div class="tp-field">
              <label class="tp-field__label brutal-text-small" for="tp-infra-pers"
                >Annual fully-loaded cost</label
              >
              <div class="tp-arr-quick">
                <button
                  class="tp-arr-chip"
                  data-preset-for="infraPers"
                  data-preset-val="250000"
                  type="button">$250K</button
                >
                <button
                  class="tp-arr-chip"
                  data-preset-for="infraPers"
                  data-preset-val="500000"
                  type="button">$500K</button
                >
                <button
                  class="tp-arr-chip"
                  data-preset-for="infraPers"
                  data-preset-val="1000000"
                  type="button">$1M</button
                >
                <button
                  class="tp-arr-chip"
                  data-preset-for="infraPers"
                  data-preset-val="2000000"
                  type="button">$2M</button
                >
                <button
                  class="tp-arr-chip"
                  data-preset-for="infraPers"
                  data-preset-val="5000000"
                  type="button">$5M</button
                >
              </div>
              <div class="tp-input-wrap">
                <span class="tp-input-pre">$</span>
                <input
                  type="number"
                  id="tp-infra-pers"
                  data-input="infraPers"
                  min="0"
                  step="10000"
                  placeholder="—"
                />
              </div>
              <div class="tp-hint brutal-text-tiny">
                DevOps, SRE, platform engineering, cloud architecture headcount.
              </div>
              <div
                class="tp-hint tp-hint--warn brutal-text-tiny"
                data-sanity-warn="infraPers"
                style="display:none"
              >
              </div>
            </div>
          </div>

          <!-- R&D OpEx -->
          <div class="tp-section">
            <span class="brutal-tool-shell__section-label tp-sec-label tp-sec-label--cat"
              ><span class="tp-cat-dot tp-cat-dot--rd"></span>R&D OpEx</span
            >

            <!-- Quick mode -->
            <div data-rd-quick>
              <div class="tp-field">
                <label class="tp-field__label brutal-text-small" for="tp-rd-opex"
                  >Annual fully-loaded cost</label
                >
                <div class="tp-arr-quick">
                  <button
                    class="tp-arr-chip"
                    data-preset-for="rdOpEx"
                    data-preset-val="1000000"
                    type="button">$1M</button
                  >
                  <button
                    class="tp-arr-chip"
                    data-preset-for="rdOpEx"
                    data-preset-val="3000000"
                    type="button">$3M</button
                  >
                  <button
                    class="tp-arr-chip"
                    data-preset-for="rdOpEx"
                    data-preset-val="5000000"
                    type="button">$5M</button
                  >
                  <button
                    class="tp-arr-chip"
                    data-preset-for="rdOpEx"
                    data-preset-val="10000000"
                    type="button">$10M</button
                  >
                  <button
                    class="tp-arr-chip"
                    data-preset-for="rdOpEx"
                    data-preset-val="25000000"
                    type="button">$25M</button
                  >
                </div>
                <div class="tp-input-wrap">
                  <span class="tp-input-pre">$</span>
                  <input
                    type="number"
                    id="tp-rd-opex"
                    data-input="rdOpEx"
                    min="0"
                    step="100000"
                    placeholder="0"
                  />
                </div>
                <div class="tp-hint brutal-text-tiny">
                  Engineering and product headcount plus tooling subscriptions. Annual fully-loaded.
                </div>
                <div
                  class="tp-hint tp-hint--warn brutal-text-tiny"
                  data-sanity-warn="rdOpEx"
                  style="display:none"
                >
                </div>
              </div>
            </div>

            <!-- Deep Dive mode -->
            <div class="tp-deep-wrap" data-rd-deep>
              <div class="tp-deep-head brutal-label-small">R&D OpEx breakdown</div>
              <div class="tp-field">
                <label class="tp-field__label brutal-text-tiny" for="tp-rd-eng"
                  >Engineering headcount</label
                >
                <div class="tp-arr-quick">
                  <button
                    class="tp-arr-chip"
                    data-preset-for="rdEng"
                    data-preset-val="500000"
                    type="button">$500K</button
                  >
                  <button
                    class="tp-arr-chip"
                    data-preset-for="rdEng"
                    data-preset-val="1000000"
                    type="button">$1M</button
                  >
                  <button
                    class="tp-arr-chip"
                    data-preset-for="rdEng"
                    data-preset-val="3000000"
                    type="button">$3M</button
                  >
                  <button
                    class="tp-arr-chip"
                    data-preset-for="rdEng"
                    data-preset-val="5000000"
                    type="button">$5M</button
                  >
                  <button
                    class="tp-arr-chip"
                    data-preset-for="rdEng"
                    data-preset-val="10000000"
                    type="button">$10M</button
                  >
                </div>
