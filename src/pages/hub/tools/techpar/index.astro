    flex-shrink: 0;
  }

  .tp-cat-dot--infra {
    background: var(--color-primary);
  }
  .tp-cat-dot--pers {
    background: var(--color-authority);
  }
  .tp-cat-dot--rd {
    background: var(--color-distinguish);
  }
  .tp-cat-dot--capex {
    background: var(--color-secondary);
  }

  .tp-field {
    margin-bottom: var(--spacing-md);
  }

  .tp-field__label {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xs);
    line-height: 1.4;
    color: var(--text-secondary);
  }

  .tp-field__req {
    color: var(--text-muted);
  }

  .tp-hint {
    color: var(--text-muted);
    margin-top: var(--spacing-xs);
    line-height: 1.5;
  }

  .tp-hint--warn {
    color: var(--color-warning);
  }

  .tp-infra-annual {
    color: var(--color-primary);
    margin-top: var(--spacing-xs);
  }

  /* ─── Baseline comparison ─────────────────────────────── */
  .tp-kpi-hero__zone-row {
    display: flex;
    align-items: stretch;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
    margin-top: var(--spacing-sm);
  }

  .tp-baseline-controls {
    display: flex;
    align-items: center;
  }

  .tp-baseline-btn {
    padding: var(--spacing-xs) var(--spacing-md);
    background: transparent;
    color: var(--text-muted);
    border: 2px solid light-dark(var(--border-light), var(--border-dark-default));
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .tp-baseline-btn:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .tp-baseline-bar {
    display: flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-xs) var(--spacing-md);
    background: transparent;
    border: 2px solid var(--color-primary);
  }

  .tp-baseline-bar__label {
    color: var(--color-primary);
    font-size: var(--text-xs);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .tp-baseline-bar__clear {
    padding: 0 4px;
    background: transparent;
    color: var(--text-muted);
    border: none;
    font-family: var(--font-family-mono);
    font-size: 0.85rem;
    line-height: 1;
    cursor: pointer;
    transition: color var(--transition-fast);
  }

  .tp-baseline-bar__clear:hover {
    color: var(--color-warning);
  }

  .tp-delta {
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    margin-left: var(--spacing-xs);
  }

  .tp-delta--improve {
    color: var(--color-primary);
  }

  .tp-delta--worsen {
    color: var(--color-warning);
  }

  .tp-cross-link {
    margin-top: var(--spacing-md);
    padding: var(--spacing-sm) var(--spacing-md);
    background: transparent;
    border: 2px solid light-dark(var(--border-light), var(--border-dark-default));
    border-left: 3px solid var(--color-primary);
    font-family: var(--font-family-mono);
    font-size: var(--text-sm);
  }

  .tp-cross-link a {
    color: var(--color-primary);
    text-decoration: none;
    font-weight: var(--font-weight-bold);
  }

  .tp-cross-link a:hover {
    text-decoration: underline;
  }

  .tp-input-wrap {
    position: relative;
    width: 100%;
    max-width: 280px;
  }

  .tp-input-pre {
    position: absolute;
    left: var(--spacing-sm);
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-family-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    pointer-events: none;
    z-index: 1;
  }

  .tp-input-suf {
    position: absolute;
    right: var(--spacing-sm);
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-family-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    pointer-events: none;
  }

  .techpar-shell input[type='number'],
  .techpar-shell input[data-arr-display] {
    width: 100%;
    background: transparent;
    border: 2px dashed light-dark(var(--border-light), var(--border-dark-default));
    color: var(--text-primary);
    font-family: var(--font-family-mono);
    font-size: var(--text-sm);
    padding: var(--spacing-sm) var(--spacing-sm) var(--spacing-sm) var(--spacing-xl);
    outline: none;
    transition:
      border-color var(--transition-fast),
      border-style var(--transition-fast);
    appearance: textfield;
    border-radius: 0;
  }

  .techpar-shell input[type='number']::-webkit-inner-spin-button {
    appearance: none;
  }

  .techpar-shell input[type='number']:focus,
  .techpar-shell input[data-arr-display]:focus {
    border-color: var(--color-primary);
    border-style: solid;
  }

  .techpar-shell input[type='number'].tp-input--no-pre {
    padding-left: var(--spacing-sm);
  }

  .techpar-shell input[type='number'].tp-input--has-suf {
    padding-right: var(--spacing-2xl);
  }

  /* ── ARR quick-pick chips ──────────────────────────────────── */
  .tp-arr-quick {
    display: flex;
    flex-wrap: wrap;
    margin-bottom: var(--spacing-sm);
    border: 2px solid light-dark(var(--border-light), var(--border-dark-default));
    overflow: hidden;
    max-width: 280px;
  }

  .tp-arr-chip {
    flex: 1;
    background: transparent;
    border: none;
    border-right: 1px solid light-dark(var(--border-light), var(--border-dark-default));
    color: var(--text-muted);
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: var(--spacing-sm) var(--spacing-sm);
    cursor: pointer;
    transition: all var(--transition-fast);
    white-space: nowrap;
    text-align: center;
  }

  .tp-arr-chip:nth-child(4),
  .tp-arr-chip:last-child {
    border-right: none;
  }

  .tp-arr-chip:hover:not(.tp-arr-chip--active) {
    color: var(--text-secondary);
  }

  .tp-arr-chip--active {
    background: transparent;
    color: var(--color-primary);
    box-shadow: inset 0 0 0 2px var(--color-primary);
  }

  .tp-arr-chip--active:hover {
    background: transparent;
    color: var(--color-primary);
  }

  /* ── Stage grid ───────────────────────────────────────────── */
  .tp-stage-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
  }

  /* ── Segmented controls ───────────────────────────────────── */
  .tp-seg-row {
    display: flex;
    gap: var(--spacing-sm);
    flex-wrap: wrap;
    margin-bottom: var(--spacing-sm);
  }

  .tp-seg {
    display: flex;
    width: 100%;
    border: 2px solid light-dark(var(--border-light), var(--border-dark-default));
    overflow: hidden;
    max-width: 320px;
  }

  .tp-seg__btn {
    flex: 1;
    padding: var(--spacing-sm) var(--spacing-lg);
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    background: transparent;
    border: none;
    border-right: 1px solid light-dark(var(--border-light), var(--border-dark-default));
    cursor: pointer;
    transition: all var(--transition-fast);
    text-align: center;
  }

  .tp-seg__btn:last-child {
    border-right: none;
  }

  .tp-seg__btn--active {
    background: transparent;
    color: var(--color-primary);
    box-shadow: inset 0 0 0 2px var(--color-primary);
  }

  .tp-seg--sm {
    max-width: 180px;
    margin-bottom: var(--spacing-xs);
  }

  .tp-seg--sm .tp-seg__btn {
    padding: var(--spacing-xs) var(--spacing-sm);
  }

  .tp-seg--wide {
    max-width: 440px;
  }

  .tp-seg__btn:hover:not(.tp-seg__btn--active) {
    color: var(--text-secondary);
  }

  /* ── Deep dive wrap ───────────────────────────────────────── */
  .tp-deep-wrap {
    display: none;
    background: transparent;
    border: 2px solid light-dark(var(--border-light), var(--border-dark-default));
    padding: var(--spacing-md);
    margin-bottom: var(--spacing-sm);
  }

  .tp-deep-wrap--on {
    display: block;
  }

  .tp-deep-head {
    color: var(--text-muted);
    margin-bottom: var(--spacing-sm);
  }

  .tp-deep-sum {
    color: var(--text-secondary);
    margin-top: var(--spacing-sm);
    padding-top: var(--spacing-sm);
    border-top: 2px solid light-dark(var(--border-light), var(--border-dark-default));
  }

  .tp-deep-sum span {
    color: var(--color-primary);
  }

  /* ── CapEx toggle ─────────────────────────────────────────── */
  .tp-capex-row {
    display: none;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-sm);
    background: transparent;
    border: 2px solid light-dark(var(--border-light), var(--border-dark-default));
    margin-bottom: var(--spacing-lg);
    cursor: pointer;
    font-family: var(--font-family-mono);
  }

  .tp-capex-row--vis {
    display: flex;
  }

  .tp-capex-row input[type='checkbox'] {
    accent-color: var(--color-primary);
    width: 14px;
    height: 14px;
    cursor: pointer;
    flex-shrink: 0;
  }

  /* ── Exit field visibility ────────────────────────────────── */
  .tp-exit-field {
    display: none;
  }

  .tp-exit-field--vis {
    display: block;
  }

  /* ── Navigation buttons ───────────────────────────────────── */
  .tp-nav-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-top: var(--spacing-xl);
  }

  .tp-nav-row__next {
    margin-left: auto;
    text-align: right;
  }

  .tp-nav-row__hint {
    display: block;
    margin-top: 4px;
    color: var(--text-muted);
  }

  .tp-nav-row .tool-action-bar {
    margin-left: auto;
  }

  /* Button overrides (base styles from global .brutal-btn) */
  .tp-btn-next {
    flex: 1;
  }

  .tp-btn-next:disabled {
    opacity: 0.3;
  }

  /* ── Empty state ──────────────────────────────────────────── */
  .tp-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 40vh;
    gap: var(--spacing-sm);
    text-align: center;
  }

  .tp-empty--hidden {
    display: none;
  }

  .tp-empty__sym {
    width: 64px;
    height: 64px;
    color: var(--text-muted);
  }

  .tp-empty__msg {
    color: var(--text-muted);
    line-height: 1.6;
  }

  .tp-empty__cta {
    margin-top: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-xl);
    border: 2px solid var(--color-primary);
    background: transparent;
    color: var(--color-primary);
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    cursor: pointer;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: all var(--transition-fast);
  }

  .tp-empty__cta:hover {
    background: var(--color-primary);
    color: var(--bg-dark);
  }

  /* ── Analysis content ─────────────────────────────────────── */
  .tp-analysis-content {
    display: none;
  }

  .tp-analysis-content--on {
    display: block;
  }

  /* ── Primary KPI hero (frosted glass) ────────────────────── */
  .tp-kpi-hero {
    padding: var(--spacing-xl);
    background: light-dark(rgba(0, 0, 0, 0.005), rgba(255, 255, 255, 0.005));
    backdrop-filter: blur(3px);
    border: 2px solid light-dark(var(--border-light), var(--border-dark-default));
    border-top: 3px solid var(--color-primary);
    margin-bottom: var(--spacing-lg);
  }

  .tp-kpi-hero__num {
    font-family: var(--font-family-mono);
    font-size: 4.5rem;
    font-weight: var(--font-weight-bold);
    line-height: 1;
    transition: color var(--transition-fast);
  }

  .tp-kpi-hero__lbl {
    color: var(--text-secondary);
    margin-top: var(--spacing-xs);
  }

  .tp-kpi-hero__basis {
    margin-top: 2px;
  }

  /* Zone pill */

  /* Zone pill is injected via innerHTML */
  .tp-kpi-hero :global(.tp-zone-pill) {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-xs) var(--spacing-md);
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 2px solid;
  }

  .tp-kpi-hero :global(.tp-zone-dot) {
    width: 5px;
    height: 5px;
  }

  /* Benchmark bar */
  .tp-bench-wrap {
    margin-top: var(--spacing-lg);
  }

  .tp-bench-track {
    height: 3px;
    background: light-dark(var(--border-light), var(--border-dark-default));
    position: relative;
  }

  .tp-bench-fill {
    position: absolute;
    height: 100%;
    top: 0;
    left: 0;
    transition:
      width var(--transition-slow),
      background var(--transition-fast);
  }

  .tp-bench-lbls {
    display: flex;
    justify-content: space-between;
    margin-top: var(--spacing-xs);
  }

  .tp-bench-lbl {
    color: var(--text-muted);
  }

  .tp-bench-mid {
    color: var(--color-primary);
  }

  /* ── Signal card (frosted glass) ─────────────────────────── */
  .tp-signal {
    padding: var(--spacing-lg);
    background: light-dark(rgba(0, 0, 0, 0.005), rgba(255, 255, 255, 0.005));
    backdrop-filter: blur(3px);
    border: 2px solid light-dark(var(--border-light), var(--border-dark-default));
    border-left: 3px solid var(--color-primary);
    margin-bottom: var(--spacing-lg);
  }

  .tp-signal__stage {
    color: var(--text-muted);
    margin-bottom: 2px;
  }

  .tp-signal__zone {
    margin-bottom: var(--spacing-sm);
  }

  .tp-signal__head {
    line-height: 1.3;
    margin-bottom: var(--spacing-sm);
  }

  .tp-signal__body {
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .tp-signal__div {
    height: 2px;
    background: light-dark(var(--border-light), var(--border-dark-default));
    margin: var(--spacing-md) 0;
  }

  /* Signal metrics are injected via innerHTML */
  .tp-signal :global(.tp-sig-met) {
    margin-bottom: var(--spacing-sm);
  }

  .tp-signal :global(.tp-sig-met:last-child) {
    margin-bottom: 0;
  }

  .tp-signal :global(.tp-sig-mlbl) {
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--spacing-xs);
  }

  .tp-signal :global(.tp-sig-mval) {
    font-family: var(--font-family-mono);
    font-size: var(--text-2xl);
    font-weight: var(--font-weight-semibold);
    line-height: 1;
  }

  .tp-signal :global(.tp-sig-msub) {
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: var(--spacing-xs);
  }

  .tp-signal :global(.tp-sig-note) {
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    color: var(--text-secondary);
    line-height: 1.7;
  }

  /* ── KPI grid ─────────────────────────────────────────────── */
  .tp-kpi-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xl);
  }

  /* KPI cells are injected via innerHTML — use :global for children */
  .tp-kpi-grid :global(.tp-kpi-cell) {
    background: light-dark(rgba(0, 0, 0, 0.005), rgba(255, 255, 255, 0.005));
    backdrop-filter: blur(3px);
    border: 2px solid light-dark(var(--border-light), var(--border-dark-default));
    padding: var(--spacing-md);
    display: flex;
    flex-direction: column;
  }

  .tp-kpi-grid :global(.tp-kpi-cell--highlight) {
    grid-column: 1 / -1;
    border-left: 3px solid var(--color-primary);
    padding: var(--spacing-lg);
  }

  .tp-kpi-grid :global(.tp-kpi-cell--highlight .tp-kpi-val) {
    font-size: var(--text-2xl);
  }

  .tp-kpi-grid :global(.tp-kpi-lbl) {
    font-family: var(--font-family-mono);
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: var(--font-weight-bold);
    line-height: 1;
    margin-bottom: var(--spacing-sm);
  }

  .tp-kpi-grid :global(.tp-kpi-val) {
    font-family: var(--font-family-mono);
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    line-height: 1;
    color: var(--text-primary);
    margin-bottom: var(--spacing-xs);
  }

  .tp-kpi-grid :global(.tp-kpi-val--pos) {
    color: var(--color-primary);
  }
  .tp-kpi-grid :global(.tp-kpi-val--warn) {
    color: var(--color-warning);
  }
  .tp-kpi-grid :global(.tp-kpi-val--bad) {
    color: var(--color-error);
  }

  .tp-kpi-grid :global(.tp-kpi-sub) {
    font-family: var(--font-family-mono);
    font-size: 10px;
    color: var(--text-muted);
    line-height: 1.3;
    margin-top: auto;
    padding-top: var(--spacing-xs);
    border-top: 2px solid light-dark(var(--border-light), var(--border-dark-default));
  }

  .tp-kpi-grid :global(.tp-kpi-cell--highlight .tp-kpi-sub) {
    border-top: none;
    padding-top: 0;
  }

  /* ── Category bars ────────────────────────────────────────── */
  .tp-cat-section {
    display: none;
    margin-bottom: var(--spacing-lg);
  }

  .tp-cat-section--on {
    display: block;
  }

  .tp-cat-head {
    margin-bottom: var(--spacing-md);
  }

  /* Category bar rows are injected via innerHTML */
  .tp-cat-section :global(.tp-cat-row) {
    margin-bottom: var(--spacing-md);
  }

  .tp-cat-section :global(.tp-cat-row:last-child) {
    margin-bottom: 0;
  }

  .tp-cat-section :global(.tp-cat-meta) {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--spacing-xs);
  }

  .tp-cat-section :global(.tp-cat-name) {
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .tp-cat-section :global(.tp-cat-pct) {
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
  }

  .tp-cat-section :global(.tp-cat-bench) {
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .tp-cat-section :global(.tp-cat-track) {
    height: 5px;
    background: light-dark(var(--border-light), var(--border-dark-default));
    position: relative;
    overflow: hidden;
  }

  .tp-cat-section :global(.tp-cat-band) {
    position: absolute;
    height: 100%;
    background: var(--techpar-chart-band-fill);
  }

  .tp-cat-section :global(.tp-cat-fill) {
    position: absolute;
    height: 100%;
    top: 0;
    left: 0;
    transition: width var(--transition-slow);
  }

  /* ── Benchmark table (frosted glass) ─────────────────────── */
  .tp-bench-table-wrap {
    margin-bottom: var(--spacing-lg);
    padding: var(--spacing-md);
    background: light-dark(rgba(0, 0, 0, 0.005), rgba(255, 255, 255, 0.005));
    backdrop-filter: blur(3px);
    border: 2px solid light-dark(var(--border-light), var(--border-dark-default));
  }

  .tp-bench-table-head {
    color: var(--color-primary);
    margin-bottom: var(--spacing-sm);
  }

  /* Adjacent benchmark notes get a dashed separator */
  .tool-bench-note + .tool-bench-note {
    margin-top: var(--spacing-xs);
    padding-top: var(--spacing-xs);
    border-top: 1px dashed light-dark(var(--border-light), var(--border-dark-default));
  }

  /* ── Historical data section ────────────────────────────── */
  .tp-historical {
    margin-bottom: var(--spacing-md);
    border: 2px solid light-dark(var(--border-light), var(--border-dark-default));
  }

  .tp-historical__trigger {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    cursor: pointer;
    color: var(--text-muted);
    transition: color var(--transition-fast);
    list-style: none;
  }

  .tp-historical__trigger::-webkit-details-marker {
    display: none;
  }

  .tp-historical__trigger::before {
    content: '\25B6';
    font-size: 0.6em;
    transition: transform var(--transition-fast);
  }

  .tp-historical[open] > .tp-historical__trigger::before {
    transform: rotate(90deg);
  }

  .tp-historical__trigger:hover {
    color: var(--text-secondary);
  }

  .tp-historical__body {
