        /* ── Layout ──────────────────────────────────────────────── */
        .tp-panel {
            display: block !important;
            max-width: none !important;
        }

        .tp-panel[data-panel="profile"],
        .tp-panel[data-panel="costs"] {
            display: none !important;
        }

        /* ── Trajectory: include on its own page ─────────────────── */
        .tp-panel[data-panel="trajectory"] {
            display: block !important;
            break-before: page;
        }

        .tp-panel[data-panel="trajectory"] .tp-panel__header {
            display: block !important;
        }

        .tp-panel[data-panel="trajectory"] .tp-panel__header .tp-step {
            display: none !important;
        }

        .tp-traj-content {
            display: block !important;
        }

        [data-traj-empty] {
            display: none !important;
        }

        .tp-traj-chart-wrap {
            break-inside: avoid;
            page-break-inside: avoid;
        }

        .tp-traj-dot {
            display: none !important;
        }

        .tp-panel__header {
            display: none !important;
        }

        .tp-analysis-content {
            display: block !important;
        }

        .techpar-section {
            padding: 0 !important;
        }

        /* ── Header / footer ─────────────────────────────────────── */
        .techpar-shell::before {
            content: 'TechPar Analysis';
            display: block;
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: var(--spacing-xs);
            padding-bottom: var(--spacing-xs);
            border-bottom: 2px solid var(--color-primary);
        }

        .techpar-shell::after {
            content: 'Generated by TechPar  |  globalstrategic.tech/hub/tools/techpar';
            display: block;
            font-size: 0.65rem;
            color: var(--text-muted);
            margin-top: var(--spacing-lg);
            border-top: 1px solid var(--border-light);
            padding-top: var(--spacing-sm);
        }

        /* ── Hero KPI ────────────────────────────────────────────── */
        .tp-kpi-hero {
            text-align: center;
            margin-bottom: var(--spacing-md);
            padding-bottom: var(--spacing-md);
            border-bottom: 1px solid var(--border-light);
        }

        .tp-kpi-hero__num {
            font-size: 3rem !important;
        }

        /* ── Signal card ─────────────────────────────────────────── */
        .tp-signal {
            break-inside: avoid;
            border: 1px solid var(--border-light) !important;
            page-break-inside: avoid;
        }

        /* ── KPI grid ────────────────────────────────────────────── */
        .tp-kpi-grid {
            break-inside: avoid;
            page-break-inside: avoid;
        }

        /* ── Category bars ───────────────────────────────────────── */
        .tp-cat-section {
            break-inside: avoid;
            page-break-inside: avoid;
        }

        /* ── Scenario comparison ─────────────────────────────────── */
        .tp-scenario-compare {
            break-inside: avoid;
            page-break-inside: avoid;
        }

        /* ── Benchmark table ─────────────────────────────────────── */
        .tp-bench-table-wrap {
            break-inside: avoid;
            page-break-inside: avoid;
        }

        /* ── Methodology: force open ─────────────────────────────── */
        .tp-methodology {
            break-inside: avoid;
            page-break-inside: avoid;
        }

        .tp-methodology > .tp-methodology__body {
            display: block !important;
        }

        .tp-methodology__trigger::before {
            display: none !important;
        }

        /* ── Context callout ─────────────────────────────────────── */
        .tp-ctx {
            break-inside: avoid;
            page-break-inside: avoid;
        }

        /* ── Typography: force black for readability ─────────────── */
        .tp-kpi-hero__lbl,
        .tp-kpi-hero__basis {
            color: #333 !important;
        }
    }
</style>

