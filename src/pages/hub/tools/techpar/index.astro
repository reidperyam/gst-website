---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import HubHeader from '../../../../components/hub/HubHeader.astro';
import { trackPageView } from '../../../../utils/analytics';

trackPageView('techpar', 'TechPar | GST');
---

<BaseLayout
    title="TechPar | Strategic Intelligence Hub"
    description="A technology cost structure analysis tool for PE diligence and portfolio company benchmarking. Enter spend across infrastructure, personnel, and R&D to compute a blended technology cost ratio benchmarked against stage-adjusted ranges."
    ogTitle="TechPar | GST"
    ogDescription="Technology cost structure analysis tool. Enter spend across infrastructure, personnel, and R&D to compute a blended cost ratio benchmarked against stage-adjusted ranges."
    ogImage="/og-image.png"
    ogUrl="https://globalstrategic.tech/hub/tools/techpar"
>
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "TechPar",
        "description": "Technology cost structure analysis tool for PE diligence and portfolio company benchmarking",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "publisher": { "@type": "Organization", "name": "Global Strategic Technologies" }
    })} />

    <section class="techpar-section">
        <div class="container">
            <HubHeader
                title="TechPar"
                subtitle="Benchmark total technology cost against stage-adjusted ranges. Built for IC packages, board reporting, and sell-side preparation."
            />

            <div data-techpar class="techpar-shell">

                <!-- Tab bar -->
                <div class="tp-tab-bar" data-tab-bar>
                    <button class="tp-tab tp-tab--active" data-tab="profile" type="button">
                        <svg class="tp-tab__icon" width="16" height="16" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="6" stroke-linejoin="miter" aria-hidden="true">
                            <rect x="12" y="12" width="40" height="40"></rect>
                        </svg>
                        <span class="tp-tab__label">Profile</span>
                    </button>
                    <button class="tp-tab" data-tab="costs" type="button">
                        <svg class="tp-tab__icon" width="16" height="16" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="6" stroke-linejoin="miter" aria-hidden="true">
                            <circle cx="32" cy="32" r="20"></circle>
                        </svg>
                        <span class="tp-tab__label">Costs</span>
                    </button>
                    <button class="tp-tab" data-tab="analysis" type="button">
                        <svg class="tp-tab__icon" width="16" height="16" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="6" stroke-linejoin="miter" aria-hidden="true">
                            <path d="M12 52 L32 12 L52 52" fill="none"></path>
                        </svg>
                        <span class="tp-tab__label">Analysis</span>
                        <span class="tp-tab__badge" data-badge="analysis"></span>
                    </button>
                    <button class="tp-tab" data-tab="trajectory" type="button">
                        <svg class="tp-tab__icon" width="16" height="16" viewBox="9 9 46 46" fill="none" stroke="currentColor" stroke-width="6" stroke-linejoin="miter" aria-hidden="true">
                            <path d="M32 12 L52 52 L12 52 Z"></path>
                        </svg>
                        <span class="tp-tab__label">Trajectory</span>
                    </button>
                    <button class="tp-tab-reset" data-action="reset" type="button" title="Reset all inputs">Reset</button>
                </div>

                <!-- ── TAB: PROFILE ──────────────────────────────────── -->
                <div class="tp-panel tp-panel--active" data-panel="profile">
                    <div class="tp-panel__header">
                        <span class="tp-step label-small">Step 1 of 4</span>
                        <h2 class="tp-panel__title heading-md">Company profile</h2>
                        <p class="tp-panel__sub text-small">Stage and revenue drive all benchmark ranges. Everything else adapts to what you enter here.</p>
                    </div>

                    <div class="tp-section">
                        <span class="tp-sec-label label">Company stage</span>
                        <div class="tp-stage-grid" data-stage-grid>
                            <button class="tp-stage-card" data-stage="seed" type="button">
                                <span class="tp-stage-card__name">Seed / Pre-A</span>
                                <span class="tp-stage-card__range">60&ndash;100%</span>
                            </button>
                            <button class="tp-stage-card" data-stage="series_a" type="button">
                                <span class="tp-stage-card__name">Series A</span>
                                <span class="tp-stage-card__range">45&ndash;75%</span>
                            </button>
                            <button class="tp-stage-card" data-stage="series_bc" type="button">
                                <span class="tp-stage-card__name">Series B&ndash;C</span>
                                <span class="tp-stage-card__range">35&ndash;55%</span>
                            </button>
                            <button class="tp-stage-card" data-stage="pe" type="button">
                                <span class="tp-stage-card__name">PE-backed</span>
                                <span class="tp-stage-card__range">25&ndash;40%</span>
                            </button>
                            <button class="tp-stage-card" data-stage="enterprise" type="button">
                                <span class="tp-stage-card__name">Enterprise</span>
                                <span class="tp-stage-card__range">18&ndash;32%</span>
                            </button>
                        </div>
                        <div class="tp-hint text-tiny">Sets benchmark ranges and zone thresholds for your growth stage.</div>
                    </div>

                    <div class="tp-section">
                        <span class="tp-sec-label label">Display currency</span>
                        <div class="tp-seg" data-seg="currency">
                            <button class="tp-seg__btn tp-seg__btn--active" data-currency="$" type="button">USD</button>
                            <button class="tp-seg__btn" data-currency="€" type="button">EUR</button>
                            <button class="tp-seg__btn" data-currency="£" type="button">GBP</button>
                            <button class="tp-seg__btn" data-currency="C$" type="button">CAD</button>
                            <button class="tp-seg__btn" data-currency="A$" type="button">AUD</button>
                        </div>
                        <div class="tp-hint text-tiny">Display only. All values remain in your local currency.</div>
                    </div>

                    <div class="tp-section">
                        <span class="tp-sec-label label">Revenue</span>
                        <div class="tp-field">
                            <label class="tp-field__label text-small" for="tp-arr">ARR or TTM Revenue <span class="tp-field__req">(required)</span></label>
                            <div class="tp-arr-quick" data-arr-quick>
                                <button class="tp-arr-chip" data-arr-val="10000000" type="button">$10M</button>
                                <button class="tp-arr-chip" data-arr-val="25000000" type="button">$25M</button>
                                <button class="tp-arr-chip" data-arr-val="50000000" type="button">$50M</button>
                                <button class="tp-arr-chip" data-arr-val="100000000" type="button">$100M</button>
                                <button class="tp-arr-chip" data-arr-val="250000000" type="button">$250M</button>
                            </div>
                            <div class="tp-input-wrap">
                                <span class="tp-input-pre">$</span>
                                <input type="text" id="tp-arr" data-input="arr" data-arr-display inputmode="numeric" placeholder="e.g. 12,500,000" autocomplete="off" />
                            </div>
                            <div class="tp-hint text-tiny">Annual recurring revenue or trailing twelve months. All benchmarks are expressed relative to this figure.</div>
                        </div>
                    </div>

                    <div class="tp-section">
                        <span class="tp-sec-label label">Revenue growth assumption</span>
                        <div class="tp-seg-row">
                            <div class="tp-seg" data-seg="growth">
                                <button class="tp-seg__btn" data-growth="10" type="button">10%</button>
                                <button class="tp-seg__btn" data-growth="20" type="button">20%</button>
                                <button class="tp-seg__btn" data-growth="30" type="button">30%</button>
                                <button class="tp-seg__btn" data-growth="50" type="button">50%</button>
                            </div>
                        </div>
                        <div class="tp-input-wrap">
                            <input type="number" id="tp-growth-custom" data-input="growthCustom" min="1" max="500" placeholder="Custom" class="tp-input--no-pre tp-input--has-suf" />
                            <span class="tp-input-suf">%</span>
                        </div>
                        <div class="tp-hint text-tiny">Used in trajectory projections. Does not affect current-period KPIs.</div>
                        <div class="tp-hint tp-hint--warn text-tiny" data-growth-warn style="display:none">Growth above 100% produces extreme trajectory projections. Verify this reflects your planning model.</div>
                    </div>

                    <div class="tp-field tp-exit-field" data-exit-field>
                        <label class="tp-field__label text-small" for="tp-exit-mult">Exit multiple assumption</label>
                        <div class="tp-arr-quick">
                            <button class="tp-arr-chip" data-preset-for="exitMult" data-preset-val="6" type="button">6×</button>
                            <button class="tp-arr-chip" data-preset-for="exitMult" data-preset-val="10" type="button">10×</button>
                            <button class="tp-arr-chip" data-preset-for="exitMult" data-preset-val="12" type="button">12×</button>
                            <button class="tp-arr-chip" data-preset-for="exitMult" data-preset-val="15" type="button">15×</button>
                            <button class="tp-arr-chip" data-preset-for="exitMult" data-preset-val="20" type="button">20×</button>
                        </div>
                        <div class="tp-input-wrap">
                            <input type="number" id="tp-exit-mult" data-input="exitMult" class="tp-input--no-pre tp-input--has-suf" min="1" max="30" value="12" />
                            <span class="tp-input-suf">&times;</span>
                        </div>
                        <div class="tp-hint text-tiny">Revenue multiple at exit. Used in exit value calculations.</div>
                    </div>

                    <div class="tp-nav-row">
                        <button class="tp-btn-next" data-action="go-costs" type="button">Enter technology costs &rarr;</button>
                    </div>
                </div>

                <!-- ── TAB: COSTS ────────────────────────────────────── -->
                <div class="tp-panel" data-panel="costs">
                    <div class="tp-panel__header">
                        <span class="tp-step label-small">Step 2 of 4</span>
                        <h2 class="tp-panel__title heading-md">Technology costs</h2>
                        <p class="tp-panel__sub text-small">Enter annual spend across each cost category. Infrastructure hosting is required. All others are optional and unlock additional KPIs.</p>
                    </div>

                    <!-- Mode toggle -->
                    <div class="tp-section">
                        <span class="tp-sec-label label">Input mode</span>
                        <div class="tp-seg" data-seg="mode">
                            <button class="tp-seg__btn tp-seg__btn--active" data-mode="quick" type="button">Quick</button>
                            <button class="tp-seg__btn" data-mode="deepdive" type="button">Deep Dive</button>
                        </div>
                        <div class="tp-hint text-tiny">Deep Dive breaks R&D into sub-categories and unlocks the revenue-per-engineer KPI.</div>
                    </div>

                    <!-- CapEx toggle -->
                    <label class="tp-capex-row" data-capex-row>
                        <input type="checkbox" data-input="gaapChk" />
                        <span class="tp-capex-row__label text-small">GAAP view: remove R&D CapEx from total (as capitalized on income statement)</span>
                    </label>

                    <!-- Infrastructure hosting -->
                    <div class="tp-section">
                        <span class="tp-sec-label label tp-sec-label--cat"><span class="tp-cat-dot tp-cat-dot--infra"></span>Infrastructure and hosting</span>
                        <div class="tp-field">
                            <label class="tp-field__label text-small" for="tp-infra">Monthly cloud spend <span class="tp-field__req">(required)</span></label>
                            <div class="tp-arr-quick">
                                <button class="tp-arr-chip" data-preset-for="infra" data-preset-val="5000" type="button">$5K</button>
                                <button class="tp-arr-chip" data-preset-for="infra" data-preset-val="15000" type="button">$15K</button>
                                <button class="tp-arr-chip" data-preset-for="infra" data-preset-val="50000" type="button">$50K</button>
                                <button class="tp-arr-chip" data-preset-for="infra" data-preset-val="150000" type="button">$150K</button>
                                <button class="tp-arr-chip" data-preset-for="infra" data-preset-val="500000" type="button">$500K</button>
                            </div>
                            <div class="tp-input-wrap">
                                <span class="tp-input-pre">$</span>
                                <input type="number" id="tp-infra" data-input="infra" min="0" step="1000" placeholder="0" />
                                <span class="tp-input-suf">/ mo</span>
                            </div>
                            <div class="tp-hint text-tiny">Cloud, data center, CDN, observability, managed services. Auto-converted to annual.</div>
                        </div>
                    </div>

                    <!-- Infrastructure personnel -->
                    <div class="tp-section">
                        <span class="tp-sec-label label tp-sec-label--cat"><span class="tp-cat-dot tp-cat-dot--pers"></span>Infrastructure personnel</span>
                        <div class="tp-field">
                            <label class="tp-field__label text-small" for="tp-infra-pers">Annual fully-loaded cost</label>
                            <div class="tp-arr-quick">
                                <button class="tp-arr-chip" data-preset-for="infraPers" data-preset-val="250000" type="button">$250K</button>
                                <button class="tp-arr-chip" data-preset-for="infraPers" data-preset-val="500000" type="button">$500K</button>
                                <button class="tp-arr-chip" data-preset-for="infraPers" data-preset-val="1000000" type="button">$1M</button>
                                <button class="tp-arr-chip" data-preset-for="infraPers" data-preset-val="2000000" type="button">$2M</button>
                                <button class="tp-arr-chip" data-preset-for="infraPers" data-preset-val="5000000" type="button">$5M</button>
                            </div>
                            <div class="tp-input-wrap">
                                <span class="tp-input-pre">$</span>
                                <input type="number" id="tp-infra-pers" data-input="infraPers" min="0" step="10000" placeholder="&#8212;" />
                            </div>
                            <div class="tp-hint text-tiny">DevOps, SRE, platform engineering, cloud architecture headcount.</div>
                        </div>
                    </div>

                    <!-- R&D OpEx -->
                    <div class="tp-section">
                        <span class="tp-sec-label label tp-sec-label--cat"><span class="tp-cat-dot tp-cat-dot--rd"></span>R&D OpEx</span>

                        <!-- Quick mode -->
                        <div data-rd-quick>
                            <div class="tp-field">
                                <label class="tp-field__label text-small" for="tp-rd-opex">Annual fully-loaded cost <span class="tp-field__req">(required)</span></label>
                                <div class="tp-arr-quick">
                                    <button class="tp-arr-chip" data-preset-for="rdOpEx" data-preset-val="1000000" type="button">$1M</button>
                                    <button class="tp-arr-chip" data-preset-for="rdOpEx" data-preset-val="3000000" type="button">$3M</button>
                                    <button class="tp-arr-chip" data-preset-for="rdOpEx" data-preset-val="5000000" type="button">$5M</button>
                                    <button class="tp-arr-chip" data-preset-for="rdOpEx" data-preset-val="10000000" type="button">$10M</button>
                                    <button class="tp-arr-chip" data-preset-for="rdOpEx" data-preset-val="25000000" type="button">$25M</button>
                                </div>
                                <div class="tp-input-wrap">
                                    <span class="tp-input-pre">$</span>
                                    <input type="number" id="tp-rd-opex" data-input="rdOpEx" min="0" step="100000" placeholder="0" />
                                </div>
                                <div class="tp-hint text-tiny">Engineering and product headcount plus tooling subscriptions. Annual fully-loaded.</div>
                            </div>
                        </div>

                        <!-- Deep Dive mode -->
                        <div class="tp-deep-wrap" data-rd-deep>
                            <div class="tp-deep-head label-small">R&D OpEx breakdown</div>
                            <div class="tp-field">
                                <label class="tp-field__label text-tiny" for="tp-rd-eng">Engineering headcount</label>
                                <div class="tp-arr-quick">
                                    <button class="tp-arr-chip" data-preset-for="rdEng" data-preset-val="500000" type="button">$500K</button>
                                    <button class="tp-arr-chip" data-preset-for="rdEng" data-preset-val="1000000" type="button">$1M</button>
                                    <button class="tp-arr-chip" data-preset-for="rdEng" data-preset-val="3000000" type="button">$3M</button>
                                    <button class="tp-arr-chip" data-preset-for="rdEng" data-preset-val="5000000" type="button">$5M</button>
                                    <button class="tp-arr-chip" data-preset-for="rdEng" data-preset-val="10000000" type="button">$10M</button>
                                </div>
                                <div class="tp-input-wrap">
                                    <span class="tp-input-pre">$</span>
                                    <input type="number" id="tp-rd-eng" data-input="rdEng" min="0" step="100000" placeholder="&#8212;" />
                                </div>
                                <div class="tp-hint text-tiny">Salaries, benefits, and contractor costs for software engineers. Annual fully-loaded.</div>
                            </div>
                            <div class="tp-field">
                                <label class="tp-field__label text-tiny" for="tp-rd-prod">Product headcount</label>
                                <div class="tp-arr-quick">
                                    <button class="tp-arr-chip" data-preset-for="rdProd" data-preset-val="250000" type="button">$250K</button>
                                    <button class="tp-arr-chip" data-preset-for="rdProd" data-preset-val="500000" type="button">$500K</button>
                                    <button class="tp-arr-chip" data-preset-for="rdProd" data-preset-val="1000000" type="button">$1M</button>
                                    <button class="tp-arr-chip" data-preset-for="rdProd" data-preset-val="2000000" type="button">$2M</button>
                                    <button class="tp-arr-chip" data-preset-for="rdProd" data-preset-val="5000000" type="button">$5M</button>
                                </div>
                                <div class="tp-input-wrap">
                                    <span class="tp-input-pre">$</span>
                                    <input type="number" id="tp-rd-prod" data-input="rdProd" min="0" step="100000" placeholder="&#8212;" />
                                </div>
                                <div class="tp-hint text-tiny">Product managers, designers, and QA. Annual fully-loaded.</div>
                            </div>
                            <div class="tp-field">
                                <label class="tp-field__label text-tiny" for="tp-rd-tool">Tooling and subscriptions</label>
                                <div class="tp-arr-quick">
                                    <button class="tp-arr-chip" data-preset-for="rdTool" data-preset-val="50000" type="button">$50K</button>
                                    <button class="tp-arr-chip" data-preset-for="rdTool" data-preset-val="100000" type="button">$100K</button>
                                    <button class="tp-arr-chip" data-preset-for="rdTool" data-preset-val="250000" type="button">$250K</button>
                                    <button class="tp-arr-chip" data-preset-for="rdTool" data-preset-val="500000" type="button">$500K</button>
                                    <button class="tp-arr-chip" data-preset-for="rdTool" data-preset-val="1000000" type="button">$1M</button>
                                </div>
                                <div class="tp-input-wrap">
                                    <span class="tp-input-pre">$</span>
                                    <input type="number" id="tp-rd-tool" data-input="rdTool" min="0" step="10000" placeholder="&#8212;" />
                                </div>
                                <div class="tp-hint text-tiny">IDEs, CI/CD, monitoring, SaaS dev tools, and license fees. Annual cost.</div>
                            </div>
                            <div class="tp-deep-sum text-small">R&D OpEx total: <span data-deep-total>&#8212;</span></div>
                        </div>

                        <div class="tp-field" data-fte-field>
                            <label class="tp-field__label text-tiny" for="tp-eng-fte">Engineering headcount (FTEs)</label>
                            <div class="tp-arr-quick">
                                <button class="tp-arr-chip" data-preset-for="engFTE" data-preset-val="5" type="button">5</button>
                                <button class="tp-arr-chip" data-preset-for="engFTE" data-preset-val="10" type="button">10</button>
                                <button class="tp-arr-chip" data-preset-for="engFTE" data-preset-val="25" type="button">25</button>
                                <button class="tp-arr-chip" data-preset-for="engFTE" data-preset-val="50" type="button">50</button>
                                <button class="tp-arr-chip" data-preset-for="engFTE" data-preset-val="100" type="button">100</button>
                            </div>
                            <div class="tp-input-wrap">
                                <input type="number" id="tp-eng-fte" data-input="engFTE" class="tp-input--no-pre" min="0" step="1" placeholder="&#8212;" />
                            </div>
                            <div class="tp-hint text-tiny">Unlocks revenue-per-engineer KPI.</div>
                        </div>
                    </div>

                    <!-- R&D CapEx -->
                    <div class="tp-section">
                        <span class="tp-sec-label label tp-sec-label--cat"><span class="tp-cat-dot tp-cat-dot--capex"></span>R&D CapEx</span>
                        <div class="tp-field">
                            <label class="tp-field__label text-small" for="tp-rd-capex">Annual capitalized software development</label>
                            <div class="tp-arr-quick">
                                <button class="tp-arr-chip" data-preset-for="rdCapEx" data-preset-val="500000" type="button">$500K</button>
                                <button class="tp-arr-chip" data-preset-for="rdCapEx" data-preset-val="1000000" type="button">$1M</button>
                                <button class="tp-arr-chip" data-preset-for="rdCapEx" data-preset-val="2000000" type="button">$2M</button>
                                <button class="tp-arr-chip" data-preset-for="rdCapEx" data-preset-val="5000000" type="button">$5M</button>
                                <button class="tp-arr-chip" data-preset-for="rdCapEx" data-preset-val="10000000" type="button">$10M</button>
                            </div>
                            <div class="tp-input-wrap">
                                <span class="tp-input-pre">$</span>
                                <input type="number" id="tp-rd-capex" data-input="rdCapEx" min="0" step="100000" placeholder="&#8212;" />
                            </div>
                            <div class="tp-hint text-tiny">Enables GAAP view toggle above and CapEx-of-R&D benchmark.</div>
                        </div>
                    </div>

                    <div class="tp-nav-row">
                        <button class="tp-btn-back" data-action="go-profile" type="button">&larr; Profile</button>
                        <button class="tp-btn-next" data-action="go-analysis" data-btn-analysis type="button" disabled>View analysis &rarr;</button>
                    </div>
                </div>

                <!-- ── TAB: ANALYSIS ─────────────────────────────────── -->
                <div class="tp-panel" data-panel="analysis">
                    <div class="tp-panel__header">
                        <span class="tp-step label-small">Step 3 of 4</span>
                        <h2 class="tp-panel__title heading-md">Analysis</h2>
                        <p class="tp-panel__sub text-small" data-analysis-sub>Technology cost structure benchmarked against stage-adjusted ranges.</p>
                    </div>

                    <!-- Empty state -->
                    <div class="tp-empty" data-analysis-empty>
                        <svg class="tp-empty__sym" width="64" height="64" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="6" stroke-linejoin="miter" aria-hidden="true"><path d="M12 52 L32 12 L52 52" fill="none"></path></svg>
                        <div class="tp-empty__msg text-small" data-analysis-empty-msg>Enter ARR on the Profile tab<br/>to compute TechPar.</div>
                        <button class="tp-empty__cta" data-action="go-profile" data-analysis-empty-cta type="button">Go to profile &rarr;</button>
                    </div>

                    <!-- Content -->
                    <div data-analysis-content class="tp-analysis-content">
                        <!-- Primary KPI -->
                        <div class="tp-kpi-hero" data-kpi-hero>
                            <div class="tp-kpi-hero__num" data-hero-num>&#8212;</div>
                            <div class="tp-kpi-hero__lbl text-small">total technology cost as % of revenue</div>
                            <div class="tp-kpi-hero__basis text-tiny" data-hero-basis></div>
                            <div class="tp-kpi-hero__zone-row">
                                <div data-hero-zone-pill></div>
                                <div class="tp-baseline-controls">
                                    <button class="tp-baseline-btn" data-action="set-baseline" type="button">Set as baseline</button>
                                    <div class="tp-baseline-bar" data-baseline-bar style="display:none">
                                        <span class="tp-baseline-bar__label label-small">Baseline</span>
                                        <button class="tp-baseline-bar__clear" data-action="clear-baseline" type="button">&times;</button>
                                    </div>
                                </div>
                            </div>
                            <div class="tp-bench-wrap">
                                <div class="tp-bench-track"><div class="tp-bench-fill" data-bench-fill></div></div>
                                <div class="tp-bench-lbls">
                                    <span class="tp-bench-lbl text-tiny">0%</span>
