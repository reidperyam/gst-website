    .tp-stage-card--active {
        border-color: var(--color-primary);
        background: var(--accent-light-bg);
    }

    .tp-stage-card--active .tp-stage-card__name {
        color: var(--color-primary);
    }

    .tp-stage-card--active .tp-stage-card__range {
        color: var(--color-primary);
    }

    .tp-stage-card:hover:not(.tp-stage-card--active) {
        border-color: var(--text-light-muted);
    }

    /* ── Segmented controls ───────────────────────────────────── */
    .tp-seg-row {
        display: flex;
        gap: var(--spacing-sm);
        flex-wrap: wrap;
        margin-bottom: var(--spacing-sm);
