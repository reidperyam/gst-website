    padding: var(--spacing-xs) var(--spacing-sm);
    background: none;
    border: none;
    border-left: 2px solid transparent;
    color: var(--text-muted);
    font-family: var(--font-family-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .tp-toolbar__reset:hover {
    color: var(--text-primary);
  }

  .tp-toolbar__reset--confirming {
    color: var(--color-error);
    border-left-color: var(--color-error);
    background: color-mix(in srgb, var(--color-error) 8%, transparent);
    animation: tp-confirm-pulse 0.3s ease-out;
  }

  @keyframes tp-confirm-pulse {
    0% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-3px);
    }
    50% {
      transform: translateX(3px);
    }
    75% {
      transform: translateX(-2px);
    }
    100% {
      transform: translateX(0);
    }
  }

  .tp-tab {
    flex: 1;
    min-width: 80px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xs);
    padding: var(--spacing-sm) var(--spacing-sm);
    cursor: pointer;
    border: none;
    background: transparent;
    color: var(--text-muted);
    border-bottom: 2px solid transparent;
    transition: all var(--transition-fast);
    white-space: nowrap;
    position: relative;
    font-family: var(--font-family-mono);
  }

  .tp-tab--active {
    color: var(--color-tertiary);
    border-bottom-color: var(--color-primary);
    background: var(--accent-light-bg);
  }

  .tp-tab:hover:not(.tp-tab--active) {
    color: var(--text-secondary);
  }

  .tp-tab__icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .tp-tab__label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  /* ── Panels ───────────────────────────────────────────────── */
  .tp-panel {
    display: none;
    max-width: 680px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  .tp-panel--active {
    display: block;
    animation: tp-fade-in 150ms ease-out;
  }

  @keyframes tp-fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .tp-panel__header {
    margin-bottom: var(--spacing-xl);
  }

  .tp-step {
    color: var(--color-tertiary);
    display: block;
    margin-bottom: var(--spacing-sm);
  }

  .tp-panel__title {
    margin-bottom: var(--spacing-sm);
  }

  .tp-panel__sub {
    color: var(--text-secondary);
    line-height: 1.65;
  }

  /* ── Sections & fields ────────────────────────────────────── */
  .tp-section {
    margin-bottom: var(--spacing-xl);
  }

  .tp-sec-label {
    display: block;
    border-bottom: 2px solid light-dark(var(--border-light), var(--border-dark-default));
    padding-bottom: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
