    .tp-seg {
        display: flex;
        border: 1px solid var(--text-light-muted);
        overflow: hidden;
        max-width: 280px;
    }

    .tp-seg__btn {
        flex: 1;
        padding: var(--spacing-sm) var(--spacing-lg);
        font-family: var(--font-family);
        font-size: var(--text-xs);
        color: var(--text-light-muted);
        background: transparent;
        border: none;
        border-right: 1px solid var(--text-light-muted);
        cursor: pointer;
        transition: all var(--transition-fast);
        text-align: center;
    }

    .tp-seg__btn:last-child {
        border-right: none;
    }

    .tp-seg__btn--active {
        background: var(--accent-light-bg);
        color: var(--color-primary);
    }

    .tp-seg__btn:hover:not(.tp-seg__btn--active) {
        color: var(--text-light-secondary);
    }

    /* ── Deep dive wrap ───────────────────────────────────────── */
    .tp-deep-wrap {
        display: none;
        background: var(--bg-light-alt);
        border: 1px solid var(--border-light);
        padding: var(--spacing-md);
        margin-bottom: var(--spacing-sm);
    }

    .tp-deep-wrap--on {
        display: block;
    }

    .tp-deep-head {
        color: var(--text-light-muted);
        margin-bottom: var(--spacing-sm);
    }

    .tp-deep-sum {
        color: var(--text-light-secondary);
        margin-top: var(--spacing-sm);
        padding-top: var(--spacing-sm);
        border-top: 1px solid var(--border-light);
    }

    .tp-deep-sum span {
        color: var(--color-primary);
    }

    /* ── CapEx toggle ─────────────────────────────────────────── */
    .tp-capex-row {
        display: none;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-sm) var(--spacing-sm);
        background: var(--bg-light-alt);
        border: 1px solid var(--border-light);
        margin-bottom: var(--spacing-lg);
        cursor: pointer;
    }

    .tp-capex-row--vis {
        display: flex;
    }

    .tp-capex-row input[type=checkbox] {
        accent-color: var(--color-primary);
        width: 14px;
        height: 14px;
        cursor: pointer;
        flex-shrink: 0;
    }

    /* ── Exit field visibility ────────────────────────────────── */
    .tp-exit-field {
        display: none;
    }

    .tp-exit-field--vis {
        display: block;
    }

    /* ── Navigation buttons ───────────────────────────────────── */
    .tp-nav-row {
        display: flex;
        gap: var(--spacing-sm);
        margin-top: var(--spacing-xl);
    }

    .tp-btn-next {
        flex: 1;
        padding: var(--spacing-md);
        background: var(--color-primary);
        color: var(--bg-dark);
        border: none;
        font-family: var(--font-family);
        font-size: var(--text-xs);
        font-weight: var(--font-weight-bold);
        cursor: pointer;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: background var(--transition-fast);
    }

    .tp-btn-next:hover {
        background: var(--color-primary-dark);
    }

    .tp-btn-next:disabled {
        opacity: 0.3;
        cursor: not-allowed;
    }

    .tp-btn-back {
        padding: var(--spacing-md) var(--spacing-xl);
        background: transparent;
        color: var(--text-light-secondary);
        border: 1px solid var(--border-light);
        font-family: var(--font-family);
        font-size: var(--text-xs);
        cursor: pointer;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        transition: all var(--transition-fast);
    }

    .tp-btn-back:hover {
        color: var(--text-light-primary);
        border-color: var(--text-light-muted);
    }

    /* ── Empty state ──────────────────────────────────────────── */
    .tp-empty {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 40vh;
        gap: var(--spacing-sm);
        text-align: center;
    }

    .tp-empty--hidden {
        display: none;
    }

    .tp-empty__sym {
        width: 64px;
        height: 64px;
        color: var(--text-light-muted);
    }

    .tp-empty__msg {
        color: var(--text-light-muted);
        line-height: 1.6;
    }

    .tp-empty__cta {
        margin-top: var(--spacing-sm);
        padding: var(--spacing-sm) var(--spacing-xl);
        border: 1px solid var(--color-primary);
        background: transparent;
        color: var(--color-primary);
        font-family: var(--font-family);
        font-size: var(--text-xs);
        cursor: pointer;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        transition: all var(--transition-fast);
    }

    .tp-empty__cta:hover {
        background: var(--accent-light-bg);
    }

    /* ── Analysis content ─────────────────────────────────────── */
    .tp-analysis-content {
        display: none;
    }

    .tp-analysis-content--on {
        display: block;
    }

    /* ── Primary KPI hero ─────────────────────────────────────── */
    .tp-kpi-hero {
        padding: var(--spacing-xl);
        background: var(--bg-light-alt);
        border: 1px solid var(--border-light);
        margin-bottom: var(--spacing-lg);
    }

    .tp-kpi-hero__num {
        font-size: 4.5rem;
        font-weight: var(--font-weight-bold);
        line-height: 1;
        transition: color var(--transition-fast);
    }

    .tp-kpi-hero__lbl {
        color: var(--text-light-secondary);
        margin-top: var(--spacing-xs);
    }

    .tp-kpi-hero__basis {
        margin-top: 2px;
    }

    /* Zone pill */
    /* Zone pill is injected via innerHTML */
    .tp-kpi-hero :global(.tp-zone-pill) {
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-xs) var(--spacing-md);
        font-size: var(--text-xs);
        letter-spacing: 0.05em;
        border: 1px solid;
        margin-top: var(--spacing-sm);
    }

    .tp-kpi-hero :global(.tp-zone-dot) {
        width: 5px;
        height: 5px;
        border-radius: 50%;
    }

    /* Benchmark bar */
    .tp-bench-wrap {
        margin-top: var(--spacing-lg);
    }

    .tp-bench-track {
        height: 3px;
        background: var(--bg-light-alt);
        position: relative;
        border-radius: 2px;
    }

    .tp-bench-fill {
        position: absolute;
        height: 100%;
        top: 0;
        left: 0;
        transition: width var(--transition-slow), background var(--transition-fast);
        border-radius: 2px;
    }

    .tp-bench-lbls {
        display: flex;
        justify-content: space-between;
        margin-top: var(--spacing-xs);
    }

    .tp-bench-lbl {
        color: var(--text-light-muted);
    }

    .tp-bench-mid {
        color: var(--color-primary);
    }

    /* ── Signal card ──────────────────────────────────────────── */
    .tp-signal {
        padding: var(--spacing-lg);
        border: 1px solid var(--border-light);
        background: var(--bg-light-alt);
        margin-bottom: var(--spacing-lg);
    }

    .tp-signal__stage {
        color: var(--text-light-muted);
        margin-bottom: 2px;
    }

    .tp-signal__zone {
        margin-bottom: var(--spacing-sm);
    }

    .tp-signal__head {
        line-height: 1.3;
        margin-bottom: var(--spacing-sm);
    }

    .tp-signal__body {
        color: var(--text-light-secondary);
        line-height: 1.7;
    }

    .tp-signal__div {
        height: 1px;
        background: var(--border-light);
        margin: var(--spacing-md) 0;
    }

    /* Signal metrics are injected via innerHTML */
    .tp-signal :global(.tp-sig-met) {
        margin-bottom: var(--spacing-sm);
    }

    .tp-signal :global(.tp-sig-met:last-child) {
        margin-bottom: 0;
    }

    .tp-signal :global(.tp-sig-mlbl) {
        font-size: var(--text-xs);
        letter-spacing: 0.07em;
        text-transform: uppercase;
        color: var(--text-light-muted);
        margin-bottom: var(--spacing-xs);
    }

    .tp-signal :global(.tp-sig-mval) {
        font-size: var(--text-2xl);
        font-weight: var(--font-weight-semibold);
        line-height: 1;
    }

    .tp-signal :global(.tp-sig-msub) {
        font-size: var(--text-xs);
        color: var(--text-light-muted);
        margin-top: var(--spacing-xs);
    }

    .tp-signal :global(.tp-sig-note) {
        font-size: var(--text-xs);
        color: var(--text-light-secondary);
        line-height: 1.7;
    }

    /* ── KPI grid ─────────────────────────────────────────────── */
    .tp-kpi-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: var(--spacing-sm);
        margin-bottom: var(--spacing-xl);
    }

    /* KPI cells are injected via innerHTML — use :global for children */
    .tp-kpi-grid :global(.tp-kpi-cell) {
        border: 1px solid var(--border-light);
        padding: var(--spacing-md);
        display: flex;
        flex-direction: column;
    }

    .tp-kpi-grid :global(.tp-kpi-cell--highlight) {
        grid-column: 1 / -1;
        background: var(--bg-light-alt);
        border-left: 3px solid var(--color-primary);
        padding: var(--spacing-lg);
    }

    .tp-kpi-grid :global(.tp-kpi-cell--highlight .tp-kpi-val) {
        font-size: var(--text-2xl);
    }

    .tp-kpi-grid :global(.tp-kpi-lbl) {
        font-size: 10px;
        color: var(--text-light-muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: var(--font-weight-bold);
        line-height: 1;
        margin-bottom: var(--spacing-sm);
    }

    .tp-kpi-grid :global(.tp-kpi-val) {
        font-size: var(--text-lg);
        font-weight: var(--font-weight-semibold);
        line-height: 1;
        color: var(--text-light-primary);
        margin-bottom: var(--spacing-xs);
    }

    .tp-kpi-grid :global(.tp-kpi-val--pos) { color: var(--techpar-kpi-positive); }
    .tp-kpi-grid :global(.tp-kpi-val--warn) { color: var(--techpar-kpi-warn); }
    .tp-kpi-grid :global(.tp-kpi-val--bad) { color: var(--techpar-kpi-negative); }

    .tp-kpi-grid :global(.tp-kpi-sub) {
        font-size: 10px;
        color: var(--text-light-muted);
        line-height: 1.3;
        margin-top: auto;
        padding-top: var(--spacing-xs);
        border-top: 1px solid var(--border-light);
    }

    .tp-kpi-grid :global(.tp-kpi-cell--highlight .tp-kpi-sub) {
        border-top: none;
        padding-top: 0;
    }

    /* ── Category bars ────────────────────────────────────────── */
    .tp-cat-section {
        display: none;
        margin-bottom: var(--spacing-lg);
    }

    .tp-cat-section--on {
        display: block;
    }

    .tp-cat-head {
        margin-bottom: var(--spacing-md);
    }

    /* Category bar rows are injected via innerHTML */
    .tp-cat-section :global(.tp-cat-row) {
        margin-bottom: var(--spacing-md);
    }

    .tp-cat-section :global(.tp-cat-row:last-child) {
        margin-bottom: 0;
    }

    .tp-cat-section :global(.tp-cat-meta) {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: var(--spacing-xs);
    }

    .tp-cat-section :global(.tp-cat-name) {
        font-size: var(--text-xs);
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
    }

    .tp-cat-section :global(.tp-cat-pct) {
        font-size: var(--text-xs);
        font-weight: var(--font-weight-semibold);
    }

    .tp-cat-section :global(.tp-cat-bench) {
        font-size: var(--text-xs);
        color: var(--text-light-muted);
    }

    .tp-cat-section :global(.tp-cat-track) {
        height: 5px;
        background: var(--bg-light-alt);
        position: relative;
        border-radius: 3px;
        overflow: hidden;
    }

    .tp-cat-section :global(.tp-cat-band) {
        position: absolute;
        height: 100%;
        background: var(--techpar-chart-band-fill);
    }

    .tp-cat-section :global(.tp-cat-fill) {
        position: absolute;
        height: 100%;
        top: 0;
        left: 0;
        border-radius: 3px;
        transition: width var(--transition-slow);
    }

    /* ── Benchmark table ──────────────────────────────────────── */
    .tp-bench-table-wrap {
        margin-bottom: var(--spacing-lg);
    }

    .tp-bench-table-head {
        color: var(--color-primary);
        margin-bottom: var(--spacing-sm);
    }

    .tp-btbl {
        width: 100%;
        border-collapse: collapse;
    }

    .tp-btbl td {
        padding: var(--spacing-sm);
        font-size: var(--text-xs);
        border-bottom: 1px solid var(--border-light);
        color: var(--text-light-secondary);
    }

    .tp-btbl td:last-child {
        text-align: right;
    }

    .tp-btbl tr.tp-btbl--active td {
        background: var(--accent-light-bg);
    }

    .tp-btbl tr.tp-btbl--active td:last-child {
        color: var(--color-primary);
    }

    .tp-bench-disc {
        color: var(--text-light-muted);
        margin-top: var(--spacing-sm);
        line-height: 1.5;
    }

    /* ── Context callout ──────────────────────────────────────── */
    .tp-ctx {
        border-left: 2px solid var(--color-primary);
        background: var(--accent-light-bg);
        padding: var(--spacing-sm) var(--spacing-md);
        font-size: var(--text-xs);
        color: var(--text-light-secondary);
        line-height: 1.7;
        margin-bottom: 0;
    }

    /* ── Trajectory ───────────────────────────────────────────── */
    .tp-traj-content {
        display: none;
    }

    .tp-traj-content--on {
        display: block;
    }

    .tp-traj-note {
        font-size: var(--text-xs);
        color: var(--text-light-muted);
        line-height: 1.6;
        padding: var(--spacing-sm) var(--spacing-md);
        background: var(--bg-light-alt);
        border-left: 2px solid var(--text-light-muted);
        margin-bottom: var(--spacing-lg);
    }

    .tp-traj-note--convergence {
        border-color: var(--color-primary);
        color: var(--text-light-secondary);
    }

    .tp-traj-chart-wrap {
        position: relative;
        height: min(42vh, 320px);
        margin-bottom: var(--spacing-sm);
    }

    .tp-traj-dot {
        position: absolute;
        width: 13px;
        height: 13px;
        border-radius: 50%;
        border: 2px solid var(--bg-light);
        transform: translate(-50%, -50%);
        pointer-events: none;
        z-index: 5;
        display: none;
        transition: left var(--transition-slow), top var(--transition-slow);
    }

    .tp-traj-legend {
        display: flex;
        gap: var(--spacing-md);
        flex-wrap: wrap;
        margin-bottom: var(--spacing-lg);
    }

    /* Trajectory legend items are injected via innerHTML */
    .tp-traj-legend :global(.tp-tleg) {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        font-size: var(--text-xs);
        color: var(--text-light-secondary);
    }

    .tp-traj-legend :global(.tp-tleg__sw) {
        width: 14px;
        height: 8px;
        border-radius: 1px;
        flex-shrink: 0;
    }

    /* ── Responsive ───────────────────────────────────────────── */
    @media (min-width: 640px) {
        .tp-kpi-grid {
            grid-template-columns: repeat(3, 1fr);
        }

        .tp-kpi-grid :global(.tp-kpi-cell--highlight) {
            grid-column: 1 / -1;
        }
    }

    @media (max-width: 768px) {
        .tp-stage-grid {
            grid-template-columns: repeat(3, 1fr);
        }

        .tp-input-wrap,
        .tp-seg {
            max-width: 100%;
        }
    }

    @media (max-width: 480px) {
        .tp-stage-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .tp-kpi-hero__num {
            font-size: 3rem;
        }

        .tp-traj-chart-wrap {
            height: min(42vh, 280px);
        }

        .tp-nav-row {
            position: sticky;
            bottom: 0;
            z-index: 8;
            background: var(--bg-light);
            padding: var(--spacing-sm) 0 var(--spacing-md);
            border-top: 1px solid var(--border-light);
            flex-direction: column-reverse;
            gap: var(--spacing-sm);
        }

        .tp-btn-next,
        .tp-btn-back {
            width: 100%;
            justify-content: center;
            min-height: 48px;
        }

        .tp-tab__label {
            font-size: 0.6rem;
        }
    }
</style>

<script>
    import { Chart, registerables } from 'chart.js';
    import { compute, buildTrajectory, zoneColorVar, zoneBgVar, zoneLabel, kpiClass, formatDollars, formatPercent } from '../../../../utils/techpar-engine';
    import type { TechParInputs, TechParResult, StageConfig } from '../../../../utils/techpar-engine';
    import { STAGES } from '../../../../data/techpar/stages';
    import { SIGNAL_COPY } from '../../../../data/techpar/signal-copy';

    Chart.register(...registerables);

    // ─── State ─────────────────────────────────────────────────
    let stageKey = 'series_bc';
    let growthRate = 20;
    let mode: 'quick' | 'deepdive' = 'quick';
    let trajChart: Chart | null = null;

    // ─── DOM helpers ───────────────────────────────────────────
    const $$ = (sel: string) => document.querySelectorAll(sel);
    const g = (attr: string) => document.querySelector(`[data-${attr}]`) as HTMLElement | null;

    function getInput(name: string): number {
        const el = document.querySelector(`[data-input="${name}"]`) as HTMLInputElement | null;
        const raw = el?.value?.replace(/,/g, '') || '';
        return parseFloat(raw) || 0;
    }

    function getStyle(varName: string): string {
        return getComputedStyle(document.documentElement).getPropertyValue(varName).trim();
    }

    // ─── Tab navigation ────────────────────────────────────────
    function goTab(tab: string) {
        $$('.tp-tab').forEach(t => t.classList.remove('tp-tab--active'));
        $$('.tp-panel').forEach(p => p.classList.remove('tp-panel--active'));
        document.querySelector(`.tp-tab[data-tab="${tab}"]`)?.classList.add('tp-tab--active');
        document.querySelector(`[data-panel="${tab}"]`)?.classList.add('tp-panel--active');
        document.querySelector('[data-tab-bar]')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
        if (tab === 'trajectory') {
            const result = runCompute();
            if (result) renderTrajectory(result);
        }
    }

    // Tab button clicks
    $$('.tp-tab').forEach(btn => {
        btn.addEventListener('click', () => {
            goTab((btn as HTMLElement).dataset.tab || 'profile');
        });
    });

    // Navigation action buttons
    document.querySelectorAll('[data-action]').forEach(btn => {
        btn.addEventListener('click', () => {
            const action = (btn as HTMLElement).dataset.action;
            if (action === 'go-costs') goTab('costs');
            else if (action === 'go-profile') goTab('profile');
            else if (action === 'go-analysis') goTab('analysis');
            else if (action === 'go-trajectory') goTab('trajectory');
            else if (action === 'reset') resetAll();
        });
    });

    // ─── Reset ──────────────────────────────────────────────────
    function resetAll() {
        // Clear all inputs
        document.querySelectorAll<HTMLInputElement>('.techpar-shell input').forEach(el => {
            if (el.type === 'checkbox') el.checked = false;
            else if (el.dataset.input === 'exitMult') el.value = '12';
            else el.value = '';
        });

        // Reset JS state to defaults
        stageKey = 'series_bc';
        growthRate = 20;
        mode = 'quick';

        // Reset stage cards
        $$('.tp-stage-card').forEach(c => c.classList.remove('tp-stage-card--active'));
        document.querySelector('[data-stage="series_bc"]')?.classList.add('tp-stage-card--active');

        // Reset growth buttons and custom input
        $$('[data-growth]').forEach(b => b.classList.remove('tp-seg__btn--active'));
        document.querySelector('[data-growth="20"]')?.classList.add('tp-seg__btn--active');
        const growthCustomEl = document.getElementById('tp-growth-custom') as HTMLInputElement | null;
        if (growthCustomEl) growthCustomEl.value = '20';

        // Reset mode toggle
        $$('[data-mode]').forEach(b => b.classList.remove('tp-seg__btn--active'));
        document.querySelector('[data-mode="quick"]')?.classList.add('tp-seg__btn--active');
        const rdQuick = g('rd-quick');
        const rdDeep = g('rd-deep');
        if (rdQuick) rdQuick.style.display = 'block';
        if (rdDeep) rdDeep.classList.remove('tp-deep-wrap--on');

        // Reset deep-dive sum
        const deepTotal = g('deep-total');
        if (deepTotal) deepTotal.innerHTML = '\u2014';

        // Clear ARR chip highlights
        document.querySelectorAll('.tp-arr-chip').forEach(c => c.classList.remove('tp-arr-chip--active'));

        // Destroy trajectory chart
        if (trajChart) { trajChart.destroy(); trajChart = null; }

        // Re-run update and go to profile tab
        updateAll();
        goTab('profile');
    }

    // ─── Stage selector ────────────────────────────────────────
    $$('.tp-stage-card').forEach(card => {
        card.addEventListener('click', () => {
            $$('.tp-stage-card').forEach(c => c.classList.remove('tp-stage-card--active'));
            card.classList.add('tp-stage-card--active');
            stageKey = (card as HTMLElement).dataset.stage || 'series_bc';
            if (trajChart) { trajChart.destroy(); trajChart = null; }
            updateAll();
        });
    });

    // ─── Growth rate selector ──────────────────────────────────
    const growthCustomInput = document.getElementById('tp-growth-custom') as HTMLInputElement | null;
    if (growthCustomInput) growthCustomInput.value = String(growthRate);

    $$('[data-growth]').forEach(btn => {
        btn.addEventListener('click', () => {
            $$('[data-growth]').forEach(b => b.classList.remove('tp-seg__btn--active'));
            btn.classList.add('tp-seg__btn--active');
            growthRate = parseInt((btn as HTMLElement).dataset.growth || '20', 10);
            if (growthCustomInput) growthCustomInput.value = String(growthRate);
            updateAll();
        });
    });

    // ─── Growth rate custom input ──────────────────────────────
    growthCustomInput?.addEventListener('input', () => {
        const val = parseFloat(growthCustomInput.value);
        if (!isNaN(val) && val > 0) {
            $$('[data-growth]').forEach(b => b.classList.remove('tp-seg__btn--active'));
            growthRate = val;
            updateAll();
        }
    });

    // ─── Mode toggle ───────────────────────────────────────────
    $$('[data-mode]').forEach(btn => {
        btn.addEventListener('click', () => {
            $$('[data-mode]').forEach(b => b.classList.remove('tp-seg__btn--active'));
            btn.classList.add('tp-seg__btn--active');
            mode = ((btn as HTMLElement).dataset.mode || 'quick') as 'quick' | 'deepdive';
            const rdQuick = g('rd-quick');
            const rdDeep = g('rd-deep');
            if (rdQuick) rdQuick.style.display = mode === 'quick' ? 'block' : 'none';
            if (rdDeep) rdDeep.classList.toggle('tp-deep-wrap--on', mode === 'deepdive');
            updateAll();
        });
    });

    // ─── Deep Dive sum ─────────────────────────────────────────
    function sumDeep() {
        const sum = getInput('rdEng') + getInput('rdProd') + getInput('rdTool');
        const el = g('deep-total');
        if (el) el.innerHTML = sum > 0 ? `<span>${formatDollars(sum)}</span>` : '\u2014';
        updateAll();
    }

    ['rdEng', 'rdProd', 'rdTool'].forEach(name => {
        document.querySelector(`[data-input="${name}"]`)?.addEventListener('input', sumDeep);
    });

    // ─── All other inputs ──────────────────────────────────────
    ['infra', 'infraPers', 'rdOpEx', 'rdCapEx', 'engFTE', 'exitMult', 'gaapChk'].forEach(name => {
        const el = document.querySelector(`[data-input="${name}"]`);
        if (el) el.addEventListener(el.getAttribute('type') === 'checkbox' ? 'change' : 'input', updateAll);
    });

    // ─── ARR: comma formatting + quick-pick chips ─────────────
    const arrInput = document.getElementById('tp-arr') as HTMLInputElement | null;
    const arrChips = document.querySelectorAll<HTMLButtonElement>('[data-arr-val]');

    function formatWithCommas(n: number): string {
        return n.toLocaleString('en-US');
    }

    function setArrValue(val: number) {
        if (!arrInput) return;
        arrInput.value = val > 0 ? formatWithCommas(val) : '';
        arrInput.dispatchEvent(new Event('input', { bubbles: true }));
    }

    function syncArrChips() {
        const current = getInput('arr');
        arrChips.forEach(chip => {
            const chipVal = Number(chip.dataset.arrVal);
            chip.classList.toggle('tp-arr-chip--active', chipVal === current && current > 0);
        });
    }

    arrChips.forEach(chip => {
        chip.addEventListener('click', () => {
            const val = Number(chip.dataset.arrVal);
            const current = getInput('arr');
            // Toggle off if same value clicked again
            setArrValue(val === current ? 0 : val);
            syncArrChips();
        });
    });

    if (arrInput) {
        arrInput.addEventListener('input', () => {
            const raw = arrInput.value.replace(/[^0-9]/g, '');
            const num = parseInt(raw, 10);
            if (raw && !isNaN(num)) {
                // Preserve cursor position relative to end
                const distFromEnd = arrInput.value.length - (arrInput.selectionStart || 0);
                arrInput.value = formatWithCommas(num);
                const newPos = Math.max(0, arrInput.value.length - distFromEnd);
                arrInput.setSelectionRange(newPos, newPos);
            } else if (!raw) {
                arrInput.value = '';
            }
            syncArrChips();
            updateAll();
        });
    }

    // ─── Cost preset chips ────────────────────────────────────
    document.querySelectorAll<HTMLButtonElement>('[data-preset-for]').forEach(chip => {
        chip.addEventListener('click', () => {
            const inputName = chip.dataset.presetFor!;
            const val = Number(chip.dataset.presetVal);
            const input = document.querySelector(`[data-input="${inputName}"]`) as HTMLInputElement | null;
            if (!input) return;
            const current = parseFloat(input.value) || 0;
            input.value = val === current ? '' : String(val);
            // Sync chip highlights for this input group
            document.querySelectorAll<HTMLButtonElement>(`[data-preset-for="${inputName}"]`).forEach(c => {
                c.classList.toggle('tp-arr-chip--active', Number(c.dataset.presetVal) === (val === current ? 0 : val));
            });
            input.dispatchEvent(new Event('input', { bubbles: true }));
        });
    });

    // ─── Build inputs from DOM ─────────────────────────────────
    function buildInputs(): TechParInputs {
        const gaapEl = document.querySelector('[data-input="gaapChk"]') as HTMLInputElement | null;
        return {
            arr: getInput('arr'),
            stage: stageKey as TechParInputs['stage'],
            mode,
            capexView: gaapEl?.checked ? 'gaap' : 'cash',
            growthRate,
            exitMultiple: getInput('exitMult') || 12,
            infraHosting: getInput('infra'),
            infraPersonnel: getInput('infraPers'),
            rdOpEx: getInput('rdOpEx'),
            rdCapEx: getInput('rdCapEx'),
            engFTE: getInput('engFTE'),
            engCost: getInput('rdEng'),
            prodCost: getInput('rdProd'),
            toolingCost: getInput('rdTool'),
        };
    }

    function runCompute() {
        return compute(buildInputs());
    }

    // ─── Main update ───────────────────────────────────────────
    function updateAll() {
        const inputs = buildInputs();
        const r = compute(inputs);

        // Exit field visibility
        const showExit = stageKey === 'pe' || stageKey === 'enterprise';
        g('exit-field')?.classList.toggle('tp-exit-field--vis', showExit);

        // CapEx toggle visibility
        const hasCapEx = getInput('rdCapEx') > 0;
        g('capex-row')?.classList.toggle('tp-capex-row--vis', hasCapEx);
        if (!hasCapEx) {
            const chk = document.querySelector('[data-input="gaapChk"]') as HTMLInputElement;
            if (chk) chk.checked = false;
        }

        // Analysis button
        const btnAnalysis = document.querySelector('[data-btn-analysis]') as HTMLButtonElement;
        if (btnAnalysis) btnAnalysis.disabled = !r;

        // Tab completion — teal bottom border on done tabs
        const profileDone = inputs.arr > 0;
        const costsDone = r !== null;
        document.querySelector('[data-tab="profile"]')?.classList.toggle('tp-tab--done', profileDone);
        document.querySelector('[data-tab="costs"]')?.classList.toggle('tp-tab--done', costsDone);

        // Analysis badge
        const analysisAlert = r && (r.zone === 'above' || r.zone === 'elevated' || r.zone === 'critical');
        document.querySelector('[data-badge="analysis"]')?.classList.toggle('tp-tab__badge--on', !!analysisAlert);

        if (!r) {
            // Show empty states
            g('analysis-empty')?.classList.remove('tp-empty--hidden');
            g('analysis-content')?.classList.remove('tp-analysis-content--on');
            g('traj-empty')?.classList.remove('tp-empty--hidden');
            g('traj-content')?.classList.remove('tp-traj-content--on');
            if (trajChart) { trajChart.destroy(); trajChart = null; }
            return;
        }

        // Show content
        g('analysis-empty')?.classList.add('tp-empty--hidden');
        g('analysis-content')?.classList.add('tp-analysis-content--on');
        g('traj-empty')?.classList.add('tp-empty--hidden');
        g('traj-content')?.classList.add('tp-traj-content--on');

        renderAnalysis(r);
        // Only render trajectory if that tab is active
        if (document.querySelector('[data-panel="trajectory"]')?.classList.contains('tp-panel--active')) {
            renderTrajectory(r);
        }
    }

    // ─── Analysis render ───────────────────────────────────────
    function renderAnalysis(r: TechParResult) {
        const zoneCol = getStyle(zoneColorVar(r.zone));
        const zoneBg = getStyle(zoneBgVar(r.zone));
        const s = r.stageConfig;
        const gaapEl = document.querySelector('[data-input="gaapChk"]') as HTMLInputElement;
        const isGAAP = gaapEl?.checked ?? false;

        // Hero number
        const heroNum = g('hero-num');
        if (heroNum) {
            heroNum.textContent = formatPercent(r.totalTechPct);
            heroNum.style.color = zoneCol;
        }

        // Basis label
        const heroBasis = g('hero-basis');
        if (heroBasis) {
            heroBasis.textContent = isGAAP ? 'GAAP basis: R&D CapEx excluded' : 'Cash basis';
            heroBasis.style.color = isGAAP ? getStyle('--techpar-zone-above') : '';
        }

        // Zone pill
        const pillContainer = g('hero-zone-pill');
        if (pillContainer) {
            pillContainer.innerHTML = `<div class="tp-zone-pill" style="border-color:${zoneCol};background:${zoneBg};color:${zoneCol}"><span class="tp-zone-dot" style="background:${zoneCol}"></span>${zoneLabel(r.zone)}</div>`;
        }

        // Benchmark bar
        const maxB = s.zones.critical * 1.2;
        const bw = Math.min(r.totalTechPct / maxB * 100, 100);
        const benchFill = g('bench-fill');
        if (benchFill) {
            benchFill.style.width = `${bw}%`;
            benchFill.style.background = zoneCol;
        }
        const mid = (s.zones.lo + s.zones.hi) / 2;
        const benchMid = g('bench-mid');
        if (benchMid) benchMid.textContent = `\u25BC ${mid.toFixed(0)}% midpoint`;
        const benchMax = g('bench-max');
        if (benchMax) benchMax.textContent = maxB.toFixed(0) + '%';

        // Benchmark table active row
        $$('[data-bench-row]').forEach(tr => {
            tr.classList.toggle('tp-btbl--active', (tr as HTMLElement).dataset.benchRow === stageKey);
        });

        // Signal card
        const copy = SIGNAL_COPY[stageKey as TechParInputs['stage']]?.[r.zone];
        const sigStage = g('sig-stage');
        if (sigStage) sigStage.textContent = s.label;
        const sigZone = g('sig-zone');
        if (sigZone) { sigZone.textContent = zoneLabel(r.zone); sigZone.style.color = zoneCol; }
        const sigHead = g('sig-head');
        if (sigHead) { sigHead.textContent = copy?.headline || ''; sigHead.style.color = zoneCol; }
        const sigBody = g('sig-body');
        if (sigBody) sigBody.textContent = copy?.body || '';
        const sigMets = g('sig-mets');
        if (sigMets) sigMets.innerHTML = buildMetrics(r, zoneCol, s);

        // KPI grid
        const kpiGrid = g('kpi-grid');
        if (kpiGrid) {
            let cells = '';
            const kc = (l: string, v: string, sub: string, cls: string = '') =>
                `<div class="tp-kpi-cell"><div class="tp-kpi-lbl">${l}</div><div class="tp-kpi-val${cls ? ' tp-kpi-val--' + cls : ''}">${v}</div>${sub ? `<div class="tp-kpi-sub">${sub}</div>` : ''}</div>`;

            cells += `<div class="tp-kpi-cell tp-kpi-cell--highlight"><div class="tp-kpi-lbl">Annual tech cost</div><div class="tp-kpi-val">${formatDollars(r.total)}</div><div class="tp-kpi-sub">${isGAAP ? 'GAAP' : 'cash basis'}</div></div>`;
            cells += kc('Infra hosting', formatPercent(r.kpis.infraHostingPct), `bench ${s.benchmarks.infraHosting[0]}\u2013${s.benchmarks.infraHosting[1]}%`, kpiClass(r.kpis.infraHostingPct, s.benchmarks.infraHosting[0], s.benchmarks.infraHosting[1]));
            if (r.kpis.infraPersonnelPct !== null) cells += kc('Infra personnel', formatPercent(r.kpis.infraPersonnelPct), `bench ${s.benchmarks.infraPersonnel[0]}\u2013${s.benchmarks.infraPersonnel[1]}%`, kpiClass(r.kpis.infraPersonnelPct, s.benchmarks.infraPersonnel[0], s.benchmarks.infraPersonnel[1]));
            if (r.kpis.rdOpExPct !== null) cells += kc('R&D OpEx', formatPercent(r.kpis.rdOpExPct), `bench ${s.benchmarks.rdOpEx[0]}\u2013${s.benchmarks.rdOpEx[1]}%`, kpiClass(r.kpis.rdOpExPct, s.benchmarks.rdOpEx[0], s.benchmarks.rdOpEx[1]));
            if (r.kpis.rdCapExPct !== null) cells += kc('R&D CapEx % rev', formatPercent(r.kpis.rdCapExPct), 'capitalized dev');
            if (r.kpis.rdCapExOfRD !== null) cells += kc('CapEx of total R&D', formatPercent(r.kpis.rdCapExOfRD), `bench ${s.benchmarks.rdCapExOfRD[0]}\u2013${s.benchmarks.rdCapExOfRD[1]}%`);
            cells += kc('Blended infra', formatPercent(r.kpis.blendedInfra), 'hosting + personnel');
            if (r.kpis.revenuePerEngineer !== null) cells += kc('Revenue / engineer', formatDollars(r.kpis.revenuePerEngineer), 'ARR per engineering FTE');
            if (r.kpis.engPctOfRD !== null) cells += kc('Engineering % R&D', formatPercent(r.kpis.engPctOfRD), '');
            if (r.kpis.prodPctOfRD !== null) cells += kc('Product % R&D', formatPercent(r.kpis.prodPctOfRD), '');
            kpiGrid.innerHTML = cells;
        }

        // Category bars
        const catSection = g('cat-section');
        const catBars = g('cat-bars');
        if (catSection && catBars) {
            if (r.categories.length >= 2) {
                catSection.classList.add('tp-cat-section--on');
                let bHtml = '';
                r.categories.forEach(cat => {
                    const catCol = getStyle(cat.colorVar);
                    const pct = cat.pctArr;
                    const benchHi = cat.benchmarkHi > 0 ? cat.benchmarkHi : pct * 1.5;
                    const maxV = Math.max(pct, benchHi) * 1.2;
                    const fw = Math.min(pct / maxV * 100, 100);
                    const bx = cat.benchmarkLo > 0 ? cat.benchmarkLo / maxV * 100 : 0;
                    const bw = cat.benchmarkHi > 0 ? (cat.benchmarkHi - cat.benchmarkLo) / maxV * 100 : 0;
                    bHtml += `<div class="tp-cat-row">
                        <div class="tp-cat-meta">
                            <div class="tp-cat-name"><span class="tp-cat-dot" style="width:7px;height:7px;border-radius:50%;background:${catCol}"></span>${cat.label}</div>
                            <div style="display:flex;align-items:baseline;gap:var(--spacing-sm)">
                                <span class="tp-cat-pct" style="color:${catCol}">${formatPercent(pct)}</span>
                                ${cat.benchmarkHi > 0 ? `<span class="tp-cat-bench">bench ${cat.benchmarkLo}\u2013${cat.benchmarkHi}%</span>` : ''}
                            </div>
                        </div>
                        <div class="tp-cat-track">
                            ${cat.benchmarkHi > 0 ? `<div class="tp-cat-band" style="left:${bx}%;width:${bw}%"></div>` : ''}
                            <div class="tp-cat-fill" style="width:${fw}%;background:${catCol}"></div>
                        </div>
                    </div>`;
                });
                catBars.innerHTML = bHtml;
            } else {
                catSection.classList.remove('tp-cat-section--on');
            }
        }

        // Context block
        const exitMult = getInput('exitMult') || 12;
        const annualImpact = r.stageConfig.key === 'seed' ? 0 : buildInputs().arr * 0.01 * exitMult;
        const ctxBlock = g('ctx-block');
        if (ctxBlock) {
            ctxBlock.innerHTML = `For PE-backed and enterprise companies, total technology cost above the healthy ceiling translates directly to EBITDA compression and exit value. At a <strong style="color:var(--text-light-primary)">${exitMult}&times;</strong> revenue multiple, each 1% of ARR in excess technology spend represents <strong style="color:var(--color-primary)">${formatDollars(annualImpact)}</strong> in exit value per year.`;
        }
    }

    function buildMetrics(r: TechParResult, col: string, s: StageConfig): string {
        let h = '';
        if (r.zone === 'underinvest') {
            h = `<div class="tp-sig-met"><div class="tp-sig-mlbl">Investment to healthy floor: 36 months</div>
                <div class="tp-sig-mval" style="color:${col}">${formatDollars(r.gap.underinvestGap)}</div></div>`;
        } else if (r.zone === 'ahead') {
            h = `<div class="tp-sig-met"><div class="tp-sig-mlbl">Annual advantage vs ${s.zones.hi}% ceiling</div>
                <div class="tp-sig-mval" style="color:${col}">${formatDollars(r.gap.annualAdvantage)}</div></div>`;
        } else if (r.zone !== 'healthy') {
            h = `<div class="tp-sig-met"><div class="tp-sig-mlbl">Excess above ${s.zones.hi}% ceiling: 36 months</div>
                <div class="tp-sig-mval" style="color:${col}">${formatDollars(r.gap.cumulative36)}</div></div>`;
            if (s.frame === 'dollars') {
                const exitMult = getInput('exitMult') || 12;
                h += `<div class="tp-sig-met" style="margin-top:var(--spacing-sm)"><div class="tp-sig-mlbl">Exit value at ${exitMult}&times;</div>
                    <div class="tp-sig-mval" style="color:var(--color-primary)">${formatDollars(r.gap.exitValue)}</div>
                    <div class="tp-sig-msub">recoverable through optimization</div></div>`;
            } else {
                h += `<div class="tp-sig-met" style="margin-top:var(--spacing-sm);padding-top:var(--spacing-sm);border-top:1px solid var(--border-light)">
                    <div class="tp-sig-note">At ${s.label}, trajectory matters more than the current number. The key question is whether this ratio declines as revenue scales.</div></div>`;
            }
        }
        return h;
    }

    // ─── Trajectory render ─────────────────────────────────────
    function renderTrajectory(r: TechParResult) {
        const s = r.stageConfig;
        const zoneCol = getStyle(zoneColorVar(r.zone));

        // Note banner
        const note = g('traj-note');
        if (note) {
            note.className = 'tp-traj-note' + (s.frame === 'convergence' ? ' tp-traj-note--convergence' : '');
            note.textContent = s.note;
        }

        // Trajectory signal card
        const copy = SIGNAL_COPY[stageKey as TechParInputs['stage']]?.[r.zone];
        const tsStage = g('ts-stage');
        if (tsStage) tsStage.textContent = s.label;
        const tsZone = g('ts-zone');
        if (tsZone) { tsZone.textContent = zoneLabel(r.zone); tsZone.style.color = zoneCol; }
        const tsHead = g('ts-head');
        if (tsHead) { tsHead.textContent = copy?.headline || ''; tsHead.style.color = zoneCol; }
        const tsBody = g('ts-body');
        if (tsBody) tsBody.textContent = copy?.body || '';
        const tsMets = g('ts-mets');
        if (tsMets) tsMets.innerHTML = buildMetrics(r, zoneCol, s);

        // Build chart data
        const inputs = buildInputs();
        const traj = buildTrajectory(inputs, s);

        if (trajChart) { trajChart.destroy(); trajChart = null; }

        const canvas = document.querySelector('[data-traj-canvas]') as HTMLCanvasElement;
        if (!canvas) return;

        const bandFill = getStyle('--techpar-chart-band-fill');
        const bandBorder = getStyle('--techpar-chart-band-border');
        const underFill = getStyle('--techpar-chart-under-fill');
        const revLineCol = getStyle('--techpar-chart-revenue-line');
        const txtMuted = getStyle('--text-light-muted');
        const borderLight = getStyle('--border-light');
        const bgLight = getStyle('--bg-light-alt');

        const datasets: any[] = [
            { label: '_z', data: Array(37).fill(0), borderColor: 'transparent', borderWidth: 0, pointRadius: 0, fill: false },
            { label: '_uf', data: traj.underFloor, borderColor: `${getStyle('--techpar-zone-underinvest')}4d`, borderWidth: 1, borderDash: [3, 3], pointRadius: 0, fill: { target: '-1', above: underFill, below: 'transparent' }, tension: 0.3 },
            { label: '_blo', data: traj.bandLo, borderColor: 'transparent', borderWidth: 0, pointRadius: 0, fill: false, tension: 0.3 },
            { label: 'Healthy range', data: traj.bandHi, borderColor: bandBorder, borderWidth: 1, borderDash: [4, 3], pointRadius: 0, fill: { target: '-1', above: bandFill, below: 'transparent' }, tension: 0.3 },
            { label: 'Total tech cost', data: traj.spend, borderColor: zoneCol, borderWidth: 2, pointRadius: 0, fill: false, tension: 0.3 },
        ];

        if (s.frame === 'convergence') {
            datasets.push({
                label: 'Monthly revenue',
                data: traj.revenue,
                borderColor: revLineCol,
                borderWidth: 1,
                borderDash: [2, 4],
                pointRadius: 0,
                fill: false,
                tension: 0.3,
            });
        }

        const maxY = Math.max(...traj.spend, ...traj.bandHi, ...(s.frame === 'convergence' ? traj.revenue : [])) * 1.12;

        trajChart = new Chart(canvas.getContext('2d')!, {
            type: 'line',
            data: { labels: traj.labels, datasets },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: { duration: 320, easing: 'easeInOutCubic' },
                plugins: {
                    legend: {
                        display: true,
                        labels: {
                            color: txtMuted,
                            font: { family: getStyle('--font-family') || "'Helvetica Neue', Arial, sans-serif", size: 9 },
                            boxWidth: 8,
                            padding: 10,
                            filter: (item: any) => !item.text.startsWith('_'),
                        },
                    },
                    tooltip: {
                        backgroundColor: bgLight,
                        titleColor: getStyle('--text-light-primary'),
                        bodyColor: txtMuted,
                        borderColor: borderLight,
                        borderWidth: 1,
                        padding: 8,
                        titleFont: { family: getStyle('--font-family') || "'Helvetica Neue', Arial, sans-serif", size: 9 },
                        bodyFont: { family: getStyle('--font-family') || "'Helvetica Neue', Arial, sans-serif", size: 9 },
                        filter: (item: any) => !item.dataset.label.startsWith('_'),
                        callbacks: {
                            title: (c: any) => `Month ${c[0].dataIndex}`,
                            label: (c: any) => `${c.dataset.label}: ${formatDollars(c.parsed.y)}/mo`,
                        },
                    },
                },
                scales: {
                    x: {
                        grid: { color: borderLight + '33', lineWidth: 0.5 },
                        ticks: { color: txtMuted, font: { family: getStyle('--font-family') || "'Helvetica Neue', Arial, sans-serif", size: 9 }, maxTicksLimit: 7 },
                    },
                    y: {
                        min: 0,
                        max: maxY,
                        grid: { color: borderLight + '33', lineWidth: 0.5 },
                        ticks: {
                            color: txtMuted,
                            font: { family: getStyle('--font-family') || "'Helvetica Neue', Arial, sans-serif", size: 9 },
                            callback: (v: any) => formatDollars(v as number),
                        },
                    },
                },
            },
        });

        // User position dot
        setTimeout(() => {
            if (!trajChart) return;
            const meta = trajChart.getDatasetMeta(4);
            if (meta?.data?.[0]) {
                const pt = meta.data[0];
                const dot = document.querySelector('[data-traj-dot]') as HTMLElement;
                if (dot) {
                    dot.style.background = zoneCol;
                    dot.style.boxShadow = `0 0 0 5px ${zoneCol}33`;
                    dot.style.left = pt.x + 'px';
                    dot.style.top = pt.y + 'px';
                    dot.style.display = 'block';
                }
            }
        }, 60);

        // Legend
        const legItems = [
            { sw: `background:${underFill};border:1px solid ${getStyle('--techpar-zone-underinvest')}66`, l: 'Underinvestment zone' },
            { sw: `background:${bandFill};border:1px solid ${bandBorder}`, l: `Healthy range (${s.zones.lo}\u2013${s.zones.hi}%)` },
            { sw: `background:transparent;border:2px solid ${zoneCol};border-radius:50%;width:9px;height:9px`, l: 'Your position today' },
        ];
        if (s.frame === 'convergence') {
            legItems.push({ sw: `background:transparent;border-top:1px dashed ${revLineCol}`, l: 'Monthly revenue' });
        }
        const legend = g('traj-legend');
        if (legend) {
            legend.innerHTML = legItems.map(x =>
                `<div class="tp-tleg"><div class="tp-tleg__sw" style="${x.sw}"></div>${x.l}</div>`
            ).join('');
        }
    }

    // ─── Init ──────────────────────────────────────────────────
    updateAll();
</script>
</BaseLayout>
