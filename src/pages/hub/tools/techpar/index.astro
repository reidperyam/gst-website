        top: 50%;
        transform: translateY(-50%);
        font-size: var(--text-sm);
        color: var(--text-light-muted);
        pointer-events: none;
        z-index: 1;
    }

    .tp-input-suf {
        position: absolute;
        right: var(--spacing-sm);
        top: 50%;
        transform: translateY(-50%);
        font-size: var(--text-sm);
        color: var(--text-light-muted);
        pointer-events: none;
    }

    .techpar-shell input[type=number],
    .techpar-shell input[data-arr-display] {
        width: 100%;
        background: var(--bg-light-alt);
        border: 1px solid var(--border-light);
        color: var(--text-light-primary);
        font-family: var(--font-family);
        font-size: var(--text-sm);
        padding: var(--spacing-sm) var(--spacing-sm) var(--spacing-sm) var(--spacing-xl);
        outline: none;
        transition: border-color var(--transition-fast);
        -moz-appearance: textfield;
        border-radius: 0;
    }

    .techpar-shell input[type=number]::-webkit-inner-spin-button {
        -webkit-appearance: none;
    }

    .techpar-shell input[type=number]:focus,
    .techpar-shell input[data-arr-display]:focus {
        border-color: var(--color-primary);
    }

    .techpar-shell input[type=number].tp-input--no-pre {
        padding-left: var(--spacing-sm);
    }

    .techpar-shell input[type=number].tp-input--has-suf {
        padding-right: var(--spacing-2xl);
    }

    /* ── ARR quick-pick chips ──────────────────────────────────── */
    .tp-arr-quick {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-xs);
        margin-bottom: var(--spacing-sm);
    }

    .tp-arr-chip {
        background: var(--bg-light-alt);
        border: 1px solid var(--border-light);
        color: var(--text-light-secondary);
        font-family: var(--font-family);
        font-size: var(--text-xs);
        padding: var(--spacing-xs) var(--spacing-sm);
        cursor: pointer;
        transition: all var(--transition-fast);
        white-space: nowrap;
    }

    .tp-arr-chip:hover {
        border-color: var(--color-primary);
        color: var(--color-primary);
    }

    .tp-arr-chip--active {
        background: var(--color-primary);
        border-color: var(--color-primary);
        color: var(--bg-dark);
    }

    .tp-arr-chip--active:hover {
        background: var(--color-primary);
        border-color: var(--color-primary);
        color: var(--bg-dark);
    }

    /* ── Stage grid ───────────────────────────────────────────── */
    .tp-stage-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: var(--spacing-sm);
        margin-bottom: var(--spacing-lg);
