        .tp-traj-legend :global(.tp-tleg-group--zones) {
            display: grid;
            grid-template-columns: 1fr 1fr;
        }

        .tp-nav-row {
            position: sticky;
            bottom: 0;
            z-index: 8;
            background: var(--bg-light);
            padding: var(--spacing-sm) 0 var(--spacing-md);
            border-top: 1px solid var(--border-light);
            flex-direction: column-reverse;
            gap: var(--spacing-sm);
        }

        .tp-btn-next,
        .tp-btn-back {
            width: 100%;
            justify-content: center;
            min-height: 48px;
        }

        .tp-tab__label {
            font-size: 0.6rem;
        }

        .tp-nav-row__actions {
            flex-wrap: wrap;
        }

        .tp-btn-share {
            min-height: 40px;
        }
    }

    /* ─── Print stylesheet ─────────────────────────────────── */
    @media print {
        /* ── Hide interactive chrome ─────────────────────────────── */
        .site-header,
        .tp-tab-bar,
        .tp-nav-row,
        .tp-arr-chip,
        [data-preset-for],
        .tp-empty,
        .tp-btn-next,
        .tp-btn-back,
        .tp-btn-share,
        .tp-baseline-controls,
        .tp-scenario-list,
        .tp-cross-link,
        .tp-bench-wrap,
        .hub-header__back,
        .hub-header__sub,
