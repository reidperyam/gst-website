        from { opacity: 0; }
        to   { opacity: 1; }
    }

    .tp-panel__header {
        margin-bottom: var(--spacing-xl);
    }

    .tp-step {
        color: var(--color-primary);
        display: block;
        margin-bottom: var(--spacing-sm);
    }

    .tp-panel__title {
        margin-bottom: var(--spacing-sm);
    }

    .tp-panel__sub {
        color: var(--text-light-secondary);
        line-height: 1.65;
    }

    /* ── Sections & fields ────────────────────────────────────── */
    .tp-section {
        margin-bottom: var(--spacing-xl);
    }

    .tp-sec-label {
        display: block;
        border-bottom: 1px solid var(--border-light);
        padding-bottom: var(--spacing-sm);
        margin-bottom: var(--spacing-lg);
    }

    .tp-sec-label--cat {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
    }

    .tp-cat-dot {
