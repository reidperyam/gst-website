---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import HubHeader from '../../../../components/hub/HubHeader.astro';
import { trackPageView } from '../../../../utils/analytics';
import { DOMAINS, TOTAL_QUESTIONS } from '../../../../data/infrastructure-cost-governance/domains';

trackPageView('infrastructure-cost-governance', 'Infrastructure Cost Governance | GST');

const domainCount = DOMAINS.length;
---

<BaseLayout
  title="Infrastructure Cost Governance | GST"
  description="A structured maturity assessment for cloud cost management. Answer 20 questions across six operational domains and receive a scored diagnostic with a prioritized improvement checklist."
  ogTitle="Infrastructure Cost Governance | GST"
  ogDescription="Cloud cost maturity assessment for PE diligence, board reviews, and 100-day planning. Score your cloud spend governance across six operational domains."
  ogImage="/og-image.png"
  ogImageAlt="Infrastructure Cost Governance Maturity Assessment"
  ogUrl="https://globalstrategic.tech/hub/tools/infrastructure-cost-governance"
>
  <script
    is:inline
    type="application/ld+json"
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: 'Infrastructure Cost Governance',
      description:
        'Cloud cost maturity assessment across six operational domains for PE diligence, board reviews, and 100-day planning',
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Web',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      publisher: { '@type': 'Organization', name: 'Global Strategic Technologies' },
      datePublished: '2026-03-01',
      dateModified: '2026-03-21',
      featureList: [
        '20 questions across 6 cloud cost domains',
        'Scored diagnostic with benchmarks',
        'Prioritized improvement checklist',
        'Shareable results for board reviews',
      ],
      author: {
        '@type': 'Person',
        name: 'Reid Peryam',
        jobTitle: 'Strategic Technology Advisor',
        sameAs: ['https://www.linkedin.com/in/reidperyam/'],
        description:
          'Technology advisor with experience across 100+ PE technology diligence engagements',
        knowsAbout: [
          'Cloud Cost Optimization',
          'Infrastructure Governance',
          'FinOps',
          'Technical Due Diligence',
          'M&A Tech Strategy',
        ],
      },
    })}
  />

  <section class="icg-section">
    <div class="container">
      <HubHeader
        title="Infrastructure Cost Governance"
        subtitle="A structured maturity assessment for cloud cost management. Answer 20 questions across six operational domains and receive a scored diagnostic with a prioritized improvement checklist. Scoring model informed by cloud cost governance patterns across PE portfolio companies."
      />

      <div data-icg class="brutal-tool-shell brutal-tool-shell--narrow icg-shell">
        <!-- ── Landing view (step 0) ─────────────────────────────── -->
        <div data-view="landing" class="icg-view">
          <div class="landing-content">
            <div class="brutal-callout landing-callout">
              <span class="brutal-callout__title landing-callout__title"
                >Who should complete this assessment.</span
              >
              This tool takes 5 to 7 minutes. Domains 3 through 6 require familiarity with cloud infrastructure.
              PE investors and executives should complete this alongside their engineering lead, or send
              them the link directly.
            </div>

            <div class="stats-row">
              <div class="brutal-stat-tile">
                <div class="brutal-stat-tile__value">{domainCount}</div>
                <div class="brutal-stat-tile__label">domains</div>
              </div>
              <div class="brutal-stat-tile">
                <div class="brutal-stat-tile__value">{TOTAL_QUESTIONS}</div>
                <div class="brutal-stat-tile__label">questions</div>
              </div>
              <div class="brutal-stat-tile">
                <div class="brutal-stat-tile__value">5-7 min</div>
                <div class="brutal-stat-tile__label">to complete</div>
              </div>
            </div>

            <div class="icg-stage-selector">
              <span class="icg-stage-selector__label brutal-label"
                >Company stage <span class="icg-stage-optional brutal-text-tiny">(optional)</span
                ></span
              >
              <div class="icg-stage-grid" data-stage-grid>
                <button
                  class="brutal-option-card brutal-option-card--compact"
                  data-stage="pre-series-b"
                  type="button">Pre-Series B</button
                >
                <button
                  class="brutal-option-card brutal-option-card--compact"
                  data-stage="series-bc"
                  type="button">Series B-C</button
                >
                <button
                  class="brutal-option-card brutal-option-card--compact"
                  data-stage="pe-backed"
                  type="button">PE-backed 2+ yr</button
                >
                <button
                  class="brutal-option-card brutal-option-card--compact"
                  data-stage="enterprise"
                  type="button">Enterprise</button
                >
              </div>
              <div class="icg-stage-hint brutal-text-tiny">
                Sets benchmark context for your results. You can skip this.
              </div>
            </div>

            <div data-resume-prompt class="brutal-callout icg-resume-prompt is-hidden">
              <p class="brutal-text-small icg-resume-prompt__text">
                You have an incomplete assessment saved from a previous session.
              </p>
              <div class="icg-resume-actions">
                <button data-action="resume" type="button" class="brutal-btn brutal-btn--secondary"
                  >Resume</button
                >
                <button data-action="discard" type="button" class="brutal-btn brutal-btn--secondary"
                  >Start fresh</button
                >
              </div>
            </div>

            <button
              data-action="start"
              type="button"
              class="brutal-btn brutal-btn--primary brutal-btn--full icg-btn-primary--full"
              >Begin assessment</button
            >

            <div class="tool-action-bar tool-action-bar--center">
              <button
                data-action="landing-copy"
                type="button"
                class="brutal-btn brutal-btn--secondary"
                title="Copy a shareable link to this assessment">Copy link</button
              >
              <a
                data-action="landing-email"
                href="#"
                class="brutal-btn brutal-btn--secondary"
                title="Open a pre-filled email inviting your engineering lead to complete the assessment"
                >Send to engineering lead</a
              >
            </div>
          </div>
        </div>

        <!-- ── Wizard view (steps 1-6) ───────────────────────────── -->
        <div data-view="wizard" class="icg-view is-hidden">
          <div class="wizard-content">
            <!-- Progress bar -->
            <div class="brutal-progress-bar icg-progress">
              <div class="brutal-progress-bar__track icg-progress__track">
                <div class="brutal-progress-bar__fill icg-progress__fill" data-progress-fill></div>
              </div>
              <span class="brutal-progress-bar__label icg-progress__label" data-progress-label
              ></span>
            </div>

            <!-- Domain header -->
            <div class="icg-domain-header">
              <div class="icg-domain-header__meta">
                <span class="brutal-label icg-domain-label" data-domain-label></span>
                <span class="icg-foundational-badge is-hidden" data-foundational-badge
                  >foundational</span
                >
              </div>
              <h2 class="brutal-heading-md icg-domain-name" data-domain-name></h2>
              <p class="brutal-text-small icg-domain-desc" data-domain-desc></p>
              <p class="brutal-text-small icg-foundational-note is-hidden" data-foundational-note>
                This is a foundational domain. Scores here affect how results in later sections
                should be interpreted.
              </p>
            </div>

            <!-- Questions container -->
            <div data-questions-container class="icg-questions"></div>

            <!-- Navigation -->
            <div class="icg-wizard-nav">
              <button data-action="back" type="button" class="brutal-btn brutal-btn--secondary"
                >Back to intro</button
              >
              <button
                data-action="next"
                type="button"
                class="brutal-btn brutal-btn--primary"
                disabled>Next domain</button
              >
            </div>
          </div>
        </div>

        <!-- ── Results view (step 7) ─────────────────────────────── -->
        <div data-view="results" class="icg-view is-hidden">
          <div class="results-content">
            <!-- Maturity score -->
            <div class="icg-score-display" data-score-display>
              <div data-gauge-container class="icg-gauge"></div>
              <div class="icg-score-level brutal-heading-md" data-score-level></div>
              <div class="icg-score-desc brutal-text-small" data-score-desc></div>
              <div class="icg-stage-context brutal-text-small is-hidden" data-stage-context></div>
              <div class="icg-skipped-note brutal-text-tiny is-hidden" data-skipped-note></div>
            </div>

            <!-- Foundational flag (conditional) -->
            <div
              class="brutal-callout brutal-callout--warning icg-foundational-warning is-hidden"
              data-foundational-warning
            >
              <div
                class="brutal-callout__title icg-foundational-warning__title"
                data-foundational-warning-title
              >
              </div>
              <div
                class="icg-foundational-warning__text brutal-text-small"
                data-foundational-warning-text
              >
              </div>
            </div>

            <!-- Quick wins -->
            <div data-quick-wins class="brutal-callout icg-quick-wins is-hidden"></div>

            <!-- Radar chart -->
            <div class="icg-card">
              <div class="brutal-tool-shell__section-label">Domain profile</div>
              <div data-radar-chart class="icg-radar"></div>
            </div>

            <!-- Domain breakdown -->
            <div class="icg-card">
              <div class="brutal-tool-shell__section-label">Domain breakdown</div>
              <div data-domain-bars class="icg-domain-bars"></div>
            </div>

            <!-- Benchmark reference -->
            <div class="icg-card">
              <div class="brutal-tool-shell__section-label">Benchmark reference</div>
              <table class="brutal-bench-table">
                <tbody data-benchmark-body>
                  <tr data-stage-row="pre-series-b"
                    ><td>Pre-Series B / high-growth startup</td><td data-bench="15-35">15-35</td
                    ></tr
                  >
                  <tr data-stage-row="series-bc"
                    ><td>Series B-C SaaS, scaling team</td><td data-bench="30-55">30-55</td></tr
                  >
                  <tr data-stage-row="pe-backed"
                    ><td>PE-backed portco, 2+ years post-acquisition</td><td data-bench="45-70"
                      >45-70</td
                    ></tr
                  >
                  <tr data-stage-row="enterprise"
                    ><td>Enterprise with established FinOps practice</td><td data-bench="65-90"
                      >65-90</td
                    ></tr
                  >
                </tbody>
              </table>
              <div class="tool-bench-note brutal-text-tiny">
                Ranges reflect illustrative patterns from GST diligence and value creation
                engagements. Individual results vary based on team maturity and infrastructure
                complexity.
              </div>
            </div>

            <!-- Cost context -->
            <div class="brutal-callout icg-cost-context">
              <div class="brutal-text-small">
                Cloud infrastructure as a percentage of revenue varies widely by company stage,
                business model, and architecture. Early-stage companies often run above 30 percent
                while scaling ahead of revenue. Mature SaaS businesses may converge below 10
                percent. <strong>The trend matters more than the number</strong> - assess whether spend
                is moving in the right direction relative to revenue growth and whether the governance
                practices above are in place to sustain that trajectory.
              </div>
            </div>

            <!-- Recommendations -->
            <div data-recs-container class="icg-recs"></div>

            <!-- Actions row -->
            <div
              class="tool-action-bar tool-action-bar--center tool-action-bar--bordered tool-action-bar--stack"
            >
              <button
                data-action="copy-summary"
                type="button"
                class="brutal-btn brutal-btn--secondary"
                title="Copy a plain-text summary of your results to clipboard">Copy summary</button
              >
              <button
                data-action="copy"
                type="button"
                class="brutal-btn brutal-btn--secondary"
                title="Copy a shareable link that preserves your answers and dismissed recommendations"
                >Copy link</button
              >
              <button
                data-action="export-json"
                type="button"
                class="brutal-btn brutal-btn--secondary"
                title="Download your results as a structured JSON file for portfolio aggregation"
                >Download JSON</button
              >
              <button
                data-action="print"
                type="button"
                class="brutal-btn brutal-btn--secondary"
                title="Your browser will open a print dialog. Select Save as PDF to download."
                >Print / Save as PDF</button
              >
              <a
                data-action="email"
                href="#"
                class="brutal-btn brutal-btn--secondary"
                title="Open a pre-filled email with your results link. The recipient can complete the assessment independently."
                >Send to engineering lead</a
              >
              <button
                data-action="compare"
                type="button"
                class="brutal-btn brutal-btn--secondary is-hidden"
                title="Compare saved snapshots side by side">Compare</button
              >
              <button
                data-action="review"
                type="button"
                class="brutal-btn brutal-btn--secondary"
                title="Review your answers across all six domains">Review answers</button
              >
              <button data-action="reset" type="button" class="brutal-btn brutal-btn--secondary"
                >Start over</button
              >
            </div>

            <!-- Snapshot save -->
            <div class="icg-snapshot-save-row">
              <input
                data-snapshot-label
                type="text"
                class="brutal-input icg-snapshot-label-input"
                placeholder="Label (e.g., 90-day review)"
                maxlength="60"
              />
              <button
                data-action="save-snapshot"
                type="button"
                class="brutal-btn brutal-btn--secondary">Save snapshot</button
              >
            </div>

            <!-- Snapshot manager -->
            <div data-snapshot-manager class="icg-snapshot-manager is-hidden">
              <div class="brutal-tool-shell__section-label">Saved snapshots</div>
              <div data-snapshot-list class="icg-snapshot-list-items"></div>
              <button
                data-action="clear-snapshots"
                type="button"
                class="brutal-btn brutal-btn--secondary icg-snapshot-clear"
                >Clear all snapshots</button
              >
            </div>
          </div>
        </div>

        <!-- ── Comparison view ────────────────────────────────────── -->
        <div data-view="comparison" class="icg-view is-hidden">
          <div class="comparison-content">
            <div class="brutal-tool-shell__section-label">Snapshot comparison</div>
            <div data-comparison-body class="icg-comparison-body"></div>
            <div class="icg-comparison-actions">
              <button
                data-action="back-to-results"
                type="button"
                class="brutal-btn brutal-btn--secondary">Back to results</button
              >
            </div>
          </div>
        </div>

        <!-- ── Methodology ─────────────────────────────────────────── -->
        <details class="tool-methodology tool-methodology--delta">
          <summary class="tool-methodology__trigger">How the assessment works</summary>
          <div class="tool-methodology__body">
            <h4 class="tool-methodology__heading">Scoring model</h4>
            <p>
              Each of the 20 questions is scored on a four-point scale: Not in place (0), Ad hoc
              (1), Established (2), Optimized (3). Domain scores are the percentage of points earned
              out of the maximum possible for that domain.
            </p>

            <h4 class="tool-methodology__heading">Domain weighting</h4>
            <p>
              Foundational domains (Visibility and Tagging, Account Structure and Attribution) carry
              1.5&times; weight in the overall score. The remaining four domains carry 1.0&times;
              weight. This reflects the principle that visibility and attribution are prerequisites
              for effective optimization.
            </p>

            <h4 class="tool-methodology__heading">Maturity levels</h4>
            <p>
              The overall score maps to four maturity levels: Reactive (0&ndash;25), Aware
              (26&ndash;50), Optimizing (51&ndash;75), and Strategic (76&ndash;100).
            </p>

            <h4 class="tool-methodology__heading">FinOps Foundation alignment</h4>
            <p>
              The maturity levels map loosely to the FinOps Foundation&rsquo;s Crawl-Walk-Run
              framework. Reactive and Aware correspond to the Crawl phase, where organizations are
              building foundational visibility. Optimizing aligns with Walk, where active management
              is in place. Strategic maps to Run, where cost governance is embedded in engineering
              culture. For more on the framework, see <a
                href="https://www.finops.org/framework/"
                target="_blank"
                rel="noopener noreferrer">finops.org/framework</a
              >.
            </p>

            <h4 class="tool-methodology__heading">Foundational flag</h4>
            <p>
              If either foundational domain scores at or below 33%, a warning is surfaced. Low
              foundational scores indicate that higher-level optimization practices may be
              unreliable because the organization cannot see or attribute its spend.
            </p>

            <h4 class="tool-methodology__heading">Recommendations</h4>
            <p>
              Recommendations are triggered when a question scores at or below a defined threshold.
              They are sorted by impact tier (high, medium, low) and can be dismissed as not
              applicable. Dismissed items are excluded from the printed report.
            </p>

            <h4 class="tool-methodology__heading">Benchmarks</h4>
            <p>
              The benchmark ranges reflect illustrative patterns from GST diligence and value
              creation engagements. Individual results depend on company stage, team maturity, and
              infrastructure complexity.
            </p>

            <h4 class="tool-methodology__heading">Snapshots and comparison</h4>
            <p>
              After completing an assessment, click Save snapshot to store your results in your
              browser. Up to three snapshots are kept; saving a fourth removes the oldest. Once you
              have two or more snapshots, a Compare button appears. It shows the two most recent
              snapshots side by side with per-domain score deltas. Use this to track governance
              improvements over time, for example between initial diligence and a 90-day
              post-acquisition review. Snapshots are stored in your browser only and can be cleared
              from the snapshot manager below the action buttons.
            </p>

            <h4 class="tool-methodology__heading">Privacy</h4>
            <p>
              All calculations run entirely in your browser&mdash;no inputs are sent to our servers.
              Anonymous page-view and interaction analytics (Google Analytics 4) help us improve the
              tool. See our <a href="/privacy">privacy policy</a> for details.
            </p>

            <p class="tool-methodology__updated">Methodology last updated March 2026</p>

            <div class="tool-methodology__author">
              <span class="tool-methodology__author-name">Reid Peryam</span>
              <span class="tool-methodology__author-sep">&middot;</span>
              <span>Strategic Technology Advisor</span>
              <span class="tool-methodology__author-sep">&middot;</span>
              <span>100+ PE technology diligence engagements</span>
              <span class="tool-methodology__author-sep">&middot;</span>
              <a
                href="https://www.linkedin.com/in/reidperyam/"
                target="_blank"
                rel="noopener noreferrer"
                class="tool-methodology__author-link">LinkedIn</a
              >
            </div>
          </div>
        </details>
      </div>

      <a href="/hub/tools" class="brutal-btn brutal-btn--secondary icg-back-link">Return to Tools</a
      >
    </div>
  </section>
</BaseLayout>

<style>
  /* ── Page wrapper ─────────────────────────────────────────────────────── */
  .icg-section {
    padding-bottom: var(--spacing-3xl);
  }

  /* ── Tool shell — base styles provided by global .tool-shell + .tool-shell--narrow ── */

  /* .icg-shell retained for ICG-specific overrides only */

  /* ── View toggling ────────────────────────────────────────────────────── */
  .is-hidden {
    display: none;
  }

  /* ── Landing view ─────────────────────────────────────────────────────── */
  .landing-content {
    max-width: 560px;
    margin: 0 auto;
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  .wizard-content {
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  .results-content {
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  .comparison-content {
    padding: var(--spacing-xl) var(--spacing-lg);
  }

  /* .landing-callout — layout overrides only; visual treatment from .brutal-callout */
  .landing-callout {
    margin-bottom: var(--spacing-xl);
  }

  .landing-content > .tool-action-bar {
    margin-top: var(--spacing-md);
    gap: var(--spacing-md);
  }

  /* ── Resume prompt — layout overrides only; visual treatment from .brutal-callout ── */
  .icg-resume-prompt {
    margin-bottom: var(--spacing-lg);
  }

  .icg-resume-prompt__text {
    margin-bottom: var(--spacing-md);
  }

  .icg-resume-actions {
    display: flex;
    gap: var(--spacing-sm);
  }

  .icg-resume-actions .brutal-btn {
    flex: 1;
  }

  .stats-row {
    display: flex;
    gap: var(--gap-normal);
    margin-bottom: var(--spacing-xl);
  }

  /* stat-tile — visual treatment from global .brutal-stat-tile; no scoped overrides needed */

  /* ── Button overrides (base styles from global .brutal-btn) ────────── */
  .icg-btn-primary--full {
    padding: var(--spacing-md) 0;
  }

  /* ── Progress bar — layout overrides only; visual treatment from .brutal-progress-bar ── */
  .icg-progress {
    margin-bottom: var(--spacing-xl);
  }

  /* ── Domain header ────────────────────────────────────────────────────── */
  .icg-domain-header {
    margin-bottom: var(--spacing-xl);
  }

  .icg-domain-header__meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-xs);
  }

  .icg-domain-label {
    color: var(--color-primary);
  }

  .icg-foundational-badge {
    font-size: 0.6rem;
    font-weight: var(--font-weight-bold);
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 1px var(--spacing-sm);
    border: 1px solid var(--color-primary);
    background: transparent;
    color: var(--color-primary);
  }

  .icg-domain-name {
    margin-bottom: var(--spacing-xs);
  }

  .icg-domain-desc {
    color: var(--text-secondary);
  }

  .icg-foundational-note {
    color: var(--text-muted);
    font-style: italic;
    margin-top: var(--spacing-sm);
  }

  /* ── Question cards (injected via innerHTML — must use :global) ────── */
  .icg-questions {
    display: flex;
    flex-direction: column;
    gap: var(--gap-normal);
  }

  :global(.icg-question-card) {
    padding: var(--spacing-md) var(--spacing-lg);
    border: 2px solid var(--border-light);
    background: transparent;
  }

  :global(html.dark-theme .icg-question-card) {
    border-color: var(--border-dark-default);
  }

  :global(.icg-question-text) {
    font-size: var(--text-sm);
    font-family: monospace;
    font-weight: var(--font-weight-normal);
    color: var(--text-primary);
    margin-bottom: var(--spacing-md);
    line-height: 1.6;
  }

  :global(.icg-question-num) {
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-family: monospace;
    font-weight: var(--font-weight-bold);
    margin-right: var(--spacing-xs);
  }

  :global(.icg-options-row) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xs);
  }

  /* ── Question rationale ────────────────────────────────────────────────── */
  :global(.icg-rationale) {
    margin-top: var(--spacing-sm);
  }

  :global(.icg-rationale__trigger) {
    font-size: var(--text-xs);
    color: var(--text-muted);
    cursor: pointer;
    list-style: none;
    transition: color var(--transition-fast);
  }

  :global(.icg-rationale__trigger::-webkit-details-marker) {
    display: none;
  }

  :global(.icg-rationale__trigger::before) {
    content: '';
    display: inline-block;
    width: 10px;
    height: 10px;
    margin-right: var(--spacing-xs);
    background-color: var(--color-primary);
    mask-image: url('/images/logo/gst-delta-icon-teal-stroke-thick.svg');
    mask-size: contain;
    mask-repeat: no-repeat;
    transition: transform var(--transition-fast);
  }

  :global(.icg-rationale[open] > .icg-rationale__trigger::before) {
    transform: rotate(180deg);
  }

  :global(.icg-rationale__trigger:hover) {
    color: var(--text-secondary);
  }

  :global(.icg-rationale__text) {
    font-size: var(--text-xs);
    color: var(--text-secondary);
    line-height: 1.6;
    margin-top: var(--spacing-xs);
    padding-left: var(--spacing-sm);
    border-left: 2px solid var(--border-light);
  }

  :global(html.dark-theme .icg-rationale__text) {
    border-left-color: var(--border-dark-default);
  }

  :global(.brutal-choice-btn--unsure) {
    grid-column: 1 / -1;
  }

  /* ── Wizard navigation ────────────────────────────────────────────────── */
  .icg-wizard-nav {
    display: flex;
