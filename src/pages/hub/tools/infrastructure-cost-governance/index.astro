---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import HubHeader from '../../../../components/hub/HubHeader.astro';
import { trackPageView } from '../../../../utils/analytics';
import { DOMAINS, TOTAL_QUESTIONS } from '../../../../data/infrastructure-cost-governance/domains';

trackPageView('infrastructure-cost-governance', 'Infrastructure Cost Governance | GST');

const domainCount = DOMAINS.length;
---

<BaseLayout
    title="Infrastructure Cost Governance | Strategic Intelligence Hub"
    description="A structured maturity assessment for cloud cost management. Answer 20 questions across six operational domains and receive a scored diagnostic with a prioritized improvement checklist."
    ogTitle="Infrastructure Cost Governance | GST"
    ogDescription="Cloud cost maturity assessment for PE diligence, board reviews, and 100-day planning. Score your cloud spend governance across six operational domains."
    ogImage="/og-image.png"
    ogUrl="https://globalstrategic.tech/hub/tools/infrastructure-cost-governance"
>
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "Infrastructure Cost Governance",
        "description": "Cloud cost maturity assessment across six operational domains for PE diligence, board reviews, and 100-day planning",
        "applicationCategory": "BusinessApplication",
        "operatingSystem": "Web",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "publisher": { "@type": "Organization", "name": "Global Strategic Technologies" },
        "datePublished": "2026-03-01",
        "dateModified": "2026-03-21",
        "featureList": ["20 questions across 6 cloud cost domains", "Scored diagnostic with benchmarks", "Prioritized improvement checklist", "Shareable results for board reviews"],
        "author": { "@type": "Person", "name": "Reid Peryam", "jobTitle": "Strategic Technology Advisor", "sameAs": ["https://www.linkedin.com/in/reidperyam/"], "description": "Technology advisor with experience across 100+ PE technology diligence engagements", "knowsAbout": ["Cloud Cost Optimization", "Infrastructure Governance", "FinOps", "Technical Due Diligence", "M&A Tech Strategy"] }
    })} />

    <section class="icg-section">
        <div class="container">

            <HubHeader
                title="Infrastructure Cost Governance"
                subtitle="A structured maturity assessment for cloud cost management. Answer 20 questions across six operational domains and receive a scored diagnostic with a prioritized improvement checklist. Purpose-built for PE diligence, board reviews, and 100-day planning."
            />

            <div data-icg class="tool-shell tool-shell--narrow icg-shell">

                <p class="tool-authority icg-authority">Scoring model informed by cloud cost governance patterns across PE portfolio companies</p>

                <!-- ── Landing view (step 0) ─────────────────────────────── -->
                <div data-view="landing" class="icg-view">
                    <div class="landing-content">
                        <div class="landing-callout">
                            <span class="landing-callout__title">Who should complete this assessment.</span>
                            This tool takes 5 to 7 minutes. Domains 3 through 6 require familiarity with cloud infrastructure. PE investors and executives should complete this alongside their engineering lead, or send them the link directly.
                        </div>

                        <div class="stats-row">
                            <div class="stat-tile">
                                <div class="stat-tile__value">{domainCount}</div>
                                <div class="stat-tile__label">domains</div>
                            </div>
                            <div class="stat-tile">
                                <div class="stat-tile__value">{TOTAL_QUESTIONS}</div>
                                <div class="stat-tile__label">questions</div>
                            </div>
                            <div class="stat-tile">
                                <div class="stat-tile__value">5-7 min</div>
                                <div class="stat-tile__label">to complete</div>
                            </div>
                        </div>

                        <div class="icg-stage-selector">
                            <span class="icg-stage-selector__label label">Company stage <span class="icg-stage-optional text-tiny">(optional)</span></span>
                            <div class="icg-stage-grid" data-stage-grid>
                                <button class="icg-stage-card" data-stage="pre-series-b" type="button">
                                    <span class="icg-stage-card__name">Pre-Series B</span>
                                    <span class="icg-stage-card__range">15&ndash;35</span>
                                </button>
                                <button class="icg-stage-card" data-stage="series-bc" type="button">
                                    <span class="icg-stage-card__name">Series B-C</span>
                                    <span class="icg-stage-card__range">30&ndash;55</span>
                                </button>
                                <button class="icg-stage-card" data-stage="pe-backed" type="button">
                                    <span class="icg-stage-card__name">PE-backed 2+ yr</span>
                                    <span class="icg-stage-card__range">45&ndash;70</span>
                                </button>
                                <button class="icg-stage-card" data-stage="enterprise" type="button">
                                    <span class="icg-stage-card__name">Enterprise</span>
                                    <span class="icg-stage-card__range">65&ndash;90</span>
                                </button>
                            </div>
                            <div class="icg-stage-hint text-tiny">Sets benchmark context for your results. You can skip this.</div>
                        </div>

                        <div data-resume-prompt class="icg-resume-prompt is-hidden">
                            <p class="text-small icg-resume-prompt__text">You have an incomplete assessment saved from a previous session.</p>
                            <div class="icg-resume-actions">
                                <button data-action="resume" type="button" class="hub-btn hub-btn--primary icg-btn-primary">Resume</button>
                                <button data-action="discard" type="button" class="hub-btn hub-btn--secondary icg-btn-secondary">Start fresh</button>
                            </div>
                        </div>

                        <button data-action="start" type="button" class="hub-btn hub-btn--primary hub-btn--full icg-btn-primary icg-btn-primary--full">Begin assessment</button>

                        <div class="landing-actions">
                            <button data-action="landing-copy" type="button" class="hub-btn hub-btn--secondary icg-btn-secondary" title="Copy a shareable link to this assessment">Copy link</button>
                            <a data-action="landing-email" href="#" class="hub-btn hub-btn--secondary icg-btn-secondary" title="Open a pre-filled email inviting your engineering lead to complete the assessment">Send to engineering lead</a>
                        </div>
                    </div>
                </div>

                <!-- ── Wizard view (steps 1-6) ───────────────────────────── -->
                <div data-view="wizard" class="icg-view is-hidden">
                    <div class="wizard-content">
                        <!-- Progress bar -->
                        <div class="icg-progress">
                            <div class="icg-progress__track">
                                <div class="icg-progress__fill" data-progress-fill></div>
                            </div>
                            <span class="icg-progress__label text-tiny" data-progress-label></span>
                        </div>

                        <!-- Domain header -->
                        <div class="icg-domain-header">
                            <div class="icg-domain-header__meta">
                                <span class="label icg-domain-label" data-domain-label></span>
                                <span class="icg-foundational-badge is-hidden" data-foundational-badge>foundational</span>
                            </div>
                            <h2 class="heading-md icg-domain-name" data-domain-name></h2>
                            <p class="text-small icg-domain-desc" data-domain-desc></p>
                            <p class="text-small icg-foundational-note is-hidden" data-foundational-note>This is a foundational domain. Scores here affect how results in later sections should be interpreted.</p>
                        </div>

                        <!-- Questions container -->
                        <div data-questions-container class="icg-questions"></div>

                        <!-- Navigation -->
                        <div class="icg-wizard-nav">
                            <button data-action="back" type="button" class="hub-btn hub-btn--secondary icg-btn-secondary">Back to intro</button>
                            <button data-action="next" type="button" class="hub-btn hub-btn--primary icg-btn-primary" disabled>Next domain</button>
                        </div>
                    </div>
                </div>

                <!-- ── Results view (step 7) ─────────────────────────────── -->
                <div data-view="results" class="icg-view is-hidden">
                    <div class="results-content">

                        <!-- Maturity score -->
                        <div class="icg-score-display" data-score-display>
                            <div data-gauge-container class="icg-gauge"></div>
                            <div class="icg-score-level heading-md" data-score-level></div>
                            <div class="icg-score-desc text-small" data-score-desc></div>
                            <div class="icg-stage-context text-small is-hidden" data-stage-context></div>
                            <div class="icg-skipped-note text-tiny is-hidden" data-skipped-note></div>
                        </div>

                        <!-- Foundational flag (conditional) -->
                        <div class="icg-foundational-warning is-hidden" data-foundational-warning>
                            <div class="icg-foundational-warning__title" data-foundational-warning-title></div>
                            <div class="icg-foundational-warning__text text-small" data-foundational-warning-text></div>
                        </div>

                        <!-- Quick wins -->
                        <div data-quick-wins class="icg-quick-wins is-hidden"></div>

                        <!-- Radar chart -->
                        <div class="icg-card">
                            <div class="icg-section-label">Domain profile</div>
                            <div data-radar-chart class="icg-radar"></div>
                        </div>

                        <!-- Domain breakdown -->
                        <div class="icg-card">
                            <div class="icg-section-label">Domain breakdown</div>
                            <div data-domain-bars class="icg-domain-bars"></div>
                        </div>

                        <!-- Benchmark reference -->
                        <div class="icg-card">
                            <div class="icg-section-label">Benchmark reference</div>
                            <table class="icg-benchmark-table">
                                <tbody data-benchmark-body>
                                    <tr data-stage-row="pre-series-b"><td>Pre-Series B / high-growth startup</td><td data-bench="15-35">15-35</td></tr>
                                    <tr data-stage-row="series-bc"><td>Series B-C SaaS, scaling team</td><td data-bench="30-55">30-55</td></tr>
                                    <tr data-stage-row="pe-backed"><td>PE-backed portco, 2+ years post-acquisition</td><td data-bench="45-70">45-70</td></tr>
                                    <tr data-stage-row="enterprise"><td>Enterprise with established FinOps practice</td><td data-bench="65-90">65-90</td></tr>
                                </tbody>
                            </table>
                            <div class="icg-benchmark-note text-tiny">Ranges reflect illustrative patterns from GST diligence and value creation engagements. Individual results vary based on team maturity and infrastructure complexity.</div>
                        </div>

                        <!-- Cost context -->
                        <div class="icg-cost-context">
                            <div class="text-small">Cloud infrastructure as a percentage of revenue varies widely by company stage, business model, and architecture. Early-stage companies often run above 30 percent while scaling ahead of revenue. Mature SaaS businesses may converge below 10 percent. <strong>The trend matters more than the number</strong> - assess whether spend is moving in the right direction relative to revenue growth and whether the governance practices above are in place to sustain that trajectory.</div>
                        </div>

                        <!-- Recommendations -->
                        <div data-recs-container class="icg-recs"></div>

                        <!-- Actions row -->
                        <div class="icg-actions">
                            <button data-action="copy-summary" type="button" class="hub-btn hub-btn--secondary icg-btn-secondary" title="Copy a plain-text summary of your results to clipboard">Copy summary</button>
                            <button data-action="copy" type="button" class="hub-btn hub-btn--secondary icg-btn-secondary" title="Copy a shareable link that preserves your answers and dismissed recommendations">Copy link</button>
                            <button data-action="export-json" type="button" class="hub-btn hub-btn--secondary icg-btn-secondary" title="Download your results as a structured JSON file for portfolio aggregation">Download JSON</button>
                            <button data-action="print" type="button" class="hub-btn hub-btn--secondary icg-btn-secondary" title="Your browser will open a print dialog. Select Save as PDF to download.">Print / Save as PDF</button>
                            <a data-action="email" href="#" class="hub-btn hub-btn--secondary icg-btn-secondary" title="Open a pre-filled email with your results link. The recipient can complete the assessment independently.">Send to engineering lead</a>
                            <button data-action="compare" type="button" class="icg-btn-secondary is-hidden" title="Compare saved snapshots side by side">Compare</button>
                            <button data-action="review" type="button" class="hub-btn hub-btn--secondary icg-btn-secondary" title="Review your answers across all six domains">Review answers</button>
                            <button data-action="reset" type="button" class="hub-btn hub-btn--secondary icg-btn-secondary">Start over</button>
                        </div>

                        <!-- Snapshot save -->
                        <div class="icg-snapshot-save-row">
                            <input data-snapshot-label type="text" class="icg-snapshot-label-input" placeholder="Label (e.g., 90-day review)" maxlength="60" />
                            <button data-action="save-snapshot" type="button" class="hub-btn hub-btn--secondary icg-btn-secondary">Save snapshot</button>
                        </div>

                        <!-- Snapshot manager -->
                        <div data-snapshot-manager class="icg-snapshot-manager is-hidden">
                            <div class="icg-section-label">Saved snapshots</div>
                            <div data-snapshot-list class="icg-snapshot-list-items"></div>
                            <button data-action="clear-snapshots" type="button" class="hub-btn hub-btn--secondary icg-btn-secondary icg-snapshot-clear">Clear all snapshots</button>
                        </div>
                    </div>
                </div>

                <!-- ── Comparison view ────────────────────────────────────── -->
                <div data-view="comparison" class="icg-view is-hidden">
                    <div class="comparison-content">
                        <div class="icg-section-label">Snapshot comparison</div>
                        <div data-comparison-body class="icg-comparison-body"></div>
                        <div class="icg-comparison-actions">
                            <button data-action="back-to-results" type="button" class="hub-btn hub-btn--secondary icg-btn-secondary">Back to results</button>
                        </div>
                    </div>
                </div>

                <!-- ── Methodology ─────────────────────────────────────────── -->
                <details class="icg-methodology">
                    <summary class="icg-methodology__trigger">How the assessment works</summary>
                    <div class="icg-methodology__body">
                        <h4 class="icg-methodology__heading">Scoring model</h4>
                        <p>Each of the 20 questions is scored on a four-point scale: Not in place (0), Ad hoc (1), Established (2), Optimized (3). Domain scores are the percentage of points earned out of the maximum possible for that domain.</p>

                        <h4 class="icg-methodology__heading">Domain weighting</h4>
                        <p>Foundational domains (Visibility and Tagging, Account Structure and Attribution) carry 1.5&times; weight in the overall score. The remaining four domains carry 1.0&times; weight. This reflects the principle that visibility and attribution are prerequisites for effective optimization.</p>

                        <h4 class="icg-methodology__heading">Maturity levels</h4>
                        <p>The overall score maps to four maturity levels: Reactive (0&ndash;25), Aware (26&ndash;50), Optimizing (51&ndash;75), and Strategic (76&ndash;100).</p>

                        <h4 class="icg-methodology__heading">FinOps Foundation alignment</h4>
                        <p>The maturity levels map loosely to the FinOps Foundation&rsquo;s Crawl-Walk-Run framework. Reactive and Aware correspond to the Crawl phase, where organizations are building foundational visibility. Optimizing aligns with Walk, where active management is in place. Strategic maps to Run, where cost governance is embedded in engineering culture. For more on the framework, see <a href="https://www.finops.org/framework/" target="_blank" rel="noopener noreferrer">finops.org/framework</a>.</p>

                        <h4 class="icg-methodology__heading">Foundational flag</h4>
                        <p>If either foundational domain scores at or below 33%, a warning is surfaced. Low foundational scores indicate that higher-level optimization practices may be unreliable because the organization cannot see or attribute its spend.</p>

                        <h4 class="icg-methodology__heading">Recommendations</h4>
                        <p>Recommendations are triggered when a question scores at or below a defined threshold. They are sorted by impact tier (high, medium, low) and can be dismissed as not applicable. Dismissed items are excluded from the printed report.</p>

                        <h4 class="icg-methodology__heading">Benchmarks</h4>
                        <p>The benchmark ranges reflect illustrative patterns from GST diligence and value creation engagements. Individual results depend on company stage, team maturity, and infrastructure complexity.</p>

                        <h4 class="icg-methodology__heading">Snapshots and comparison</h4>
                        <p>After completing an assessment, click Save snapshot to store your results in your browser. Up to three snapshots are kept; saving a fourth removes the oldest. Once you have two or more snapshots, a Compare button appears. It shows the two most recent snapshots side by side with per-domain score deltas. Use this to track governance improvements over time, for example between initial diligence and a 90-day post-acquisition review. Snapshots are stored in your browser only and can be cleared from the snapshot manager below the action buttons.</p>

                        <h4 class="icg-methodology__heading">Privacy</h4>
                        <p>All calculations run entirely in your browser&mdash;no inputs are sent to our servers. Anonymous page-view and interaction analytics (Google Analytics 4) help us improve the tool. See our <a href="/privacy">privacy policy</a> for details.</p>

                        <p class="icg-methodology__updated">Methodology last updated March 2026</p>

                        <div class="icg-methodology__author">
                            <span class="icg-methodology__author-name">Reid Peryam</span>
                            <span class="icg-methodology__author-sep">&middot;</span>
                            <span>Strategic Technology Advisor</span>
                            <span class="icg-methodology__author-sep">&middot;</span>
                            <span>100+ PE technology diligence engagements</span>
                            <span class="icg-methodology__author-sep">&middot;</span>
                            <a href="https://www.linkedin.com/in/reidperyam/" target="_blank" rel="noopener noreferrer" class="icg-methodology__author-link">LinkedIn</a>
                        </div>
                    </div>
                </details>

            </div>

            <a href="/hub/tools" class="cta-button secondary icg-back-link">Return to Tools</a>

        </div>
    </section>
</BaseLayout>

<style>
    /* ── Page wrapper ─────────────────────────────────────────────────────── */
    .icg-section {
        padding-bottom: var(--spacing-3xl);
    }

    /* ── Tool shell — base styles provided by global .tool-shell + .tool-shell--narrow ── */
    /* .icg-shell retained for ICG-specific overrides only */

    /* ── Authority line ────────────────────────────────────────────────────── */
    .icg-authority {
        padding: var(--spacing-sm) var(--spacing-lg);
    }

    /* ── View toggling ────────────────────────────────────────────────────── */
    .is-hidden {
        display: none;
    }

    /* ── Landing view ─────────────────────────────────────────────────────── */
    .landing-content {
        max-width: 560px;
        margin: 0 auto;
        padding: var(--spacing-xl) var(--spacing-lg);
    }

    .wizard-content {
        padding: var(--spacing-xl) var(--spacing-lg);
    }

    .results-content {
        padding: var(--spacing-xl) var(--spacing-lg);
    }

    .comparison-content {
        padding: var(--spacing-xl) var(--spacing-lg);
    }

    .landing-callout {
        padding: var(--spacing-md) var(--spacing-lg);
        background: var(--bg-light);
        border-radius: 8px;
        font-size: var(--text-sm);
        color: var(--text-secondary);
        line-height: 1.65;
        margin-bottom: var(--spacing-xl);
    }

    :global(html.dark-theme) .landing-callout {
        background: rgba(5, 205, 153, 0.03);
    }

    .landing-callout__title {
        display: block;
        color: var(--text-primary);
        font-weight: var(--font-weight-bold);
        font-size: var(--text-sm);
        letter-spacing: 0.02em;
        margin-bottom: var(--spacing-xs);
    }

    /* ── Resume prompt ──────────────────────────────────────────────────── */
    .icg-resume-prompt {
        padding: var(--spacing-md) var(--spacing-lg);
        border: 1px solid var(--color-primary);
        border-radius: 8px;
        background: rgba(5, 205, 153, 0.04);
        margin-bottom: var(--spacing-lg);
    }

    :global(html.dark-theme) .icg-resume-prompt {
        background: rgba(5, 205, 153, 0.06);
    }

    .icg-resume-prompt__text {
        color: var(--text-secondary);
        margin-bottom: var(--spacing-md);
    }

    .icg-resume-actions {
        display: flex;
        gap: var(--spacing-sm);
    }

    .icg-resume-actions .icg-btn-primary,
    .icg-resume-actions .icg-btn-secondary {
        flex: 1;
    }

    .stats-row {
        display: flex;
        gap: var(--gap-normal);
        margin-bottom: var(--spacing-xl);
    }

    .stat-tile {
        flex: 1;
        padding: var(--spacing-md);
        background: var(--bg-light);
        border-radius: 8px;
        text-align: center;
    }

    :global(html.dark-theme) .stat-tile {
        background: rgba(5, 205, 153, 0.03);
    }

    .stat-tile__value {
        font-size: var(--text-xl);
        font-weight: var(--font-weight-semibold);
        color: var(--text-primary);
    }

    .stat-tile__label {
        font-size: var(--text-xs);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted);
    }

    /* ── Button overrides (base styles from global .hub-btn) ────────────── */
    .icg-btn-primary--full {
        padding: var(--spacing-md) 0;
        font-size: 0.95rem;
        letter-spacing: 0.08em;
    }

    .icg-btn-secondary {
        padding: var(--spacing-sm) var(--spacing-lg);
    }

    :global(html.dark-theme) .icg-btn-secondary {
        border-color: rgba(5, 205, 153, 0.15);
    }

    /* ── Progress bar ─────────────────────────────────────────────────────── */
    .icg-progress {
        display: flex;
        align-items: center;
        gap: var(--gap-normal);
        margin-bottom: var(--spacing-xl);
    }

    .icg-progress__track {
        flex: 1;
        height: 4px;
        background: var(--border-light);
        border-radius: 4px;
        overflow: hidden;
    }

    :global(html.dark-theme) .icg-progress__track {
        background: var(--accent-light-bg-hover);
    }

    .icg-progress__fill {
        height: 100%;
        width: 0;
        background: var(--color-primary);
        border-radius: 4px;
        transition: width var(--transition-normal);
    }

    .icg-progress__label {
        white-space: nowrap;
        color: var(--text-muted);
    }

    /* ── Domain header ────────────────────────────────────────────────────── */
    .icg-domain-header {
        margin-bottom: var(--spacing-xl);
    }

    .icg-domain-header__meta {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        margin-bottom: var(--spacing-xs);
    }

    .icg-domain-label {
        color: var(--color-primary);
    }

    .icg-foundational-badge {
        font-size: 0.65rem;
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 2px var(--spacing-sm);
        border-radius: 4px;
        background: var(--accent-dark-bg);
        color: var(--color-primary);
    }

    .icg-domain-name {
        margin-bottom: var(--spacing-xs);
    }

    .icg-domain-desc {
        color: var(--text-secondary);
    }

    .icg-foundational-note {
        color: var(--text-muted);
        font-style: italic;
        margin-top: var(--spacing-sm);
    }

    /* ── Question cards (injected via innerHTML — must use :global) ────── */
    .icg-questions {
        display: flex;
        flex-direction: column;
        gap: var(--gap-normal);
    }

    :global(.icg-question-card) {
        padding: var(--spacing-md) var(--spacing-lg);
        border: 1px solid var(--border-light);
        border-radius: 8px;
        background: var(--bg-light);
    }

    :global(html.dark-theme .icg-question-card) {
        background: rgba(5, 205, 153, 0.02);
        border-color: var(--accent-light-bg-hover);
    }

    :global(.icg-question-text) {
        font-size: var(--text-sm);
        font-weight: var(--font-weight-normal);
        color: var(--text-primary);
        margin-bottom: var(--spacing-md);
        line-height: 1.6;
    }

    :global(.icg-question-num) {
        color: var(--text-muted);
        font-size: var(--text-xs);
        font-weight: var(--font-weight-bold);
        margin-right: var(--spacing-xs);
    }

    :global(.icg-options-row) {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--spacing-xs);
    }

    :global(.icg-opt-btn) {
        padding: var(--spacing-sm) var(--spacing-sm);
        border: 2px solid var(--border-light);
        border-radius: 8px;
        background: var(--bg-light-alt);
        color: var(--text-secondary);
        cursor: pointer;
        font-size: var(--text-xs);
        font-weight: var(--font-weight-bold);
        font-family: var(--font-family);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        transition: border-color var(--transition-fast), color var(--transition-fast);
        text-align: center;
        min-height: 44px;
    }

    :global(html.dark-theme .icg-opt-btn) {
        background: rgba(5, 205, 153, 0.02);
        border-color: var(--accent-light-bg-hover);
    }

    :global(.icg-opt-btn:hover) {
        border-color: var(--color-primary);
        color: var(--text-primary);
    }

    /* ── Question rationale ────────────────────────────────────────────────── */
    :global(.icg-rationale) {
        margin-top: var(--spacing-sm);
    }

    :global(.icg-rationale__trigger) {
        font-size: var(--text-xs);
        color: var(--text-muted);
        cursor: pointer;
        list-style: none;
        transition: color var(--transition-fast);
    }

    :global(.icg-rationale__trigger::-webkit-details-marker) {
        display: none;
    }

    :global(.icg-rationale__trigger::before) {
        content: '';
        display: inline-block;
        width: 10px;
        height: 10px;
        margin-right: var(--spacing-xs);
        background-color: var(--color-primary);
        mask-image: url('/images/logo/gst-delta-icon-teal-stroke-thick.svg');
        mask-size: contain;
        mask-repeat: no-repeat;
        -webkit-mask-image: url('/images/logo/gst-delta-icon-teal-stroke-thick.svg');
        -webkit-mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        transition: transform var(--transition-fast);
    }

    :global(.icg-rationale[open] > .icg-rationale__trigger::before) {
        transform: rotate(180deg);
    }

    :global(.icg-rationale__trigger:hover) {
        color: var(--text-secondary);
    }

    :global(.icg-rationale__text) {
        font-size: var(--text-xs);
        color: var(--text-secondary);
        line-height: 1.6;
        margin-top: var(--spacing-xs);
        padding-left: var(--spacing-sm);
        border-left: 2px solid var(--border-light);
    }

    :global(html.dark-theme .icg-rationale__text) {
        border-left-color: rgba(5, 205, 153, 0.15);
    }

    :global(.icg-opt-btn.selected) {
        border: 2px solid var(--color-primary);
        color: var(--text-primary);
        font-weight: var(--font-weight-bold);
        background: var(--bg-light);
        box-shadow: inset 0 0 0 1px var(--color-primary);
    }

    :global(html.dark-theme .icg-opt-btn.selected) {
        background: var(--accent-light-bg-hover);
    }

    :global(.icg-opt-btn--unsure) {
        grid-column: 1 / -1;
        border-style: dashed;
        font-style: italic;
        min-height: 36px;
    }

    :global(.icg-opt-btn--unsure.selected) {
        border: 2px dashed var(--color-primary);
        color: var(--text-primary);
        font-weight: var(--font-weight-bold);
        box-shadow: none;
    }

    /* ── Wizard navigation ────────────────────────────────────────────────── */
    .icg-wizard-nav {
        display: flex;
        gap: var(--gap-normal);
        margin-top: var(--spacing-xl);
        margin-left: calc(-1 * var(--spacing-lg));
        margin-right: calc(-1 * var(--spacing-lg));
        margin-bottom: calc(-1 * var(--spacing-xl));
        position: sticky;
        bottom: 0;
        background: var(--bg-light-alt);
        padding: var(--spacing-md) var(--spacing-lg);
        border-top: 1px solid var(--border-light);
        z-index: 10;
    }

    :global(html.dark-theme) .icg-wizard-nav {
        background: var(--bg-light-alt);
        border-top-color: var(--accent-dark-bg);
    }

    .icg-wizard-nav .icg-btn-primary {
        flex: 1;
    }


    /* ── Results: Score display ────────────────────────────────────────────── */
    .icg-score-display {
        text-align: center;
        margin-bottom: var(--spacing-2xl);
    }

    .icg-gauge {
        margin-bottom: var(--spacing-xs);
    }

    .icg-score-level {
        margin-top: var(--spacing-xs);
    }

    .icg-score-desc {
        color: var(--text-secondary);
        margin-top: var(--spacing-xs);
    }

    /* ── Results: Radar chart ───────────────────────────────────────────── */
    .icg-radar {
        text-align: center;
    }

    /* ── Results: Quick wins ────────────────────────────────────────────── */
    .icg-quick-wins {
        padding: var(--spacing-md) var(--spacing-lg);
        border-left: 3px solid var(--color-primary);
        background: rgba(5, 205, 153, 0.04);
        border-radius: 0 8px 8px 0;
        margin-bottom: var(--spacing-xl);
    }

    :global(html.dark-theme) .icg-quick-wins {
        background: rgba(5, 205, 153, 0.06);
    }

    :global(.icg-quick-win-item) {
        display: flex;
        align-items: center;
        gap: var(--spacing-xs);
        padding: var(--spacing-xs) 0;
        flex-wrap: wrap;
    }

    :global(.icg-quick-win-item__title) {
        font-size: var(--text-sm);
        font-weight: var(--font-weight-semibold);
        color: var(--text-primary);
    }

    /* ── Results: Cards ───────────────────────────────────────────────────── */
    .icg-card {
        padding: var(--spacing-lg) var(--spacing-xl);
        border: 1px solid var(--border-light);
        border-radius: 8px;
        background: var(--bg-light);
        margin-bottom: var(--spacing-xl);
    }

    :global(html.dark-theme) .icg-card {
        background: rgba(5, 205, 153, 0.02);
        border-color: var(--accent-light-bg-hover);
    }

    :global(.icg-section-label) {
        font-size: 0.75rem;
        font-weight: var(--font-weight-bold);
        color: var(--text-muted);
        margin-bottom: var(--spacing-md);
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    /* ── Results: Domain bars (injected via innerHTML — must use :global) ── */
    .icg-domain-bars {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-md);
    }

    :global(.icg-domain-bar) {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-xs);
    }

    :global(.icg-domain-bar__header) {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
    }

    :global(.icg-domain-bar__name) {
        font-size: var(--text-sm);
        font-weight: var(--font-weight-semibold);
        color: var(--text-primary);
    }

    :global(.icg-domain-bar__score) {
        font-size: var(--text-sm);
        font-weight: var(--font-weight-semibold);
    }

    :global(.icg-domain-bar__maturity) {
        font-size: var(--text-xs);
        font-weight: var(--font-weight-normal);
        color: var(--text-muted);
        margin-left: var(--spacing-xs);
    }

    :global(.icg-domain-bar__track) {
        height: 6px;
        background: var(--border-light);
        border-radius: 4px;
        overflow: hidden;
    }

    :global(html.dark-theme .icg-domain-bar__track) {
        background: var(--accent-dark-bg);
    }

    :global(.icg-domain-bar__fill) {
        height: 100%;
        border-radius: 4px;
        transition: width var(--transition-normal);
    }

    /* ── Results: Foundational warning ─────────────────────────────────────── */
    .icg-foundational-warning {
        padding: var(--spacing-md) var(--spacing-lg);
        margin-bottom: var(--spacing-xl);
        border: 1px solid var(--color-secondary);
        border-radius: 8px;
        background: rgba(204, 136, 0, 0.06);
    }

    :global(html.dark-theme) .icg-foundational-warning {
        background: rgba(255, 170, 51, 0.06);
        border-color: rgba(255, 170, 51, 0.3);
    }

    .icg-foundational-warning__title {
        font-size: var(--text-sm);
        font-weight: var(--font-weight-bold);
        color: var(--color-secondary);
        margin-bottom: var(--spacing-xs);
        letter-spacing: 0.02em;
    }

    .icg-foundational-warning__text {
        color: var(--color-secondary);
        line-height: 1.55;
    }

    /* ── Results: Benchmark table ──────────────────────────────────────────── */
    .icg-benchmark-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 var(--spacing-xs);
    }

    .icg-benchmark-table td {
        padding: var(--spacing-sm) var(--spacing-md);
        font-size: var(--text-sm);
        color: var(--text-secondary);
    }

    .icg-benchmark-table td:first-child {
        border-radius: 4px 0 0 4px;
    }

    .icg-benchmark-table td:last-child {
        text-align: right;
        white-space: nowrap;
        font-family: var(--font-family);
        font-weight: var(--font-weight-semibold);
        letter-spacing: 0.02em;
        border-radius: 0 4px 4px 0;
    }

    :global(.icg-benchmark-table td.in-range) {
        font-weight: var(--font-weight-bold);
        color: var(--color-primary);
    }

    :global(.icg-bench-label) {
        display: inline-block;
        font-size: 0.6rem;
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 1px var(--spacing-xs);
        border-radius: 3px;
        vertical-align: middle;
        margin-left: var(--spacing-xs);
        line-height: 1.4;
    }

    :global(.icg-bench-label--score) {
        background: var(--accent-light-bg-hover);
        color: var(--color-primary);
        border: 1px solid rgba(5, 205, 153, 0.25);
    }

    :global(.icg-bench-label--stage) {
        background: var(--hub-authority-blue-bg);
        color: var(--hub-authority-blue);
        border: 1px solid rgba(91, 122, 157, 0.2);
    }

    :global(html.dark-theme .icg-bench-label--score) {
        background: rgba(5, 205, 153, 0.15);
        border-color: rgba(5, 205, 153, 0.3);
    }

    :global(html.dark-theme .icg-bench-label--stage) {
        background: rgba(91, 122, 157, 0.15);
        color: #7a9dbd;
        border-color: rgba(91, 122, 157, 0.25);
    }

    .icg-benchmark-note {
        color: var(--text-muted);
        margin-top: var(--spacing-sm);
        line-height: 1.5;
        font-style: italic;
    }

    /* ── Results: Cost context ─────────────────────────────────────────────── */
    .icg-cost-context {
        padding: var(--spacing-md) var(--spacing-lg);
        border-left: 3px solid var(--color-primary);
        background: var(--bg-light-alt);
        margin-bottom: var(--spacing-xl);
    }

    :global(html.dark-theme) .icg-cost-context {
        background: rgba(5, 205, 153, 0.03);
    }

    .icg-cost-context .text-small {
        color: var(--text-secondary);
        line-height: 1.65;
    }

    .icg-cost-context strong {
        color: var(--text-primary);
        font-weight: var(--font-weight-semibold);
    }

    /* ── Results: Recommendations (injected via innerHTML — must use :global) */
    .icg-recs {
        margin-bottom: var(--spacing-xl);
    }

    :global(.icg-recs-group) {
        margin-bottom: var(--spacing-md);
    }

    :global(.icg-recs-group__label) {
        font-size: 0.75rem;
        font-weight: var(--font-weight-bold);
        margin-bottom: var(--spacing-sm);
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    :global(.icg-rec-card) {
        display: flex;
        gap: var(--gap-normal);
        padding: var(--spacing-md) var(--spacing-md);
        border: 1px solid var(--border-light);
        border-radius: 8px;
        margin-bottom: var(--spacing-sm);
        cursor: pointer;
    }

    :global(html.dark-theme .icg-rec-card) {
        border-color: var(--accent-dark-bg);
    }

    :global(.icg-rec-badge) {
        flex-shrink: 0;
        display: inline-flex;
        align-items: center;
        font-size: 0.65rem;
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: var(--spacing-xs) var(--spacing-sm);
        border-radius: 4px;
        line-height: 1;
        border: 1px solid var(--border-light);
    }

    :global(html.dark-theme .icg-rec-badge) {
        border-color: rgba(200, 200, 200, 0.1);
    }

    :global(.icg-rec-badge--high),
    :global(.icg-rec-badge--medium),
    :global(.icg-rec-badge--low) {
        background: var(--bg-light-alt);
        color: var(--text-muted);
    }

    :global(html.dark-theme .icg-rec-badge--high),
    :global(html.dark-theme .icg-rec-badge--medium),
    :global(html.dark-theme .icg-rec-badge--low) {
        background: rgba(200, 200, 200, 0.05);
    }

    :global(.icg-rec-badge--effort) {
        background: var(--bg-light-alt);
        color: var(--text-muted);
        font-style: normal;
    }

    :global(html.dark-theme .icg-rec-badge--effort) {
        background: rgba(200, 200, 200, 0.05);
    }

    :global(.icg-rec-body) {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-xs);
    }

    :global(.icg-rec-body__title) {
        font-size: var(--text-sm);
        font-weight: var(--font-weight-semibold);
        color: var(--text-primary);
        display: flex;
        align-items: center;
        gap: var(--spacing-xs);
    }


    :global(.icg-rec-body__desc) {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        line-height: 1.55;
        transition: max-height var(--transition-normal), opacity var(--transition-normal);
        max-height: 200px;
        opacity: 1;
        overflow: hidden;
    }

    :global(.icg-rec-card.is-collapsed .icg-rec-body__desc) {
        max-height: 0;
        opacity: 0;
        margin: 0;
    }

    :global(.icg-recs-empty) {
        text-align: center;
        padding: var(--spacing-xl) 0;
        color: var(--text-muted);
        font-size: var(--text-sm);
    }

    /* ── N/A dismiss button (inline with badges) ────────────────────────── */
    :global(.icg-rec-na) {
        flex-shrink: 0;
        padding: 2px var(--spacing-sm);
        margin-right: var(--spacing-xs);
        font-size: 0.65rem;
        font-weight: var(--font-weight-bold);
        font-family: var(--font-family);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        background: rgba(200, 200, 200, 0.08);
        border: 1px dashed var(--border-light);
        border-radius: 4px;
        cursor: pointer;
        transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
    }

    :global(.icg-rec-na:hover) {
        color: var(--text-primary);
        border-color: var(--text-secondary);
        background: rgba(200, 200, 200, 0.15);
    }

    :global(html.dark-theme .icg-rec-na) {
        background: rgba(200, 200, 200, 0.04);
        border-color: var(--accent-light-bg-hover);
    }

    :global(html.dark-theme .icg-rec-na:hover) {
        border-color: rgba(5, 205, 153, 0.3);
        background: var(--accent-light-bg);
    }

    /* ── Dismissed recommendation ─────────────────────────────────────────── */
    :global(.icg-rec-card.is-dismissed) {
        opacity: 0.45;
        border-style: dashed;
    }

    :global(.icg-rec-card.is-dismissed .icg-rec-na) {
        border-style: solid;
    }

    /* ── Results: Actions ──────────────────────────────────────────────────── */
    .icg-actions {
        display: flex;
        gap: var(--spacing-sm);
        flex-wrap: wrap;
        justify-content: center;
        padding-top: var(--spacing-lg);
        border-top: 1px solid var(--border-light);
    }

    :global(html.dark-theme) .icg-actions {
        border-top-color: var(--accent-dark-bg);
    }

    /* ── Landing: Actions ─────────────────────────────────────────────────── */
    .landing-actions {
        display: flex;
        gap: var(--spacing-sm);
        justify-content: center;
        margin-top: var(--spacing-md);
    }

    /* ── Snapshot manager ─────────────────────────────────────────────────── */
    .icg-snapshot-manager {
        margin-top: var(--spacing-lg);
        padding-top: var(--spacing-lg);
        border-top: 1px solid var(--border-light);
    }

    :global(html.dark-theme) .icg-snapshot-manager {
        border-top-color: var(--accent-dark-bg);
    }

    :global(.icg-snapshot-list-items) {
        margin-bottom: var(--spacing-md);
    }

    :global(.icg-snapshot-row) {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: var(--spacing-xs) 0;
        border-bottom: 1px solid var(--border-light);
        font-size: var(--text-sm);
        color: var(--text-secondary);
    }

    :global(html.dark-theme .icg-snapshot-row) {
        border-bottom-color: var(--accent-light-bg);
    }

    :global(.icg-snapshot-row__info) {
        display: flex;
        align-items: baseline;
        gap: var(--spacing-sm);
    }

    :global(.icg-snapshot-row__score) {
        font-weight: var(--font-weight-semibold);
        color: var(--text-primary);
    }

    :global(.icg-snapshot-row__delete) {
        font-size: var(--text-xs);
        color: var(--text-muted);
        background: none;
        border: none;
        cursor: pointer;
        font-family: var(--font-family);
        padding: var(--spacing-xs);
        transition: color var(--transition-fast);
    }

    :global(.icg-snapshot-row__delete:hover) {
        color: #E24B4A;
    }

    .icg-snapshot-clear {
        font-size: var(--text-xs);
    }

    /* ── Comparison view ──────────────────────────────────────────────────── */
    :global(.icg-comparison-row) {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-sm) 0;
        border-bottom: 1px solid var(--border-light);
    }

    :global(html.dark-theme .icg-comparison-row) {
        border-bottom-color: var(--accent-light-bg);
    }

    :global(.icg-comparison-row__name) {
        flex: 1;
        font-size: var(--text-sm);
        font-weight: var(--font-weight-semibold);
        color: var(--text-primary);
    }

    :global(.icg-comparison-row__scores) {
        display: flex;
        gap: var(--spacing-md);
        align-items: baseline;
        font-size: var(--text-sm);
    }

    :global(.icg-comparison-row__score) {
        color: var(--text-secondary);
        min-width: 32px;
        text-align: right;
    }

    :global(.icg-delta) {
        font-size: var(--text-xs);
        font-weight: var(--font-weight-bold);
        min-width: 40px;
        text-align: right;
    }

    :global(.icg-delta--positive) {
        color: var(--color-primary);
    }

    :global(.icg-delta--negative) {
        color: #E24B4A;
    }

    :global(.icg-delta--neutral) {
        color: var(--text-muted);
    }

    :global(.icg-comparison-overall) {
        padding: var(--spacing-md) 0;
        margin-bottom: var(--spacing-md);
        border-bottom: 2px solid var(--border-light);
        font-size: var(--text-md);
        font-weight: var(--font-weight-bold);
    }

    :global(html.dark-theme .icg-comparison-overall) {
        border-bottom-color: rgba(5, 205, 153, 0.15);
    }

    .icg-comparison-actions {
        margin-top: var(--spacing-xl);
    }

    :global(.icg-snapshot-select) {
        margin-bottom: var(--spacing-lg);
    }

    :global(.icg-snapshot-item) {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-xs) 0;
    }

    :global(.icg-snapshot-item label) {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        cursor: pointer;
    }

    :global(.icg-snapshot-item__date) {
        font-size: var(--text-xs);
        color: var(--text-muted);
    }

    /* ── Back link ────────────────────────────────────────────────────────── */
    .icg-back-link {
        display: inline-block;
        margin-top: var(--spacing-2xl);
    }

    /* ── Methodology collapsible ───────────────────────────────────────────── */
    .icg-methodology {
        margin-top: 0;
        border-top: 1px solid color-mix(in srgb, var(--color-primary) 6%, transparent);
    }

    .icg-methodology__trigger {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-sm) var(--spacing-2xl);
        cursor: pointer;
        color: var(--text-muted);
        transition: color var(--transition-fast);
        list-style: none;
        font-size: var(--text-xs);
        font-weight: var(--font-weight-bold);
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .icg-methodology__trigger::-webkit-details-marker {
        display: none;
    }

    .icg-methodology__trigger::before {
        content: '';
        display: inline-block;
        width: 10px;
        height: 10px;
        background-color: var(--color-primary);
        mask-image: url('/images/logo/gst-delta-icon-teal-stroke-thick.svg');
        mask-size: contain;
        mask-repeat: no-repeat;
        -webkit-mask-image: url('/images/logo/gst-delta-icon-teal-stroke-thick.svg');
        -webkit-mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        transition: transform var(--transition-fast);
    }

    .icg-methodology[open] > .icg-methodology__trigger::before {
        transform: rotate(180deg);
    }

    .icg-methodology__trigger:hover {
        color: var(--text-secondary);
    }

    .icg-methodology__body {
        padding: var(--spacing-sm) var(--spacing-2xl) var(--spacing-md);
        color: var(--text-secondary);
        line-height: 1.7;
        border-top: 1px solid color-mix(in srgb, var(--color-primary) 6%, transparent);
    }

    .icg-methodology__heading {
        font-size: var(--text-sm);
        font-weight: var(--font-weight-bold);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--text-primary);
        margin-top: var(--spacing-md);
        margin-bottom: var(--spacing-xs);
    }

    .icg-methodology__heading:first-child {
        margin-top: 0;
    }

    .icg-methodology__body p {
        margin-bottom: var(--spacing-sm);
    }

    .icg-methodology__updated {
        font-size: var(--text-xs);
        color: var(--text-faded);
        font-style: italic;
        margin-top: var(--spacing-sm);
    }

    /* ── Author attribution ──────────────────────────────────────────────── */
    .icg-methodology__author {
        display: flex;
        align-items: baseline;
        gap: var(--spacing-sm);
        flex-wrap: wrap;
        padding-top: var(--spacing-md);
        margin-top: var(--spacing-md);
        border-top: 1px solid color-mix(in srgb, var(--color-primary) 6%, transparent);
        font-size: var(--text-xs);
        color: var(--text-muted);
    }

    .icg-methodology__author-name {
        font-weight: var(--font-weight-semibold);
        color: var(--text-secondary);
    }

    .icg-methodology__author-sep {
        color: var(--text-faded);
    }

    .icg-methodology__author-link {
