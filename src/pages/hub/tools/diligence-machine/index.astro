    .doc-toc :global(.doc-toc-link:active) {
        color: var(--color-primary);
        background-color: var(--accent-light-bg-hover);
    }

    :global(html.dark-theme) .doc-toc :global(.doc-toc-link:hover) {
        color: var(--color-primary);
    }

    :global(html.dark-theme) .doc-toc :global(.doc-toc-link:focus-visible) {
        color: var(--color-primary);
        background-color: var(--accent-light-bg-hover);
    }

    :global(html.dark-theme) .doc-toc :global(.doc-toc-link:active) {
        color: var(--color-primary);
        background-color: var(--border-dark);
    }

    .doc-toc :global(.doc-toc-topic-name) {
        font-size: var(--text-sm);
        font-weight: var(--font-weight-semibold);
    }

    /* ─── ATTENTION AREAS ──────────────────────────────────────────────── */

    .doc-attention-anchors {
        margin-bottom: 0;
    }

    .doc-attention-grid {
        display: grid;
        gap: var(--spacing-md);
        padding-left: 0;
    }

    .doc-attention-grid :global(.doc-attention-card) {
        padding: calc(var(--spacing-xl) * 0.5) var(--spacing-xl);
        border-left: 3px solid var(--color-primary);
        background: rgba(5, 205, 153, 0.03);
        border-radius: 4px;
        min-width: 0;
        overflow: hidden;
    }

    .doc-attention-grid :global(.doc-attention-card.is-collapsed) {
        padding: var(--spacing-sm) var(--spacing-xl);
    }

    .doc-attention-grid :global(.doc-attention-card.relevance-high) {
        border-left-color: var(--hub-authority-blue);
        background: var(--hub-authority-blue-bg);
    }

    .doc-attention-grid :global(.doc-attention-card.relevance-medium) {
        border-left-color: var(--dm-methodology-brown);
        background: var(--dm-methodology-brown-bg);
    }

    :global(html.dark-theme) .doc-attention-grid :global(.doc-attention-card) {
        background: rgba(5, 205, 153, 0.06);
    }

    .doc-attention-grid :global(.doc-attention-header) {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
    }


    .doc-attention-grid :global(.doc-attention-title) {
        font-size: var(--text-base);
        font-weight: var(--font-weight-bold);
        color: var(--text-primary);
        line-height: 1.4;
        min-width: 0;
        margin: 0;
    }

    .doc-attention-grid :global(.doc-attention-divider) {
        width: 2rem;
        height: 2px;
        border: none;
        opacity: 0.4;
        margin: var(--spacing-md) 0;
    }

    .doc-attention-grid :global(.doc-attention-card .doc-attention-divider) {
        background: var(--color-primary);
    }

    .doc-attention-grid :global(.relevance-high .doc-attention-divider) {
        background: var(--hub-authority-blue);
    }

    .doc-attention-grid :global(.relevance-medium .doc-attention-divider) {
        background: var(--dm-methodology-brown);
    }

    .doc-attention-grid :global(.doc-attention-desc) {
        font-size: var(--text-sm);
        color: var(--text-secondary);
        line-height: 1.7;
        margin: 0;
    }

    /* ─── COLLAPSE / DISMISS CONTROLS ────────────────────────────────── */

    :global([data-card-toggle]) {
        cursor: pointer;
    }

    :global(.dm-na-btn) {
        flex-shrink: 0;
        padding: 2px var(--spacing-sm);
        font-size: 0.65rem;
        font-weight: var(--font-weight-bold);
        font-family: var(--font-family);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        background: rgba(200, 200, 200, 0.08);
        border: 1px dashed var(--border-light);
        border-radius: 4px;
        cursor: pointer;
        transition: color var(--transition-fast), border-color var(--transition-fast), background var(--transition-fast);
    }

    :global(.dm-na-btn:hover) {
        color: var(--text-primary);
        border-color: var(--text-secondary);
        background: rgba(200, 200, 200, 0.15);
    }

    :global(html.dark-theme .dm-na-btn) {
        background: rgba(200, 200, 200, 0.04);
        border-color: var(--accent-light-bg-hover);
    }

    :global(html.dark-theme .dm-na-btn:hover) {
        border-color: rgba(5, 205, 153, 0.3);
        background: var(--accent-light-bg);
    }


    :global(.doc-attention-card.is-dismissed),
    :global(.doc-question.is-dismissed) {
        opacity: 0.45;
        border-style: dashed;
    }

    :global(.is-dismissed .dm-na-btn) {
        border-style: solid;
    }

    /* Attention card collapse */

    .doc-attention-grid :global(.is-collapsed .doc-attention-divider) {
        max-height: 0;
        opacity: 0;
        margin: 0;
    }

    .doc-attention-grid :global(.is-collapsed .doc-attention-desc) {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin: var(--spacing-xs) 0 0;
        font-size: var(--text-xs);
        color: var(--text-muted);
    }

    /* Question card collapse */
    :global(.dm-card-body) {
        transition: max-height var(--transition-normal), opacity var(--transition-normal);
        max-height: 1000px;
        overflow: hidden;
        opacity: 1;
    }

    :global(.is-collapsed .dm-card-body) {
        max-height: 0;
        opacity: 0;
        margin: 0;
    }

    /* Truncate question text to one line when collapsed */
    :global(.doc-question.is-collapsed .doc-q-text) {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 0;
        font-weight: var(--font-weight-normal);
        font-size: var(--text-sm);
        color: var(--text-muted);
    }

    /* ─── TOPIC SECTIONS ───────────────────────────────────────────────── */
    /* All topic/question elements are dynamically injected via innerHTML,
       so they need :global() wrappers anchored on the static .doc-topics parent */

    .doc-topics :global(.doc-topic) {
        margin-top: var(--spacing-3xl);
    }

    .doc-topics :global(.doc-topic-header) {
        padding-bottom: var(--spacing-lg);
        border-bottom: 2px solid var(--color-primary);
        margin-bottom: var(--spacing-xl);
    }

    .doc-topics :global(.doc-topic-label-row) {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--spacing-xs);
    }

    .doc-topics :global(.doc-topic-number) {
        font-size: var(--text-xs);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-primary);
    }

    .doc-topics :global(.doc-topic-title) {
        font-size: var(--text-xl);
        font-weight: var(--font-weight-bold);
        color: var(--color-secondary);
        margin: 0 0 var(--spacing-xs) 0;
    }

    .doc-topics :global(.doc-section-subtitle) {
        margin: 0 0 var(--spacing-sm) 0;
        padding-left: 0;
    }

    .doc-topics :global(.doc-topic-audience) {
        font-size: var(--text-sm);
        color: var(--text-muted);
        font-style: italic;
        margin: 0;
    }

    /* ─── QUESTIONS ────────────────────────────────────────────────────── */

    .doc-topics :global(.doc-questions) {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: var(--spacing-md);
    }

    .doc-topics :global(.doc-question) {
        padding: var(--spacing-lg);
        border: 1px solid var(--border-light);
        border-radius: 2px;
        border-left: 3px solid var(--border-light);
        min-width: 0;
        overflow: hidden;
    }

    .doc-topics :global(.doc-question.is-collapsed) {
        padding: var(--spacing-sm) var(--spacing-lg);
    }

    .doc-topics :global(.doc-question.priority-high) {
        border-left-color: var(--hub-authority-blue);
    }

    .doc-topics :global(.doc-question.priority-medium) {
        border-left-color: var(--dm-methodology-brown);
    }

    .doc-topics :global(.doc-question.priority-standard) {
        border-left-color: var(--color-primary);
    }

    :global(html.dark-theme) .doc-topics :global(.doc-question) {
        border-color: var(--border-dark);
    }

    :global(html.dark-theme) .doc-topics :global(.doc-q-red-flag) {
        background: var(--dm-negative-dark-bg);
        color: var(--dm-negative);
    }

    :global(html.dark-theme) .doc-topics :global(.exit-impact-multiple-expander) {
        color: var(--dm-positive);
    }

    :global(html.dark-theme) .doc-topics :global(.exit-impact-valuation-drag) {
        color: var(--dm-warning);
    }

    :global(html.dark-theme) .doc-topics :global(.exit-impact-operational-risk) {
        color: var(--dm-negative);
    }

    .doc-topics :global(.doc-q-header) {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--spacing-sm);
    }

    .doc-topics :global(.doc-q-number) {
        font-size: var(--text-sm);
        font-weight: var(--font-weight-bold);
        color: var(--color-primary);
        margin-right: var(--spacing-sm);
    }

    .doc-topics :global(.doc-q-priority) {
        font-size: var(--text-xs);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 1px var(--spacing-sm);
        border-radius: 2px;
    }

    .doc-topics :global(.priority-high .doc-q-priority) {
        background: var(--hub-authority-blue-bg);
        color: var(--hub-authority-blue);
    }

    .doc-topics :global(.priority-medium .doc-q-priority) {
        background: var(--dm-methodology-brown-bg);
        color: var(--dm-methodology-brown);
    }

    .doc-topics :global(.priority-standard .doc-q-priority) {
        background: var(--accent-light-bg-hover);
        color: var(--color-primary);
    }

    .doc-topics :global(.doc-q-text) {
        font-size: var(--text-base);
        font-weight: var(--font-weight-semibold);
        color: var(--text-primary);
        line-height: 1.7;
        margin: 0 0 var(--spacing-sm) 0;
    }

    .doc-topics :global(.doc-q-rationale) {
        font-size: var(--text-sm);
        color: var(--text-muted);
        line-height: 1.6;
        font-style: italic;
        margin: 0;
    }

    .doc-topics :global(.doc-q-triggers) {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: var(--spacing-xs);
        margin-top: var(--spacing-sm);
        font-size: var(--text-xs);
        color: var(--text-faded);
    }

    .doc-topics :global(.doc-q-trigger-tag) {
        display: inline-block;
        padding: 1px var(--spacing-xs);
        font-size: 0.65rem;
        font-weight: var(--font-weight-semibold);
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--text-muted);
        border: 1px solid color-mix(in srgb, var(--color-primary) 15%, transparent);
        border-radius: 2px;
    }

    /* ─── V2: EXIT IMPACT BADGES ──────────────────────────────────────── */

    .doc-topics :global(.doc-q-badges) {
        display: flex;
        gap: var(--spacing-xs);
        align-items: center;
    }

    .doc-topics :global(.doc-q-exit-impact) {
        font-size: var(--text-xs);
        font-weight: var(--font-weight-bold);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 1px var(--spacing-sm);
        border-radius: 2px;
    }

    .doc-topics :global(.exit-impact-multiple-expander) {
        background: rgba(46, 139, 87, 0.12);
        color: var(--dm-success);
    }

    .doc-topics :global(.exit-impact-valuation-drag) {
        background: rgba(178, 102, 34, 0.12);
        color: var(--dm-warning-dark);
    }

    .doc-topics :global(.exit-impact-operational-risk) {
        background: rgba(178, 34, 34, 0.12);
        color: var(--dm-negative-dark);
    }

    .doc-topics :global(.doc-q-red-flag) {
        font-size: var(--text-sm);
        color: var(--dm-negative-dark);
        line-height: 1.6;
        margin: 0 0 var(--spacing-sm) 0;
        padding: var(--spacing-xs) var(--spacing-sm);
        background: var(--dm-negative-dark-bg);
        border-left: 2px solid rgba(178, 34, 34, 0.3);
        border-radius: 0 2px 2px 0;
    }

    /* ─── DOCUMENT FOOTER ──────────────────────────────────────────────── */

    .doc-footer {
        margin-top: var(--spacing-md);
        padding-top: 0;
        opacity: 0.5;
    }

    .doc-footer .doc-divider {
        margin: 0 0 var(--spacing-xs) 0;
    }

    .doc-footer-brand {
        display: flex;
        align-items: center;
        gap: var(--spacing-xs);
        margin-bottom: var(--spacing-xs);
        font-size: 0.6rem;
        font-weight: var(--font-weight-semibold);
        letter-spacing: 0.02em;
        color: var(--text-secondary);
    }

    .doc-footer-brand img {
        width: 10px;
        height: 10px;
    }

    .doc-footer-disclaimer {
        font-size: 0.6rem;
        color: var(--text-muted);
        line-height: 1.4;
        margin: 0;
        text-transform: none;
    }

    /* ─── METHODOLOGY ──────────────────────────────────────────────────── */

    .dm-methodology {
        margin-top: var(--spacing-2xl);
        border-top: 1px solid color-mix(in srgb, var(--color-primary) 6%, transparent);
    }

    .dm-methodology__trigger {
        display: flex;
        align-items: center;
        gap: var(--spacing-sm);
        padding: var(--spacing-sm) var(--spacing-lg);
        cursor: pointer;
        color: var(--text-muted);
        transition: color var(--transition-fast);
        list-style: none;
        font-size: var(--text-xs);
        font-weight: var(--font-weight-bold);
        letter-spacing: 0.1em;
        text-transform: uppercase;
    }

    .dm-methodology__trigger::-webkit-details-marker {
        display: none;
    }

    .dm-methodology__trigger::before {
        content: '';
        display: inline-block;
        width: 10px;
        height: 10px;
        background-color: var(--color-primary);
        mask-image: url('/images/logo/gst-delta-icon-teal-stroke-thick.svg');
        mask-size: contain;
        mask-repeat: no-repeat;
        -webkit-mask-image: url('/images/logo/gst-delta-icon-teal-stroke-thick.svg');
        -webkit-mask-size: contain;
        -webkit-mask-repeat: no-repeat;
        transition: transform var(--transition-fast);
    }

    .dm-methodology[open] > .dm-methodology__trigger::before {
        transform: rotate(180deg);
    }

    .dm-methodology__trigger:hover {
        color: var(--text-secondary);
    }

    .dm-methodology__body {
        padding: var(--spacing-sm) var(--spacing-2xl) var(--spacing-md);
        color: var(--text-secondary);
        line-height: 1.7;
        border-top: 1px solid color-mix(in srgb, var(--color-primary) 6%, transparent);
    }

    .dm-methodology__heading {
        font-size: var(--text-sm);
        font-weight: var(--font-weight-bold);
        letter-spacing: 0.05em;
        text-transform: uppercase;
        color: var(--text-primary);
        margin-top: var(--spacing-md);
        margin-bottom: var(--spacing-xs);
    }

    .dm-methodology__heading:first-child {
        margin-top: 0;
    }

    .dm-methodology__body p {
        margin-bottom: var(--spacing-sm);
    }

    .dm-methodology__updated {
        font-size: var(--text-xs);
        color: var(--text-faded);
        font-style: italic;
        margin-top: var(--spacing-sm);
    }

    .dm-methodology__author {
        display: flex;
        align-items: baseline;
        gap: var(--spacing-sm);
        flex-wrap: wrap;
        padding-top: var(--spacing-md);
        margin-top: var(--spacing-md);
        border-top: 1px solid color-mix(in srgb, var(--color-primary) 6%, transparent);
        font-size: var(--text-xs);
        color: var(--text-muted);
    }

    .dm-methodology__author-name {
        font-weight: var(--font-weight-semibold);
        color: var(--text-secondary);
    }

    .dm-methodology__author-sep {
        color: var(--text-faded);
    }

    .dm-methodology__author-link {
        color: var(--color-primary);
        text-decoration: none;
    }

    .dm-methodology__author-link:hover {
        text-decoration: underline;
    }

    /* ─── BACK LINK ────────────────────────────────────────────────────── */

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-sm);
        margin-top: var(--spacing-3xl);
        font-size: var(--text-sm);
        font-weight: var(--font-weight-semibold);
        color: var(--text-muted);
        text-decoration: none;
        transition: color var(--transition-fast);
    }

    .back-link:hover {
        color: var(--color-primary);
    }

    /* ─── RESPONSIVE ───────────────────────────────────────────────────── */

    @media (min-width: 768px) {
        .diligence-machine {
            padding: var(--spacing-2_5xl) 0;
        }

        /* Expand wizard step width on tablet+ for better multi-column layout */
        .wizard-step {
            max-width: 700px;
        }

        /* Headcount (4 options): 2 columns in 2x2 grid */
        .field-options-grid[data-field-id="headcount"] {
            grid-template-columns: repeat(2, 1fr);
        }

        /* Revenue Range (4 options): 2 columns in 2x2 grid */
        .field-options-grid[data-field-id="revenue-range"] {
            grid-template-columns: repeat(2, 1fr);
        }

        /* Growth Stage (3 options): 3 columns in single row */
        .field-options-grid[data-field-id="growth-stage"] {
            grid-template-columns: repeat(3, 1fr);
        }

        /* Company Age (5 options): 3 columns (2-2-1 layout) */
        .field-options-grid[data-field-id="company-age"] {
            grid-template-columns: repeat(3, 1fr);
        }
    }

    @media (min-width: 1024px) {
        /* Desktop: even wider for optimal spacing */
        .wizard-step {
            max-width: 800px;
        }

        /* Headcount (4 options): 4 columns in single row */
        .field-options-grid[data-field-id="headcount"] {
            grid-template-columns: repeat(4, 1fr);
        }

        /* Revenue Range (4 options): 4 columns in single row */
        .field-options-grid[data-field-id="revenue-range"] {
            grid-template-columns: repeat(4, 1fr);
        }

        /* Company Age (5 options): 5 columns in single row */
        .field-options-grid[data-field-id="company-age"] {
            grid-template-columns: repeat(5, 1fr);
        }
    }

    @media (max-width: 480px) {
        .diligence-machine {
            padding: var(--spacing-2xl) 0;
        }

        .wizard-progress {
            display: none;
        }

        .wizard-progress-mobile {
            display: flex;
        }

        .option-card {
            padding: var(--spacing-lg);
        }

        .compound-fields-grid {
            gap: var(--spacing-2xl);
        }

        .field-section-label {
            font-size: 0.8rem;
        }

        .wizard-nav {
            flex-direction: column;
        }

        /* Document output mobile overrides */
        .doc-page {
            padding: var(--spacing-md) var(--spacing-sm);
        }

        .doc-divider {
            margin-left: var(--spacing-md);
            margin-right: var(--spacing-md);
        }

        .doc-title {
            font-size: var(--text-xl);
        }

        .doc-page :global(.doc-section-subtitle) {
            padding-left: var(--spacing-md);
            font-size: 0.7rem;
        }

        .doc-meta :global(.doc-meta-grid) {
            grid-template-columns: repeat(2, 1fr);
            padding: 0 var(--spacing-md);
            gap: var(--spacing-xs);
        }

        .doc-meta :global(.doc-meta-card--identifier) {
            grid-column: 1 / -1;
            align-items: center;
            text-align: center;
        }

        .doc-meta :global(.doc-meta-card--identifier .doc-meta-label) {
            font-size: var(--text-sm);
        }

        .doc-meta :global(.doc-meta-identifier-input) {
            text-align: center;
            font-size: var(--text-xl);
            width: 100%;
        }

        /* Reset desktop column alignment for 2-col mobile grid */
        .doc-meta :global(.doc-meta-card--col2),
        .doc-meta :global(.doc-meta-card--col3) {
            align-items: flex-start;
            text-align: left;
        }

        /* Right-align second column in 2-col grid */
        .doc-meta :global(.doc-meta-card:nth-child(2n + 1):not(.doc-meta-card--identifier)) {
            align-items: flex-end;
            text-align: right;
        }

        .doc-meta :global(.doc-meta-actions) {
            flex-direction: column;
            padding: 0 var(--spacing-md);
            gap: var(--spacing-sm);
            align-items: stretch;
        }

        .doc-meta :global(.doc-meta-cta-button) {
            white-space: normal;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .doc-toc :global(.doc-toc-list) {
            flex-wrap: wrap;
        }

        .doc-toc :global(.doc-toc-link) {
            border-left: none;
        }

        .doc-attention-grid {
            padding: 0 var(--spacing-md);
        }

        .doc-action-bar {
            flex-wrap: wrap;
            margin-left: var(--spacing-sm);
            margin-right: var(--spacing-sm);
        }

        .doc-action-btn {
            flex: 1 1 auto;
        }

        .doc-topics :global(.doc-topic-header) {
            margin-left: var(--spacing-md);
            margin-right: var(--spacing-md);
        }

        .doc-topics :global(.doc-topic-label-row) {
            flex-direction: column;
            align-items: flex-start;
            gap: var(--spacing-xs);
        }

        /* Tighten question list spacing on mobile */
        .doc-topics :global(.doc-questions) {
            gap: var(--spacing-sm);
            margin-left: var(--spacing-sm);
            margin-right: var(--spacing-sm);
        }

        .doc-topics :global(.doc-question) {
            padding: var(--spacing-md);
        }

        .doc-topics :global(.doc-question.is-collapsed) {
            padding: var(--spacing-sm) var(--spacing-md);
        }

        .doc-attention-grid :global(.doc-attention-card.is-collapsed) {
            padding: var(--spacing-sm) var(--spacing-md);
        }

        /* Collapsed cards: title-only on mobile */
        .doc-attention-grid :global(.is-collapsed .doc-attention-desc) {
            display: none;
        }

        .doc-attention-grid :global(.is-collapsed .doc-attention-title) {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        :global(.doc-question.is-collapsed .doc-q-text) {
            font-size: var(--text-xs);
        }
    }

    /* ─── PRINT ────────────────────────────────────────────────────────── */

    @media print {
        /* Page setup */
        html, body {
            height: auto;
        }

        .wizard-container,
        .wizard-nav,
        .doc-action-bar,
        .back-link,
        .tool-authority,
        .dm-methodology {
            display: none;
        }

        .doc-meta :global(.doc-meta-actions) {
            display: none;
        }

