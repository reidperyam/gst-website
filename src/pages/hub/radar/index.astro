---
/**
 * /hub/radar — The Radar: Curated Intelligence Feed
 *
 * SERVER-RENDERED with ISR. This page fetches from the Inoreader API
 * at render time and is cached by Vercel for the configured revalidation
 * interval. No build-time data files needed.
 *
 * Content tiers:
 *   1. Signals — Original markdown posts (from content collection)
 *   2. Featured — Annotated items from Inoreader (highlights + GST Take)
 *   3. Stream — Automated RSS from Inoreader subscriptions
 */
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import RadarHeader from '../../../components/radar/RadarHeader.astro';
import SignalCard from '../../../components/radar/SignalCard.astro';
import FeaturedItem from '../../../components/radar/FeaturedItem.astro';
import StreamItem from '../../../components/radar/StreamItem.astro';
import CategoryFilter from '../../../components/radar/CategoryFilter.astro';

import { fetchAnnotatedItems, fetchAllStreams } from '../../../lib/inoreader/client';
import { toFeaturedItem, toStreamItem, CATEGORIES } from '../../../lib/inoreader/transform';
import { getCollection } from 'astro:content';
import { trackPageView } from '../../../utils/analytics';

import type { RadarFeaturedItem, RadarStreamItem } from '../../../lib/inoreader/types';

trackPageView('hub-radar', 'The Radar - Perspectives | GST');

// --- Data Fetching (runs on Vercel at revalidation time) ---

// Tier 3: Signal posts from content collection
const allSignals = await getCollection('signals');
const signals = allSignals
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

// Tier 2: Featured items (annotated in Inoreader)
let featured: RadarFeaturedItem[] = [];
try {
  const annotatedResponse = await fetchAnnotatedItems(30);
  if (annotatedResponse) {
    featured = annotatedResponse.items
      .map(toFeaturedItem)
      .filter((item): item is RadarFeaturedItem => item !== null);
  }
} catch (e) {
  console.error('[Radar] Featured items fetch failed:', e);
}

// Tier 1: Automated stream from all GST folders
let stream: RadarStreamItem[] = [];
try {
  const folderPrefix = import.meta.env.INOREADER_FOLDER_PREFIX || 'GST-';
  const streamsResponse = await fetchAllStreams(folderPrefix, 15);
  if (streamsResponse) {
    const featuredUrls = new Set(featured.map(f => f.url));
    stream = streamsResponse.items
      .filter(item => {
        const url = item.canonical?.[0]?.href || item.alternate?.[0]?.href || '';
        return !featuredUrls.has(url);
      })
      .map(toStreamItem);
  }
} catch (e) {
  console.error('[Radar] Stream fetch failed:', e);
}

const lastUpdated = new Date();
---

<BaseLayout
  title="The Radar — Technology & M&A Intelligence | GST"
  description="Curated intelligence on technology trends, M&A dynamics, and enterprise technology shifts. Practitioner perspectives from 50+ PE technology engagements."
  ogTitle="The Radar - Perspectives | GST"
  ogDescription="Curated technology and M&A intelligence for PE investors and portfolio company leaders."
  ogImage="/og-image.png"
  ogUrl="https://globalstrategic.tech/hub/radar"
>
  <div class="radar-container">
    <div class="container">
      <RadarHeader />

      <CategoryFilter categories={CATEGORIES} />

      {/* Tier 3: Signal Posts (most prominent) */}
      {signals.length > 0 && (
        <section class="radar-section" id="signals">
          <div class="section-header">
            <h2 class="section-label">Signals</h2>
            <p class="section-description">Original perspectives on emerging patterns</p>
          </div>
          <div class="signals-grid">
            {signals.slice(0, 3).map(signal => (
              <SignalCard signal={signal} />
            ))}
          </div>
        </section>
      )}

      {/* Tier 2: Featured Items (annotated with GST Take) */}
      {featured.length > 0 && (
        <section class="radar-section" id="featured">
          <div class="section-header">
            <h2 class="section-label">Featured</h2>
            <p class="section-description">Curated reads with practitioner context</p>
          </div>
          <div class="featured-list">
            {featured.map(item => (
              <FeaturedItem item={item} />
            ))}
          </div>
        </section>
      )}

      {/* Tier 1: Automated Stream */}
      {stream.length > 0 && (
        <section class="radar-section" id="stream">
          <div class="section-header">
            <h2 class="section-label">Stream</h2>
            <p class="section-description">Latest from tracked sources</p>
          </div>
          <div class="stream-list">
            {stream.slice(0, 30).map(item => (
              <StreamItem item={item} />
            ))}
          </div>
        </section>
      )}

      {/* Fallback if no content available */}
      {featured.length === 0 && stream.length === 0 && signals.length === 0 && (
        <section class="radar-section radar-empty">
          <p>Intelligence feed is currently being refreshed. Check back shortly.</p>
        </section>
      )}

      <footer class="radar-footer">
        <p class="last-updated">
          Updated {lastUpdated.toLocaleDateString('en-US', {
            month: 'short', day: 'numeric', year: 'numeric',
            hour: 'numeric', minute: '2-digit'
          })}
        </p>
        <a href="/hub" class="cta-button secondary">Return to Hub</a>
      </footer>
    </div>
  </div>
</BaseLayout>

<style>
  .radar-container {
    padding-bottom: var(--spacing-3xl);
  }

  .radar-section {
    margin-bottom: var(--spacing-3xl);
  }

  .section-header {
    margin-bottom: var(--spacing-xl);
  }

  .section-label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-light-muted);
    margin-bottom: 0.25rem;
  }

  .section-description {
    font-size: var(--text-sm);
    color: var(--text-light-secondary);
  }

  .signals-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
  }

  @media (min-width: 768px) {
    .signals-grid {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    }
  }

  .radar-empty {
    padding: var(--spacing-3xl) 0;
    text-align: center;
    color: var(--text-light-muted);
  }

  .radar-footer {
    padding: var(--spacing-xl) 0;
    border-top: 1px solid var(--border-light);
    margin-top: var(--spacing-2xl);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .last-updated {
    font-size: var(--text-xs);
    color: var(--text-light-muted);
  }

  :global(html.dark-theme) .radar-footer {
    border-top-color: var(--border-dark);
  }

  @media (max-width: 480px) {
    .radar-footer {
      flex-direction: column;
      gap: var(--spacing-lg);
      align-items: flex-start;
    }
  }
</style>
