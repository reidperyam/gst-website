---
/**
 * /hub/radar — The Radar: Curated Intelligence Feed
 *
 * SERVER-RENDERED with ISR. This page fetches from the Inoreader API
 * at render time and is cached by Vercel for the configured revalidation
 * interval. No build-time data files needed.
 *
 * Content tiers:
 *   1. Signals — Original markdown posts (from content collection)
 *   2. FYI — Annotated items from Inoreader (highlights + GST Take)
 *   3. The Wire — Automated RSS from Inoreader subscriptions
 */
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import RadarHeader from '../../../components/radar/RadarHeader.astro';
import SignalCard from '../../../components/radar/SignalCard.astro';
import FyiItem from '../../../components/radar/FyiItem.astro';
import WireItem from '../../../components/radar/WireItem.astro';
import CategoryFilter from '../../../components/radar/CategoryFilter.astro';

import { fetchAnnotatedItems, fetchAllStreams } from '../../../lib/inoreader/client';
import { toFyiItem, toWireItem, CATEGORIES } from '../../../lib/inoreader/transform';
import { getCollection } from 'astro:content';
import { trackPageView } from '../../../utils/analytics';

import type { RadarFyiItem, RadarWireItem } from '../../../lib/inoreader/types';

trackPageView('hub-radar', 'The Radar - Perspectives | GST');

// --- Data Fetching (runs on Vercel at revalidation time) ---

// Tier 1: Signal posts from content collection
const allSignals = await getCollection('signals');
const signals = allSignals
  .sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

// Tier 2: FYI items (annotated in Inoreader)
let fyi: RadarFyiItem[] = [];
try {
  const annotatedResponse = await fetchAnnotatedItems(30);
  if (annotatedResponse) {
    fyi = annotatedResponse.items
      .map(toFyiItem)
      .filter((item): item is RadarFyiItem => item !== null);
  }
} catch (e) {
  console.error('[Radar] FYI items fetch failed:', e);
}

// Tier 3: The Wire — automated feed from all GST folders
let wire: RadarWireItem[] = [];
try {
  const folderPrefix = import.meta.env.INOREADER_FOLDER_PREFIX || 'GST-';
  const streamsResponse = await fetchAllStreams(folderPrefix, 15);
  if (streamsResponse) {
    const fyiUrls = new Set(fyi.map(f => f.url));
    const allWireItems = streamsResponse.items
      .filter(item => {
        const url = item.canonical?.[0]?.href || item.alternate?.[0]?.href || '';
        return !fyiUrls.has(url);
      })
      .map(toWireItem);

    // Guarantee each category is represented before filling chronologically.
    // Without this, categories with older items get pushed past the display cap.
    const MIN_PER_CATEGORY = 3;
    const MAX_WIRE = 30;
    const picked = new Set<string>();
    const result: RadarWireItem[] = [];

    // Pass 1: pick up to MIN_PER_CATEGORY items per category (newest first)
    const categoryKeys = Object.keys(CATEGORIES);
    for (const cat of categoryKeys) {
      let count = 0;
      for (const item of allWireItems) {
        if (item.category === cat && count < MIN_PER_CATEGORY) {
          picked.add(item.id);
          result.push(item);
          count++;
        }
      }
    }

    // Pass 2: fill remaining slots chronologically from unpicked items
    for (const item of allWireItems) {
      if (result.length >= MAX_WIRE) break;
      if (!picked.has(item.id)) {
        result.push(item);
      }
    }

    // Sort final set by date so the display order stays chronological
    wire = result.sort((a, b) =>
      new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
    );
  }
} catch (e) {
  console.error('[Radar] Wire fetch failed:', e);
}

const lastUpdated = new Date();
---

<BaseLayout
  title="The Radar — Technology & M&A Intelligence | GST"
  description="Curated intelligence on technology trends, M&A dynamics, and enterprise technology shifts. Practitioner perspectives from 50+ PE technology engagements."
  ogTitle="The Radar - Perspectives | GST"
  ogDescription="Curated technology and M&A intelligence for PE investors and portfolio company leaders."
  ogImage="/og-image.png"
  ogUrl="https://globalstrategic.tech/hub/radar"
>
  <div class="radar-container">
    <div class="container">
      <RadarHeader />

      <CategoryFilter categories={CATEGORIES} />

      {/* Tier 1: Signal Posts (most prominent) */}
      {signals.length > 0 && (
        <section class="radar-section radar-section--signals" id="signals">
          <details class="radar-section__details" data-section="signals">
            <summary class="section-header">
              <span class="section-toggle" aria-hidden="true"></span>
              <div class="section-header__text">
                <h2 class="section-label">Δ Signals</h2>
                <p class="section-description">Original analysis from GST</p>
              </div>
            </summary>
            <div class="signals-grid">
              {signals.slice(0, 3).map(signal => (
                <SignalCard signal={signal} />
              ))}
            </div>
          </details>
        </section>
      )}

      {/* Tier 2: FYI Items (annotated with GST Take) */}
      {fyi.length > 0 && (
        <section class="radar-section radar-section--fyi" id="fyi">
          <details class="radar-section__details" data-section="fyi">
            <summary class="section-header">
              <span class="section-toggle" aria-hidden="true"></span>
              <div class="section-header__text">
                <h2 class="section-label">
                  Δ FYI
                  <span class="section-count">({fyi.length})</span>
                </h2>
                <p class="section-description">Curated reads with our commentary</p>
              </div>
            </summary>
            <div class="fyi-list">
              {fyi.map(item => (
                <FyiItem item={item} />
              ))}
            </div>
          </details>
        </section>
      )}

      {/* Tier 3: The Wire — Automated Feed */}
      {wire.length > 0 && (
        <section class="radar-section radar-section--wire" id="wire">
          <details class="radar-section__details" data-section="wire">
            <summary class="section-header">
              <span class="section-toggle" aria-hidden="true"></span>
              <div class="section-header__text">
                <h2 class="section-label">Δ The Wire</h2>
                <p class="section-description">Latest from tracked sources</p>
              </div>
            </summary>
            <div class="wire-list">
              {wire.map(item => (
                <WireItem item={item} />
              ))}
            </div>
          </details>
        </section>
      )}

      {/* Fallback if no content available */}
      {fyi.length === 0 && wire.length === 0 && signals.length === 0 && (
        <section class="radar-section radar-empty">
          <p>Intelligence feed is currently being refreshed. Check back shortly.</p>
        </section>
      )}

      <footer class="radar-footer">
        <a href="/hub" class="cta-button secondary">&larr; Return to Hub</a>
        <p class="last-updated">
          Updated {lastUpdated.toLocaleDateString('en-US', {
            month: 'short', day: 'numeric', year: 'numeric',
            hour: 'numeric', minute: '2-digit'
          })}
        </p>
      </footer>
    </div>
  </div>
</BaseLayout>

<script>
  const STORAGE_KEY = 'radar-sections';

  function restoreSectionStates() {
    try {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (!saved) return;

      const states: Record<string, boolean> = JSON.parse(saved);
      for (const [section, isOpen] of Object.entries(states)) {
        const el = document.querySelector<HTMLDetailsElement>(
          `.radar-section__details[data-section="${section}"]`
        );
        if (el) el.open = isOpen;
      }
    } catch {
      // Ignore corrupted localStorage
    }
  }

  function saveSectionStates() {
    try {
      const details = document.querySelectorAll<HTMLDetailsElement>('.radar-section__details');
      const states: Record<string, boolean> = {};
      details.forEach(el => {
        const key = el.dataset.section;
        if (key) states[key] = el.open;
      });
      localStorage.setItem(STORAGE_KEY, JSON.stringify(states));
    } catch {
      // Ignore if localStorage is unavailable
    }
  }

  // Restore saved states on load
  restoreSectionStates();

  // Save state whenever a section is toggled
  document.querySelectorAll('.radar-section__details').forEach(el => {
    el.addEventListener('toggle', saveSectionStates);
  });
</script>

<style>
  .radar-container {
    padding-bottom: var(--spacing-3xl);
  }

  .radar-section {
    margin-bottom: var(--spacing-3xl);
  }

  /* --- Details/Summary reset --- */

  .radar-section__details {
    border: none;
  }

  .radar-section__details summary {
    list-style: none;
    cursor: pointer;
  }

  .radar-section__details summary::-webkit-details-marker {
    display: none;
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  .section-header__text {
    flex: 1;
    min-width: 0;
  }

  .section-toggle {
    flex-shrink: 0;
    font-size: var(--text-lg);
    font-weight: var(--font-weight-bold);
    color: var(--text-light-muted);
    width: 1.5em;
    text-align: center;
    line-height: 1;
    transition: color var(--transition-fast);
  }

  .section-toggle::before {
    content: "+";
  }

  .radar-section__details[open] .section-toggle::before {
    content: "\2212";
  }

  .section-header:hover .section-toggle {
    color: var(--color-primary);
  }

  /* Hide content spacing when collapsed */
  .radar-section__details:not([open]) .section-header {
    margin-bottom: 0;
  }

  .section-label {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-light-muted);
    margin-bottom: 0.25rem;
  }

  .section-count {
    font-weight: var(--font-weight-normal);
    text-transform: none;
    letter-spacing: normal;
    font-size: var(--text-xs);
  }

  .section-description {
    font-size: var(--text-sm);
    color: var(--text-light-secondary);
  }

  /* --- Per-section visual identity --- */

  .radar-section--signals .section-label {
    color: var(--color-primary);
    border-left: 3px solid var(--color-primary);
    padding-left: var(--spacing-md);
  }

  .radar-section--fyi {
    background: var(--accent-light-bg);
    border: 1px solid var(--border-light);
    padding: var(--spacing-xl);
  }

  .radar-section--fyi .section-label {
    color: var(--text-light-primary);
    border-left: 3px dashed var(--color-primary);
    padding-left: var(--spacing-md);
  }

  .radar-section--wire .section-label {
    color: var(--text-light-muted);
    border-left: 3px dotted var(--text-light-muted);
    padding-left: var(--spacing-md);
  }

  /* --- Content grids/lists --- */

  .signals-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xl);
  }

  @media (min-width: 768px) {
    .signals-grid {
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    }
  }

  .radar-empty {
    padding: var(--spacing-3xl) 0;
    text-align: center;
    color: var(--text-light-muted);
  }

  .radar-footer {
    margin-top: var(--spacing-3xl);
    padding: var(--spacing-2xl) 0;
    background: transparent;
    border-top: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-lg);
  }

  .last-updated {
    font-size: var(--text-xs);
    color: var(--text-light-muted);
  }

  /* --- Dark theme --- */

  :global(html.dark-theme) .radar-section--fyi {
    border-color: var(--border-dark);
  }

  /* --- Mobile --- */

  @media (max-width: 480px) {
    .radar-section--fyi {
      padding: var(--spacing-md);
    }

    .section-label {
      font-size: var(--text-xs);
    }
  }
</style>
