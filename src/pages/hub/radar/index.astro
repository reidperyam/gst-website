---
/**
 * /hub/radar — The Radar: Curated Intelligence Feed
 *
 * SERVER-RENDERED with ISR. The page shell (header, nav, category filter)
 * renders instantly. The feed content is a server island (`server:defer`)
 * that fetches from the Inoreader API and streams in when ready.
 *
 * Content tiers (rendered in a single unified feed):
 *   1. FYI — Annotated items from Inoreader (highlights + GST Take)
 *   2. The Wire — Automated RSS from Inoreader subscriptions
 */
export const prerender = false;

import BaseLayout from '../../../layouts/BaseLayout.astro';
import RadarHeader from '../../../components/radar/RadarHeader.astro';
import RadarFeed from '../../../components/radar/RadarFeed.astro';
import RadarFeedSkeleton from '../../../components/radar/RadarFeedSkeleton.astro';
import CategoryFilter from '../../../components/radar/CategoryFilter.astro';

import { CATEGORIES } from '../../../lib/inoreader/transform';
import { trackPageView } from '../../../utils/analytics';
import DeltaIcon from '../../../components/DeltaIcon.astro';

trackPageView('hub-radar', 'The Radar - Perspectives | GST');
---

<BaseLayout
  title="The Radar — Technology & M&A Intelligence | GST"
  description="Curated intelligence on technology trends, M&A dynamics, and enterprise technology shifts. Practitioner perspectives from 50+ PE technology engagements."
  ogTitle="The Radar - Perspectives | GST"
  ogDescription="Curated technology and M&A intelligence for PE investors and portfolio company leaders."
  ogImage="/og-image.png"
>
  <!-- Print-only report header (hidden on screen) -->
  <div class="print-report-header" aria-hidden="true">
    <div class="print-report-header__brand">
      <DeltaIcon class="bullet-icon" />
      <span>GST</span>
    </div>
    <div class="print-report-header__title">The Radar</div>
    <div class="print-report-header__date">Generated {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
  </div>

  <div class="radar-container">
    <div class="container">
      <RadarHeader />

      <CategoryFilter categories={CATEGORIES} />

      <RadarFeed server:defer>
        <RadarFeedSkeleton slot="fallback" />
      </RadarFeed>

      <a href="/hub" class="cta-button secondary">Return to Hub</a>
    </div>
  </div>
</BaseLayout>

<style>
  .radar-container {
    padding-bottom: var(--spacing-3xl);
  }

  @media print {
    .category-filter,
    .cta-button {
      display: none;
    }

    .radar-container {
      padding: 0;
    }

    @page {
      margin: 1.5cm;
    }
  }
</style>
