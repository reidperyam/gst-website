---
/**
 * Individual Signal post pages.
 * Static-rendered at build time via getStaticPaths.
 */
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { trackPageView } from '../../../../utils/analytics';

export async function getStaticPaths() {
  const signals = await getCollection('signals');
  return signals.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

trackPageView(`signal-${post.id}`, `${post.data.title} | GST`);

const pubDate = new Date(post.data.publishedAt);
const dateStr = pubDate.toLocaleDateString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric'
});
---

<BaseLayout
  title={`${post.data.title} | The Radar`}
  description={post.data.description}
  ogTitle={post.data.title}
  ogDescription={post.data.description}
  ogImage="/og-image.png"
  ogUrl={`https://globalstrategic.tech/hub/radar/signals/${post.id}`}
>
  <article class="signal-article">
    <div class="container">
      <nav class="signal-breadcrumb">
        <a href="/hub">Hub</a>
        <span class="separator">/</span>
        <a href="/hub/radar">The Radar</a>
        <span class="separator">/</span>
        <span>Signal</span>
      </nav>

      <header class="signal-header">
        <span class="signal-label">Δ Signal</span>
        <h1>{post.data.title}</h1>
        <div class="signal-meta">
          <time datetime={pubDate.toISOString()}>{dateStr}</time>
          <span class="signal-category">{post.data.category}</span>
        </div>
        {post.data.tags.length > 0 && (
          <div class="signal-tags">
            {post.data.tags.map(tag => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </header>

      <div class="signal-content">
        <Content />
      </div>

      <footer class="signal-footer">
        <a href="/hub/radar" class="cta-button secondary">Back to Radar</a>
      </footer>
    </div>
  </article>
</BaseLayout>

<style>
  .signal-article {
    padding-bottom: var(--spacing-3xl);
  }

  .signal-breadcrumb {
    font-size: var(--text-sm);
    color: var(--text-light-muted);
    padding: var(--spacing-xl) 0 var(--spacing-2xl);
  }

  .signal-breadcrumb a {
    color: var(--color-primary);
    text-decoration: none;
    transition: opacity var(--transition-fast);
  }

  .signal-breadcrumb a:hover {
    opacity: 0.8;
  }

  .signal-breadcrumb .separator {
    margin: 0 var(--spacing-sm);
  }

  .signal-header {
    margin-bottom: var(--spacing-2xl);
    padding-bottom: var(--spacing-xl);
    border-bottom: 1px solid var(--border-light);
  }

  .signal-label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    display: block;
    margin-bottom: var(--spacing-md);
  }

  .signal-header h1 {
    font-size: 2rem;
    font-weight: var(--font-weight-bold);
    color: var(--text-light-primary);
    line-height: 1.3;
    margin-bottom: var(--spacing-lg);
  }

  .signal-meta {
    font-size: var(--text-sm);
    color: var(--text-light-muted);
    display: flex;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-md);
  }

  .signal-category {
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: var(--text-xs);
  }

  .signal-tags {
    display: flex;
    gap: var(--spacing-sm);
  }

  .tag {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-light-muted);
    border: 1px solid var(--border-light);
    padding: 0.125rem var(--spacing-xs);
  }

  .signal-content {
    max-width: 680px;
    line-height: 1.8;
    color: var(--text-light-primary);
    font-size: var(--text-base);
  }

  .signal-content :global(p) {
    margin-bottom: var(--spacing-xl);
  }

  .signal-content :global(h2) {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: var(--text-light-primary);
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-lg);
  }

  .signal-content :global(h3) {
    font-size: var(--text-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--text-light-primary);
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-md);
  }

  .signal-content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: var(--spacing-lg);
    margin: var(--spacing-xl) 0;
    font-style: italic;
    color: var(--text-light-secondary);
  }

  .signal-content :global(ul),
  .signal-content :global(ol) {
    padding-left: var(--spacing-xl);
    margin-bottom: var(--spacing-xl);
  }

  .signal-content :global(li) {
    margin-bottom: var(--spacing-sm);
  }

  .signal-footer {
    padding-top: var(--spacing-2xl);
    margin-top: var(--spacing-2xl);
    border-top: 1px solid var(--border-light);
  }

  :global(html.dark-theme) .signal-header {
    border-bottom-color: var(--border-dark);
  }

  :global(html.dark-theme) .tag {
    border-color: var(--border-dark);
  }

  :global(html.dark-theme) .signal-footer {
    border-top-color: var(--border-dark);
  }

  @media (max-width: 768px) {
    .signal-header h1 {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .signal-header h1 {
      font-size: 1.25rem;
    }

    .signal-meta {
      flex-direction: column;
      gap: var(--spacing-sm);
    }
  }
</style>
