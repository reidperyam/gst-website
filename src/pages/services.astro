---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import CTASection from '../components/CTASection.astro';
import EngagementFlow from '../components/EngagementFlow.astro';
import { trackPageView } from '../utils/analytics';

// Track page view
trackPageView('services', 'Services | Strategic Advisory & Implementation');

const faqItems = [
    {
        question: "What's the difference between buy-side and sell-side diligence?",
        answer: "<p><strong>Buy-side</strong> diligence is for investors or companies acquiring a business. Is the technology sound? What will it cost to integrate, maintain, or scale? Where are the hidden risks, and where are the untapped opportunities that could accelerate growth after close (value creation)? We give you the full picture so you can negotiate from a position of knowledge.</p><p><strong>Sell-side</strong> diligence is for founders and executives preparing to sell their company. The objective is to maximize the valuation of the company's technology in the eyes of external investors. Buyers will scrutinize everything, and unresolved issues like technical debt, security gaps, or poor documentation can reduce your price or kill a deal entirely. We work with you before going to market to fix those issues proactively, so your technology becomes a selling point rather than a liability.</p>"
    },
    {
        question: "What is value creation?",
        answer: "Value creation is the process of leveraging technology to grow the business after an acquisition or investment. This can mean scaling operations to handle more customers without proportional cost increases, unlocking new revenue streams through platform capabilities, expanding market share by shipping faster than competitors, or reducing operational overhead through automation. In a PE context, value creation is where the real returns come from, not just cutting costs, but building the technology foundation that compounds growth across the hold period."
    },
    {
        question: "What does a technology due diligence engagement include?",
        answer: "A typical engagement includes a comprehensive review of the target's architecture, infrastructure, security posture, development practices, and technical team. We deliver a detailed findings report with risk quantification, remediation cost estimates, and a prioritized integration roadmap tailored to your investment thesis."
    },
    {
        question: "How long does a typical buy-side diligence take?",
        answer: "Most buy-side technical diligence engagements are completed in three to six weeks, depending on the complexity of the target's technology stack and the availability of key personnel. We can accommodate accelerated timelines for competitive deal processes when needed."
    },
    {
        question: "Do you work with companies outside the US?",
        answer: "Yes. We regularly support cross-border transactions and have conducted diligence on targets across North America, Europe, and Asia-Pacific. Our frameworks are designed to evaluate distributed teams, multi-region infrastructure, and varying regulatory environments."
    },
];
---

<BaseLayout
    title="Services | GST"
    description="GST's technology advisory, M&A services, and leadership offerings to create value and accelerate business objectives."
    ogTitle="Technology Advisory Services | GST"
    ogDescription="M&A advisory, product development, and technical leadership for high-stakes environments."
    ogImage="/og-image.png"
    ogImageAlt="GST Services - M&A Advisory, Product Development, Technical Leadership"
    faqItems={faqItems}
>
    <!-- Print-only report header (hidden on screen) -->
    <div class="print-report-header" aria-hidden="true">
        <div class="print-report-header__brand">
            <img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" width="24" height="24" />
            <span>GST</span>
        </div>
        <div class="print-report-header__title">Services</div>
        <div class="print-report-header__date">Generated {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</div>
    </div>

    <Hero
        title="Technology Advisory & Execution"
        subtitle="for High-Stakes Environments"
        description="Fit-to-need solutions for value creation, risk management, and business acceleration"
    />

    <section class="services-section">
        <div class="container">
            <div class="services-cards">
                <div class="service-card">
                    <h3>M&A Advisory</h3>
                    <span class="service-subtitle">Buy Side, Sell Side, Value Creation</span>
                    <ul class="service-list">
                        <li><img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" class="bullet-icon" aria-hidden="true" loading="lazy" /><span>Buy-side: quantify the true costs, risks and opportunities before you sign</span></li>
                        <li><img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" class="bullet-icon" aria-hidden="true" loading="lazy" /><span>Sell-side: prepare founders 6 to 3 months before exit to maximize valuation</span></li>
                        <li><img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" class="bullet-icon" aria-hidden="true" loading="lazy" /><span>Buy-side & Sell-side: Identify hidden technical debt, security exposures, and compliance gaps that erode deal value</span></li>
                        <li><img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" class="bullet-icon" aria-hidden="true" loading="lazy" /><span>Buy-side & Sell-side: Flag architecture challenges and opportunities, and harden security posture pre-transaction</span></li>
                    </ul>
                </div>
                <div class="service-card">
                    <h3>Product Development</h3>
                    <span class="service-subtitle">Engineering Excellence</span>
                    <ul class="service-list">
                        <li><img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" class="bullet-icon" aria-hidden="true" loading="lazy" /><span>Remediate legacy monolithic architectures into scalable, maintainable systems</span></li>
                        <li><img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" class="bullet-icon" aria-hidden="true" loading="lazy" /><span>Multi-region cloud infrastructure and platform engineering</span></li>
                        <li><img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" class="bullet-icon" aria-hidden="true" loading="lazy" /><span>CI/CD pipeline acceleration and SDLC optimization</span></li>
                        <li><img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" class="bullet-icon" aria-hidden="true" loading="lazy" /><span>Compress release cycles from quarters to weeks</span></li>
                    </ul>
                </div>
                <div class="service-card">
                    <h3>Technical Leadership</h3>
                    <span class="service-subtitle">Strategic Partnership</span>
                    <ul class="service-list">
                        <li><img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" class="bullet-icon" aria-hidden="true" loading="lazy" /><span>Fractional CTO advisory for rapid scaling and platform migrations</span></li>
                        <li><img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" class="bullet-icon" aria-hidden="true" loading="lazy" /><span>Board-level technical communication and reporting</span></li>
                        <li><img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" class="bullet-icon" aria-hidden="true" loading="lazy" /><span>Bridge the gap between architecture decisions and business risk</span></li>
                        <li><img src="/images/logo/gst-delta-icon-teal-stroke-thick.svg" alt="" class="bullet-icon" aria-hidden="true" loading="lazy" /><span>Post-acquisition integration and technology strategy alignment</span></li>
                    </ul>
                </div>
            </div>
        </div>
    </section>

    <section class="audience-section">
        <div class="container">
            <div class="audience-content">
                <h2 class="heading-lg">Who Is GST For?</h2>
                <div class="audience-cards">
                    <div class="audience-card">
                        <h3>Private Equity & Investment Teams</h3>
                        <p>Evaluating targets with complex legacy systems or scaling potential. GST quantifies what's under the hood so you can price risk accurately and build a credible value creation plan before close.</p>
                    </div>
                    <div class="audience-card">
                        <h3>SaaS Founders & Executives</h3>
                        <p>Navigating the Series B scaling plateau or the build vs. buy crossroads. GST helps you make the architectural and organizational calls that determine whether growth compounds or stalls.</p>
                    </div>
                    <div class="audience-card">
                        <h3>Performance-Conscious Organizations</h3>
                        <p>Needing an independent, vendor-neutral audit of their technical posture. GST tells you what your internal teams and existing vendors won't: where the real exposure is and what to do about it.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <EngagementFlow />

    <section class="faq-section">
        <div class="container">
            <h2 class="heading-lg">Frequently Asked Questions</h2>
            <div class="faq-list">
                {faqItems.map((item) => (
                    <details class="faq-item">
                        <summary class="faq-question">{item.question}</summary>
                        <div class="faq-answer" set:html={item.answer} />
                    </details>
                ))}
            </div>
        </div>
    </section>

    <CTASection
        title="Let's discuss your next challenge"
        description="Schedule a confidential consultation to discuss your objectives."
        buttonText="Schedule a Consultation"
        calendlyUrl="https://calendly.com/globalstrategictech"
    />
</BaseLayout>

<style>
    .print-report-header {
        display: none;
    }

    .services-overview {
        padding: 3rem 0;
        background: rgba(5, 205, 153, 0.05);
        border-bottom: 1px solid rgba(5, 205, 153, 0.1);
    }

    .overview-content {
        max-width: 900px;
    }

    .services-overview h2 {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1.5rem;
    }

    .services-overview p {
        font-size: 1.1rem;
        color: var(--text-secondary);
        line-height: 1.8;
    }

    :global(html.dark-theme) .services-overview {
        background: rgba(5, 205, 153, 0.08);
        border-bottom-color: rgba(5, 205, 153, 0.15);
    }

    .services-section {
        padding: 2.5rem 0;
    }

    .services-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem;
    }

    .service-card {
        padding: 2.5rem;
        background: rgba(0, 0, 0, 0.005);
        backdrop-filter: blur(3px);
        -webkit-backdrop-filter: blur(3px);
        border: 2px solid var(--border-light);
        border-top: 3px solid var(--color-primary);
        transition: all var(--transition-normal);
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .service-card:hover {
        border-color: var(--color-primary);
    }

    .service-card h3 {
        font-size: 1.4rem;
        font-family: monospace;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: var(--spacing-sm);
        line-height: 1.3;
    }

    .service-subtitle {
        font-size: 0.75rem;
        font-family: monospace;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--color-primary);
        margin-bottom: var(--spacing-xl);
        display: block;
    }

    .service-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--spacing-md);
    }

    .service-list li {
        display: flex;
        align-items: flex-start;
        gap: var(--spacing-md);
        font-size: 1rem;
        font-family: monospace;
        color: var(--text-secondary);
        line-height: 1.6;
    }

    .service-list .bullet-icon {
        width: 14px;
        height: 14px;
        flex-shrink: 0;
        margin-top: 0.3em;
        opacity: 0.7;
    }

    :global(html.dark-theme) .service-card {
        background: rgba(255, 255, 255, 0.005);
        border-color: rgba(255, 255, 255, 0.15);
        border-top-color: var(--color-primary);
    }

    :global(html.dark-theme) .service-card:hover {
        border-color: var(--color-primary);
    }

    .audience-section {
        padding: var(--spacing-3xl) 0;
    }

    .audience-content {
        max-width: 1100px;
        margin: 0 auto;
    }

    .audience-content .heading-lg {
        font-family: monospace;
        text-transform: uppercase;
        margin-bottom: var(--spacing-2xl);
        text-align: center;
    }

    .audience-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2.5rem;
    }

    .audience-card {
        padding: 2rem;
        border-left: 3px solid var(--color-primary);
    }

    .audience-card h3 {
        font-size: 1.15rem;
        font-family: monospace;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: var(--spacing-md);
        line-height: 1.3;
    }

    .audience-card p {
        font-size: 0.95rem;
        font-family: monospace;
        color: var(--text-secondary);
        line-height: 1.7;
        margin: 0;
    }

    @media (max-width: 1024px) {
        .audience-cards {
            grid-template-columns: repeat(2, 1fr);
            gap: 1.75rem;
        }
    }

    @media (max-width: 768px) {
        .audience-section {
            padding: var(--spacing-2xl) 0;
        }

        .audience-cards {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .audience-card {
            padding: 1.5rem;
        }

        .audience-card h3 {
            font-size: 1.05rem;
        }

        .audience-card p {
            font-size: 0.9rem;
        }
    }

    @media (max-width: 480px) {
        .audience-card {
            padding: 1.25rem;
        }

        .audience-card h3 {
            font-size: 1rem;
        }

        .audience-card p {
            font-size: 0.85rem;
        }
    }

    @media (max-width: 1024px) {
        .services-cards {
            grid-template-columns: repeat(2, 1fr);
            gap: 1.75rem;
        }

        .service-card {
            padding: 1.75rem;
        }

        .service-card h3 {
            font-size: 1.2rem;
        }

        .service-list li {
            font-size: 0.95rem;
        }
    }

    @media (max-width: 768px) {
        .services-overview {
            padding: 2rem 0;
        }

        .services-overview h2 {
            font-size: 1.5rem;
            margin-bottom: 1rem;
        }

        .services-overview p {
            font-size: 1rem;
        }

        .services-section {
            padding: 2.5rem 0;
        }

        .services-cards {
            grid-template-columns: 1fr;
            gap: 1.5rem;
        }

        .service-card {
            padding: 1.5rem;
        }

        .service-card h3 {
            font-size: 1.15rem;
        }

        .service-list li {
            font-size: 0.95rem;
        }
    }

    @media (max-width: 480px) {
        .services-overview {
            padding: 1.5rem 0;
        }

        .services-overview h2 {
            font-size: 1.25rem;
            margin-bottom: 0.75rem;
        }

        .services-overview p {
            font-size: 0.9rem;
            line-height: 1.6;
        }

        .services-section {
            padding: 2rem 0;
        }

        .services-cards {
            gap: 1.25rem;
        }

        .service-card {
            padding: 1.25rem;
        }

        .service-card h3 {
            font-size: 1.05rem;
        }

        .service-list li {
            font-size: 0.9rem;
        }

        .service-list .bullet-icon {
            width: 12px;
            height: 12px;
        }
    }

    .faq-section {
        padding: var(--spacing-3xl) 0;
    }

    .faq-section .heading-lg {
        font-family: monospace;
        text-transform: uppercase;
        margin-bottom: var(--spacing-2xl);
        text-align: center;
    }

    .faq-list {
        max-width: 800px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: var(--spacing-md);
    }

    .faq-item {
        background: transparent;
        border: 2px solid var(--border-light);
        transition: background var(--transition-normal), border-color var(--transition-normal);
    }

    .faq-item[open] {
        background: transparent;
        border-color: var(--color-primary);
    }

    .faq-question {
        padding: var(--spacing-xl);
        font-size: var(--text-lg);
        font-family: monospace;
        font-weight: var(--font-weight-semibold);
        color: var(--text-primary);
        cursor: pointer;
        list-style: none;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--spacing-md);
        transition: color var(--transition-fast);
    }

    .faq-question::-webkit-details-marker {
        display: none;
    }

    .faq-question::after {
        content: '+';
        font-size: var(--text-2xl);
        font-weight: var(--font-weight-bold);
        color: var(--color-primary);
        flex-shrink: 0;
        transition: transform var(--transition-fast);
    }

    .faq-item[open] .faq-question::after {
        content: '\2212';
    }

    .faq-question:hover {
        color: var(--color-primary);
    }

    .faq-answer {
        padding: 0 var(--spacing-xl) var(--spacing-xl);
        font-size: var(--text-base);
        font-family: monospace;
        color: var(--text-secondary);
        line-height: 1.7;
    }

    .faq-answer :global(p) {
        margin: 0 0 var(--spacing-md) 0;
    }

    .faq-answer :global(p:last-child) {
        margin-bottom: 0;
    }

    :global(html.dark-theme) .faq-item {
        background: transparent;
        border-color: rgba(255, 255, 255, 0.15);
    }

    :global(html.dark-theme) .faq-item[open] {
        background: transparent;
        border-color: var(--color-primary);
    }

    @media (max-width: 768px) {
        .faq-section {
            padding: var(--spacing-2xl) 0;
        }

        .faq-question {
            padding: var(--spacing-lg);
            font-size: var(--text-base);
        }

        .faq-answer {
            padding: 0 var(--spacing-lg) var(--spacing-lg);
            font-size: var(--text-sm);
        }
    }

    @media (max-width: 480px) {
        .faq-question {
            padding: var(--spacing-md);
        }

        .faq-answer {
            padding: 0 var(--spacing-md) var(--spacing-md);
            font-size: var(--text-sm);
        }
    }

    /* Print */
    @media print {
        .print-report-header {
            display: flex !important;
            align-items: center;
            gap: 1rem;
            padding-bottom: 1rem;
            margin-bottom: 2rem;
            border-bottom: 2px solid #000;
            font-family: monospace;
        }

        .print-report-header__brand {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-weight: 900;
            font-size: 1.25rem;
            text-transform: uppercase;
        }

        .print-report-header__title {
            font-weight: 700;
            font-size: 1rem;
            text-transform: uppercase;
            letter-spacing: 0.06em;
        }

        .print-report-header__date {
            margin-left: auto;
            font-size: 0.75rem;
            color: #666;
        }

        .service-card {
            break-inside: avoid;
        }

        .faq-item {
            break-inside: avoid;
        }

        @page {
            margin: 1.5cm;
        }
    }
</style>

<script>
    import { trackEvent } from '../utils/analytics';

    document.querySelectorAll('.faq-item').forEach((item) => {
        item.addEventListener('toggle', () => {
            const details = item as HTMLDetailsElement;
            const question = details.querySelector('.faq-question')?.textContent?.trim() || '';
            trackEvent({
                event: 'faq_interaction',
                category: 'engagement',
                question,
                action: details.open ? 'open' : 'close',
                page: 'services',
            });
        });
    });
</script>
