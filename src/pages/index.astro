---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import WhoWeSupport from '../components/WhoWeSupport.astro';
import WhatWeDo from '../components/WhatWeDo.astro';
import WhyClientsTrustUs from '../components/WhyClientsTrustUs.astro';
import CTASection from '../components/CTASection.astro';

// Track page view
---

<BaseLayout
  title="GST | M&A Strategic Technology Advisory"
  description="M&A technical due diligence, post-acquisition integration, and platform modernization. Led by Reid Peryam, 20-year technology strategy veteran."
  ogTitle="GST | Strategic Technology Advisory"
  ogDescription="Specialized technical diligence and AI strategy for organizations navigating complex product transitions."
  ogImage="https://globalstrategic.tech/og-image.png"
  ogImageAlt="GST - Strategic Technology Advisory for M&A and Digital Transformation"
  ogUrl="https://globalstrategic.tech"
>
  <Hero
    description="GST helps technology-focused investors, founders, and executives scale with confidence to create value, manage risks, and accelerate their business."
    primaryCTA={{
      text: 'Schedule an Intro Call',
      href: 'https://calendarbridge.com/book/globalstrategictech/',
    }}
    secondaryCTA={{
      text: 'View Advisory Services',
      href: '/services',
    }}
    trustLine="Vendor-neutral. Executive-ready outputs. Built for high-stakes decisions."
  />

  <WhoWeSupport />

  <WhatWeDo />

  <WhyClientsTrustUs />

  <CTASection
    title="Let's discuss your next challenge"
    description="Schedule a confidential consultation to discuss your objectives."
    buttonText="Schedule a Consultation"
    bookingUrl="https://calendarbridge.com/book/globalstrategictech/"
    emailAddress="contact@globalstrategic.tech"
  />
</BaseLayout>
