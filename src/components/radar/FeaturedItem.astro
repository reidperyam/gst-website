---
/**
 * Featured item card — Tier 2 content.
 * Displays article with highlighted passage and GST Take.
 * All editorial content comes from Inoreader annotations.
 */
import { CATEGORIES } from '../../lib/inoreader/transform';
import type { RadarFeaturedItem } from '../../lib/inoreader/types';

interface Props {
  item: RadarFeaturedItem;
}

const { item } = Astro.props;
const cat = CATEGORIES[item.category];
const pubDate = new Date(item.publishedAt);
const dateStr = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---

<article class="featured-item" data-category={item.category}>
  <div class="featured-item__meta">
    {cat && (
      <span class="category-tag" style={`--tag-color: ${cat.color}`}>
        {cat.label}
      </span>
    )}
    <span class="source">{item.source}</span>
    <span class="date">{dateStr}</span>
  </div>

  <h3 class="featured-item__title">
    <a href={item.url} target="_blank" rel="noopener noreferrer">
      {item.title}
    </a>
  </h3>

  {item.summary && (
    <p class="featured-item__summary">{item.summary}</p>
  )}

  {item.highlightedText && (
    <blockquote class="featured-item__highlight">
      {item.highlightedText}
    </blockquote>
  )}

  {item.gstTake && (
    <div class="featured-item__take">
      <span class="take-label">Δ GST Take</span>
      <p>{item.gstTake}</p>
    </div>
  )}
</article>

<style>
  .featured-item {
    padding: var(--spacing-xl) 0;
    border-bottom: 1px solid var(--border-light);
  }

  .featured-item__meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    font-size: var(--text-xs);
    color: var(--text-light-muted);
    margin-bottom: var(--spacing-sm);
  }

  .category-tag {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--tag-color);
    border: 1px solid var(--tag-color);
    padding: 0.125rem var(--spacing-sm);
  }

  .featured-item__title {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    line-height: 1.4;
    margin-bottom: var(--spacing-sm);
  }

  .featured-item__title a {
    color: var(--text-light-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .featured-item__title a:hover {
    color: var(--color-primary);
  }

  .featured-item__summary {
    font-size: var(--text-sm);
    color: var(--text-light-secondary);
    line-height: 1.6;
    margin-bottom: var(--spacing-md);
  }

  .featured-item__highlight {
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--text-light-secondary);
    border-left: 2px solid var(--border-light);
    padding-left: var(--spacing-lg);
    margin: var(--spacing-md) 0;
    line-height: 1.6;
  }

  .featured-item__take {
    background: var(--accent-light-bg);
    border-left: 3px solid var(--color-primary);
    padding: var(--spacing-md) var(--spacing-lg);
    margin-top: var(--spacing-md);
  }

  .take-label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    display: block;
    margin-bottom: 0.25rem;
  }

  .featured-item__take p {
    font-size: var(--text-sm);
    color: var(--text-light-primary);
    line-height: 1.6;
    margin: 0;
  }

  :global(html.dark-theme) .featured-item {
    border-bottom-color: var(--border-dark);
  }

  :global(html.dark-theme) .featured-item__highlight {
    border-left-color: var(--border-dark);
  }

  @media (max-width: 480px) {
    .featured-item__meta {
      flex-wrap: wrap;
    }

    .featured-item__title {
      font-size: var(--text-lg);
    }
  }
</style>
