---
/**
 * Wire item — Tier 1 automated feed content.
 * Compact: category dot, headline, source, date.
 */
import { CATEGORIES } from '../../lib/inoreader/transform';
import type { RadarWireItem } from '../../lib/inoreader/types';

interface Props {
  item: RadarWireItem;
}

const { item } = Astro.props;
const cat = CATEGORIES[item.category];
const pubDate = new Date(item.publishedAt);
const dateStr = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---

<article class="wire-item" data-category={item.category}>
  <div class="wire-item__indicator">
    {cat && <span class="dot" style={`background: ${cat.color}`}></span>}
  </div>
  <div class="wire-item__content">
    <a href={item.url} target="_blank" rel="noopener noreferrer" class="wire-item__title">
      {item.title}
    </a>
    <div class="wire-item__meta">
      <span class="source">{item.source}</span>
      <span class="date">{dateStr}</span>
    </div>
  </div>
</article>

<style>
  .wire-item {
    display: flex;
    gap: var(--spacing-md);
    padding: var(--spacing-md) 0;
    border-bottom: 1px solid var(--border-light);
  }

  .wire-item__indicator {
    padding-top: 0.375rem;
    flex-shrink: 0;
  }

  .dot {
    display: block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }

  .wire-item__title {
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    text-decoration: none;
    line-height: 1.4;
    display: block;
    margin-bottom: 0.25rem;
    transition: color var(--transition-fast);
  }

  .wire-item__title:hover {
    color: var(--color-primary);
  }

  .wire-item__meta {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .wire-item__meta .source::after {
    content: "·";
    margin: 0 var(--spacing-xs);
  }

  :global(html.dark-theme) .wire-item {
    border-bottom-color: rgba(255, 255, 255, 0.05);
  }
</style>
