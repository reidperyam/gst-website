---
/**
 * RadarFeedSkeleton — Placeholder shown while RadarFeed server island loads.
 * Mimics the wire-item layout with pulsing bars.
 * Uses global .skeleton-bar and .skeleton-dot classes from global.css.
 */
---

<div class="feed-skeleton" aria-hidden="true">
  {Array.from({ length: 6 }).map((_, i) => (
    <div class="skeleton-item">
      <div class="skeleton-dot skeleton-item-dot"></div>
      <div class="skeleton-content">
        <div class="skeleton-bar" style={`width: ${70 + (i % 3) * 10}%`}></div>
        <div class="skeleton-bar skeleton-bar--sm" style={`width: ${30 + (i % 3) * 10}%; animation-delay: 0.3s`}></div>
      </div>
    </div>
  ))}
</div>

<style>
  .feed-skeleton {
    max-width: 48rem;
    margin: 0 auto;
  }

  .skeleton-item {
    display: flex;
    gap: var(--spacing-md);
    padding: var(--spacing-md) 0;
    border-bottom: 1px solid var(--border-light);
  }

  .skeleton-item-dot {
    margin-top: 0.375rem;
  }

  .skeleton-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
</style>
