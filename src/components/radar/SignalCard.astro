---
/**
 * Signal post card — Tier 3 original content.
 * Most prominent display. Links to full Signal post page.
 */
interface Props {
  signal: {
    id: string;
    data: {
      title: string;
      description: string;
      publishedAt: Date;
      category: string;
      tags: string[];
    };
  };
}

const { signal } = Astro.props;
const pubDate = new Date(signal.data.publishedAt);
const dateStr = pubDate.toLocaleDateString('en-US', {
  month: 'short', day: 'numeric', year: 'numeric'
});
---

<article class="signal-card" data-category={signal.data.category}>
  <div class="signal-card__label">
    <span class="delta">Δ</span> Signal
  </div>
  <h3 class="signal-card__title">
    <a href={`/hub/radar/signals/${signal.id}`}>
      {signal.data.title}
    </a>
  </h3>
  <p class="signal-card__description">{signal.data.description}</p>
  <div class="signal-card__meta">
    <time datetime={pubDate.toISOString()}>{dateStr}</time>
    <div class="signal-card__tags">
      {signal.data.tags.slice(0, 3).map(tag => (
        <span class="tag">{tag}</span>
      ))}
    </div>
  </div>
</article>

<style>
  .signal-card {
    background: var(--bg-light-alt);
    border: 1px solid var(--border-light);
    border-top: 3px solid var(--color-primary);
    padding: var(--spacing-xl);
    transition: border-color var(--transition-fast);
  }

  .signal-card:hover {
    border-color: var(--color-primary);
  }

  .signal-card__label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: var(--spacing-md);
  }

  .signal-card__title {
    font-size: var(--text-xl);
    font-weight: var(--font-weight-semibold);
    line-height: 1.3;
    margin-bottom: var(--spacing-sm);
  }

  .signal-card__title a {
    color: var(--text-light-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .signal-card__title a:hover {
    color: var(--color-primary);
  }

  .signal-card__description {
    font-size: var(--text-sm);
    color: var(--text-light-secondary);
    line-height: 1.6;
    margin-bottom: var(--spacing-lg);
  }

  .signal-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--text-xs);
    color: var(--text-light-muted);
  }

  .signal-card__tags {
    display: flex;
    gap: var(--spacing-sm);
  }

  .tag {
    font-size: 0.6875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-light-muted);
    border: 1px solid var(--border-light);
    padding: 0.125rem var(--spacing-xs);
  }

  :global(html.dark-theme) .signal-card {
    border-color: var(--border-dark);
    border-top-color: var(--color-primary);
  }

  :global(html.dark-theme) .tag {
    border-color: var(--border-dark);
  }

  @media (max-width: 480px) {
    .signal-card__meta {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--spacing-sm);
    }
  }
</style>
