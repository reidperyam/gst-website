---
/**
 * FYI item — Tier 2 curated content.
 * Collapsed by default; expands to show summary, highlight, and GST Take.
 * Uses native <details>/<summary> for zero-JS, accessible expand/collapse.
 */
import { CATEGORIES } from '../../lib/inoreader/transform';
import type { RadarFyiItem } from '../../lib/inoreader/types';

interface Props {
  item: RadarFyiItem;
}

const { item } = Astro.props;
const catColor = CATEGORIES[item.category]?.color ?? '#9B59B6';
const pubDate = new Date(item.publishedAt);
const dateStr = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---

<article class="fyi-item" data-category={item.category} style={`--cat-color: ${catColor}`}>
  <details class="fyi-item__details">
    <summary class="fyi-item__header">
      <div class="fyi-item__meta">
        <span class="editors-pick-tag">Editor's Pick</span>
        <span class="source">{item.source}</span>
        <span class="date">{dateStr}</span>
      </div>
      <div class="fyi-item__headline">
        <span class="fyi-item__toggle" aria-hidden="true"></span>
        <h3 class="fyi-item__title">
          <a href={item.url} target="_blank" rel="noopener noreferrer"
             onclick="event.stopPropagation();">
            {item.title}
          </a>
        </h3>
      </div>
    </summary>
    <div class="fyi-item__body">
      {item.summary && (
        <p class="fyi-item__summary">{item.summary}</p>
      )}

      {item.highlightedText && (
        <div class="fyi-item__highlight">
          <span class="highlight-label">Highlighted</span>
          <blockquote>{item.highlightedText}</blockquote>
        </div>
      )}

      {item.highlightedText && item.gstTake && (
        <div class="fyi-item__nested-take">
          <span class="take-label">Δ GST Take</span>
          <p>{item.gstTake}</p>
        </div>
      )}

      {!item.highlightedText && item.gstTake && (
        <div class="fyi-item__take">
          <span class="take-label">Δ GST Take</span>
          <p>{item.gstTake}</p>
        </div>
      )}
    </div>
  </details>
</article>

<style>
  .fyi-item {
    padding: var(--spacing-md) 0;
    border-bottom: 1px solid var(--border-light);
  }

  /* Reset native details/summary styling */
  .fyi-item__details summary {
    list-style: none;
    cursor: pointer;
  }

  .fyi-item__details summary::-webkit-details-marker {
    display: none;
  }

  .fyi-item__header {
    display: block;
  }

  .fyi-item__meta {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    font-size: var(--text-xs);
    color: var(--text-light-muted);
    margin-bottom: var(--spacing-xs);
  }

  .editors-pick-tag {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #b26622;
    border: 1px solid #b26622;
    padding: 0.125rem var(--spacing-sm);
  }

  :global(html.dark-theme) .editors-pick-tag {
    color: #d4923a;
    border-color: #d4923a;
  }

  .fyi-item__headline {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .fyi-item__title {
    font-size: var(--text-base);
    font-weight: var(--font-weight-semibold);
    line-height: 1.4;
    margin: 0;
    flex: 1;
  }

  .fyi-item__title a {
    color: var(--text-light-primary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .fyi-item__title a:hover {
    color: var(--color-primary);
  }

  .fyi-item__toggle {
    flex-shrink: 0;
    width: 1.5rem;
    text-align: center;
    line-height: 1;
    margin-top: -0.125rem;
  }

  .fyi-item__toggle::before {
    content: "+";
    font-family: monospace;
    font-size: var(--text-xl);
    font-weight: var(--font-weight-bold);
    color: var(--text-light-muted);
    transition: color var(--transition-fast);
  }

  .fyi-item__details[open] .fyi-item__toggle::before {
    content: "\2212";
  }

  .fyi-item__header:hover .fyi-item__toggle::before {
    color: var(--color-primary);
  }

  /* Expanded body */
  .fyi-item__body {
    padding-top: var(--spacing-sm);
    padding-left: var(--spacing-xl);
  }

  .fyi-item__summary {
    font-size: var(--text-sm);
    color: var(--text-light-secondary);
    line-height: 1.5;
    margin-bottom: var(--spacing-sm);
  }

  .fyi-item__highlight {
    border-left: 3px solid var(--cat-color);
    padding: var(--spacing-sm) var(--spacing-md);
    margin: var(--spacing-sm) 0;
  }

  .highlight-label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--cat-color);
    display: block;
    margin-bottom: 0.25rem;
  }

  .fyi-item__highlight blockquote {
    font-size: var(--text-sm);
    color: var(--text-light-primary);
    line-height: 1.6;
    margin: 0;
  }

  .fyi-item__take {
    background: var(--accent-light-bg);
    border-left: 3px solid var(--color-primary);
    padding: var(--spacing-sm) var(--spacing-md);
    margin-top: var(--spacing-sm);
  }

  .fyi-item__nested-take {
    margin-top: var(--spacing-md);
    margin-left: var(--spacing-md);
    padding-top: var(--spacing-sm);
    padding-left: var(--spacing-md);
    border-top: 1px solid var(--border-light);
  }

  .fyi-item__nested-take .take-label {
    color: var(--color-primary);
  }

  .fyi-item__nested-take p {
    font-size: var(--text-sm);
    color: var(--text-light-primary);
    line-height: 1.6;
    margin: 0;
  }

  :global(html.dark-theme) .fyi-item__nested-take {
    border-top-color: var(--border-dark);
  }

  .take-label {
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    display: block;
    margin-bottom: 0.25rem;
  }

  .fyi-item__take p {
    font-size: var(--text-sm);
    color: var(--text-light-primary);
    line-height: 1.6;
    margin: 0;
  }

  :global(html.dark-theme) .fyi-item {
    border-bottom-color: var(--border-dark);
  }

  @media (max-width: 480px) {
    .fyi-item__meta {
      flex-wrap: wrap;
    }

    .fyi-item__title {
      font-size: var(--text-sm);
    }
  }
</style>
