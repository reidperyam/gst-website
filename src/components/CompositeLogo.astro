---
/**
 * Dynamic composite GST logo — palette-aware inline SVG.
 * Uses currentColor for the delta stroke and "S" letter,
 * and CSS variables for text and background colors.
 * Static version remains at public/images/icon.svg for PWA/favicon/OG use.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 120, class: className = '' } = Astro.props;
---

<svg
  viewBox="0 0 300 300"
  fill="none"
  aria-hidden="true"
  width={size}
  height={size}
  class={className}
  xmlns="http://www.w3.org/2000/svg"
  style="flex-shrink:0;"
>
  <!-- Background -->
  <rect width="300" height="300" fill="var(--bg-light)"></rect>
  <!-- Border -->
  <rect
    x="0"
    y="0"
    width="300"
    height="300"
    fill="none"
    stroke="var(--border-light)"
    stroke-width="2"></rect>
  <!-- Delta Symbol -->
  <g transform="translate(70, 30) scale(2.5)">
    <path
      d="M32 12 L52 52 L12 52 Z"
      fill="none"
      stroke="currentColor"
      stroke-width="6"
      stroke-linejoin="miter"></path>
  </g>
  <!-- GST Letters -->
  <text
    x="75"
    y="240"
    text-anchor="middle"
    font-family="monospace"
    font-weight="700"
    font-size="68"
    fill="var(--text-primary)">G</text
  >
  <text
    x="150"
    y="240"
    text-anchor="middle"
    font-family="monospace"
    font-weight="700"
    font-size="68"
    fill="currentColor">S</text
  >
  <text
    x="225"
    y="240"
    text-anchor="middle"
    font-family="monospace"
    font-weight="700"
    font-size="68"
    fill="var(--text-primary)">T</text
  >
</svg>
