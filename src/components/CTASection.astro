---
// Note: trackCTA is imported in the <script> block below to wire it to
// window for inline onclick handlers — the frontmatter does not need it.

interface Props {
  title: string;
  description: string;
  buttonText?: string;
  calendlyUrl?: string;
}

const {
  title,
  description,
  buttonText = 'BOOK_CALENDAR_SLOT()',
  calendlyUrl = 'https://calendly.com/globalstrategictech',
} = Astro.props;
---

<section class="cta-section" id="contact">
  <div class="container">
    <div class="cta-box">
      <h2 class="brutal-cta__title">{title}</h2>
      <p class="brutal-cta__description">{description}</p>
      <a
        href={calendlyUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="cta-button"
        onclick="trackCTA('calendly', 'cta-section')">{buttonText}</a
      >
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding: 4rem 0;
    text-align: center;
  }

  .cta-box {
    background: var(--bg-light);
    border: 2px solid var(--color-primary);
    padding: 4rem;
    max-width: 800px;
    margin: 0 auto;
    position: relative;
  }

  .cta-box h2 {
    font-size: 2.5rem;
    color: var(--text-primary);
    margin-bottom: 1.5rem;
    font-weight: 600;
  }

  .cta-box p {
    color: var(--text-secondary);
    font-size: 1.15rem;
    margin-bottom: 2.5rem;
  }

  :global(html.dark-theme) .cta-box {
    background: var(--cta-box-bg);
    border-color: var(--color-primary);
  }

  :global(html.dark-theme) .cta-box h2 {
    color: var(--text-dark-primary);
  }

  :global(html.dark-theme) .cta-box p {
    color: var(--cta-box-text);
  }

  @media (max-width: 480px) {
    .cta-section {
      padding: 2.5rem 0;
    }

    .cta-box {
      padding: 2rem;
    }

    .cta-box h2 {
      font-size: 1.5rem;
      line-height: 1.3;
      margin-bottom: 1rem;
    }

    .cta-box p {
      font-size: 0.95rem;
      margin-bottom: 1.5rem;
    }
  }
</style>

<script>
  import { trackCTA } from '../utils/analytics';

  // Make trackCTA available to inline onclick handlers.
  // TODO(phase-3): replace with proper ambient `Window` type declaration.
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  (window as any).trackCTA = trackCTA;
</script>
