---
import SwatchControlStyles from './SwatchControlStyles.astro';
import { palettes } from '../../data/palettes';
---

<SwatchControlStyles />

<div class="palette-panel" id="palette-panel" data-testid="palette-panel">
  <div class="palette-panel__resize" id="panel-resize" title="Drag to resize"></div>
  <div class="palette-panel__edge">
    <button
      class="palette-panel__toggle"
      id="panel-toggle"
      type="button"
      aria-label="Toggle palette editor"
      data-testid="palette-panel-toggle"
    >
      <svg viewBox="0 0 64 64" fill="none" class="palette-panel__icon"
        ><path
          d="M32 12 L52 52 L12 52 Z"
          fill="none"
          stroke="currentColor"
          stroke-width="6"
          stroke-linejoin="miter"></path></svg
      >
    </button>
    <div class="palette-panel__tabs" id="palette-tabs" data-testid="palette-tabs">
      {
        palettes.map((p, i) => (
          <button
            class={`palette-panel__tab${i === 0 ? ' palette-panel__tab--active' : ''}`}
            type="button"
            data-palette={p.id}
            title={p.name}
          >
            {p.id}
          </button>
        ))
      }
    </div>
    <button
      class="palette-panel__popout"
      id="panel-popout-toggle"
      type="button"
      title="Pop out palette to all pages"
      aria-label="Toggle site-wide palette"
      data-testid="palette-popout-toggle"
    >
      <svg viewBox="0 0 64 64" fill="none" class="palette-panel__icon"
        ><path
          d="M32 12 L52 52 L12 52 Z"
          fill="none"
          stroke="currentColor"
          stroke-width="6"
          stroke-linejoin="miter"></path></svg
      >
    </button>
    <button
      class="palette-panel__theme-toggle"
      id="panel-theme-toggle"
      type="button"
      title="Toggle dark theme"
      aria-label="Toggle dark theme"
      data-testid="palette-theme-toggle"
    >
      <svg viewBox="0 0 64 64" fill="none" class="palette-panel__icon"
        ><path
          d="M32 12 L52 52 L12 52 Z"
          fill="none"
          stroke="currentColor"
          stroke-width="6"
          stroke-linejoin="miter"></path></svg
      >
    </button>
  </div>
  <div class="palette-panel__body" id="panel-body">
    <div class="palette-panel__grab-handle" id="panel-grab-handle" aria-hidden="true">
      <span class="palette-panel__grab-bar"></span>
    </div>
    <div class="palette-panel__mobile-header" id="panel-mobile-header"></div>
    <div class="palette-panel__header">
      <span class="brutal-label" id="panel-palette-name">0. Current</span>
      <button
        class="brutal-btn brutal-btn--secondary colors-reset-btn"
        type="button"
        id="reset-all"
        data-testid="palette-reset-all"
        title="Clear all color edits and restore the current palette defaults">Reset</button
      >
    </div>

    <div class="palette-panel__section">
      <div class="palette-panel__swatch-grid">
        <div class="brand-swatch" data-var="--color-primary">
          <div class="brand-swatch__color" style="background: var(--color-primary);"></div>
          <div class="brand-swatch__label">primary</div>
          <div class="brand-swatch__value"></div>
        </div>
        <div class="brand-swatch" data-var="--color-primary-dark">
          <div class="brand-swatch__color" style="background: var(--color-primary-dark);"></div>
          <div class="brand-swatch__label">primary-dark</div>
          <div class="brand-swatch__value"></div>
        </div>
        <div class="brand-swatch" data-var="--color-secondary">
          <div class="brand-swatch__color" style="background: var(--color-secondary);"></div>
          <div class="brand-swatch__label">secondary</div>
          <div class="brand-swatch__value"></div>
        </div>
        <div class="brand-swatch" data-var="--color-success">
          <div class="brand-swatch__color" style="background: var(--color-success);"></div>
          <div class="brand-swatch__label">success</div>
          <div class="brand-swatch__value"></div>
        </div>
        <div class="brand-swatch" data-var="--color-warning">
          <div class="brand-swatch__color" style="background: var(--color-warning);"></div>
          <div class="brand-swatch__label">warning</div>
          <div class="brand-swatch__value"></div>
        </div>
        <div class="brand-swatch" data-var="--color-error">
          <div class="brand-swatch__color" style="background: var(--color-error);"></div>
          <div class="brand-swatch__label">error</div>
          <div class="brand-swatch__value"></div>
        </div>
      </div>
    </div>

    <div class="palette-panel__section">
      <span class="brutal-label-small">Tertiary</span>
      <div class="palette-panel__swatch-grid">
        <div
          class="brand-swatch"
          data-var="--color-tertiary"
          title="Accessible text accent on light surfaces — card chips, metric highlights"
        >
          <div class="brand-swatch__color" style="background: var(--color-tertiary);"></div>
          <div class="brand-swatch__label">tertiary</div>
          <div class="brand-swatch__value"></div>
        </div>
        <div
          class="brand-swatch"
          data-var="--color-tertiary-dark"
          title="Hover/pressed variant of tertiary"
        >
          <div class="brand-swatch__color" style="background: var(--color-tertiary-dark);"></div>
          <div class="brand-swatch__label">tertiary-dark</div>
          <div class="brand-swatch__value"></div>
        </div>
      </div>
    </div>

    <div class="palette-panel__section">
      <span class="brutal-label-small">Expanded</span>
      <div class="palette-panel__swatch-grid">
        <div class="brand-swatch" data-var="--color-authority">
          <div class="brand-swatch__color" style="background: var(--color-authority);"></div>
          <div class="brand-swatch__label">authority</div>
          <div class="brand-swatch__value"></div>
        </div>
        <div class="brand-swatch" data-var="--color-distinguish">
          <div class="brand-swatch__color" style="background: var(--color-distinguish);"></div>
          <div class="brand-swatch__label">distinguish</div>
          <div class="brand-swatch__value"></div>
        </div>
        <div class="brand-swatch" data-var="--color-subdued">
          <div class="brand-swatch__color" style="background: var(--color-subdued);"></div>
          <div class="brand-swatch__label">subdued</div>
          <div class="brand-swatch__value"></div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="palette-panel__backdrop" id="panel-backdrop" hidden></div>
<button
  class="palette-panel__fab"
  id="panel-fab"
  type="button"
  aria-label="Open palette editor"
  data-testid="palette-fab"
>
  <svg viewBox="0 0 64 64" fill="none" class="palette-panel__fab-icon"
    ><path
      d="M32 12 L52 52 L12 52 Z"
      fill="none"
      stroke="currentColor"
      stroke-width="6"
      stroke-linejoin="miter"></path></svg
  >
</button>

<script is:inline>
  // Set popout active state before transitions fire to prevent animation on page load
  try {
    if (localStorage.getItem('palette-popped-out') === 'true') {
      document.getElementById('panel-popout-toggle')?.classList.add('is-active');
    }
  } catch {
    /* ignore — localStorage unavailable */
  }
</script>

<style>
  .colors-reset-btn {
    flex-shrink: 0;
    font-size: var(--text-xs) !important;
    padding: var(--spacing-xs) var(--spacing-md) !important;
  }

  /* ── Sticky Palette Panel ────────────────────────────────── */
  .palette-panel {
    position: fixed;
    top: 50%;
    right: 0;
    transform: translateY(-50%);
    z-index: var(--z-palette-panel);
    display: flex;
    align-items: stretch;
  }

  /* ── Visibility: hidden unless on brand page or popped out ── */
  :global(html:not(.palette-popped-out, [data-palette-always])) .palette-panel {
    display: none !important;
  }

  .palette-panel__edge {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    background: var(--bg-light);
    border: 2px solid var(--border-light);
    border-left: none;
  }

  .palette-panel.is-open .palette-panel__edge {
    border-color: var(--color-primary);
  }

  .palette-panel__toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-sm);
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--border-light);
    color: var(--text-muted);
    cursor: pointer;
    transition: color var(--transition-fast);
  }

  .palette-panel__toggle:hover {
    color: var(--color-primary);
  }

  .palette-panel.is-open .palette-panel__toggle {
    color: var(--color-primary);
  }

  .palette-panel__icon {
    width: 16px;
    height: 16px;
    transition: transform var(--transition-fast);
  }

  .palette-panel__popout {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-sm);
    background: transparent;
    border: none;
    border-top: 1px solid var(--border-light);
    color: var(--text-muted);
    cursor: pointer;
    transition: color var(--transition-fast);
  }

  .palette-panel__popout:hover {
    color: var(--color-primary);
  }

  .palette-panel__popout .palette-panel__icon {
    transform: rotate(90deg);
  }

  .palette-panel__popout.is-active .palette-panel__icon {
    transform: rotate(-90deg);
  }

  .palette-panel.is-open .palette-panel__toggle .palette-panel__icon {
    transform: rotate(90deg);
  }

  .palette-panel__popout.is-active {
    color: var(--color-primary);
  }

  .palette-panel__theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-sm);
    background: transparent;
    border: none;
    border-top: 1px solid var(--border-light);
    color: var(--text-muted);
    cursor: pointer;
    transition: color var(--transition-fast);
    margin-top: auto;
  }

  .palette-panel__theme-toggle:hover {
    color: var(--color-primary);
  }

  /* Resize handle — vertical bar on the outside (left) edge of the panel */
  .palette-panel__resize {
    display: none;
    width: 8px;
    cursor: ew-resize;
    background: var(--border-light);
    transition: background var(--transition-fast);
    flex-shrink: 0;
    user-select: none;
  }

  .palette-panel__resize:hover,
  .palette-panel__resize.is-dragging {
    background: var(--color-primary);
  }

  .palette-panel.is-open .palette-panel__resize {
    display: block;
  }

  .palette-panel__body {
    width: 520px;
    max-height: 80vh;
    overflow-y: auto;
    background: var(--bg-light);
    border: 2px solid var(--color-primary);
    border-right: none;
    padding: var(--spacing-lg);
    display: none;
    scrollbar-width: thin;
  }

  .palette-panel.is-open .palette-panel__body {
    display: block;
  }

  .palette-panel__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--border-light);
  }

  .palette-panel__tabs {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .palette-panel__tab {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-xs);
    font-family: monospace;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    color: var(--text-muted);
    background: transparent;
    border: none;
    border-right: 2px solid transparent;
    cursor: pointer;
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background var(--transition-fast);
  }

  .palette-panel__tab:hover:not(.palette-panel__tab--active) {
    color: var(--text-secondary);
    background: var(--accent-light-bg);
  }

  .palette-panel__tab--active {
    color: var(--color-primary);
    border-right-color: var(--color-primary);
    background: var(--accent-light-bg);
  }

  .palette-panel__section {
    margin-bottom: var(--spacing-md);
  }

  .palette-panel__section .brutal-label-small {
    display: block;
    margin-bottom: var(--spacing-xs);
  }

  .palette-panel__swatch-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-sm);
  }

  /* Panel swatches — compact but readable */
  .palette-panel .brand-swatch__color {
    aspect-ratio: 1.6;
  }

  .palette-panel .brand-swatch__usage {
    display: none;
  }

  /* ── Mobile bottom sheet elements (hidden on desktop) ────── */
  .palette-panel__grab-handle {
    display: none;
  }

  .palette-panel__grab-bar {
    width: 40px;
    height: 4px;
    background: rgba(128, 128, 128, 0.4);
    border-radius: 2px;
  }

  .palette-panel__mobile-header {
    display: none;
  }

  .palette-panel__backdrop {
    display: none;
  }

  .palette-panel__fab {
    display: none;
  }

  .palette-panel__fab-icon {
    width: 24px;
    height: 24px;
  }

  /* ── Visibility gating for FAB + backdrop (same as panel) ── */
  :global(html:not(.palette-popped-out, [data-palette-always])) .palette-panel__fab,
  :global(html:not(.palette-popped-out, [data-palette-always])) .palette-panel__backdrop {
    display: none !important;
  }

  /* ── Mobile: bottom sheet layout ───────────────────────── */
  @media (max-width: 768px) {
    /* Hide desktop-only elements */
    .palette-panel__resize {
      display: none !important;
    }

    .palette-panel__edge {
      display: none !important;
    }

    /* Convert panel to bottom sheet */
    .palette-panel {
      inset: auto 0 0;
      transform: translateY(100%);
      transition: transform var(--transition-slow);
      flex-direction: column;
    }

    .palette-panel.is-open {
      transform: translateY(0);
    }

    /* Body becomes full-width sheet content */
    .palette-panel__body {
      width: 100%;
      max-height: 60vh;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior: contain;
      border: none;
      border-top: 2px solid var(--color-primary);
      border-right: none;
    }

    /* Always show body when is-open on mobile (desktop uses display toggle) */
    .palette-panel.is-open .palette-panel__body {
      display: block;
    }

    /* Grab handle */
    .palette-panel__grab-handle {
      display: flex;
      justify-content: center;
      padding: var(--spacing-sm) 0 var(--spacing-xs);
      cursor: grab;
      touch-action: none;
    }

    /* Mobile header — horizontal tab row + controls */
    .palette-panel__mobile-header {
      display: flex;
      align-items: center;
      gap: var(--spacing-xs);
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      padding: 0 var(--spacing-lg) var(--spacing-sm);
      scrollbar-width: none;
    }

    .palette-panel__mobile-header::-webkit-scrollbar {
      display: none;
    }

    .palette-panel__mobile-header .palette-panel__tab {
      flex-shrink: 0;
      min-width: 44px;
      min-height: 44px;
      border: 1px solid var(--border-light);
      border-radius: 4px;
      border-right: 1px solid var(--border-light);
    }

    .palette-panel__mobile-header .palette-panel__tab--active {
      border-color: var(--color-primary);
      border-bottom-width: 2px;
    }

    .palette-panel__mobile-header .palette-panel__theme-toggle,
    .palette-panel__mobile-header .palette-panel__popout {
      flex-shrink: 0;
      min-width: 44px;
      min-height: 44px;
      border: 1px solid var(--border-light);
      border-radius: 4px;
      margin-top: 0;
    }

    /* Swatch grid — 2 columns on mobile */
    .palette-panel__swatch-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    /* Backdrop overlay */
    .palette-panel__backdrop {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.4);
      z-index: calc(var(--z-palette-panel) - 1);
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--transition-slow);
    }

    .palette-panel__backdrop.is-visible {
      opacity: 1;
      pointer-events: auto;
    }

    /* FAB — floating action button */
    .palette-panel__fab {
      display: flex;
      align-items: center;
      justify-content: center;
      position: fixed;
      bottom: 16px;
      right: 16px;
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: var(--color-primary);
      color: var(--bg-light);
      border: none;
      box-shadow: var(--shadow-md);
      z-index: var(--z-palette-panel);
      cursor: pointer;
      transition:
        transform var(--transition-fast),
        opacity var(--transition-fast),
        bottom var(--transition-fast);
    }

    .palette-panel__fab:active {
      transform: scale(0.92);
    }

    /* Hide FAB when sheet is open */
    .palette-panel.is-open ~ .palette-panel__fab {
      transform: scale(0);
      opacity: 0;
      pointer-events: none;
    }
  }
</style>

<script>
  import '../../scripts/palette-manager';
</script>
