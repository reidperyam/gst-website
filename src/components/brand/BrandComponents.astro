<!-- Section 7: Components -->
<section class="brand-section" id="components">
  <div class="container">
    <h2 class="brutal-heading-md brand-section__title">Components</h2>

    <h3 class="brutal-heading-sm brand-group-title" id="comp-hub-buttons">Hub Buttons</h3>
    <div class="brand-component-row">
      <div class="brand-component-item">
        <button class="brutal-btn brutal-btn--primary">Primary</button>
        <code class="brand-code">.brutal-btn--primary</code>
