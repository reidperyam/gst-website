            <path
              d="M32 12 L52 52 L12 52 Z"
              fill="none"
              stroke="currentColor"
              stroke-width="6"
              stroke-linejoin="miter"></path>
          </svg>
        </div>
        <code class="brand-code">.delta-chevron</code>
      </div>
