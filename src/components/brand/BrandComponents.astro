<!-- Section 7b: Component States -->
<section class="brand-section" id="component-states">
  <div class="container">
    <h2 class="brutal-heading-md brand-section__title">Component States</h2>
    <p
      class="brutal-text-small"
      style="margin-bottom: var(--spacing-xl); color: var(--text-muted);"
    >
      Interactive components rendered in each visual state. Forced via <code class="brand-code"
        >data-demo-state</code
      > attributes.
    </p>

    <h3 class="brutal-heading-sm brand-group-title" id="states-button">Button States</h3>
    <div class="brand-state-row">
      <div class="brand-state-item">
        <button class="brutal-btn brutal-btn--primary">Default</button>
        <code class="brand-code">default</code>
      </div>
      <div class="brand-state-item">
        <button class="brutal-btn brutal-btn--primary" data-demo-state="hover">Hover</button>
        <code class="brand-code">:hover</code>
      </div>
      <div class="brand-state-item">
        <button class="brutal-btn brutal-btn--primary" data-demo-state="focus">Focus</button>
        <code class="brand-code">:focus-visible</code>
      </div>
      <div class="brand-state-item">
        <button class="brutal-btn brutal-btn--primary" disabled>Disabled</button>
        <code class="brand-code">:disabled</code>
      </div>
    </div>
    <div class="brand-state-row">
      <div class="brand-state-item">
        <button class="brutal-btn brutal-btn--secondary">Default</button>
        <code class="brand-code">secondary</code>
      </div>
      <div class="brand-state-item">
        <button class="brutal-btn brutal-btn--secondary" data-demo-state="hover">Hover</button>
        <code class="brand-code">:hover</code>
      </div>
      <div class="brand-state-item">
        <button class="brutal-btn brutal-btn--secondary" data-demo-state="focus">Focus</button>
        <code class="brand-code">:focus-visible</code>
      </div>
      <div class="brand-state-item">
        <button class="brutal-btn brutal-btn--secondary" disabled>Disabled</button>
        <code class="brand-code">:disabled</code>
      </div>
    </div>

    <h3 class="brutal-heading-sm brand-group-title" id="states-form-field">Form Field States</h3>
    <div class="brand-state-grid">
      <div class="brand-state-item brand-state-item--wide">
        <div class="brutal-field">
          <label class="brutal-field__label">Default</label>
          <input class="brutal-field__input" type="text" placeholder="Placeholder text" />
        </div>
        <code class="brand-code">default — dashed border</code>
      </div>
      <div class="brand-state-item brand-state-item--wide">
        <div class="brutal-field">
          <label class="brutal-field__label">Focused</label>
          <input
            class="brutal-field__input"
            type="text"
            value="Entered text"
            data-demo-state="focus"
          />
        </div>
        <code class="brand-code">:focus — solid border, teal</code>
      </div>
      <div class="brand-state-item brand-state-item--wide">
        <div class="brutal-field">
          <label class="brutal-field__label">Disabled</label>
          <input class="brutal-field__input" type="text" value="Cannot edit" disabled />
        </div>
        <code class="brand-code">:disabled — reduced opacity</code>
      </div>
      <div class="brand-state-item brand-state-item--wide">
        <div class="brutal-field">
          <label class="brutal-field__label"
            >Error <span class="brutal-field__req" style="color: var(--color-error);"
              >(invalid)</span
            ></label
          >
          <input
            class="brutal-field__input"
            type="text"
            value="Bad input"
            data-demo-state="error"
          />
        </div>
        <code class="brand-code">error — red border</code>
      </div>
      <div class="brand-state-item brand-state-item--wide">
        <div class="brutal-field">
          <label class="brutal-field__label">Read-only</label>
          <input
            class="brutal-field__input"
            type="text"
            value="Locked value"
            readonly
            data-demo-state="readonly"
          />
        </div>
        <code class="brand-code">readonly — muted text, no cursor</code>
      </div>
    </div>

    <h3 class="brutal-heading-sm brand-group-title" id="states-option-card">Option Card States</h3>
    <div class="brand-state-row">
      <div class="brand-state-item">
        <div class="brutal-option-card">
          <span class="brutal-option-card__label">Default</span>
          <span class="brutal-option-card__description">Base state</span>
        </div>
        <code class="brand-code">default</code>
      </div>
      <div class="brand-state-item">
        <div class="brutal-option-card" data-demo-state="hover">
          <span class="brutal-option-card__label">Hover</span>
          <span class="brutal-option-card__description">Teal border + subtle bg</span>
        </div>
        <code class="brand-code">:hover</code>
      </div>
      <div class="brand-state-item">
        <div class="brutal-option-card" data-demo-state="focus">
          <span class="brutal-option-card__label">Focus</span>
          <span class="brutal-option-card__description">Outline ring</span>
        </div>
        <code class="brand-code">:focus-visible</code>
      </div>
      <div class="brand-state-item">
        <div class="brutal-option-card brutal-option-card--selected">
          <span class="brutal-option-card__label">Selected</span>
          <span class="brutal-option-card__description">Teal border + label</span>
        </div>
        <code class="brand-code">--selected</code>
      </div>
    </div>

    <h3 class="brutal-heading-sm brand-group-title" id="states-choice-button">
      Choice Button States
    </h3>
    <div class="brand-state-row">
      <div class="brand-state-item">
        <button class="brutal-choice-btn" type="button">Default</button>
        <code class="brand-code">default</code>
      </div>
      <div class="brand-state-item">
        <button class="brutal-choice-btn" type="button" data-demo-state="hover">Hover</button>
        <code class="brand-code">:hover</code>
      </div>
      <div class="brand-state-item">
        <button class="brutal-choice-btn" type="button" data-demo-state="focus">Focus</button>
        <code class="brand-code">:focus-visible</code>
      </div>
      <div class="brand-state-item">
        <button class="brutal-choice-btn brutal-choice-btn--selected" type="button">Selected</button
        >
        <code class="brand-code">--selected</code>
      </div>
      <div class="brand-state-item">
        <button class="brutal-choice-btn brutal-choice-btn--unsure" type="button">Unsure</button>
        <code class="brand-code">--unsure</code>
      </div>
      <div class="brand-state-item">
        <button
          class="brutal-choice-btn brutal-choice-btn--unsure brutal-choice-btn--selected"
          type="button">Unsure+Sel</button
        >
        <code class="brand-code">--unsure --selected</code>
      </div>
    </div>
  </div>
</section>

<style>
  .brand-drawer-demo {
    position: relative;
    border: 2px solid light-dark(var(--border-light), var(--border-dark-default));
    border-top: 3px solid var(--color-primary);
    min-height: 200px;
    overflow: hidden;
  }

  .brand-drawer-toggle {
    margin: var(--spacing-lg);
  }

  .brand-drawer-panel {
    position: absolute;
    top: 0;
    right: -280px;
    width: 260px;
    height: 100%;
    background: light-dark(rgba(255, 255, 255, 0.95), rgba(20, 20, 20, 0.95));
    backdrop-filter: blur(8px);
    border-left: 2px solid light-dark(var(--border-light), var(--border-dark-default));
    padding: var(--spacing-md);
    transition: right var(--transition-normal) ease;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .brand-drawer-panel:global(.open) {
    right: 0;
  }

  .brand-drawer-panel__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--border-light);
  }

  .brand-drawer-panel__close {
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--text-muted);
    padding: var(--spacing-xs);
    display: flex;
    transition: color var(--transition-fast);
  }

  .brand-drawer-panel__close:hover {
    color: var(--color-primary);
  }

  .brand-drawer-panel__chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
  }

  .brand-drawer-panel__chips .filter-chip {
    cursor: pointer;
  }
</style>

<script>
  const toggle = document.getElementById('brand-drawer-toggle');
  const panel = document.getElementById('brand-drawer-panel');
  const close = document.getElementById('brand-drawer-close');

  if (toggle && panel && close) {
    toggle.addEventListener('click', () => {
      const isOpen = panel.classList.toggle('open');
      toggle.setAttribute('aria-expanded', String(isOpen));
    });

    close.addEventListener('click', () => {
      panel.classList.remove('open');
      toggle.setAttribute('aria-expanded', 'false');
    });

    panel.querySelectorAll('.brand-drawer-panel__chips').forEach((group) => {
      group.querySelectorAll('[data-brand-chip]').forEach((chip) => {
        chip.addEventListener('click', () => {
          group.querySelectorAll('[data-brand-chip]').forEach((c) => c.classList.remove('active'));
          (chip as HTMLElement).classList.add('active');
        });
      });
    });
  }
</script>
