      <div class="brand-component-item brand-component-item--full">
        <div class="brutal-tool-shell__authority">Authority Line Specimen</div>
        <code class="brand-code">.brutal-tool-shell__authority</code>
      </div>
    </div>
    <div class="brand-component-row">
      <div class="brand-component-item brand-component-item--full">
        <div class="brutal-tool-shell__section-label">Section Label Specimen</div>
        <code class="brand-code">.brutal-tool-shell__section-label</code>
      </div>
