            </div>
            <div class="brand-drawer-panel__chips">
              <div class="filter-chip active" data-brand-chip>All</div>
              <div class="filter-chip" data-brand-chip>Technology</div>
              <div class="filter-chip" data-brand-chip>Healthcare</div>
              <div class="filter-chip" data-brand-chip>Finance</div>
            </div>
          </div>
