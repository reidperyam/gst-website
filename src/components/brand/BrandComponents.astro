                style="font-weight:700; letter-spacing:0.12em; text-transform:uppercase;"
                >FILTERS</span
              >
              <button
                class="brand-drawer-panel__close"
                id="brand-drawer-close"
                type="button"
                aria-label="Close demo drawer"
              >
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <line x1="18" y1="6" x2="6" y2="18"></line>
