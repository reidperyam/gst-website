    >
    </div><div class="brand-swatch__usage">R&amp;D OpEx spend</div>
  </div>
</div>

<h4 class="brutal-label colors-subgroup-title">Diligence Machine</h4>
<div class="brand-swatch-grid">
  <div class="brand-swatch" data-var="--dm-methodology-brown">
    <div class="brand-swatch__color" style="background: var(--dm-methodology-brown);"></div><div
      class="brand-swatch__label"
    >
      --dm-methodology-brown
    </div><div class="brand-swatch__derives">&rarr; --color-subdued</div><div
      class="brand-swatch__value"
    >
    </div><div class="brand-swatch__usage">Methodology sections</div>
  </div>
  <div class="brand-swatch" data-var="--dm-results-blue">
    <div class="brand-swatch__color" style="background: var(--dm-results-blue);"></div><div
