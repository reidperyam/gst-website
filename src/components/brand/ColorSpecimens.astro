  <div class="brand-swatch" data-var="--techpar-zone-elevated">
    <div class="brand-swatch__color" style="background: var(--techpar-zone-elevated);"></div><div
      class="brand-swatch__label"
    >
      --techpar-zone-elevated
    </div><div class="brand-swatch__derives">&rarr; --color-error</div><div
      class="brand-swatch__value"
    >
    </div><div class="brand-swatch__usage">Elevated overspend</div>
  </div>
  <div class="brand-swatch" data-var="--techpar-category-personnel">
    <div class="brand-swatch__color" style="background: var(--techpar-category-personnel);">
