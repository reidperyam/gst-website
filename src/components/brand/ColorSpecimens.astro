      class="brand-swatch__label"
    >
      --techpar-zone-healthy
    </div><div class="brand-swatch__derives">&rarr; --color-primary</div><div
      class="brand-swatch__value"
    >
    </div><div class="brand-swatch__usage">Within benchmark</div>
  </div>
  <div class="brand-swatch" data-var="--techpar-zone-ahead">
    <div class="brand-swatch__color" style="background: var(--techpar-zone-ahead);"></div><div
      class="brand-swatch__label"
    >
      --techpar-zone-ahead
    </div><div class="brand-swatch__derives">&rarr; --color-success</div><div
      class="brand-swatch__value"
    >
