<h4 class="brutal-label colors-subgroup-title">ICG Maturity</h4>
<div class="brand-swatch-grid">
  <div class="brand-swatch" data-var="--icg-maturity-reactive">
    <div class="brand-swatch__color" style="background: var(--icg-maturity-reactive);"></div><div
      class="brand-swatch__label"
    >
      --icg-maturity-reactive
    </div><div class="brand-swatch__derives">&rarr; --color-error</div><div
