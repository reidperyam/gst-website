<style>
  .colors-group-title {
    margin-top: var(--spacing-2xl);
    margin-bottom: var(--spacing-lg);
  }

  .colors-group-title:first-of-type {
    margin-top: var(--spacing-lg);
  }

  .colors-subgroup-title {
    margin-top: var(--spacing-xl);
    margin-bottom: var(--spacing-sm);
  }

  .colors-code {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-muted);
    background: var(--accent-subtle-bg);
    padding: 2px 6px;
    border-radius: 3px;
    white-space: nowrap;
  }

  /* ── Swatch Grid ─────────────────────────────────────────── */
  .brand-swatch-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--gap-normal);
  }

  .brand-swatch__color {
    aspect-ratio: 1;
    border: 1px solid var(--border-light);
    margin-bottom: var(--spacing-xs);
  }

  .brand-swatch__label {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-secondary);
    word-break: break-all;
  }

  .brand-swatch__value {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--text-muted);
    min-height: 1.2em;
  }

  /* ── Token Reference Table ─────────────────────────────────── */
  .colors-token-note {
    color: var(--text-muted);
    margin-bottom: var(--spacing-lg);
  }

  .colors-token-table {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border-light);
    font-family: monospace;
    font-size: var(--text-xs);
    margin-bottom: var(--spacing-xl);
    max-width: 720px;
  }

  .colors-token-row {
    display: grid;
    grid-template-columns: 170px 1fr 1fr;
    gap: var(--spacing-md);
    padding: var(--spacing-sm) var(--spacing-md);
    border-bottom: 1px solid var(--border-light);
    color: var(--text-secondary);
    align-items: center;
  }

  .colors-token-row:last-child {
    border-bottom: none;
  }

  .colors-token-row--header {
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-primary);
    background: var(--accent-light-bg);
  }

  @media (max-width: 768px) {
    .colors-token-row {
      grid-template-columns: 1fr;
      gap: var(--spacing-xs);
    }

    .colors-token-row--header {
      display: none;
    }
  }

  .brand-swatch__derives {
    font-size: var(--text-xs);
    font-family: monospace;
    color: var(--color-primary);
    opacity: 0.7;
  }

  .brand-swatch__usage {
    font-size: 0.65rem;
    color: var(--text-faded);
    line-height: 1.3;
    height: 1.3em;
    overflow: hidden;
  }

  /* ── Component Specimens ─────────────────────────────────── */
  .colors-specimens {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .colors-specimen-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-lg);
    align-items: center;
  }

  .colors-specimen-card {
    max-width: 420px;
  }

  .colors-specimen-shell {
    max-width: 500px;
  }

  /* Status chips */
  .colors-status-row {
    gap: var(--spacing-md);
  }

  .colors-status-chip {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-lg);
    border: 1px solid var(--border-light);
    font-family: monospace;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .colors-status-dot {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
  }

  /* Expanded token cards */
  .colors-expanded-specimens {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: var(--gap-normal);
  }

  .colors-expanded-card {
    padding: var(--spacing-md) var(--spacing-lg);
    background: transparent;
  }

  .colors-expanded-label {
    font-family: monospace;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-primary);
    margin-bottom: var(--spacing-xs);
  }

  .colors-expanded-text {
    font-family: monospace;
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: 1.5;
  }

  /* Maturity scale */
  .colors-maturity-scale {
    display: flex;
    gap: 0;
  }

  .colors-maturity-level {
    flex: 1;
    padding: var(--spacing-sm) var(--spacing-md);
    font-family: monospace;
    font-size: var(--text-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: center;
  }

  /* Dot grid */
  .colors-dot-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-lg);
  }

  .colors-dot-item {
    display: flex;
