---

---

<section class="brand-section" id="typography">
  <div class="container">
    <h2 class="brutal-heading-md brand-section__title">Typography</h2>

    <h3 class="brutal-heading-sm brand-group-title" id="type-font-stack">Font Stack</h3>
    <p class="brutal-text-base">
      <code class="brand-code">--font-family</code>: <span
        class="brand-font-stack"
        data-var="--font-family"></span>
    </p>

    <h3 class="brutal-heading-sm brand-group-title" id="type-sizes">Text Size Scale</h3>
    <div class="brand-type-specimens">
      <div class="brand-type-specimen" data-var="--text-xs">
        <span data-specimen style="font-size: var(--text-xs);">The quick brown fox — text-xs</span>
        <code class="brand-code">--text-xs</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-sm">
        <span data-specimen style="font-size: var(--text-sm);">The quick brown fox — text-sm</span>
        <code class="brand-code">--text-sm</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-base">
        <span data-specimen style="font-size: var(--text-base);"
          >The quick brown fox — text-base</span
        >
        <code class="brand-code">--text-base</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-lg">
        <span data-specimen style="font-size: var(--text-lg);">The quick brown fox — text-lg</span>
        <code class="brand-code">--text-lg</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-xl">
        <span data-specimen style="font-size: var(--text-xl);">The quick brown fox — text-xl</span>
        <code class="brand-code">--text-xl</code>
        <span class="brand-type-value"></span>
      </div>
      <div class="brand-type-specimen" data-var="--text-2xl">
        <span data-specimen style="font-size: var(--text-2xl);">The quick brown fox — text-2xl</span
        >
        <code class="brand-code">--text-2xl</code>
        <span class="brand-type-value"></span>
      </div>
    </div>

    <h3 class="brutal-heading-sm brand-group-title" id="type-weights">Font Weights</h3>
    <div class="brand-type-specimens">
      <div class="brand-type-specimen">
        <span data-specimen style="font-weight: var(--font-weight-normal);"
          >Normal (400) — The quick brown fox</span
        >
        <code class="brand-code">--font-weight-normal</code>
      </div>
      <div class="brand-type-specimen">
        <span data-specimen style="font-weight: var(--font-weight-semibold);"
          >Semibold (600) — The quick brown fox</span
        >
        <code class="brand-code">--font-weight-semibold</code>
      </div>
      <div class="brand-type-specimen">
        <span data-specimen style="font-weight: var(--font-weight-bold);"
          >Bold (700) — The quick brown fox</span
        >
        <code class="brand-code">--font-weight-bold</code>
      </div>
    </div>

    <h3 class="brutal-heading-sm brand-group-title" id="type-utilities">Typography Utilities</h3>
    <p class="brutal-text-small brand-section__note">
      Monospace-first variants for controls, data display, and tool interfaces. Designed to
      complement the existing Helvetica Neue system typography.
    </p>

    <div class="brand-type-specimens">
      <div class="brand-type-specimen">
        <span class="brutal-heading-xl" data-specimen>Heading XL</span>
        <code class="brand-code">.brutal-heading-xl</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-heading-lg" data-specimen>Heading LG</span>
        <code class="brand-code">.brutal-heading-lg</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-heading-md" data-specimen>Heading MD</span>
        <code class="brand-code">.brutal-heading-md</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-heading-sm" data-specimen>Heading SM</span>
        <code class="brand-code">.brutal-heading-sm</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-text-base" data-specimen
          >Text Base — The quick brown fox jumps over the lazy dog</span
        >
        <code class="brand-code">.brutal-text-base</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-text-small" data-specimen
          >Text Small — The quick brown fox jumps over the lazy dog</span
        >
        <code class="brand-code">.brutal-text-small</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-text-tiny" data-specimen
          >Text Tiny — The quick brown fox jumps over the lazy dog</span
        >
        <code class="brand-code">.brutal-text-tiny</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-label" data-specimen>Label</span>
        <code class="brand-code">.brutal-label</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-label-small" data-specimen>Label Small</span>
        <code class="brand-code">.brutal-label-small</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-data" data-specimen>$18,240,000</span>
        <code class="brand-code">.brutal-data</code>
        <span class="brand-type-meta"></span>
      </div>
      <div class="brand-type-specimen">
        <span class="brutal-data-sm" data-specimen>12.4%</span>
        <code class="brand-code">.brutal-data-sm</code>
        <span class="brand-type-meta"></span>
      </div>
    </div>
  </div>
</section>

<!-- Section 4: Spacing Scale -->
<section class="brand-section" id="spacing">
  <div class="container">
    <h2 class="brutal-heading-md brand-section__title">Spacing Scale</h2>

    <h3 class="brutal-heading-sm brand-group-title" id="spacing-tokens">Spacing Tokens</h3>
    <div class="brand-spacing-list">
      <div class="brand-spacing-row" data-var="--spacing-xs">
        <code class="brand-code brand-spacing-name">--spacing-xs</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-xs);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-sm">
        <code class="brand-code brand-spacing-name">--spacing-sm</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-sm);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-md">
        <code class="brand-code brand-spacing-name">--spacing-md</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-md);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-lg">
        <code class="brand-code brand-spacing-name">--spacing-lg</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-lg);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-xl">
        <code class="brand-code brand-spacing-name">--spacing-xl</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-xl);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-2xl">
        <code class="brand-code brand-spacing-name">--spacing-2xl</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-2xl);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-2_5xl">
        <code class="brand-code brand-spacing-name">--spacing-2_5xl</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-2_5xl);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--spacing-3xl">
        <code class="brand-code brand-spacing-name">--spacing-3xl</code>
        <div class="brand-spacing-bar" style="width: var(--spacing-3xl);"></div>
        <span class="brand-spacing-value"></span>
      </div>
    </div>

    <h3 class="brutal-heading-sm brand-group-title" id="spacing-gaps">Gap Tokens</h3>
    <div class="brand-spacing-list">
      <div class="brand-spacing-row" data-var="--gap-tight">
        <code class="brand-code brand-spacing-name">--gap-tight</code>
        <div class="brand-spacing-bar" style="width: var(--gap-tight);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--gap-normal">
        <code class="brand-code brand-spacing-name">--gap-normal</code>
        <div class="brand-spacing-bar" style="width: var(--gap-normal);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--gap-wide">
        <code class="brand-code brand-spacing-name">--gap-wide</code>
        <div class="brand-spacing-bar" style="width: var(--gap-wide);"></div>
        <span class="brand-spacing-value"></span>
      </div>
      <div class="brand-spacing-row" data-var="--gap-extra-wide">
        <code class="brand-code brand-spacing-name">--gap-extra-wide</code>
        <div class="brand-spacing-bar" style="width: var(--gap-extra-wide);"></div>
        <span class="brand-spacing-value"></span>
      </div>
    </div>
  </div>
</section>

<!-- Section 5: Shadows -->
<section class="brand-section" id="shadows">
  <div class="container">
    <h2 class="brutal-heading-md brand-section__title">Shadows</h2>

    <p class="brutal-text-small brand-section__note">
      Hard-edged borders replace diffuse shadows. Elevation conveyed through border weight and
      primary-color accents rather than blur.
    </p>
    <div class="brand-shadow-grid">
      <div class="brutal-shadow brutal-shadow--sm">
        <code class="brand-code">--shadow-sm</code>
        <span class="brutal-shadow__desc">2px border</span>
      </div>
      <div class="brutal-shadow brutal-shadow--md">
        <code class="brand-code">--shadow-md</code>
        <span class="brutal-shadow__desc">2px border + bottom accent</span>
      </div>
      <div class="brutal-shadow brutal-shadow--lg">
        <code class="brand-code">--shadow-lg</code>
        <span class="brutal-shadow__desc">2px border + left accent</span>
      </div>
    </div>
  </div>
</section>

<!-- Section 6: Transitions -->
<section class="brand-section" id="transitions">
  <div class="container">
    <h2 class="brutal-heading-md brand-section__title">Transitions</h2>

    <p class="brutal-text-small brand-section__note">
      Border-color and text-color transitions instead of scale transforms. State changes are
      immediate and structural — no lift, no grow.
    </p>
    <div class="brand-transition-grid">
      <div
        class="brutal-transition"
        style="transition: border-color var(--transition-fast), color var(--transition-fast), background var(--transition-fast);"
      >
        <code class="brand-code">--transition-fast</code>
        <span class="brand-transition-value" data-var="--transition-fast"></span>
        <span class="brutal-transition__hint">Hover me</span>
      </div>
      <div
        class="brutal-transition"
        style="transition: border-color var(--transition-normal), color var(--transition-normal), background var(--transition-normal);"
      >
        <code class="brand-code">--transition-normal</code>
        <span class="brand-transition-value" data-var="--transition-normal"></span>
        <span class="brutal-transition__hint">Hover me</span>
      </div>
      <div
        class="brutal-transition"
        style="transition: border-color var(--transition-slow), color var(--transition-slow), background var(--transition-slow);"
      >
        <code class="brand-code">--transition-slow</code>
        <span class="brand-transition-value" data-var="--transition-slow"></span>
        <span class="brutal-transition__hint">Hover me</span>
      </div>
    </div>
  </div>
</section>
