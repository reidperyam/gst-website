---
/**
 * Site-wide breadcrumb navigation component.
 * Auto-generates from URL pathname using the shared slug-to-name mapping.
 * Renders accessible markup with proper ARIA attributes.
 *
 * Placed in BaseLayout.astro — every non-homepage page gets breadcrumbs automatically.
 */
import { slugToName } from '../utils/breadcrumbs';

const pathname = Astro.url.pathname.replace(/\/$/, '');
const segments = pathname.split('/').filter(Boolean);

// Build full crumb list including Home, then FIFO-truncate to 3 max
const allCrumbs = [
  { name: 'Home', href: '/', isLast: false },
  ...segments.map((slug, index) => ({
    name: slugToName(slug),
    href: '/' + segments.slice(0, index + 1).join('/'),
    isLast: index === segments.length - 1,
  })),
];

const MAX_BREADCRUMBS = 3;
const crumbs = allCrumbs.length > MAX_BREADCRUMBS
  ? allCrumbs.slice(allCrumbs.length - MAX_BREADCRUMBS)
  : allCrumbs;
---

<nav aria-label="Breadcrumb" class="breadcrumb">
  <ol class="breadcrumb__list">
    {crumbs.map((crumb) => (
      <li class="breadcrumb__item">
        {crumb.isLast ? (
          <span aria-current="page">{crumb.name}</span>
        ) : (
          <>
            <a href={crumb.href}>{crumb.name}</a>
            <span class="breadcrumb__separator" aria-hidden="true">/</span>
          </>
        )}
      </li>
    ))}
  </ol>
</nav>

<style>
  .breadcrumb {
    padding: var(--spacing-lg) 0 0;
    margin-bottom: var(--spacing-lg);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  .breadcrumb__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: nowrap;
    align-items: baseline;
    font-size: var(--text-sm);
    color: var(--text-muted);
    overflow: hidden;
  }

  .breadcrumb__item {
    display: flex;
    align-items: baseline;
    white-space: nowrap;
    line-height: 1.4;
  }

  .breadcrumb__item:last-child {
    overflow: hidden;
  }

  .breadcrumb__item a,
  .breadcrumb__item [aria-current="page"] {
    font-size: var(--text-sm);
    font-weight: normal;
    line-height: 1.4;
  }

  .breadcrumb__item [aria-current="page"] {
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .breadcrumb__item a {
    color: var(--color-primary);
    text-decoration: none;
    text-transform: none;
    letter-spacing: normal;
    border-bottom: none;
    transition: opacity var(--transition-fast);
    -webkit-tap-highlight-color: transparent;
    outline: none;
  }

  .breadcrumb__item a:hover {
    opacity: 0.8;
  }

  .breadcrumb__item a:active {
    opacity: 0.6;
  }

  .breadcrumb__separator {
    margin: 0 var(--spacing-sm);
  }

  @media (max-width: 480px) {
    .breadcrumb {
      padding: var(--spacing-sm) 0 0;
      margin-bottom: var(--spacing-md);
    }
  }
</style>
