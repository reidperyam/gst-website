---
/**
 * SEO Component
 * Provides structured data, meta tags, and Open Graph tags for SEO optimization
 * Includes JSON-LD for search engine indexing and social media sharing
 */

interface Props {
    title?: string;
    description?: string;
    ogTitle?: string;
    ogDescription?: string;
    ogImage?: string;
    ogType?: string;
    ogUrl?: string;
    canonicalUrl?: string;
    // Enhanced social media meta tags
    ogImageAlt?: string;
    ogImageWidth?: number;
    ogImageHeight?: number;
    ogImageType?: string;
    ogSiteName?: string;
    ogLocale?: string;
    twitterSite?: string;
    faqItems?: Array<{ question: string; answer: string }>;
}

const {
    title = 'GST | M&A Strategic Technology Advisory',
    description = 'M&A technical due diligence, post-acquisition integration, and platform modernization. Led by Reid Peryam, 20-year technology strategy veteran.',
    ogTitle = 'GST | Strategic Technology Advisory',
    ogDescription = 'Specialized technical diligence and AI strategy for organizations navigating complex product transitions.',
    ogImage = '/og-image.png',
    ogType = 'website',
    ogUrl,
    canonicalUrl,
    // Enhanced social media meta tags
    ogImageAlt = 'GST - M&A Strategic Technology Advisory and Technical Due Diligence',
    ogImageWidth = 1200,
    ogImageHeight = 630,
    ogImageType = 'image/png',
    ogSiteName = 'GST',
    ogLocale = 'en_US',
    twitterSite = '@globalstrategic',
    faqItems,
} = Astro.props;

// Dynamic URL generation using Astro.url
const currentUrl = Astro.url.href;
const baseUrl = `${Astro.url.protocol}//${Astro.url.host}`;

// Use provided URLs or auto-generate from current page
const finalCanonicalUrl = canonicalUrl || currentUrl;
const finalOgUrl = ogUrl || currentUrl;

// Convert relative image paths to absolute URLs
const absoluteOgImage = ogImage.startsWith('http')
    ? ogImage
    : `${baseUrl}${ogImage.startsWith('/') ? ogImage : '/' + ogImage}`;

// Breadcrumb slug-to-name lookup
const breadcrumbNames: Record<string, string> = {
    'services': 'Services',
    'about': 'About',
    'ma-portfolio': 'M&A Portfolio',
    'privacy': 'Privacy Policy',
    'terms': 'Terms of Service',
    'hub': 'The GST Hub',
    'tools': 'The Workbench',
    'diligence-machine': 'Diligence Machine',
    'library': 'The Library',
    'business-architectures': 'Business Architectures',
    'vdr-structure': 'VDR Structure',
    'radar': 'The Radar',
};

// Build BreadcrumbList from pathname
const pathname = Astro.url.pathname.replace(/\/$/, '');
const segments = pathname.split('/').filter(Boolean);
const isHomepage = segments.length === 0;

const breadcrumbJsonLd = !isHomepage ? {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    'itemListElement': [
        {
            '@type': 'ListItem',
            'position': 1,
            'name': 'Home',
            'item': 'https://globalstrategic.tech/',
        },
        ...segments.map((slug, index) => {
            const position = index + 2;
            const name = breadcrumbNames[slug] || slug.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
            const isLast = index === segments.length - 1;
            const path = '/' + segments.slice(0, index + 1).join('/') + '/';

            return isLast
                ? { '@type': 'ListItem' as const, 'position': position, 'name': name }
                : { '@type': 'ListItem' as const, 'position': position, 'name': name, 'item': `https://globalstrategic.tech${path}` };
        }),
    ],
} : null;

// Build FAQPage schema when faqItems are provided
const faqJsonLd = faqItems && faqItems.length > 0 ? {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': faqItems.map(item => ({
        '@type': 'Question',
        'name': item.question,
        'acceptedAnswer': {
            '@type': 'Answer',
            'text': item.answer,
        },
    })),
} : null;

