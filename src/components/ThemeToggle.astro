---
// ThemeToggle.astro - Theme switcher component
// Short click: toggles light/dark theme
// Long-press (7s): triggers palette panel popout (easter egg for PWA users)
import DeltaIcon from './DeltaIcon.astro';
---

<button
  class="theme-toggle"
  id="themeToggle"
  data-testid="theme-toggle"
  title="Toggle dark theme"
  aria-label="Toggle dark theme"
>
  <DeltaIcon class="theme-toggle-icon" />
</button>

<style>
  .theme-toggle {
    background: transparent;
    border: none;
    color: var(--color-primary);
    cursor: pointer;
    font-size: 5rem;
    transition: color var(--transition-fast);
    padding: 0;
    line-height: 1;
    display: flex;
    align-items: center;
    height: 0.85rem;
    touch-action: none;
  }

  .theme-toggle:hover {
    color: var(--color-primary);
  }

  .theme-toggle:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 0.25rem;
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 0.25rem;
  }

  .theme-toggle:focus:not(:focus-visible) {
    outline: none;
  }

  /* :global() needed — .theme-toggle-icon is on a DeltaIcon child component
     whose rendered <svg> gets DeltaIcon's scope, not ThemeToggle's */
  .theme-toggle :global(.theme-toggle-icon) {
    width: 0.67em;
    height: 0.67em;
    display: block;
  }

  .theme-toggle--holding :global(.theme-toggle-icon) {
    animation: hold-pulse 0.8s ease-in-out infinite;
  }

  @keyframes hold-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.5;
      transform: scale(1.3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .theme-toggle--holding :global(.theme-toggle-icon) {
      animation: none;
    }
  }
</style>

<script>
  import { trackThemeToggle } from '../utils/analytics';

  const themeToggle = document.getElementById('themeToggle');

  if (themeToggle) {
    const LONG_PRESS_MS = 5000;

    // Haptic pulse schedule: [delay from press start, vibration duration]
    const HAPTIC_SCHEDULE: [number, number][] = [
      [1000, 50],
      [2000, 75],
      [3000, 100],
      [4000, 150],
    ];
    const HAPTIC_SUCCESS_DURATION = 300;

    let pressTimer: ReturnType<typeof setTimeout> | null = null;
    let hapticTimers: ReturnType<typeof setTimeout>[] = [];
    let didLongPress = false;

    function vibrate(ms: number): void {
      try {
        navigator?.vibrate?.(ms);
      } catch {
        // Graceful no-op on unsupported browsers
      }
    }

    function toggleTheme(): void {
      document.documentElement.classList.toggle('dark-theme');
      const isDark = document.documentElement.classList.contains('dark-theme');
      try {
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      } catch (e) {
        console.error('Failed to save theme preference:', e);
      }
      trackThemeToggle(isDark ? 'dark' : 'light');
    }

    function cancelPress(): void {
      if (pressTimer) {
        clearTimeout(pressTimer);
        pressTimer = null;
      }
      for (const t of hapticTimers) clearTimeout(t);
      hapticTimers = [];
      themeToggle!.classList.remove('theme-toggle--holding');
    }

    function startPress(): void {
      // Schedule haptic pulses
      for (const [delay, duration] of HAPTIC_SCHEDULE) {
        hapticTimers.push(setTimeout(() => vibrate(duration), delay));
      }

      // Delay visual feedback — don't hint at the easter egg on casual presses
      hapticTimers.push(
        setTimeout(() => themeToggle!.classList.add('theme-toggle--holding'), 3000)
      );

      // At 7s: success buzz + trigger palette popout
      pressTimer = setTimeout(() => {
        didLongPress = true;
        vibrate(HAPTIC_SUCCESS_DURATION);
        themeToggle!.classList.remove('theme-toggle--holding');
        document.dispatchEvent(new CustomEvent('palettePopoutRequested'));
      }, LONG_PRESS_MS);
    }

    themeToggle.addEventListener('pointerdown', (e) => {
      if (e.button !== 0) return; // primary button only
      didLongPress = false;
      // Skip easter egg when palette is already visible
      if (!document.documentElement.classList.contains('palette-popped-out')) {
        startPress();
      }
    });

    themeToggle.addEventListener('pointerup', cancelPress);
    themeToggle.addEventListener('pointerleave', cancelPress);
    themeToggle.addEventListener('pointercancel', cancelPress);

    // Theme toggle fires on click — works for both real clicks (pointer
    // sequence ending in click) and programmatic dispatches (test helpers).
    // Long-press sets didLongPress=true to suppress the toggle.
    themeToggle.addEventListener('click', () => {
      if (!didLongPress) toggleTheme();
    });
  }
</script>
