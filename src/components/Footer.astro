---
import ThemeToggle from './ThemeToggle.astro';
---

<footer role="contentinfo">
  <div class="container">
    <div class="footer-top">
      <div class="footer-links">
        <a
          href="https://www.linkedin.com/company/global-strategic-technologies/"
          target="_blank"
          rel="noopener noreferrer">LinkedIn</a
        >
        <a href="/privacy">Privacy</a>
        <a href="/terms">Terms</a>
        <a
          href="mailto:contact@globalstrategic.tech?subject=GST%20%7C%20Global%20Strategic%20Tech%20%7C%20https%3A%2F%2Fglobalstrategic.tech&body=Hi%20GST%2C%20I%20have%20a%20question%2Fcomment%2Finsight%20I'd%20like%20to%20share"
          >Contact</a
        >
      </div>
      <ThemeToggle />
    </div>
  </div>
</footer>

<style>
  footer {
    padding: 1.25rem 0 0;
    background: var(--bg-light-alt);
    border-top: 2px solid var(--color-primary);
    position: relative;
    z-index: 0;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0;
    gap: 0.75rem;
  }

  .footer-links {
    display: flex;
    gap: 0.75rem;
    align-items: center;
  }

  .footer-links a {
    color: var(--text-secondary);
    text-decoration: none;
    font-family: monospace;
    font-size: var(--text-sm);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition:
      color var(--transition-fast),
      border-bottom var(--transition-fast);
    position: relative;
    padding-bottom: 0.25rem;
    border-bottom: 2px solid transparent;
  }

  .footer-links a:hover {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  .footer-links a:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 0.25rem;
  }

  .footer-links a:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 0.25rem;
  }

  .footer-links a:focus:not(:focus-visible) {
    outline: none;
  }

  :global(html.dark-theme) footer {
    background: var(--footer-bg);
    border-top-color: var(--color-primary);
  }

  :global(html.dark-theme) .footer-links a:hover {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  @media (max-width: 480px) {
    footer {
      padding: 1.5rem 0 0.75rem;
    }

    .footer-top {
      flex-direction: row;
      gap: 1rem;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 0.75rem;
    }

    .footer-links {
      gap: 1rem;
      flex: 1;
      justify-content: flex-start;
    }

    .footer-links a {
      font-size: var(--text-xs);
    }
  }

  /* Tablet (480px - 768px) */
  @media (min-width: 480px) and (max-width: 767px) {
    footer {
      padding: 1.5rem 0 0.375rem;
    }

    .footer-top {
      margin-bottom: 0.75rem;
      gap: 1.25rem;
    }

    .footer-links {
      gap: 1.25rem;
    }
  }

  /* Desktop (768px+) */
  @media (min-width: 768px) {
    footer {
      padding: 2rem 0 0.5rem;
    }

    .footer-top {
      margin-bottom: 1rem;
      gap: 2rem;
    }

    .footer-links {
      gap: 2rem;
    }
  }

  /* Print */
  @media print {
    footer {
      display: none;
    }
  }
</style>
