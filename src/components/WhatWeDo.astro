---
// WhatWeDo section - displays core service offerings with SVG bullet indicators
import DeltaIcon from './DeltaIcon.astro';
---

<section class="what-we-do" aria-label="What we do">
  <div class="container">
    <div class="services-content">
      <h2 class="brutal-heading-lg">What We Do</h2>
      <p class="intro-text">
        GST unlocks enterprise value through expert business technology advisory.
      </p>

      <ul class="services-list">
        <li>
          <span>Buy-side and sell-side technical diligence</span>
          <DeltaIcon class="bullet-icon" />
        </li>
        <li>
          <span>Architecture and platform assessments</span>
          <DeltaIcon class="bullet-icon" />
        </li>
        <li>
          <span>Security, compliance, and operational risk evaluation</span>
          <DeltaIcon class="bullet-icon" />
        </li>
        <li>
          <span>Product development and execution roadmaps</span>
          <DeltaIcon class="bullet-icon" />
        </li>
        <li>
          <span>Independent advisory for executives and boards</span>
          <DeltaIcon class="bullet-icon" />
        </li>
      </ul>

      <p class="closing-text">Clear findings. Decision-ready outputs. Practical next steps.</p>
    </div>
  </div>
</section>

<style>
  /* Component styles following design system patterns */
  .what-we-do {
    padding: var(--spacing-3xl) 0;
    background: transparent;
    position: relative;
  }

  .services-content {
    max-width: 900px;
    margin: 0 auto;
    text-align: right;
  }

  .brutal-heading-lg {
    margin-bottom: var(--spacing-xl);
  }

  .intro-text {
    font-size: var(--text-lg);
    font-family: monospace;
    color: var(--text-secondary);
    margin-bottom: var(--spacing-2xl);
    line-height: 1.7;
  }

  .services-list {
    list-style: none;
    margin-bottom: var(--spacing-2xl);
    display: flex;
    flex-direction: column;
    gap: var(--gap-wide);
  }

  .services-list li {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-lg);
    justify-content: flex-end;
    font-size: var(--text-base);
    font-family: monospace;
    color: var(--text-primary);
    line-height: 1.6;
  }

  .closing-text {
    font-size: var(--text-base);
    font-family: monospace;
    color: var(--text-secondary);
    line-height: 1.8;
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-2xl);
    border-top: 2px solid var(--border-light);
  }

  .closing-text::before {
    content: '// ';
    color: var(--color-primary);
    font-weight: 900;
  }

  /* Dark theme support */
  :global(html.dark-theme) .what-we-do {
    background: transparent;
  }

  :global(html.dark-theme) .closing-text {
    border-top-color: var(--border-dark-default);
  }

  /* Responsive design */
  @media (max-width: 768px) {
    .what-we-do {
      padding: var(--spacing-2xl) 0;
    }

    .intro-text {
      font-size: var(--text-base);
      margin-bottom: var(--spacing-xl);
    }

    .services-list {
      gap: var(--gap-normal);
    }

    .services-list li span {
      font-size: var(--text-small);
    }

    .closing-text {
      font-size: var(--text-small);
    }
  }

  @media (max-width: 480px) {
    .what-we-do {
      padding: var(--spacing-xl) 0;
    }

    .services-list li {
      gap: var(--spacing-md);
    }
  }
</style>
