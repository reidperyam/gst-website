---
import type { Project } from '../../types/portfolio';
import ProjectModal from './ProjectModal.astro';

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;
---

<div class="portfolio-grid-container brutal-frosted--blur-only">
  <div class="container">
    <div class="grid" data-testid="portfolio-grid">
      {
        projects.map((project) => (
          <div
            class="project-card"
            data-project-id={project.id}
            data-testid="project-card"
            role="button"
            tabindex="0"
          >
            <div class="card-header">
              <div>
                <h3 class="project-title">{project.codeName}</h3>
                <p class="project-industry">{project.industry}</p>
              </div>
              <div class="year-badge">{project.year}</div>
            </div>

            <div class="metrics">
              <div class="metric">
                <div class="metric-label">ARR</div>
                <div class="metric-value arr">
                  {project.arr === 'Not in source' ? '--' : project.arr}
                </div>
              </div>
              <div class="metric">
                <div class="metric-label">Stage</div>
                <div class="metric-value">{project.growthStage}</div>
              </div>
            </div>

            <p class="summary">{project.summary}</p>

            <div class="tags">
              <div class="tag theme">{project.theme}</div>
              <div class="tag engagement">{project.engagementCategory}</div>
            </div>
          </div>
        ))
      }
    </div>
  </div>

  <!-- Project Details Modal -->
  <ProjectModal />
</div>

<style>
  .portfolio-grid-container {
    padding: 2rem 0 4rem;
  }

  .container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
    gap: 1.5rem;
  }

  .no-results-message {
    grid-column: 1 / -1;
    padding: 3rem 1.5rem;
    text-align: center;
    color: light-dark(var(--text-secondary), var(--text-dark-muted));
    font-size: var(--text-base);
  }

  .project-card {
    background: light-dark(var(--bg-light), var(--bg-dark-secondary));
    border: 1px solid light-dark(var(--border-light), var(--border-dark));
    padding: 1.5rem;
    cursor: pointer;
    transition: all var(--transition-normal);
    position: relative;
    display: flex;
    flex-direction: column;
    z-index: 1;
  }

  .project-card:hover {
    border-color: var(--color-primary);
  }

  .project-card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
    gap: 1rem;
  }

  .project-title {
    font-family: monospace;
    font-weight: 900;
    font-size: var(--text-xl);
    color: var(--text-primary);
    margin: 0 0 0.25rem;
    letter-spacing: -0.01em;
    line-height: 1.3;
  }

  .project-industry {
    font-family: monospace;
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin: 0;
    font-weight: 500;
  }

  .year-badge {
    font-family: monospace;
    background: light-dark(var(--filter-chip-bg), var(--accent-dark-bg));
    color: var(--text-secondary);
    padding: 0.35rem 0.75rem;
    border-radius: 0;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .metrics {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin: 1rem 0;
    padding: 1rem;
    background: var(--search-input-bg);
    border-left: 3px solid var(--color-primary);
  }

  .metric {
    display: flex;
    flex-direction: column;
  }

  .metric-label {
    font-family: monospace;
    font-size: var(--text-2xs);
    color: light-dark(var(--text-faded), var(--text-dark-muted));
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.35rem;
    font-weight: 700;
  }

  .metric-value {
    font-family: monospace;
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .metric-value.arr {
    color: var(--color-tertiary);
    font-size: var(--text-lg);
  }

  .summary {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 1rem 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-sm);
    margin: var(--spacing-sm) 0;
  }

  .tag {
    font-family: monospace;
    background: var(--accent-dark-bg);
    color: var(--color-primary);
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: 0;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tag.theme,
  .tag.engagement {
    background: var(--accent-light-bg-hover);
    color: var(--color-tertiary);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .container {
      padding: 0 1rem;
    }

    .project-title {
      font-size: var(--text-lg);
    }

    .metrics {
      gap: 0.75rem;
    }
  }

  @media (max-width: 480px) {
    .container {
      padding: 0 0.75rem;
    }

    .portfolio-grid-container {
      padding: 1rem 0 2rem;
    }

    .grid {
      gap: 1rem;
    }

    .project-card {
      padding: 1rem;
    }

    .card-header {
      margin-bottom: 0.75rem;
    }

    .project-title {
      font-size: var(--text-base);
    }

    .metrics {
      margin: 0.75rem 0;
      padding: 0.75rem;
      gap: 0.5rem;
    }

    .metric-value {
      font-size: var(--text-sm);
    }

    .metric-value.arr {
      font-size: var(--text-base);
    }

    .summary {
      font-size: var(--text-sm);
      margin: 0.75rem 0;
    }
  }

  @media (max-width: 768px) {
    .project-modal {
      width: 95%;
      padding: 1.5rem;
      max-height: 90vh;
    }

    .modal-close {
      top: 1rem;
      right: 1rem;
      padding: 0.65rem;
    }

    .modal-metrics {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .modal-title {
      font-size: var(--text-2xl);
    }
  }

  @media (max-width: 480px) {
    .project-modal {
      width: 100%;
      padding: 1.25rem;
      max-height: 95vh;
    }

    .modal-close {
      top: 0.75rem;
      right: 0.75rem;
      padding: 0.6rem;
      min-width: 40px;
      min-height: 40px;
    }

    .modal-title {
      font-size: var(--text-xl);
    }

    .modal-metrics {
      grid-template-columns: 1fr;
      margin-bottom: 1rem;
      padding-bottom: 1rem;
    }
  }
</style>

<script is:inline define:vars={{ projectsData: JSON.stringify(projects) }}>
  // Initialize global state if not already done
  if (!window.portfolioState) {
    let allProjects;
    try {
      allProjects = JSON.parse(projectsData);
    } catch (e) {
      console.error('Failed to parse projects data:', e);
      allProjects = [];
    }

    window.portfolioState = {
      allProjects: allProjects,
      filteredProjects: [],
      filters: { search: '', stage: 'all', theme: 'all', year: 'all' },
      growthStages: [],
      matureStages: [],
    };
  }

  function openProjectModal(projectId) {
    // Use ProjectModal component's open function
    window.projectModal.open(projectId, window.portfolioState.allProjects);
  }

  function trackFilterApplication(filterType, filterValue) {
    // Track filter actions in analytics
    if (window.gtag) {
      window.gtag('event', 'filter_applied', {
        event_category: 'portfolio',
        filter_type: filterType,
        filter_value: filterValue,
      });
    }
  }

  function initPortfolioGrid() {
    const cards = document.querySelectorAll('.project-card');

    // Card click handlers
    cards.forEach((card) => {
      card.addEventListener('click', () => {
        openProjectModal(card.dataset.projectId);
      });

      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openProjectModal(card.dataset.projectId);
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPortfolioGrid);
  } else {
    initPortfolioGrid();
  }

  // Listen for filter updates and track them
  window.addEventListener('portfolioFiltered', (e) => {
    // Track the filter application
    if (e.detail && e.detail.filterType && e.detail.filterValue) {
      trackFilterApplication(e.detail.filterType, e.detail.filterValue);
    }
    initPortfolioGrid();
  });

  // Also set up a mutation observer to watch for card visibility changes
  const observer = new MutationObserver(() => {
    // Re-initialize when DOM changes
    const visibleCards = document.querySelectorAll('.project-card:not([style*="display: none"])');
    if (visibleCards.length > 0) {
      setTimeout(() => initPortfolioGrid(), 100);
    }
  });

  const gridContainer = document.querySelector('.grid');
  if (gridContainer) {
    observer.observe(gridContainer, {
      attributes: true,
      attributeFilter: ['style'],
      subtree: true,
      childList: true,
    });
  }
</script>
