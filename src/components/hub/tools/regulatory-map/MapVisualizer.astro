---
/**
 * Interactive SVG world map rendered by D3.js on the client.
 * Publishes `regionSelected` CustomEvent when a country is clicked.
 */
---

<div class="brutal-map-container" id="mapContainer" data-testid="map-container">
  <div class="map-controls">
    <button id="zoomIn" class="brutal-map-control" aria-label="Zoom in" title="Zoom in">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"
        ><path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"
        ></path></svg
      >
    </button>
    <button id="zoomOut" class="brutal-map-control" aria-label="Zoom out" title="Zoom out">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"
        ><path d="M3 8h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"
        ></path></svg
      >
    </button>
    <button id="zoomReset" class="brutal-map-control" aria-label="Reset zoom" title="Reset zoom">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"
        ><rect
          x="3"
          y="3"
          width="10"
          height="10"
          rx="1"
          stroke="currentColor"
          stroke-width="1.5"
          fill="none"></rect></svg
      >
    </button>
  </div>
  <div class="brutal-map-tap-bar" id="mapTapBar" hidden>
    <span class="brutal-map-tap-bar__name" id="tapBarName"></span>
    <button class="brutal-map-tap-bar__action" id="tapBarAction">View details</button>
  </div>
  <svg
    id="mapSvg"
    class="map-svg"
    role="img"
    aria-label="Interactive world map showing countries with regulatory data highlighted. Use scroll wheel or pinch to zoom, drag to pan."
    preserveAspectRatio="xMidYMid meet"></svg>
  <div class="brutal-map-tooltip" id="mapTooltip" role="tooltip" aria-hidden="true"></div>
  <div class="map-quick-zoom" id="mapQuickZoom">
    <button class="brutal-quick-zoom" data-region="americas" aria-label="Zoom to Americas"
      >AMR</button
    >
    <button class="brutal-quick-zoom" data-region="europe" aria-label="Zoom to Europe">EUR</button>
    <button class="brutal-quick-zoom" data-region="asia-pacific" aria-label="Zoom to Asia-Pacific"
      >APAC</button
    >
    <button
      class="brutal-quick-zoom"
      data-region="africa-mideast"
      aria-label="Zoom to Africa & Middle East">MEA</button
    >
  </div>
  <div class="brutal-map-hint" id="mapPinchHint" hidden aria-hidden="true">
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
    >
      <path d="M6 12L2 8M6 12L2 16M18 12L22 8M18 12L22 16"></path>
    </svg>
    <span>Pinch to zoom</span>
  </div>
</div>

<style>
  .map-svg {
    display: block;
    width: 100%;
    height: auto;
    cursor: grab;
  }

  .map-svg:active {
    cursor: grabbing;
  }

  .map-controls {
    position: absolute;
    top: var(--spacing-sm);
    right: var(--spacing-sm);
    display: flex;
    flex-direction: column;
    gap: 2px;
    z-index: 5;
  }

  @media (max-width: 1023px) {
    .map-controls {
      right: auto;
      left: var(--spacing-sm);
    }

    /* Thinner map border on tablet/mobile */
    .brutal-map-container {
      border-width: 1px;
    }
  }

  /* Hide +/−/reset on mobile — quick-zoom buttons provide navigation */
  @media (max-width: 1023px) {
    .map-controls {
      display: none;
    }
  }

  /* Remove browser default focus outline on SVG paths; selection is shown via fill/stroke */
  :global(.country-path:focus),
  :global(.country-path:focus-visible),
  :global(.state-path:focus),
  :global(.state-path:focus-visible) {
    outline: none;
  }

  /* Country path base state */
  :global(.country-path) {
    fill: light-dark(rgba(26, 26, 26, 0.08), rgba(255, 255, 255, 0.06));
    stroke: light-dark(rgba(26, 26, 26, 0.15), var(--border-dark-default));
    stroke-width: 0.5;
    transition: fill var(--transition-fast);
    cursor: default;
  }

  /* Country with regulation data */
  :global(.country-path--active) {
    fill: light-dark(var(--color-primary-25), var(--color-primary-30));
    cursor: pointer;
  }

  :global(.country-path--active:hover) {
    fill: light-dark(var(--color-primary-45), var(--color-primary-50));
  }

  /* Selected country */
  :global(.country-path--selected) {
    fill: light-dark(var(--color-primary-60), var(--color-primary-65));
    stroke: var(--color-secondary);
    stroke-width: 1.5;
  }

  /* US state path base state */
  :global(.state-path) {
    fill: transparent;
    stroke: light-dark(rgba(26, 26, 26, 0.12), rgba(255, 255, 255, 0.08));
    stroke-width: 0.3;
    transition: fill var(--transition-fast);
    cursor: default;
  }

  /* State with regulation data */
  :global(.state-path--active) {
    fill: light-dark(var(--color-primary-25), var(--color-primary-30));
    cursor: pointer;
  }

  :global(.state-path--active:hover) {
    fill: light-dark(var(--color-primary-45), var(--color-primary-50));
  }

  /* Selected state */
  :global(.state-path--selected) {
    fill: light-dark(var(--color-primary-60), var(--color-primary-65));
    stroke: var(--color-secondary);
    stroke-width: 1;
  }

  /* Timeline-highlighted regions (multi-region highlight) */
  :global(.country-path--highlighted) {
    fill: light-dark(var(--color-primary-50), var(--color-primary-55));
    stroke: var(--color-secondary);
    stroke-width: 1.2;
  }

  :global(.state-path--highlighted) {
    fill: light-dark(var(--color-primary-50), var(--color-primary-55));
    stroke: var(--color-secondary);
    stroke-width: 0.8;
  }

  /* Tap bar — mobile only */
  .brutal-map-tap-bar {
    display: none;
  }

  @media (max-width: 1023px) {
    .brutal-map-tap-bar {
      display: flex;
    }

    .brutal-map-tap-bar[hidden] {
      display: none;
    }
  }

  /* Pinch hint — mobile only positioning */
  .brutal-map-hint {
    display: none;
  }

  @media (max-width: 1023px) {
    .brutal-map-hint {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      display: flex;
      align-items: center;
      gap: var(--spacing-xs);
      z-index: 15;
      pointer-events: none;
      opacity: 0;
      transition: opacity var(--transition-normal);
    }

    .brutal-map-hint.visible {
      opacity: 1;
    }

    .brutal-map-hint[hidden] {
      display: none;
    }
  }

  /* Quick-zoom container — mobile/tablet positioning */
  .map-quick-zoom {
    display: none;
  }

  @media (max-width: 1023px) {
    .map-quick-zoom {
      display: flex;
      gap: var(--spacing-xs);
      position: absolute;
      bottom: var(--spacing-sm);
      right: var(--spacing-sm);
      z-index: 5;
    }
  }

  /* Mobile zoom button touch targets */
  @media (max-width: 767px) {
    .brutal-map-control {
      width: 44px;
      height: 44px;
    }

    .brutal-map-control svg {
      width: 20px;
      height: 20px;
    }
  }

  /* Tooltip visibility */
  .brutal-map-tooltip {
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .brutal-map-tooltip.visible {
    opacity: 1;
  }
</style>
