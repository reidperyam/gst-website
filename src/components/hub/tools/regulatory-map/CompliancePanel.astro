---
/**
 * Compliance detail panel that displays regulation information
 * for the selected country. Subscribes to `regionSelected` CustomEvent.
 */
---

<aside
  class="brutal-panel"
  id="compliancePanel"
  data-testid="compliance-panel"
  aria-live="polite"
  hidden
>
  <div class="brutal-bottom-sheet__handle" id="bottomSheetHandle" aria-hidden="true">
    <span class="brutal-bottom-sheet__handle-bar"></span>
  </div>
  <div class="brutal-panel__header">
    <h2 class="brutal-panel__title" id="panelCountryName"></h2>
    <div class="brutal-panel__actions">
      <button
        class="brutal-panel__copy"
        id="panelCopyLink"
        aria-label="Copy link to this view"
        title="Copy link"
      >
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path
            d="M6.5 9.5l3-3M5.5 7L4 8.5a2.12 2.12 0 003 3L8.5 10m-1-3.5L9 5l1.5-1.5a2.12 2.12 0 013 3L12 8"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"></path>
        </svg>
      </button>
      <span class="brutal-panel__count" id="panelRegCount"></span>
    </div>
  </div>
  <div class="brutal-panel__regulations" id="panelRegulations"></div>
</aside>

<style>
  /* Bottom sheet handle — hidden on desktop */
  .brutal-bottom-sheet__handle {
    display: none;
  }

  /* Dark theme — box-shadow is dark-only (non-color structural shadow) */
  :global(html.dark-theme) .brutal-panel {
    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.4);
  }

  :global(.brutal-reg-card) {
    background: light-dark(transparent, var(--bg-dark-tertiary));
  }

  /* Desktop */
  @media (min-width: 1024px) {
    .brutal-panel {
      max-height: calc(100vh - 280px);
      position: sticky;
      top: var(--spacing-lg);
    }
  }

  /* Mobile bottom sheet */
  @media (max-width: 1023px) {
    .brutal-panel {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      max-height: 60vh;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
      overscroll-behavior: contain;
      border-bottom: none;
      transform: translateY(100%);
      transition: transform var(--transition-slow);
      z-index: var(--z-compliance-panel);
    }

    .brutal-panel[hidden] {
      display: block;
      transform: translateY(100%);
    }

    .brutal-panel.brutal-panel--sheet-open {
      transform: translateY(0);
    }

    .brutal-bottom-sheet__handle {
      display: flex;
      justify-content: center;
      padding: var(--spacing-sm) 0 var(--spacing-xs);
      cursor: grab;
      touch-action: none;
    }

    .brutal-bottom-sheet__handle-bar {
      width: 40px;
      height: 4px;
      background: var(--text-faded);
    }
  }
</style>
