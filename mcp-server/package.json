{
  "name": "@gst/mcp-server",
  "version": "0.1.0",
  "description": "Local stdio MCP server exposing the GST diligence engine and portfolio search.",
  "type": "module",
  "private": true,
  "bin": {
    "gst-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "node scripts/generate-regulations-index.mjs",
    "build": "tsc --noEmit && node build.mjs",
    "pretypecheck": "node scripts/generate-regulations-index.mjs",
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/generate-regulations-index.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "esbuild": "^0.27.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
